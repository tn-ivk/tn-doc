<?xml version="1.0" encoding="utf-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">
  <Fragment>
    <UI>
      <!--
        Base UI: WixUI_InstallDir provides the standard dialog sequence
        (Welcome -> License -> InstallDir -> VerifyReady -> Install -> Complete).
        We inject ServiceNameDlg between InstallDirDlg and VerifyReadyDlg.
      -->
      <ui:WixUI Id="WixUI_InstallDir" InstallDirectory="INSTALLFOLDER" />

      <!--
        Override InstallDirDlg "Next" to go to ServiceNameDlg instead of VerifyReadyDlg.
        Order="5" is higher than the default Order in WixUI_InstallDir, so it takes precedence.
      -->
      <Publish Dialog="InstallDirDlg" Control="Next" Event="NewDialog"
               Value="ServiceNameDlg" Order="5"
               Condition="NOT Installed" />

      <!-- ServiceNameDlg navigation: Back -> InstallDirDlg -->
      <Publish Dialog="ServiceNameDlg" Control="Back" Event="NewDialog"
               Value="InstallDirDlg" />

      <!-- ServiceNameDlg navigation: Next -> VerifyReadyDlg -->
      <Publish Dialog="ServiceNameDlg" Control="Next" Event="NewDialog"
               Value="VerifyReadyDlg" />

      <!--
        Override VerifyReadyDlg "Back" to return to ServiceNameDlg instead of InstallDirDlg.
        Only during first install (NOT Installed), during maintenance/repair the standard
        flow is preserved.
      -->
      <Publish Dialog="VerifyReadyDlg" Control="Back" Event="NewDialog"
               Value="ServiceNameDlg" Order="5"
               Condition="NOT Installed" />
    </UI>
  </Fragment>
</Wix>
