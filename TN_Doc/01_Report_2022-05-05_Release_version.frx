<Report ScriptLanguage="CSharp" ReferencedAssemblies="System.dll&#13;&#10;System.Drawing.dll&#13;&#10;System.Windows.Forms.dll&#13;&#10;System.Data.dll&#13;&#10;System.Xml.dll&#13;&#10;Newtonsoft.Json.dll&#13;&#10;System.Core.dll&#13;&#10;TN_ToolsFastReport.dll&#13;&#10;TN_Docs.dll" DoublePass="true" SmoothGraphics="true" ReportInfo.Created="06/18/2021 09:21:52" ReportInfo.Modified="05/29/2022 17:40:16" ReportInfo.CreatorVersion="2021.4.4.0">
  <ScriptText>using System;
using System.Reflection;
using System.Collections;
using System.Collections.Generic;
using System.ComponentModel;
//using System.Windows.Forms;    // удалить перед передачей шаблона Алексею!!! (также убрать из Свойства... -&gt;  Скрипт: System.Windows.Forms.dll)
using System.Drawing;
using System.Data;
using System.IO;
using FastReport;
using FastReport.Data;
using FastReport.Dialog;
using FastReport.Barcode;
using FastReport.Table;
using FastReport.Utils;
using System.Linq;
using Newtonsoft.Json;
 
namespace FastReport
{
   public class ReportScript
   {
      TN_ToolsFastReport.Tools tools = new TN_ToolsFastReport.Tools();  // классы отчета
      TN_DocReport.Root report; // переменная, для хранения данных из входного параметра
      int numLineParams=0; //кол-во параметров линий в основной таблице
      int numBIKParams=0; // кол-во параметров БИК,в таблице БИК
      int showNumberColumns =0;// кол-во линий, требуемых отобразить в основной таблице
     // int linesCount=0;
                          
      
      List &lt;TN_DocReport.Line&gt; listUsedLines;
      List&lt;TN_DocReport.Parameters&gt; listLineParams;
      List&lt;TN_DocReport.Parameters&gt; listBIKParams;//visibleBIKfields;       
      List&lt;TN_DocReport.Signers&gt;signersList;
      Dictionary&lt;int, string&gt; reportName;
      Dictionary&lt;string, TextRenderType&gt;  dictTextRenderType;
      int reportType;
      DateTime dtBegin;
      DateTime dtEnd;
      int tempCounter;
      
    private void Page_StartPage(object sender, EventArgs e)
      {         
         //using (var sr = new StreamReader(&quot;C:/SVN/FastReport/Входящие данные от Алексея (классы и json)/01_Report/DocReports.json&quot;))
         //using (var sr = new StreamReader(&quot;D:/!_Work/!_Транснефть/SVN/Work/Sources/Reports/FRX/Входящие данные от Алексея (классы и json)/01_Report/DocReports.json&quot;))
         //{
            // Read the stream as a string, and write the string to the console.
            //Report.SetParameterValue(&quot;Report&quot;, sr.ReadToEnd());
         //}
        
         //// === Десериализация данных (формат json) из входного параметра - Report                             
         string reportJson = (string)Report.GetParameterValue(&quot;Report&quot;);
         Newtonsoft.Json.JsonSerializerSettings settingsReport = new Newtonsoft.Json.JsonSerializerSettings();
         settingsReport.TypeNameHandling = TypeNameHandling.All;
         report = JsonConvert.DeserializeObject&lt;TN_DocReport.Root&gt;(reportJson, settingsReport);
         
         //// === Определение кол-ва ИЛ, необходимых отобразить в отчете  для основной таблицы.
         showNumberColumns=report.Doc.Settings.Data.TableLine.ShowNumberColumns;
         
         //=== Определение кол-ва ИЛ (с данными).
         listUsedLines = report.Doc.DataIVK.TableReport.Report.Obj.Line.Where(y =&gt; y.Used == 1).ToList();
         
         // === Определение кол-ва параметров ИЛ для основной таблицы.
         listLineParams = report.Doc.Settings.Data.TableLine.Parameters.Where(x =&gt; x.Visible == true).ToList();
         numLineParams = listLineParams.Count;
         
         //// === Определение кол-ва параметров БИКа, для таблицы БИК
         listBIKParams = report.Doc.Settings.Data.TableBIK.Parameters.Where(x =&gt; x.Visible == true).ToList();
         
         //// === Создание списка свойств класса CfgReport.Signer.
         signersList = report.Doc.Settings.Footer.Signers.Where(x =&gt; x.Name.Length &gt;0).ToList();
          
         dtBegin = tools.UnixTimestampToDatetime((long)report.Doc.DataIVK.TableReport.Begin);
         dtEnd = tools.UnixTimestampToDatetime((long)report.Doc.DataIVK.TableReport.End);
         
         //// === Настройки страницы 
         // Ширина и высота (в мм)
         Page.PaperWidth =report.Doc.Settings.General.PageSettings.PaperWidth;
         Page.PaperHeight =report.Doc.Settings.General.PageSettings.PaperHeight;
      
         // Поля/отступы от краёв (в мм)
         Page.TopMargin=report.Doc.Settings.General.PageSettings.TopMargin;
         Page.BottomMargin=report.Doc.Settings.General.PageSettings.BottomMargin;
         Page.LeftMargin=report.Doc.Settings.General.PageSettings.LeftMargin;
         Page.RightMargin=report.Doc.Settings.General.PageSettings.RightMargin;
         
         //// ===  Определение типа отчетов: за два часа, за смену, за сутки, за месяц, за время ведения ТКО.
         reportName = new Dictionary&lt;int, string&gt;();
         reportName[0] = &quot;Отчет за один час&quot;;
         reportName[1] = &quot;Отчет за два часа&quot;;
         reportName[2] = &quot;Отчет за смену&quot;;
         reportName[3] = &quot;Отчет за сутки&quot;;
         reportName[4] = &quot;Отчет за месяц&quot;;
         reportName[5] = &quot;Отчет за время ведения ТКО&quot;;
         reportType = Convert.ToInt32(report.Doc.DataIVK.TableReport.ReportType);
         
         // Запуск отрисовки таблиц на странице отчета
         DrawTableHeader(); 
         
         if (report.Doc.Settings.Data.TableBIK.Visible==true)
         {
            for(int i= 0; i &lt; report.Doc.DataIVK.TableReport.Report.Obj.BIK.Count; i++)
            {
               TN_DocReport.BIK bik = report.Doc.DataIVK.TableReport.Report.Obj.BIK[i];
               DrawTableBIK(bik, i);  // Создание, настройка, заполнение данными и вывод на страницу таблицы BIKTable (таблицы БИК)
            }
         }
         DrawTableSigners();
      }
      
      //// ======================== //// ======================== //// ======================== ////

      //// &quot;Шапка&quot; отчета //
      private void DrawTableHeader()
      {
         //ReportTitle.FillColor = Color.Green; //for test
         
         // Setup Columns
         float widthDynamicCols=(Page.PaperWidth-Page.LeftMargin-Page.RightMargin)/TableHeader.ColumnCount;         
         for (int i = 0; i &lt; (TableHeader.ColumnCount); i++)                 
         {
            TableHeader.Columns[i].Width = widthDynamicCols*Units.Millimeters;
         }
         // === Fill table with the data                                                                                
         Prefix_SIKN_Name.Text = string.Format(&quot;{0} {1}&quot;, report.Doc.Settings.Header.Prefix_SIKN_Name,
         report.Doc.DataIVK.TableReport.Report.Obj.Additional[0].SIKN_Name);
         NameIVK.Text = report.Doc.Settings.Header.NameIVK; 
         Factory.Text=report.Doc.DataIVK.TableReport.Report.Obj.Additional[0].Factory;
         TankerName.Text=report.Doc.DataIVK.TableReport.Report.Obj.Additional[0].TankerName;
         ExtendAddInfo.Text=report.Doc.DataIVK.TableReport.Report.Obj.Additional[0].ExtendAddInfo;
         ReportType.Text = reportName[reportType]; // Тип отчета
         ReportTime.Text= String.Format(&quot;За период с {0:dd.MM.yyyy HH:mm} до {1:dd.MM.yyyy HH:mm}&quot;, dtBegin, dtEnd);
         //TableHeader[z,y].Border.Lines=BorderLines.All; // for tests
         } 

      //// ======================== //// ======================== //// ======================== ////
      private void TableReport_ManualBuild(object sender, EventArgs e)
      {
         if (report.Doc.Settings.Data.TableLine.Visible==true)
         {
            bool columnSIKNVisible = report.Doc.Settings.Data.TableLine.ColumnSIKN.Visible;
            int amountLinesCols= listUsedLines.Count;
            int amountSumCols=0;
            double widthLinesCols =0;
            double widthSIKNCol = 0;
            float widthFixedCols = 0;
            tempCounter = 0;

            // Get num cols for  Lines &amp; SIKN (depend from &quot;СolumnSIKN&quot; - &quot;Visible&quot;: true/false)
            if (report.Doc.Settings.Data.TableLine.ColumnSIKN.Visible==true)
            {
               amountSumCols = amountLinesCols+1;
            }
            else 
            {
               amountSumCols = amountLinesCols;
            }
            
            //MessageBox.Show(&quot;amountSumCols - &quot; + amountSumCols.ToString());
            //MessageBox.Show(&quot;TableReport.ColumnCount - &quot; + TableReport.ColumnCount.ToString());
            
            if (Engine.FirstPass == true)
            {
               tempCounter = 0;
               //// ===  Add dynamic columns
               for (int i = 3; i &lt; amountSumCols+3; i++)
               {
                  TableColumn column = new TableColumn();  
                  TableReport.Columns.Add(column);   
                  
                  // Set names for Columns
                  if (columnSIKNVisible==true &amp; i==(amountSumCols+3)-1) // проверка: нужно ли задавать name для столбца СИКН
                  {
                     column.Name = &quot;colSIKN&quot;;
                  }
                  else
                  {
                     column.Name = &quot;colLine&quot; + tempCounter.ToString();
                  }
                                    
                  // Assign property of the previous cells for new cell (for dynamic columns)
                  for (int j=0;j&lt;TableReport.RowCount;j++)
                  {
                     TableReport[i,j].AssignAll(TableReport[(i-1),j]);
                  }
                  tempCounter++;
               }
            }
            
            //// ===  Calculate common width for Lines columns &amp; SIKN column
            widthLinesCols = report.Doc.Settings.Data.TableLine.ColumnsWidth; //Get common width for Lines columns 
            widthSIKNCol=report.Doc.Settings.Data.TableLine.ColumnSIKN.Width; //Get width for SIKN column
            widthFixedCols =(Column01.Width+Column02.Width+Column03.Width)/Units.Millimeters;

            if (widthLinesCols==0) 
            {
               if (report.Doc.Settings.Data.TableLine.ColumnSIKN.Visible== true) 
               {
                  if (report.Doc.Settings.Data.TableLine.ColumnSIKN.Width==0) 
                  {
                     widthSIKNCol=widthLinesCols = (Page.PaperWidth - Page.LeftMargin - Page.RightMargin - widthFixedCols) / amountSumCols; 
                  }
                  else
                  {
                     widthSIKNCol = report.Doc.Settings.Data.TableLine.ColumnSIKN.Width;
                     widthLinesCols = (Page.PaperWidth - Page.LeftMargin - Page.RightMargin - widthFixedCols - widthSIKNCol) / amountSumCols; 
                  }
               }
               else
               {
                  widthLinesCols = (Page.PaperWidth - Page.LeftMargin - Page.RightMargin - widthFixedCols) / amountSumCols; 
               }
            }    
            else
            {
               if (report.Doc.Settings.Data.TableLine.ColumnSIKN.Visible== true) 
               {
                  if (report.Doc.Settings.Data.TableLine.ColumnSIKN.Width==0) 
                  {
                     widthSIKNCol = (Page.PaperWidth - Page.LeftMargin - Page.RightMargin - widthFixedCols) - (widthLinesCols * amountLinesCols);
                  }
               }
            }    
            
            int numLine = 0;
            // Setup width for Line &amp; SIKN columns
            for (int i = 3; i &lt; (TableReport.Columns.Count); i++) 
            {                                                                                                          
               if (TableReport.Columns[i].Name.Contains(&quot;colLine&quot;)==true) 
               {
                  TableReport.Columns[i].Width=(float)widthLinesCols*Units.Millimeters; // set width for Line columns
                  TableReport[i,0].Text = listUsedLines[numLine].Name;
               }
               else
               {
                  TableReport.Columns[i].Width=(float)widthSIKNCol *Units.Millimeters; // set width for SIKN column
                  TableReport[TableReport.Columns.Count-1,0].Text = report.Doc.Settings.Data.TableLine.ColumnSIKN.Name;
               }
               numLine++;
            }       
           
            for (int n = 0; n &lt; TableReport.FixedRows; n++)            
            {
               TableReport.PrintRow(n);
               TableReport.PrintColumns();                                             
            } 
            
            // Fill table with data
            object result = &quot;-&quot;;
            for (int j = 1; j &lt; listLineParams.Count; j++)
            {
               Counter.Text=j.ToString();   
               Name.Text=listLineParams[j].Name;
               SI.Text=listLineParams[j].SI;
                               
               //Data for Lines columns
               for (int z = 0; z &lt; listUsedLines.Count; z++)
               {                     
                  result = &quot;-&quot;;
                  tools.GetPropertyValue(listUsedLines[z], listLineParams[j].Key, ref result);
                  TableReport[(z+3),1].Text = tools.GetNormalizedValue(result).ToString();
               }
                
               //Data for SIKN column
               if (report.Doc.Settings.Data.TableLine.ColumnSIKN.Visible==true)
               {             
                  for (int z = 0; z &lt; listUsedLines.Count; z++)
                  {                     
                     result = &quot;-&quot;;
                     tools.GetPropertyValue(report.Doc.DataIVK.TableReport.Report.Obj.SIKN, listLineParams[j].Key, ref result);
                      TableReport[(TableReport.ColumnCount-1),1].Text = tools.GetNormalizedValue(result).ToString();
                  }
               }
               TableReport.PrintRow(1);
               TableReport.PrintColumns();                                             
            }
         }
      }
     
      public void DrawTableBIK(TN_DocReport.BIK bik, int idx)
      {
         if (Engine.FirstPass == true)
         {
            int rows = 0;
            //// Create &amp; setup: Band as dataBandBIK //
            DataBand dataBandBIK = new DataBand(); // создание экземпляра датабенда
            dataBandBIK.Name = &quot;DataBandBIK&quot;;
            dataBandBIK.CanGrow=true;
            //dataBandBIK.Height = 10f * Units.Millimeters;           
            //dataBandBIK.FillColor = Color.Red; // for test
            Page.Bands.Add(dataBandBIK);  // &quot;прикрепление&quot; датабенда к странице 1
            
            //// Create &amp; setup: Table as tableBIK// ---------------------------------
            TableObject tableBIK = new TableObject(); // создание экземпляра таблицы tableBIK
            //tableBIK.Top = (float)conf.Data.TableBIKSettings.Offset*Units.Millimeters; // установка отступа сверху (в см.) для таблицы
            dataBandBIK.Objects.Add(tableBIK); // &quot;прикрепление&quot; таблицы к  датабенду 
            tableBIK.Top =2f * Units.Millimeters;           

            // Set columns numbers for table
            decimal columns = 8;
         
            //// === Setup columns of the tableBIK
            // ширина нединамических  столбцов (в мм)
            float widthColumn1 = 7.5f; // width column 1 

            // ширина динамических столбцов. От ширины страницы отнимаются: 
            //отступы (слева, справа), ширин первого столбца. Результат делится на заданное кол-во колонок минус 1 (первый столбец).
            float widthRemainingColumns = ((Page.PaperWidth-Page.LeftMargin-Page.RightMargin-widthColumn1)/((float)columns-1));

            //Calculate Rows number
            decimal tempvar = (decimal)listBIKParams.Count/(columns-1);
            rows = (Decimal.ToInt32(Math.Ceiling(tempvar))*2);
         
            //// === Create columns, set width, link their to the tableBIK // 
            for (int i = 0; i &lt; columns ; i++)
            {
               TableColumn column = new TableColumn();  
               tableBIK.Columns.Add(column);   
               switch (i)
               {
                  case 0: 
                     column.Width = widthColumn1* Units.Millimeters; 
                     break;
                  default:
                     column.Width = widthRemainingColumns* Units.Millimeters; 
                     break;
               } 
            }
            //Create rows, set width, link their to the tableBIK //
            for (int n = 0; n &lt; rows; n++)
            {
               TableRow row = new TableRow();  
               tableBIK.Rows.Add(row);          
               tableBIK.Rows[n].AutoSize = true;
            }
            
            //// Fill the cells with color and Data
            int z=0;
            object result = &quot;-&quot;;
            for (int j = 0; j &lt; (tableBIK.RowCount); j++)
            {
               for (int i = 1; i &lt; tableBIK.ColumnCount; i++,  z++ )
               {
                  if (z==listBIKParams.Count) 
                     break;             
                                              
                  // Fill table headers cells with text
                  tableBIK[i,j].Text = String.Format(&quot;&lt;b&gt;{0}, {1}&quot;, listBIKParams[z].Name, listBIKParams[z].SI);
                  //tableBIK[i,j].FillColor=Color.Gainsboro;
                  tableBIK[i,j].FontWidthRatio=(float)0.85;
                  tableBIK[i,j].Font =  new Font(&quot;Arial&quot;, (float)8.0, FontStyle.Bold); 
                  tableBIK[i,j].Border.Lines=BorderLines.All;
                  
                  // Fill regular cells with data
                  result = &quot;-&quot;;
                  tools.GetPropertyValue(report.Doc.DataIVK.TableReport.Report.Obj.BIK[0], listBIKParams[z].Key, ref result); //SearchSuitableValueBIK
                  tableBIK[i,j+1].Text = tools.GetNormalizedValue(result).ToString();
                  tableBIK[i,j+1].Font = new Font(&quot;Arial&quot;, (float)8.0, FontStyle.Regular); 
                  tableBIK[i,j+1].Border.Lines=BorderLines.All;                               
               }
               j++;
            }
            // Fill with data 1 column
            if (report.Doc.DataIVK.TableReport.Report.Obj.BIK.Count==1)
            {     
               tableBIK[0,0].Text = &quot;&lt;b&gt;БИК&quot;;
            }
            else
            {
               tableBIK[0,0].Text = &quot;&lt;b&gt;БИК &quot;+(idx+1).ToString(); 
            }
            
            tableBIK[0,0].Angle = 270; // rotate font to 270 degree 
            tableBIK[0,0].Font =  new Font(&quot;Arial&quot;, (float)8.0, FontStyle.Bold); 
            tableBIK[0,0].RowSpan =rows;
            tableBIK[0,0].Border.Lines=BorderLines.All;
         
            //setup of the all cells
            for (int i = 0; i &lt; columns; i++)
            {
               for (int j = 0; j &lt; rows; j++)
               {
                  tableBIK[i,j].HorzAlign=HorzAlign.Center; // отцентровать текст в ячейке по горизонтали
                  tableBIK[i,j].VertAlign=VertAlign.Center; // отцентровать текст в ячейке по вертикали
                  tableBIK[i,j].TextRenderType=TextRenderType.HtmlTags;
                  tableBIK[i,j].FontWidthRatio=(float)0.85;
               }
            }       
         }
      }    
      
      //// === &quot;Подвал&quot; отчета =======================================
      private void DrawTableSigners()
      {
         if (Page.PaperWidth&gt;  210 )
         {
            Signers.Width = 110*Units.Millimeters;
         }
         else
         {
            Signers.Width = 90*Units.Millimeters;
         }
         
         // Fill the table with data                  
         TableSigners[0,0].Text = String.Format(&quot;Основное СИ плотности на момент формирования отчета: плотномер № {0}.&quot;, report.Doc.DataIVK.TableReport.Report.Obj.Additional[0].NumOfUsedDens);
         TableSigners[0,2].Text = report.Doc.Settings.Footer.Signers[0].Name;
         TableSigners[0,4].Text = report.Doc.Settings.Footer.Signers[1].Name;
         TableSigners[0,6].Text = report.Doc.Settings.Footer.Signers[2].Name;         
         
         int reportID = (Convert.ToInt32(report.Doc.DataIVK.TableReport.ReportType)-1);
         
         // Отображение подписантов согласно типа отчета
         for (int y = 0; y &lt; signersList.Count ; y++) 
         {
            switch(y)
            {
               case 0:
                  TableSigners.Rows[2].Visible=signersList[y].ShowSigner[reportID].Visible;
                  TableSigners.Rows[3].Visible=TableSigners.Rows[2].Visible;
                  break;
               
               case 1:  
                  TableSigners.Rows[4].Visible=signersList[y].ShowSigner[reportID].Visible;
                  TableSigners.Rows[5].Visible=TableSigners.Rows[4].Visible;
                  break;
               
               case 2:  
                  TableSigners.Rows[6].Visible=signersList[y].ShowSigner[reportID].Visible;
                  TableSigners.Rows[7].Visible=TableSigners.Rows[6].Visible;
                  break;
            }
         }
      }

      private void PageFooter_BeforeLayout(object sender, EventArgs e)
      {
         if((Int32)Report.GetVariableValue(&quot;TotalPages&quot;) &lt; 2) 
         { 
            //MessageBox.Show(&quot;TotalPages &lt; 2&quot;);
            PageFooter.Visible = false; 
         }
         else
         {
            // MessageBox.Show(&quot;TotalPages &gt; 1&quot;);
            PageNumeration.Width = (Page.PaperWidth-Page.LeftMargin-Page.RightMargin)*Units.Millimeters;
         }
      }
   }
}</ScriptText>
