@using TN_Doc.Services
@inject IViteManifestService ViteManifest
@{
    ViewData["Title"] = "Конфигуратор настроек";
    Layout = null;

    // Получаем пути к файлам из Vite manifest (с хэшами для cache busting)
    var entryFile = ViteManifest.GetEntryFile("configurator") ?? "configurator.js";
    var cssFile = ViteManifest.GetCssFile("configurator") ?? "configurator.css";
}

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>

    <!-- Configurator styles (путь из manifest с хэшем) -->
    <link rel="stylesheet" href="~/configurator/@cssFile" />

    <style>
        html, body {
            height: 100%;
            overflow: hidden;
            background-color: #ffffff;
        }
        body {
            margin: 0;
            padding: 0;
            font-family: 'Segoe UI', 'PT Astra Sans', Oxygen, Ubuntu, Cantarell, Arial, sans-serif;
        }
        #app {
            width: 100%;
            height: 100vh;
            background-color: #ffffff;
        }
        /* Fallback-индикатор загрузки (виден до монтирования Vue) */
        .app-loading-fallback {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            height: 100%;
            color: #666;
            font-size: 0.95rem;
            gap: 0.75rem;
        }
        .app-loading-fallback .spinner {
            width: 32px;
            height: 32px;
            border: 3px solid #e0e0e0;
            border-top-color: #1b6ec2;
            border-radius: 50%;
            animation: spin 0.8s linear infinite;
        }
        @@keyframes spin {
            to { transform: rotate(360deg); }
        }
    </style>
</head>
<body>
    <div id="app">
        <!-- Fallback: виден пока Vue не смонтировался, затем заменяется Vue-компонентом -->
        <div class="app-loading-fallback">
            <div class="spinner"></div>
            <span>Загрузка конфигуратора...</span>
        </div>
    </div>

    <!-- Configurator script (путь из manifest с хэшем, БЕЗ asp-append-version) -->
    <script type="module" src="~/configurator/@entryFile"></script>
</body>
</html>
