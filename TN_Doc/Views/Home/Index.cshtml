@using Microsoft.EntityFrameworkCore.Metadata.Internal
@{
    
    ViewData["Title"] = $" Модуль - документы ({ ViewData["Version"]})";
}
<body>
    <div class="cont">
            <table class="mainTable">
                <tr>
                    <td class="topPanel" colspan="2" align="right">
                        <button id="ButtonDictionaries" data-toggle="modal" data-target="#modal-window"
                            data-backdrop="static" data-keyboard="false">
                            Справочники
                        </button>
                    </td>
                </tr>
                <tr>
                    <td class="leftPanel">
                        <table class="filterTable">
                            <tr>
                                <td height="25" width="150">
                                    Устройство:
                                </td>
                                <td height="25">
                                    <select class="filterSelect" id="ComboboxDevice"></select>
                                </td>
                            </tr>
                            <tr>
                                <td height="25">
                                    Документ:
                                </td>
                                <td height="25">
                                    <select class="filterSelect" id="ComboboxDocGUID"></select>
                                </td>
                            </tr>
                            <tr>
                                <td height="25">
                                    Дата начала:
                                </td>
                                <td height="25">
                                    <input class="filterDatepicker" id="DatepickerBegin" />
                                </td>
                            </tr>
                            <tr>
                                <td height="25">
                                    Дата окончания:
                                </td>
                                <td height="25">
                                    <input class="filterDatepicker" id="DatepickerEnd" />
                                </td>
                            </tr>
                            <tr>
                                <td height="25" colspan="2" align="right">
                                    <input class="filterButton" id="ButtonGetData" type="button" value="Получить данные"
                                           onclick="table.ajax.reload()">
                                </td>
                            </tr>
                            <tr>
                            <td colspan="2" valign="top">
                                <table id="DataTable" class="display compact searched-table" style="width: 100%; height: 100%;">
                                        <thead>
                                            <tr>
                                                <th height="25">Дата, время</th>
                                                <th>Описание</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <tr>
                                                <td height="25">dt</td>
                                                <td>description</td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </td>
                            </tr>
                        </table>
                    </td>
                    <td class="rightPanel">
                        <table class="docTable">
                            <tr>
                                <td height="25" width="250">
                                    <input id="ButtonReview" type="button" value="Просмотр" onclick="GetDoc()">
                                    <input id="ButtonEdit" type="button" value="Редактирование" onclick="GetEditDoc()">
                                </td>
                            <td id="viewPanel">
                                    <table width="100%" height="100%" style="border: 1px none rgb(248, 2, 2)">
                                        <td align="left" style="border: 1px none rgb(248, 2, 2)">
                                            <select id="ComboboxTemplateDoc">Форма документа</select>
                                            <select id="ComboboxProtocolNumber">Номер протокола</select>
                                        </td>
                                        <td align="right" style="border: 1px none rgb(248, 2, 2)">
                                            <select id="ComboboxExportFormat">Экспорт</select>
                                            <input class="bExport" id="ButtonExport" type="button" value="Экспорт"
                                                   onclick="ExportDoc()">
                                            <select id="ComboboxPrinterName">Принтер</select>
                                            <input id="ButtonPrint" type="button" value="Печать" onclick="PrintDoc()">
                                        </td>
                                    </table>
                                </td>
                            <td id="editPanel" align="right" hidden>
@*                                <button id="ButtonElis" type="button" class="btn btn-primary" data-toggle="modal" data-target="#elis" hidden>
                                        Получить данные из ЕЛИС
                                    </button>*@
                                <button id="ButtonElis" type="button" data-toggle="modal" data-target="#elis" onclick="ButtonElis" hidden>
                                    Получить данные из ЕЛИС
                                </button>
                                    <input id="ButtonSave" type="button" value="Сохранить" onclick="SaveDoc()">
                                </td>
                            </tr>
                            <tr>
                                <td colspan="3">
                                    <iframe name=print_frame class="FR" src=""></iframe>
                                </td>
                            </tr>
                        </table>
                    </td>
                </tr>
            </table>
    </div>





@*todo: вынести в отдельный  html*@
<div class="modal fade"
     onselectstart="return false"
     oncontextmenu="return false"
     id="modal-window"
     tabindex="-1" role="dialog">

    <div class="modal-dialog modal-dialog-centered modal-dir-editor-width" role="document">
        <div class="modal-content modal-dir-editor-height">
            <div class="modal-header">
                
                <ul class="nav nav-pills nav-fill tabs-selector">
                    <li class="nav-item">
                        <a class="nav-link active" data-type="#main-dir-page" type="button">Персонал</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" data-type="#qp-dir-page" type="button">Методы испытаний</a>
                    </li>
                </ul>
                

                <div class="close-menu" aria-label="Close">
                    <button type="button" class="btn btn-outline-primary save-btn close-menu-item">
                        <i class="fa fa-spinner fa-spin d-none" aria-hidden="true"></i>
                        <i class="fa fa-floppy-o" aria-hidden="true"></i>
                    </button>
                    <button type="button" class="btn btn-outline-danger close-menu-item close-modal-wnd-btn" data-dismiss="modal">
                        <i class="fa fa-times" aria-hidden="true"></i>
                    </button>
                </div>
            </div>

            <div class="modal-body">
                <div class="container-fluid">
                    <div class="row tab-item" id="main-dir-page">
                        <div class="col-3">
                            <ul class="list-group" id="dictionaries-list">
                                <li class="list-group-item active" data-type="#user-group"> Группы пользователей</li>
                                <li class="list-group-item" data-type="#licences"> Доверенности</li>
                                <li class="list-group-item" data-type="#users"> Пользователи</li>
                            </ul>
                        </div>
                        <div class="col-9">
                            <div class="dictionaries">
                                <div class="dir-item" id="user-group">
                                    <div class="table-container">
                                        <div class="table-content">
                                            <table class="user-group-table  table table-bordered inner-item-center">
                                                <thead >
                                                <tr class="table-secondary">
                                                    <th scope="col">Активен</th>
                                                    <th scope="col">Название</th>
                                                </tr>
                                                </thead>
                                            </table>
                                        </div>
                                        <div class="table-bottom-menu">
                                        </div>
                                    </div>

                                </div>

                                <div class="dir-item  d-none" id="users">
                                    <div class="table-container">
                                        <div class="table-content">
                                            <table class="users-table table table-bordered inner-item-center">
                                                <thead>
                                                <tr class="table-primary">
                                                    <th scope="col">Активен</th>
                                                    <th scope="col">Группа</th>
                                                    <th scope="col">Фамилия</th>
                                                    <th scope="col">Имя</th>
                                                    <th scope="col">Отчество</th>
                                                    <th scope="col">Организация</th>
                                                    <th scope="col">Должность</th>
                                                    <th scope="col">Доверенность</th>
                                                    <th scope="col">Действия</th>
                                                </tr>
                                                </thead>
                                            </table>
                                        </div>
                                        <div class="table-bottom-menu">
                                            <button class="btn btn-primary default-btn-size add-user-btn">
                                                <div class="padding-one-px-top">
                                                    <i class="fa fa-plus" aria-hidden="true"></i>
                                                </div>
                                                <div>
                                                    <label>Добавить</label>
                                                </div>
                                            </button>
                                        </div>
                                    </div>
                                </div>

                                <div class="dir-item  d-none" id="licences">
                                    <div class="table-container">
                                        <div class="table-content">
                                            <table class="licences-table table table-bordered inner-item-center">
                                                <thead>
                                                <tr class="table-primary">
                                                    <th scope="col">Активен</th>
                                                    <th scope="col">Номер доверенности</th>
                                                    <th scope="col">Дата доверенности</th>
                                                    <th scope="col">Действия</th>
                                                </tr>
                                                </thead>
                                            </table>

                                        </div>
                                        <div class="table-bottom-menu">
                                            <button class="btn btn-primary default-btn-size add-lic-btn">
                                                <div class="padding-one-px-top">
                                                    <i class="fa fa-plus" aria-hidden="true"></i>
                                                </div>
                                                <div>
                                                    <label>Добавить</label>
                                                </div>
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                    </div>
                    <div class="tab-item row d-none" id="qp-dir-page">
                        <div class="col-3">
                            <ul class="list-group" id="qp-list">
                            </ul>
                        </div>
                        <div class="col-9">
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>


@* Окно для получения данных из "ЕЛИС" *@

<div class="modal fade" id="elis" tabindex="-1" role="dialog">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="exampleModalLongTitle">Получение данных из ЕЛИС</h5>

                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>

            </div>
            <div class="modal-body">

                <h6 class="modal-title" id="info"></h6>

                <br/>
                    <button id="buttonDataRequest" type="button" class="btn btn-primary" onclick="GetElisData()">
                        <span id="spinnerDataRequest" class="spinner-border spinner-border-sm" role="status" aria-hidden="true" hidden></span>
                        <span id="textDataRequest" class="visually-hidden">Запросить данные</span>
                    </button>
                    <div id="listPassports" class="list-group">
                      
                    </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Закрыть</button>
                    <button type="button" class="btn btn-primary" data-dismiss="modal" onclick="FillPassportDataElis()">Применить</button>
            </div>
        </div>
    </div>
</div>

@* Окно для подтверждения действий пользователя *@
@* Текст вставляется через перегрузку метода  confirm *@

<div id="PromiseConfirm" class="modal"   onselectstart="return false">
    <div class="modal-dialog modal-dialog-centered "  role="document">
            <div class="modal-content  rounded  border border-5 border-primary">
                <div class="modal-header">
                    <h7 class="modal-title">
                        <i style="font-size: 1.5em;"></i> <span>Внимание</span>
                    </h7>
                </div>
                <div class="modal-body">
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-primary confirm-ok-btn" data-dismiss="modal">Да</button>
                    <button type="button" class="btn btn-outline-danger  confirm-cancel-btn" data-dismiss="modal">Нет</button>
                </div>
            </div>
    </div>
</div>


<script>
        RedefinitionConfirmWindow();
        InitElement();
</script>
</body>