{
  "name": "@tn-doc/e2e",
  "version": "1.0.0",
  "private": true,
  "description": "E2E tests for TN_Doc using Playwright",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug",
    "test:report": "playwright show-report",
    "codegen": "playwright codegen http://localhost:38509"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@types/node": "^20.11.0",
    "typescript": "^5.4.5"
  }
}
