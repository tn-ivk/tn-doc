{
  "name": "@tn-doc/client",
  "version": "1.4.2",
  "private": true,
  "workspaces": [
    "statusbar",
    "configurator",
    "shared",
    "e2e"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=statusbar",
    "dev:configurator": "npm run dev --workspace=configurator",
    "build": "npm run build --workspace=statusbar",
    "build:configurator": "npm run build --workspace=configurator",
    "build:all": "npm run build --workspaces --if-present",
    "type-check": "npm run type-check --workspaces --if-present",
    "clean": "rm -rf statusbar/node_modules configurator/node_modules shared/node_modules e2e/node_modules node_modules",
    "test:e2e": "npm run test --workspace=e2e",
    "test:e2e:headed": "npm run test:headed --workspace=e2e",
    "test:e2e:ui": "npm run test:ui --workspace=e2e"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  }
}