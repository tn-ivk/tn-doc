{
  "name": "@tn-doc/client",
  "version": "1.4.2",
  "private": true,
  "workspaces": [
    "statusbar",
    "shared"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=statusbar",
    "build": "npm run build --workspace=statusbar",
    "build:all": "npm run build --workspaces --if-present",
    "type-check": "npm run type-check --workspaces --if-present",
    "clean": "rm -rf statusbar/node_modules shared/node_modules node_modules"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  }
}