    private void Page_StartPage(object sender, EventArgs e)
    {
      //// Десериализация данных (формат json) из входного параметра - Json                         
      string json = (string)Report.GetParameterValue(&quot;JsonDoc&quot;);
      Newtonsoft.Json.JsonSerializerSettings settings = new Newtonsoft.Json.JsonSerializerSettings();
      settings.TypeNameHandling = TypeNameHandling.All;
      
      doc = JsonConvert.DeserializeObject&lt;TN.Doc.Doc&gt;(json, settings);
      General = (TN.DocData.General) doc.Doc.Settings.General;
      Header = (TN.Doc.HeaderDoc) doc.Doc.Settings.Header;
      SettingsData = (TN.Doc.DataDoc) doc.Doc.Settings.Data;
      Footer = (TN.Doc.FooterDoc) doc.Doc.Settings.Footer;
      Dictionarys = (TN.Doc.DictionarysDoc) doc.Doc.Settings.Dictionarys;  
      DataIVK = (TN.Doc.DataIVKDoc) doc.Doc.DataIVK; 
      
      //// === Настройки страницы 
      // Ширина и высота (в мм)
      Page.PaperHeight = General.PageSettings.PaperHeight;
      Page.PaperWidth = General.PageSettings.PaperWidth;
         
      // Поля/отступы от краёв (в мм)
      Page.TopMargin = General.PageSettings.TopMargin;
      Page.BottomMargin = General.PageSettings.BottomMargin;
      Page.LeftMargin = General.PageSettings.LeftMargin;
      Page.RightMargin = General.PageSettings.RightMargin;
     
      // Запуск отрисовки таблиц на странице отчета
      DrawTableHeader();    
      DrawTableConclusion();
    }
    #region //Имхо лишний метод
    private void PrintTable(TableObject table)
    {
      for (int i=0;i&lt;table.RowCount;i++)
      {       
        table.PrintRow(i);
        table.PrintColumns();
      }    
    } 
    #endregion
      
    public void DrawTableHeader()
    {
      List &lt;TN.Doc.MprInfo&gt; listPRs_Info;
         
      //Setup Columns width
      TableHeader01.Columns[0].Width = (Page.PaperWidth-Page.LeftMargin-Page.RightMargin)*Units.Millimeters;
         
      // Fill table with data   
      ProtokolNum.Text = &quot;П Р О Т О К О Л  № &quot; + DataIVK.TableKmxSikn425PrPr.AdditionalInfo.ProtokolNum;
      Place_SIKN.Text = string.Format(&quot;СИКН №{0}, {1}, {2}&quot;, 
        DataIVK.TableKmxSikn425PrPr.AdditionalInfo.PlaceSikn, 
        DataIVK.TableKmxSikn425PrPr.AdditionalInfo.PlacePsp,
        DataIVK.TableKmxSikn425PrPr.AdditionalInfo.PlaceFactory);
      
      CPM_RSU_Type.Text = &quot;Тип СИ массового расхода &lt;u&gt; &quot; + DataIVK.TableKmxSikn425PrPr.AdditionalInfo.MprRsuInfo.Sensor.DevType;
      CPM_RSU_FactoryNumber.Text = &quot;Заводской номер &lt;u&gt; &quot; + DataIVK.TableKmxSikn425PrPr.AdditionalInfo.MprRsuInfo.Sensor.DevNumb;
      CPM_RSU_Delta.Text = &quot;Пределы допускаемой относительной погрешности, % &lt;u&gt; -&quot;;
      Place_SIKN.Text = &quot;СИКН/СИКНП &lt;u&gt; &quot; + DataIVK.TableKmxSikn425PrPr.AdditionalInfo.PlaceSikn;
      Place_PSP.Text = &quot;ПСП &lt;u&gt; &quot; + DataIVK.TableKmxSikn425PrPr.AdditionalInfo.PlacePsp;
  
      listPRs_Info = DataIVK.TableKmxSikn425PrPr.AdditionalInfo.MprOsuInfo.Where(i =&gt; ! i.Sensor.DevType.Contains(&quot;-&quot;) &amp; String.IsNullOrEmpty(i.Sensor.DevType) == false).ToList();
      switch(listPRs_Info.Count)
      {
        case 0:
          PRs_Info.Text = &quot;СРМ: &quot;;
          CPM_OSU_Type.Text = &quot;Тип контрольного СИ массового расхода &lt;u&gt;          &quot;;
          CPM_OSU_FactoryNumber.Text = &quot;Заводской номер &lt;u&gt;          &quot;;
          CPM_OSU_Delta.Text = &quot;Пределы допускаемой относительной погрешности, % &lt;u&gt;          &quot;;
          CPM_OSU_CheckDate.Text = &quot;Дата поверки &lt;u&gt;          &quot;;
          break;  
            
        default:
          // Add need number of rows for 
          if (Engine.FirstPass == true)
          {
            int cols;
            int rows;
            for (rows = 4; rows &lt; (listPRs_Info.Count*4); rows++)                 
            {
              TableRow row = new TableRow(); 
              TablePRs.Rows.Add(row);
                     
              if ((TablePRs.Rows.Count % 4) == 1)
              {
                for (cols=0; cols &lt;TablePRs.ColumnCount; cols++)
                {
                  TablePRs[cols, rows].AssignAll(TablePRs[cols, 0]);
                }
              }
              else
              {
                for (cols=0; cols &lt;(TablePRs.ColumnCount); cols++)
                {
                  TablePRs[cols, rows].AssignAll(TablePRs[cols, 1]);
                }
              }
            }      
                  
            // Fill cells of the TablePRs with data from json
            int tempCounter = 0;
            for (int i=0; i &lt;TablePRs.RowCount ; i++)
            {
              if ((i % 4) == 0)
              {
                TablePRs[0,i].Text= String.Format(&quot;СРМ{0}:&quot;, tempCounter+1);
                TablePRs[1,i].Text= &quot;Тип контрольного СИ массового расхода &lt;u&gt; &quot; + listPRs_Info[tempCounter].Sensor.DevType;
                TablePRs[1,i+1].Text= &quot;Заводской номер &lt;u&gt; &quot; + listPRs_Info[tempCounter].Sensor.DevNumb;
                TablePRs[1,i+2].Text= &quot;Пределы допускаемой относительной погрешности, % &lt;u&gt; -&quot;; //+ listPRs_Info[tempCounter].Sensor.DevType;
                TablePRs[1,i+3].Text= &quot;Дата поверки &lt;u&gt; -&quot;; // + listPRs_Info[tempCounter].Sensor.DevType;
                tempCounter++;
              }
            }
          }
          break;
      }
    }
              
