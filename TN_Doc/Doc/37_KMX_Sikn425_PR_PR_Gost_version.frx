    private void Table1Results_ManualBuild(object sender, EventArgs e)
    {            
      List &lt;TN.Doc.Table2&gt; listTable2Results;
      List &lt;TN.Doc.Table3&gt; listTable3Results;
      List &lt;TN.Doc.Table1Result&gt; listTable1Results;
      
      listTable2Results = DataIVK.TableKmxSikn425PrPr.Protokol.Table2.Where(i =&gt; ! i.ser.Contains(&quot;-&quot;) &amp; String.IsNullOrEmpty(i.ser) == false).ToList();
      listTable3Results = DataIVK.TableKmxSikn425PrPr.Protokol.Table3.Where(i =&gt; ! i.ser.Contains(&quot;-&quot;) &amp; String.IsNullOrEmpty(i.ser) == false).ToList();
      listTable1Results = DataIVK.Table1Result.Where(i =&gt; ! i.ser.Contains(&quot;-&quot;) &amp; String.IsNullOrEmpty(i.ser) == false).ToList();
      
      //Setup Columns width
      //int sumDynamicCols=8;
      //float widthDynamicCol=(Page.PaperWidth-Page.LeftMargin-Page.RightMargin)/sumDynamicCols;                  
      //for (int w = 0; w &lt; (Table1Results.ColumnCount); w++)                 
      //{
      //  Table1Results.Columns[w].Width = widthDynamicCol * Units.Millimeters;
      //}  
         
      //Draw Fixed rows
      for (int n = 0; n &lt; Table1Results.FixedRows; n++)
      {
        Table1Results.PrintRow(n);
        Table1Results.PrintColumns();                                             
      }
      
      //Fill table with data      
      for (int n = 0; n &lt; (listTable1Results.Count); n++)
      {
        Ser.Text = listTable1Results[n].ser;
        Row.Text = listTable1Results[n].row;
        Q_jik.Text = tools.GetNormalizedValue(listTable1Results[n].Q_jik);
        Q_KMH_ji.Text = tools.GetNormalizedValue(listTable1Results[n].Q_KMH_ji); 
        M_jik.Text = tools.GetNormalizedValue(listTable1Results[n].M_jik);
        M_KMH_ji.Text = tools.GetNormalizedValue(listTable1Results[n].M_KMH_ji);
        delta_KMH_ji.Text = tools.GetNormalizedValue(listTable1Results[n].delta_KMH_ji);

        Table1Results.PrintRow(3);     
        Table1Results.PrintColumns();          
      }
    }
  
    private void Table5Results_ManualBuild(object sender, EventArgs e)
