        Table5Results.PrintColumns();                                             
      }
      //Fill table with data      
      for (int n = 0; n &lt; (listTable5Results.Count); n++)
      {
        Ser2.Text = listTable5Results[n].ser;
        Row2.Text = listTable5Results[n].row;
        MPR_Id2.Text = listTable5Results[n].MPR_Id;
        Q_jik2.Text = tools.GetNormalizedValue(listTable5Results[n].Q_jik);
        Q_KMH_ji2.Text = tools.GetNormalizedValue(listTable5Results[n].Q_KMH_ji); 
        M_jik2.Text = tools.GetNormalizedValue(listTable5Results[n].M_jik);
        M_KMH_ji2.Text = tools.GetNormalizedValue(listTable5Results[n].M_KMH_ji);
        delta_KMH_ji2.Text = tools.GetNormalizedValue(listTable5Results[n].delta_KMH_ji);

        Table5Results.PrintRow(3);     
        Table5Results.PrintColumns();          
      }
    }
      
    
      
