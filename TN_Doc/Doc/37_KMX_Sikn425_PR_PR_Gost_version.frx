<Report ScriptLanguage="CSharp" ReferencedAssemblies="System.dll&#13;&#10;System.Drawing.dll&#13;&#10;System.Windows.Forms.dll&#13;&#10;System.Data.dll&#13;&#10;System.Xml.dll&#13;&#10;Newtonsoft.Json.dll&#13;&#10;System.Collections.dll&#13;&#10;System.Core.dll&#13;&#10;TN_ToolsFastReport.dll&#13;&#10;TN_DocGeneral.dll&#13;&#10;KMX_Sikn425_PR_PR.dll" DoublePass="true" ReportInfo.Created="03/25/2020 12:46:46" ReportInfo.Modified="12/11/2024 13:33:42" ReportInfo.CreatorVersion="2024.2.20.0">
  <ScriptText>//1 mm on the screen = 3.78 pixels
using System;
using System.Reflection;
using System.Collections;
using System.Collections.Generic;
using System.ComponentModel;         
using System.Drawing;
using System.Data;
using System.IO;
using FastReport;
using FastReport.Data;
using FastReport.Dialog;
using FastReport.Barcode;
using FastReport.Table;
using FastReport.Utils;
using System.Linq;
using Newtonsoft.Json;
using TN.DocData;

namespace FastReport
{
  public class ReportScript
  {
    TN_ToolsFastReport.Tools tools = new TN_ToolsFastReport.Tools();  // классы отчета
    TN.Doc.Doc doc; // данные из входного параметра
    TN.DocData.General General;
    TN.Doc.HeaderDoc Header;
    TN.Doc.DataDoc SettingsData;
    TN.Doc.FooterDoc Footer;
    TN.Doc.DictionarysDoc Dictionarys;
    TN.Doc.DataIVKDoc DataIVK;      
      
    private void Page_StartPage(object sender, EventArgs e)
    {
      // Десериализация данных (формат json) из входного параметра - Json                         
      string json = (string)Report.GetParameterValue(&quot;JsonDoc&quot;);
      Newtonsoft.Json.JsonSerializerSettings settings = new Newtonsoft.Json.JsonSerializerSettings();
      settings.TypeNameHandling = TypeNameHandling.All;
      
      doc = JsonConvert.DeserializeObject&lt;TN.Doc.Doc&gt;(json, settings);
      General = (TN.DocData.General) doc.Doc.Settings.General;
      Header = (TN.Doc.HeaderDoc) doc.Doc.Settings.Header;
      SettingsData = (TN.Doc.DataDoc) doc.Doc.Settings.Data;
      Footer = (TN.Doc.FooterDoc) doc.Doc.Settings.Footer;
      Dictionarys = (TN.Doc.DictionarysDoc) doc.Doc.Settings.Dictionarys;  
      DataIVK = (TN.Doc.DataIVKDoc) doc.Doc.DataIVK; 
      
      // === Настройки страницы 
      // Ширина и высота (в мм)
      Page.PaperHeight = General.PageSettings.PaperHeight;
      Page.PaperWidth = General.PageSettings.PaperWidth;
         
      // Поля/отступы от краёв (в мм)
      Page.TopMargin = General.PageSettings.TopMargin;
      Page.BottomMargin = General.PageSettings.BottomMargin;
      Page.LeftMargin = General.PageSettings.LeftMargin;
      Page.RightMargin = General.PageSettings.RightMargin;
     
      // Запуск отрисовки таблиц на странице отчета
      DrawTableHeader();    
      DrawTableConclusion();
    }
     
    public void DrawTableHeader()
    {
      List &lt;TN.Doc.MprInfo&gt; listPRs_Info;
         
      //Setup Columns width
      TableHeader01.Columns[0].Width = (Page.PaperWidth-Page.LeftMargin-Page.RightMargin)*Units.Millimeters;
         
      // Fill table with data   
      ProtokolNum.Text = &quot;П Р О Т О К О Л  № &quot; + DataIVK.TableKmxSikn425PrPr.AdditionalInfo.ProtokolNum;
      
      CPM_RSU_Type.Text = &quot;Тип СИ массового расхода &lt;u&gt; &quot; + DataIVK.TableKmxSikn425PrPr.AdditionalInfo.MprRsuInfo.Sensor.DevType;
      CPM_RSU_FactoryNumber.Text = &quot;Заводской номер &lt;u&gt; &quot; + DataIVK.TableKmxSikn425PrPr.AdditionalInfo.MprRsuInfo.Sensor.DevNumb;
      CPM_RSU_Delta.Text = &quot;Пределы допускаемой относительной погрешности, % &lt;u&gt; -&quot;;
      Place_SIKN.Text = &quot;СИКН/СИКНП &lt;u&gt; &quot; + DataIVK.TableKmxSikn425PrPr.AdditionalInfo.PlaceSikn;
      Place_PSP.Text = &quot;ПСП &lt;u&gt; &quot; + DataIVK.TableKmxSikn425PrPr.AdditionalInfo.PlacePsp;
    
      listPRs_Info = DataIVK.TableKmxSikn425PrPr.AdditionalInfo.MprOsuInfo.Where(i =&gt; ! i.Sensor.DevType.Contains(&quot;-&quot;) &amp; String.IsNullOrEmpty(i.Sensor.DevType) == false).ToList();
      switch(listPRs_Info.Count)
      {
        case 0:
          PRs_Info.Text = &quot;СРМ: &quot;;
          CPM_OSU_Type.Text = &quot;Тип контрольного СИ массового расхода &lt;u&gt;          &quot;;
          CPM_OSU_FactoryNumber.Text = &quot;Заводской номер &lt;u&gt;          &quot;;
          CPM_OSU_Delta.Text = &quot;Пределы допускаемой относительной погрешности, % &lt;u&gt;          &quot;;
          CPM_OSU_CheckDate.Text = &quot;Дата поверки &lt;u&gt;          &quot;;
          break;  
            
        default:
          // Add need number of rows for 
          if (Engine.FirstPass == true)
          {
            int cols;
            int rows;
            for (rows = 4; rows &lt; (listPRs_Info.Count*4); rows++)                 
            {
              TableRow row = new TableRow(); 
              TablePRs.Rows.Add(row);
                     
              if ((TablePRs.Rows.Count % 4) == 1)
              {
                for (cols=0; cols &lt;TablePRs.ColumnCount; cols++)
                {
                  TablePRs[cols, rows].AssignAll(TablePRs[cols, 0]);
                }
              }
              else
              {
                for (cols=0; cols &lt;(TablePRs.ColumnCount); cols++)
                {
                  TablePRs[cols, rows].AssignAll(TablePRs[cols, 1]);
                }
              }
            }      
                  
            // Fill cells of the TablePRs with data from json
            int tempCounter = 0;
            for (int i=0; i &lt;TablePRs.RowCount ; i++)
            {
              if ((i % 4) == 0)
              {
                TablePRs[0,i].Text= String.Format(&quot;СРМ{0}:&quot;, tempCounter+1);
                TablePRs[1,i].Text= &quot;Тип контрольного СИ массового расхода &lt;u&gt; &quot; + listPRs_Info[tempCounter].Sensor.DevType;
                TablePRs[1,i+1].Text= &quot;Заводской номер &lt;u&gt; &quot; + listPRs_Info[tempCounter].Sensor.DevNumb;
                TablePRs[1,i+2].Text= &quot;Пределы допускаемой относительной погрешности, % &lt;u&gt; -&quot;; //+ listPRs_Info[tempCounter].Sensor.DevType;
                TablePRs[1,i+3].Text= &quot;Дата поверки &lt;u&gt; -&quot;; // + listPRs_Info[tempCounter].Sensor.DevType;
                tempCounter++;
              }
            }
          }
          break;
      }
    }
    
    private void Table1Results_ManualBuild(object sender, EventArgs e)
    {            
      List &lt;TN.Doc.Table1Result&gt; listTable1Results = DataIVK.Table1Result.Where(i =&gt; ! i.ser.Contains(&quot;-&quot;) &amp; String.IsNullOrEmpty(i.ser) == false).ToList();
      
      //Draw Fixed rows
      for (int n = 0; n &lt; Table1Results.FixedRows; n++)
      {
        Table1Results.PrintRow(n);
        Table1Results.PrintColumns();                                             
      }
      
      //Fill table with data      
      for (int n = 0; n &lt; (listTable1Results.Count); n++)
      {
        Ser.Text = listTable1Results[n].ser;
        Row.Text = listTable1Results[n].row;
        MPR_Id.Text = listTable1Results[n].MPR_Id;
        Q_jik.Text = tools.GetNormalizedValue(listTable1Results[n].Q_jik);
        Q_KMH_ji.Text = tools.GetNormalizedValue(listTable1Results[n].Q_KMH_ji); 
        M_jik.Text = tools.GetNormalizedValue(listTable1Results[n].M_jik);
        M_KMH_ji.Text = tools.GetNormalizedValue(listTable1Results[n].M_KMH_ji);
        delta_KMH_ji.Text = tools.GetNormalizedValue(listTable1Results[n].delta_KMH_ji);
    
        Table1Results.PrintRow(3);     
        Table1Results.PrintColumns();          
      }
    }
      
    private void DataBandPrim_BeforeLayout(object sender, EventArgs e)
    {
      Prim.Width=(Page.PaperWidth-Page.LeftMargin-Page.RightMargin)*Units.Millimeters;
      Prim.Text = &quot;Расчеты проведены в соответствии с &lt;u&gt; МП СИКН №425 &quot;;
    }
    
    public void  DrawTableConclusion()
    {                                                    
      // Setup Cols width    
      TableConclusion1.Columns[0].Width=(Page.PaperWidth-Page.LeftMargin-Page.RightMargin)  * Units.Millimeters;
        
      // Fill Table with data
      Delta_Result.Text = string.Format(&quot;Максимальное относительное отклонение δ = «+» или «-» &lt;u&gt; {0} %&quot;, 
        DataIVK.TableKmxSikn425PrPr.Protokol.Table5.delta_KMH_max);
      ARM_Poverka_Result.Text = string.Format(&quot;СИ массового расхода {0} к дальнейшей эксплуатации&quot;, 
        DataIVK.TableKmxSikn425PrPr.AdditionalInfo.ARM_Poverka_Result);
      DateTimeLong.Text = string.Format(&quot;Дата проведения КМХ: &lt;u&gt;{0:dd.MM.yyyy} г.&quot;,
        (tools.UnixTimestampToDatetime(DataIVK.TableKmxSikn425PrPr.DateTimeLong)));               
      
      ServiceStaffCompany.Text = DataIVK.TableKmxSikn425PrPr.AdditionalInfo.ServiceStaffCompany;
      ServiceStaffPost.Text = DataIVK.TableKmxSikn425PrPr.AdditionalInfo.ServiceStaffPost;
      ServiceStaffFIO.Text = DataIVK.TableKmxSikn425PrPr.AdditionalInfo.ServiceStaffFIO;
      OperationStaffCompany.Text = DataIVK.TableKmxSikn425PrPr.AdditionalInfo.OperationStaffCompany;
      OperationStaffPost.Text = DataIVK.TableKmxSikn425PrPr.AdditionalInfo.OperationStaffPost;
      OperationStaffFIO.Text = DataIVK.TableKmxSikn425PrPr.AdditionalInfo.OperationStaffFIO;
      RecievingStaffCompany.Text = DataIVK.TableKmxSikn425PrPr.AdditionalInfo.RecievingStaffCompany;
      RecievingStaffPost.Text = DataIVK.TableKmxSikn425PrPr.AdditionalInfo.RecievingStaffPost;
      RecievingStaffFIO.Text = DataIVK.TableKmxSikn425PrPr.AdditionalInfo.RecievingStaffFIO;
    }  
      
    //// Setup heights of the all objects on the Page
    private void PageFooter_BeforeLayout(object sender, EventArgs e)
    {
      if((Int32)Report.GetVariableValue(&quot;TotalPages&quot;) &lt; 2) 
      { 
        PageFooter.Visible = false; 
      }
      else
      {
        PageNumeration.Width = (Page.PaperWidth-Page.LeftMargin-Page.RightMargin)*Units.Millimeters;
      }
    }
   

    
  }    
}

