            }
                                                                   
           Q_min.Text =  tools.GetNormalizedValue(dictTable4Results[&quot;Q_min&quot;]);                                                                
           Q_max.Text =  tools.GetNormalizedValue(dictTable4Results[&quot;Q_max&quot;]);                                                              
           K_M_MF.Text =  tools.GetNormalizedValue(dictTable4Results[&quot;K_M_MF&quot;]);                                                                                   
           S_0.Text =  tools.GetNormalizedValue(dictTable4Results[&quot;S_0&quot;]);                                                                                                   
           Epsilon.Text =  tools.GetNormalizedValue(dictTable4Results[&quot;Epsilon&quot;]);      
           Teta_A.Text =  tools.GetNormalizedValue(dictTable4Results[&quot;Teta_A&quot;]);                                                                                        
           Teta_Z.Text =  tools.GetNormalizedValue(dictTable4Results[&quot;Teta_Z&quot;]);                                                                                              
           Teta_Dens.Text =  tools.GetNormalizedValue(dictTable4Results[&quot;Teta_Dens&quot;]);                                                                                         
      
