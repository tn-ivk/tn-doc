     // List &lt;TN_DocPover_MI3189.Table4&gt; listTable4Results;

      private void Page_StartPage(object sender, EventArgs e)
      {
         //using (var sr = new StreamReader(&quot;D:/!_Work/!_Транснефть/SVN/Work/Sources/Reports/FRX/Входящие данные от Алексея (классы и json)/16_TablePoverka3189/DocPoverka3189.json&quot;))
         //{
            // Read the stream as a string
         //   Report.SetParameterValue(&quot;JsonDoc&quot;, sr.ReadToEnd());
         //}
         
         //// Десериализация данных (формат json) из входного параметра - Json                         
         string json = (string)Report.GetParameterValue(&quot;JsonDoc&quot;);
         Newtonsoft.Json.JsonSerializerSettings settings = new Newtonsoft.Json.JsonSerializerSettings();
         settings.TypeNameHandling = TypeNameHandling.All;
         
         doc = JsonConvert.DeserializeObject&lt;TN.Doc.Doc&gt;(json, settings);
         General = (TN.DocData.General) doc.Doc.Settings.General;
         Header = (TN.Doc.HeaderDoc) doc.Doc.Settings.Header;
         SettingsData = (TN.Doc.DataDoc) doc.Doc.Settings.Data;
         Footer = (TN.Doc.FooterDoc) doc.Doc.Settings.Footer;
         Dictionarys = (TN.Doc.DictionarysDoc) doc.Doc.Settings.Dictionarys;  
         DataIVK = (TN.Doc.DataIVKDoc) doc.Doc.DataIVK;
      
         //// === Настройки страницы 
         // Ширина и высота (в мм)
         
         Page.PaperHeight = General.PageSettings.PaperHeight;
         Page.PaperWidth = General.PageSettings.PaperWidth;
         //Page.Border.Lines = BorderLines.All;
         
         // Поля/отступы от краёв (в мм)
         Page.TopMargin = General.PageSettings.TopMargin;
         Page.BottomMargin = General.PageSettings.BottomMargin;
         Page.LeftMargin = General.PageSettings.LeftMargin;
         Page.RightMargin = General.PageSettings.RightMargin;
                                                                
         //// ==== Get Data from classes
         listTable1Detectors = DataIVK.TablePoverka3189.Protokol.Table1.DetName.Where(i =&gt; i.Length &gt; 1 | ! i.Contains(&quot;&quot;)).ToList();
         listTable1V0 = DataIVK.TablePoverka3189.Protokol.Table1.V0.Where(i =&gt; ! i.Contains(&quot;-&quot;) | ! i.Contains(&quot;&quot;)).ToList();
         
         // Get data for Table ! to Dictionary
         dictTable1SourceData = new Dictionary&lt;string,string&gt; ();
         
         //TODO dictTable1SourceData = typeof(TN_DocPover_MI3189.Table1).GetProperties().Where(x =&gt;! x.Name.Contains(&quot;DetName&quot;)) &amp; (z =&gt;! z.Name.Contains(&quot;V0&quot;)).ToDictionary(x =&gt; x.Name, x =&gt; x.GetValue(protocol.Doc.DataIVK.TablePoverka3189.Protokol.Table1));

         //List &lt;TN_DocPover_MI3189.Table1&gt; listTable1;
         
         //var listTable1 = protocol.Doc.DataIVK.TablePoverka3189.Protokol.Table1.Where(x =&gt;! x.Name.Contains(&quot;DetName&quot;)).ToList();
         
         foreach (var propertyInfo in DataIVK.TablePoverka3189.Protokol.Table1.GetType().GetProperties())
         {
            var propertyValue = propertyInfo.GetValue(DataIVK.TablePoverka3189.Protokol.Table1);
            if (propertyValue is string)
            {
               dictTable1SourceData.Add(propertyInfo.Name, propertyInfo.GetValue(DataIVK.TablePoverka3189.Protokol.Table1).ToString());
            }
         }
         listTable2Results = DataIVK.TablePoverka3189.Protokol.Table2.Where(i =&gt; i.Activated==1).ToList();
         listTable3Results = DataIVK.TablePoverka3189.Protokol.Table3.Where(i =&gt; ! i.Ser.Contains(&quot;-&quot;)  &amp; String.IsNullOrEmpty(i.Ser) == false).ToList();
         // ====
         
         // Get data for Table 4 to Dictionary
         string tempVar;
         dictTable4Results = new Dictionary&lt;string,string&gt; ();
         foreach (var propertyInfo in DataIVK.TablePoverka3189.Protokol.Table4.GetType().GetProperties())
         {
            var propertyValue = propertyInfo.GetValue(DataIVK.TablePoverka3189.Protokol.Table4);
            tempVar = propertyValue.ToString();   
            switch(tempVar)
            {
               //case &quot;-&quot;:
               //case &quot;&quot;:  
               //   break;
               default:
                  dictTable4Results.Add(propertyInfo.Name, propertyInfo.GetValue(DataIVK.TablePoverka3189.Protokol.Table4).ToString());
                  break;  
            }      
         }       
         /// ==== End get Data from classes
    
         // Запуск отрисовки таблиц на странице отчета
         DrawTableHeader();    
         DrawTableConclusion();
      }
      #region //Имхо лишний метод
      private void PrintTable(TableObject table)
      {
         for (int i=0;i&lt;table.RowCount;i++)
         {       
            table.PrintRow(i);
            table.PrintColumns();
         }    
      } 
      #endregion
      
      //// ======================== //// ======================== //// ======================== ////
      public void DrawTableHeader()
      {
         //Setup Columns width
         TableHeader01.Columns[0].Width = (Page.PaperWidth-Page.LeftMargin-Page.RightMargin)*Units.Millimeters;
         
         // Fill table with data   
         ProtokolNum.Text = &quot;П Р О Т О К О Л  № &quot; + DataIVK.TablePoverka3189.AdditionalInfo.ProtokolNum;
         Place_PSP.Text = DataIVK.TablePoverka3189.AdditionalInfo.Place_PSP;
         MPR_Sensor_Type.Text = DataIVK.TablePoverka3189.AdditionalInfo.MPR_Sensor_Type;
         MPR_Sensor_FactoryNumber.Text = DataIVK.TablePoverka3189.AdditionalInfo.MPR_Sensor_FactoryNumber;
         MPR_PEP_Type.Text = DataIVK.TablePoverka3189.AdditionalInfo.MPR_PEP_Type;
         MPR_PEP_FactoryNumber.Text = DataIVK.TablePoverka3189.AdditionalInfo.MPR_PEP_FactoryNumber;
         PU_Type.Text = DataIVK.TablePoverka3189.AdditionalInfo.PU_Type;
         PU_FactoryNumber.Text = DataIVK.TablePoverka3189.AdditionalInfo.PU_FactoryNumber;
         PP_Type.Text = DataIVK.TablePoverka3189.AdditionalInfo.PP_Type;
         PP_FactoryNumber.Text = DataIVK.TablePoverka3189.AdditionalInfo.PP_FactoryNumber;
         IVK_Type.Text = DataIVK.TablePoverka3189.AdditionalInfo.IVK_Type;
         IVK_FactoryNumber.Text = DataIVK.TablePoverka3189.AdditionalInfo.IVK_FactoryNumber;
         Oil_Type.Text = DataIVK.TablePoverka3189.AdditionalInfo.Oil_Type;
        
         
      }
              
      //// ======================== //// ======================== //// ======================== ////
      private void Table1SourceData_ManualBuild(object sender, EventArgs e)
      {
            //Setup Columns width
            int sumDynamicCols=Table1SourceData.ColumnCount;
            float widthDynamicCol=(Page.PaperWidth-Page.LeftMargin-Page.RightMargin)/sumDynamicCols;                  
 
            for (int w = 0; w &lt; (Table1SourceData.ColumnCount); w++)                 
            {
               Table1SourceData.Columns[w].Width = widthDynamicCol * Units.Millimeters;
            }      
                            
            //Draw Fixed rows
            for (int n = 0; n &lt; Table1SourceData.FixedRows; n++)
            {
               Table1SourceData.PrintRow(n);
               Table1SourceData.PrintColumns();                                             
            }
                                                     
            //Fill table with data
            for (int n = 0; n &lt; (listTable1Detectors.Count); n++)
            {
               DetName.Text =  listTable1Detectors[n];
               V0.Text =  tools.GetNormalizedValue(listTable1V0[n]);        
            //TODO change to dictionary from class property value (see code below)
               m_D.Text = tools.GetNormalizedValue(DataIVK.TablePoverka3189.Protokol.Table1.m_D);
               m_S.Text = tools.GetNormalizedValue(DataIVK.TablePoverka3189.Protokol.Table1.m_S);
               m_E.Text = tools.GetNormalizedValue(DataIVK.TablePoverka3189.Protokol.Table1.m_E);
               Alpha_t1.Text = tools.GetNormalizedValue(DataIVK.TablePoverka3189.Protokol.Table1.Alpha_t1);
               Teta_Sum_0.Text = tools.GetNormalizedValue(DataIVK.TablePoverka3189.Protokol.Table1.Teta_Sum_0);
               Teta_V_0.Text = tools.GetNormalizedValue(DataIVK.TablePoverka3189.Protokol.Table1.Teta_V_0);
                                                                                               
               //RowSpans
               for (int i = 0; i &lt; (Table1SourceData.ColumnCount); i++)
               {          
                  switch(i)
                  {
                     case 2:
                     case 3:  
                     case 4:
                     case 5:  
                     case 6:     
                     case 7:      
                        Table1SourceData[i,3].RowSpan =  listTable1Detectors.Count;
                        break;  
                  }
               }
               Table1SourceData.PrintRow(3);     
               Table1SourceData.PrintColumns();  
            }                             
      }
      
      //// ======================== //// ======================== //// ======================== ////
      private void Table1SourceDataContinuation_ManualBuild(object sender, EventArgs e)
      {
         
         //Setup Columns width
         int sumDynamicCols=Table1SourceDataContinuation.ColumnCount;
         float widthDynamicCol=(Page.PaperWidth-Page.LeftMargin-Page.RightMargin)/sumDynamicCols;                  
 
         for (int w = 0; w &lt; (Table1SourceDataContinuation.ColumnCount); w++)                 
         {
            Table1SourceDataContinuation.Columns[w].Width = widthDynamicCol * Units.Millimeters;
         }      
                            
         //Draw Fixed rows
         for (int n = 0; n &lt; Table1SourceDataContinuation.FixedRows; n++)
         {
            Table1SourceDataContinuation.PrintRow(n);
            Table1SourceDataContinuation.PrintColumns();                                             
         }
         
         Delta_t_PU.Text = tools.GetNormalizedValue(DataIVK.TablePoverka3189.Protokol.Table1.Delta_t_PU);
         Delta_t_PP.Text = tools.GetNormalizedValue(DataIVK.TablePoverka3189.Protokol.Table1.Delta_t_PP);
         Delta_PP.Text = tools.GetNormalizedValue(DataIVK.TablePoverka3189.Protokol.Table1.Delta_PP);
         Delta_IVK.Text = tools.GetNormalizedValue(DataIVK.TablePoverka3189.Protokol.Table1.Delta_IVK);
         K_PM.Text = tools.GetNormalizedValue(DataIVK.TablePoverka3189.Protokol.Table1.K_PM);
         K_M_ust.Text = tools.GetNormalizedValue(DataIVK.TablePoverka3189.Protokol.Table1.K_M_ust);
         MF_ust.Text = tools.GetNormalizedValue(DataIVK.TablePoverka3189.Protokol.Table1.MF_ust);
         Q_type.Text = tools.GetNormalizedValue(DataIVK.TablePoverka3189.Protokol.Table1.Q_type);
         
         Table1SourceDataContinuation.PrintRow(3);     
         Table1SourceDataContinuation.PrintColumns();  

      }
      //// ======================== //// ======================== //// ======================== ////
      private void Table1SourceDataEnding_ManualBuild(object sender, EventArgs e)
      {
                       
            //Setup Columns width as in the previous table
            for (int i = 0; i &lt; (Table1SourceDataEnding.ColumnCount); i++)
            {          
               Table1SourceDataEnding.Columns[i].Width =  Table1SourceDataContinuation.Columns[i].Width;
            }
         
            //Draw Fixed rows
            for (int n = 0; n &lt; Table1SourceDataEnding.FixedRows; n++)
            {
               Table1SourceDataEnding.PrintRow(n);
               Table1SourceDataEnding.PrintColumns();                                             
            }
         
         ZS.Text = tools.GetNormalizedValue(DataIVK.TablePoverka3189.Protokol.Table1.ZS);
         Delta_t_dop.Text = tools.GetNormalizedValue(DataIVK.TablePoverka3189.Protokol.Table1.Delta_t_dop);
         Delta_P_dop.Text = tools.GetNormalizedValue(DataIVK.TablePoverka3189.Protokol.Table1.Delta_P_dop);
         t_min.Text = tools.GetNormalizedValue(DataIVK.TablePoverka3189.Protokol.Table1.t_min);
         t_max.Text = tools.GetNormalizedValue(DataIVK.TablePoverka3189.Protokol.Table1.t_max);
         P_min.Text = tools.GetNormalizedValue(DataIVK.TablePoverka3189.Protokol.Table1.P_min);
         P_max.Text = tools.GetNormalizedValue(DataIVK.TablePoverka3189.Protokol.Table1.P_max);

         Table1SourceDataEnding.PrintRow(3);     
         Table1SourceDataEnding.PrintColumns();  
                                
      }
      //// ======================== //// ======================== //// ======================== ////
      private void Table2Results_ManualBuild(object sender, EventArgs e)
      {           
            //Setup Columns width
            int sumDynamicCols=Table2Results.ColumnCount;
            float widthDynamicCol=(Page.PaperWidth-Page.LeftMargin-Page.RightMargin)/sumDynamicCols;                  
            for (int w = 0; w &lt; (Table2Results.ColumnCount); w++)                 
            {
               Table2Results.Columns[w].Width = widthDynamicCol * Units.Millimeters;
            }      
         
            //Draw Fixed rows
            for (int n = 0; n &lt; Table2Results.FixedRows; n++)
            {
               Table2Results.PrintRow(n);
               Table2Results.PrintColumns();                                             
            }
                      
            //Fill table with data
            for (int n = 0; n &lt; (listTable2Results.Count); n++)
            {
               SerRow.Text =  String.Format(&quot;{0}/{1}&quot;, listTable2Results[n].Ser, listTable2Results[n].Row);//+ &quot; | &quot; + (n+1).ToString();
               Q_ji.Text = tools.GetNormalizedValue(listTable2Results[n].Q_ji);
               Det.Text =  tools.GetNormalizedValue(listTable2Results[n].Det);
               T_ji.Text = tools.GetNormalizedValue(listTable2Results[n].T_ji);
               t_PU_ji.Text = tools.GetNormalizedValue(listTable2Results[n].t_PU_ji);
               P_PU_ji.Text = tools.GetNormalizedValue(listTable2Results[n].P_PU_ji);
               Dens_ji.Text = tools.GetNormalizedValue(listTable2Results[n].Dens_ji);
               DensTemp_ji.Text =  tools.GetNormalizedValue(listTable2Results[n].DensTemp_ji);
            
               Table2Results.PrintRow(3);     
               Table2Results.PrintColumns();  
            }
                      
      }
      //// ======================== //// ======================== //// ======================== ////
