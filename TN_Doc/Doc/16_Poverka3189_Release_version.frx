   public class ReportScript
   {
      TN_ToolsFastReport.Tools tools = new TN_ToolsFastReport.Tools();  // классы отчета    
      TN.Doc.Doc doc; // данные из входного параметра
      TN.DocData.General General;
      TN.Doc.HeaderDoc Header;
      TN.Doc.DataDoc SettingsData;
      TN.Doc.FooterDoc Footer;
      TN.Doc.DictionarysDoc Dictionarys;
      TN.Doc.DataIVKDoc DataIVK; 
      
      List &lt;string&gt; listTable1Detectors;
      List &lt;string&gt; listTable1V0;
      Dictionary&lt;string,string&gt; dictTable1SourceData;
      
      
      //List &lt;TN_DocPover_MI3189.Table1&gt; listTable1SourceData;
      List &lt;TN.Doc.Table2&gt; listTable2Results;
      List &lt;TN.Doc.Table3&gt; listTable3Results;
