using FastReport.Utils;
using System.Linq;
using Newtonsoft.Json;
using TN.DocData;

namespace FastReport
{
   public class ReportScript
   {
      TN_ToolsFastReport.Tools tools = new TN_ToolsFastReport.Tools();  // классы отчета
      TN.Doc.Doc doc; // данные из входного параметра
      TN.DocData.General General;
      TN.Doc.HeaderDoc Header;
      TN.Doc.DataDoc SettingsData;
      TN.Doc.FooterDoc Footer;
      TN.Doc.DictionarysDoc Dictionarys;
      TN.Doc.DataIVKDoc DataIVK;       

      private void Page_StartPage(object sender, EventArgs e)
      {
         //using (var sr = new StreamReader(&quot;D:/!_Work/!_Транснефть/SVN/Work/Sources/Reports/FRX/Входящие данные от Алексея (классы и json)/33_TableKMH3272_MPR_TPR/TableKMH3272_MPR_TPR.json&quot;))
         //{
            // Read the stream as a string
         //   Report.SetParameterValue(&quot;JsonDoc&quot;, sr.ReadToEnd());
         //}
         
         //// Десериализация данных (формат json) из входного параметра - Json                         
         string json = (string)Report.GetParameterValue(&quot;JsonDoc&quot;);
         Newtonsoft.Json.JsonSerializerSettings settings = new Newtonsoft.Json.JsonSerializerSettings();
         settings.TypeNameHandling = TypeNameHandling.All;
         
         doc = JsonConvert.DeserializeObject&lt;TN.Doc.Doc&gt;(json, settings);
         General = (TN.DocData.General) doc.Doc.Settings.General;
         Header = (TN.Doc.HeaderDoc) doc.Doc.Settings.Header;
         SettingsData = (TN.Doc.DataDoc) doc.Doc.Settings.Data;
         Footer = (TN.Doc.FooterDoc) doc.Doc.Settings.Footer;
         Dictionarys = (TN.Doc.DictionarysDoc) doc.Doc.Settings.Dictionarys;  
         DataIVK = (TN.Doc.DataIVKDoc) doc.Doc.DataIVK;          
         
         //// === Настройки страницы 
         // Ширина и высота (в мм)
         Page.PaperHeight = General.PageSettings.PaperHeight;
         Page.PaperWidth = General.PageSettings.PaperWidth;
         //Page.Border.Lines = BorderLines.All;
         
         // Поля/отступы от краёв (в мм)
         Page.TopMargin = General.PageSettings.TopMargin;
         Page.BottomMargin = General.PageSettings.BottomMargin;
         Page.LeftMargin = General.PageSettings.LeftMargin;
         Page.RightMargin = General.PageSettings.RightMargin;

         DrawTableHeader();    
         DrawTableConclusion();         
      }
    
    
      #region Имхо лишний метод
      private void PrintTable(TableObject table)
      {
         for (int i=0;i&lt;table.RowCount;i++)
         {       
            table.PrintRow(i);
            table.PrintColumns();
         }    
      } 
      #endregion
      
      //// ======================== //// ======================== //// ======================== ////
      public void DrawTableHeader()
      {
         
         //Setup Columns width
         TableHeader01.Columns[0].Width = (Page.PaperWidth-Page.LeftMargin-Page.RightMargin)*Units.Millimeters;
         
         // Fill table with data   
         ProtokolNum.Text = &quot;П Р О Т О К О Л  № &quot; + DataIVK.TableKMH_MPR_TPR.AdditionalInfo.ProtokolNum;
         
         MPR_Type.Text = DataIVK.TableKMH_MPR_TPR.AdditionalInfo.MPR_Type;
         MPR_FactoryNum.Text = DataIVK.TableKMH_MPR_TPR.AdditionalInfo.MPR_FactoryNum;
         PU_Type.Text = DataIVK.TableKMH_MPR_TPR.AdditionalInfo.PU_Type;
         PU_Factory.Text = DataIVK.TableKMH_MPR_TPR.AdditionalInfo.PU_Factory;
         PU_CheckDate.Text = DataIVK.TableKMH_MPR_TPR.AdditionalInfo.PU_CheckDate;
         TPR_Type.Text = DataIVK.TableKMH_MPR_TPR.AdditionalInfo.TPR_Type;
         TPR_FactoryNum.Text = DataIVK.TableKMH_MPR_TPR.AdditionalInfo.TPR_FactoryNum;
         
         Place.Text = string.Format(&quot;Место проведения КМХ: {0}, {1} (СИКН, НГДУ, ПСП)&quot;, 
            DataIVK.TableKMH_MPR_TPR.AdditionalInfo.SIKN,
            DataIVK.TableKMH_MPR_TPR.AdditionalInfo.Place_PSP);

         KinimVisc.Text = string.Format(&quot;Вязкость нефти при КМХ, мм &lt;sup&gt;2&lt;/sup&gt;/с (сСт): {0}&quot;, 
            DataIVK.TableKMH_MPR_TPR.Protokol.Visc.KinimVisc_middle);
        
      }
              
      //// ======================== //// ======================== //// ======================== ////
      private void Table1SourceData_ManualBuild(object sender, EventArgs e)
      {
         // Setup Columns width
         int sumDynamicCols=Table1SourceData.ColumnCount;
         float widthDynamicCol=(Page.PaperWidth-Page.LeftMargin-Page.RightMargin)/sumDynamicCols;                  
 
         for (int w = 0; w &lt; (Table1SourceData.ColumnCount); w++)                 
         {
            Table1SourceData.Columns[w].Width = widthDynamicCol * Units.Millimeters;
         }      
                            
         //Draw Fixed rows
         for (int n = 0; n &lt; Table1SourceData.FixedRows; n++)
         {
            Table1SourceData.PrintRow(n);
            Table1SourceData.PrintColumns();                                             
         }

         List &lt;string&gt; listTable1Detectors;
         List &lt;string&gt; listTable1V0;
         listTable1Detectors = DataIVK.TableKMH_MPR_TPR.Protokol.Table1.DetName.Where(i =&gt; i.Length &gt; 1 &amp; String.IsNullOrEmpty(i) == false).ToList();
         listTable1V0 = DataIVK.TableKMH_MPR_TPR.Protokol.Table1.V0.Where(i =&gt; ! i.Contains(&quot;-&quot;) &amp; String.IsNullOrEmpty(i) == false).ToList();
         
            //Fill table with data
         for (int n = 0; n &lt; (listTable1Detectors.Count); n++)
         {
            DetName.Text =  listTable1Detectors[n];
                                              
            #region Если текущему элементу в listTable1Detectors нет соответствующего элемента в listTable1V0, 
            //тогда записать некий текст в Таблицу 1, вмеcто отсутствующего элемента из listTable1V0
            if (n &gt;= listTable1V0.Count() )
            {
               V0.Text = &quot;Нет данных&quot;;
            }
            else 
            {
               V0.Text =  tools.GetNormalizedValue(listTable1V0[n]);   
            }
            #endregion
            
            Delta_KP.Text = tools.GetNormalizedValue(DataIVK.TableKMH_MPR_TPR.Protokol.Table1.Delta_KP);
            m_D.Text = tools.GetNormalizedValue(DataIVK.TableKMH_MPR_TPR.Protokol.Table1.m_D);
            
            m_s.Text = tools.GetNormalizedValue(DataIVK.TableKMH_MPR_TPR.Protokol.Table1.m_s);
            m_E.Text = tools.GetNormalizedValue(DataIVK.TableKMH_MPR_TPR.Protokol.Table1.m_E);
            Delta_t_KP.Text = tools.GetNormalizedValue(DataIVK.TableKMH_MPR_TPR.Protokol.Table1.Delta_t_KP);
            Delta_PP.Text = tools.GetNormalizedValue(DataIVK.TableKMH_MPR_TPR.Protokol.Table1.Delta_PP);
            Delta_t_PP.Text = tools.GetNormalizedValue(DataIVK.TableKMH_MPR_TPR.Protokol.Table1.Delta_t_PP);
            Delta_k_UOI.Text = tools.GetNormalizedValue(DataIVK.TableKMH_MPR_TPR.Protokol.Table1.Delta_k_UOI);
            KF_konf.Text = tools.GetNormalizedValue(DataIVK.TableKMH_MPR_TPR.Protokol.Table1.KF_konf);
            ZS.Text = tools.GetNormalizedValue(DataIVK.TableKMH_MPR_TPR.Protokol.Table1.ZS);
            Alpha_cil_t.Text = tools.GetNormalizedValue(DataIVK.TableKMH_MPR_TPR.Protokol.Table1.Alpha_cil_t);
            Alpha_cil_t_kv.Text = tools.GetNormalizedValue(DataIVK.TableKMH_MPR_TPR.Protokol.Table1.Alpha_cil_t_kv);
            Alpha_t_cm.Text = tools.GetNormalizedValue(DataIVK.TableKMH_MPR_TPR.Protokol.Table1.Alpha_t_cm);
            
            //RowSpans
            for (int i = 0; i &lt; (Table1SourceData.ColumnCount); i++)
            {          
               switch(i)
               {
                  case 2:
                  case 3:  
                  case 4:
                  case 5:  
                  case 6:     
                  case 7:
                  case 8:
                  case 9: 
                  case 10: 
                  case 11: 
                  case 12: 
                  case 13: 
                  case 14:
                     Table1SourceData[i,4].RowSpan =  listTable1Detectors.Count;
                     break;  
               }
            }
                             
            Table1SourceData.PrintRow(4);     
            Table1SourceData.PrintColumns();  
         }                                 
      }

      //// ======================== //// ======================== //// ======================== ////
      private void Table2_part1_ManualBuild(object sender, EventArgs e)
      {                
         
         List &lt;TN.Doc.Table2_part1_Points&gt; listTable2_part1_Points;
         listTable2_part1_Points = DataIVK.TableKMH_MPR_TPR.Protokol.Table2_part1_Points.Where(i =&gt; ! i.K1_TPR_j.Contains(&quot;-&quot;) &amp; String.IsNullOrEmpty(i.K1_TPR_j) == false).ToList();

         List &lt;TN.Doc.Table2_part1&gt; listTable2_part1;
         listTable2_part1 = DataIVK.TableKMH_MPR_TPR.Protokol.Table2_part1.Where(i =&gt; i.Activated != 0 &amp; i.Activated != null).ToList();
         
         //Setup Columns width
         int sumDynamicCols=Table2_part1.ColumnCount;
         float widthDynamicCol=(Page.PaperWidth-Page.LeftMargin-Page.RightMargin)/sumDynamicCols;                  
         for (int w = 0; w &lt; (Table2_part1.ColumnCount); w++)                 
         {
            Table2_part1.Columns[w].Width = widthDynamicCol * Units.Millimeters;
         }      
         
         //Draw Fixed rows
         for (int n = 0; n &lt; Table2_part1.FixedRows; n++)
         {
            Table2_part1.PrintRow(n);
            Table2_part1.PrintColumns();                                             
         }
          
         //Fill table with data
         for (int n = 0; n &lt; (listTable2_part1.Count); n++)
         {
            SerRow.Text =  String.Format(&quot;{0}/{1}&quot;, listTable2_part1[n].Ser, listTable2_part1[n].Row);
            Q_ji.Text = tools.GetNormalizedValue(listTable2_part1[n].Q_ji);
            N_TPR_ji.Text = tools.GetNormalizedValue(listTable2_part1[n].N_TPR_ji);
            t_TPR_ji.Text = tools.GetNormalizedValue(listTable2_part1[n].t_TPR_ji);                                                                       
            P_TPR_ji.Text = tools.GetNormalizedValue(listTable2_part1[n].P_TPR_ji);
            t_KP_ji.Text = tools.GetNormalizedValue(listTable2_part1[n].t_KP_ji);
            P_KP_ji.Text = tools.GetNormalizedValue(listTable2_part1[n].P_KP_ji);
            t_cm_ji.Text = tools.GetNormalizedValue(listTable2_part1[n].t_cm_ji);
            Wv.Text =&quot;-&quot;;                   
            Wx.Text =&quot;-&quot;;                   
            V_KP_PR_ji.Text = tools.GetNormalizedValue(listTable2_part1[n].V_KP_PR_ji);
            K_TPR_ji.Text =  tools.GetNormalizedValue(listTable2_part1[n].K_TPR_ji);
                  
            Repeatability_K_j.Text =  tools.GetNormalizedValue(listTable2_part1_Points[n].Repeatability_K_j);                   
            K1_TPR_j.Text =  tools.GetNormalizedValue(listTable2_part1_Points[n].K1_TPR_j);                   
            K2_TPR_j.Text =  tools.GetNormalizedValue(listTable2_part1_Points[n].K2_TPR_j);                   
            Delta_k_j.Text =  tools.GetNormalizedValue(listTable2_part1_Points[n].Delta_k_j);         
            
            Table2_part1.PrintRow(4);     
            Table2_part1.PrintColumns();  
         }            
      }
      
      //// ======================== //// ======================== //// ======================== ////
      private void Table2_part2_ManualBuild(object sender, EventArgs e)
      {       
         List &lt;TN.Doc.Table2_part2_Points&gt; listTable2_part2_Points;
         listTable2_part2_Points = DataIVK.TableKMH_MPR_TPR.Protokol.Table2_part2_Points.Where(i =&gt; ! i.K_TPR_j.Contains(&quot;-&quot;) &amp; String.IsNullOrEmpty(i.K_TPR_j) == false).ToList();

         List &lt;TN.Doc.Table2_part2&gt; listTable2_part2;
         listTable2_part2 = DataIVK.TableKMH_MPR_TPR.Protokol.Table2_part2.Where(i =&gt; i.Activated != 0 &amp; i.Activated != null).ToList();
         

         //Setup Columns width
         int sumDynamicCols=Table2_part2.ColumnCount;
         float widthDynamicCol=(Page.PaperWidth-Page.LeftMargin-Page.RightMargin)/sumDynamicCols;                  
         for (int w = 0; w &lt; (Table2_part2.ColumnCount); w++)                 
         {
            Table2_part2.Columns[w].Width = widthDynamicCol * Units.Millimeters;
         }      
         
         //Draw Fixed rows
         for (int n = 0; n &lt; Table2_part2.FixedRows; n++)
         {
            Table2_part2.PrintRow(n);
            Table2_part2.PrintColumns();                                             
         }
         

         //Fill table with data
         for (int n = 0; n &lt; (listTable2_part2.Count); n++)
         {
            SerRow2.Text =  String.Format(&quot;{0}/{1}&quot;, listTable2_part2[n].Ser, listTable2_part2[n].Row);
            Q_ji2.Text = tools.GetNormalizedValue(listTable2_part2[n].Q_ji);
            
            K_TPR_j.Text =  tools.GetNormalizedValue(listTable2_part2_Points[n].K_TPR_j);                   
            N_TPR_zad_j.Text =  tools.GetNormalizedValue(listTable2_part2_Points[n].N_TPR_zad_j);                   
             
            V_TPR_ji.Text = tools.GetNormalizedValue(listTable2_part2[n].V_TPR_ji);
            
            t_TPR_ji2.Text = tools.GetNormalizedValue(listTable2_part2[n].t_TPR_ji);                                                                       
            
            P_TPR_ji2.Text = tools.GetNormalizedValue(listTable2_part2[n].P_TPR_ji);
            
            N_mas_ji.Text = tools.GetNormalizedValue(listTable2_part2[n].N_mas_ji);
            
            Dens_ji.Text = tools.GetNormalizedValue(listTable2_part2[n].Dens_ji);
            DensTemp_ji.Text = tools.GetNormalizedValue(listTable2_part2[n].DensTemp_ji);
            
            DensPress_ji.Text = tools.GetNormalizedValue(listTable2_part2[n].DensPress_ji);
            
            Dens_PP_PR_ji.Text =  tools.GetNormalizedValue(listTable2_part2[n].Dens_PP_PR_ji);
            M_RA_ji.Text =  tools.GetNormalizedValue(listTable2_part2[n].M_RA_ji);
            M_from_GH_ji.Text =  tools.GetNormalizedValue(listTable2_part2[n].M_from_GH_ji);
            
            MF_ji.Text =  tools.GetNormalizedValue(listTable2_part2[n].MF_ji);
            
            KinimVisc_ji.Text =  tools.GetNormalizedValue(listTable2_part2[n].KinimVisc_ji);
            Delta_KMH_ji.Text =  tools.GetNormalizedValue(listTable2_part2[n].Delta_KMH_ji);
                         
                  
            
            Table2_part2.PrintRow(4);     
            Table2_part2.PrintColumns();  
         }            
         
         
      }
      
      //// ======================== //// ======================== //// ======================== ////
      public void  DrawTableConclusion()
      {                                                    
         // Fill Table with data
         Conclusion.Text = string.Format(&quot;3. Заключение: δ &lt;sub&gt;ij mах &lt;/sub&gt; = {0}%. {1}&quot;,                                                     
            tools.GetNormalizedValue(DataIVK.TableKMH_MPR_TPR.Protokol.Delta_max),                                        
            DataIVK.TableKMH_MPR_TPR.AdditionalInfo.ARM_KMH_Result);                                       

         DateTimeLong.Text = string.Format(&quot;Дата проведения КМХ: &lt;u&gt;{0:dd.MM.yyyy} г.&quot;,
            (tools.UnixTimestampToDatetime(DataIVK.TableKMH_MPR_TPR.DateTimeLong)));               
         
         ServiceStaffData.Text = DataIVK.TableKMH_MPR_TPR.AdditionalInfo.ServiceStaffData;     
         DeliveryStaffData.Text = DataIVK.TableKMH_MPR_TPR.AdditionalInfo.DeliveryStaffData;                
         RecievingStaffData.Text = DataIVK.TableKMH_MPR_TPR.AdditionalInfo.RecievingStaffData;              
         PageNumeration.Width = (Page.PaperWidth-Page.LeftMargin-Page.RightMargin)*Units.Millimeters; 
      }  
      
      //// ======================== //// ======================== //// ======================== ////
      //// Setup heights of the all objects on the Page

      private void PageFooter_BeforeLayout(object sender, EventArgs e)
      {
         if((Int32)Report.GetVariableValue(&quot;TotalPages&quot;) &lt; 2) 
         { 
            PageFooter.Visible = false; 
         }
         else
         {
            PageNumeration.Width = (Page.PaperWidth-Page.LeftMargin-Page.RightMargin)*Units.Millimeters;
         }
      }
   }    
}

