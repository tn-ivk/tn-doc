<Report ScriptLanguage="CSharp" ReferencedAssemblies="System.dll&#13;&#10;System.Drawing.dll&#13;&#10;System.Windows.Forms.dll&#13;&#10;System.Data.dll&#13;&#10;System.Xml.dll&#13;&#10;Newtonsoft.Json.dll&#13;&#10;System.Collections.dll&#13;&#10;System.Core.dll&#13;&#10;TN_DocGeneral.dll&#13;&#10;KMH_PW.dll" ReportInfo.Created="03/25/2020 12:46:46" ReportInfo.Modified="05/27/2025 11:04:01" ReportInfo.CreatorVersion="2024.2.20.0">
  <ScriptText>using System;
using System.Reflection;
using System.Collections;
using System.Collections.Generic;
using System.ComponentModel;         
using System.Drawing;
using System.Data;
using System.IO;
using FastReport;
using FastReport.Data;
using FastReport.Dialog;
using FastReport.Barcode;
using FastReport.Table;
using FastReport.Utils;
using System.Linq;
using Newtonsoft.Json;
using TN.DocData;
    
namespace FastReport
{
  public class ReportScript
  {
    TN_ToolsFastReport.Tools tools = new TN_ToolsFastReport.Tools();  // классы отчета
    TN.Doc.Doc doc; // данные из входного параметра
    TN.DocData.General General;
    TN.Doc.HeaderDoc Header;
    TN.Doc.DataDoc SettingsData;
    TN.Doc.FooterDoc Footer;
    TN.Doc.DictionarysDoc Dictionarys;
    TN.Doc.DataIVKDoc DataIVK;
    
    int protocolNumber;
    int KMH_TYPE; 
    int NefType;

    private void Page_StartPage(object sender, EventArgs e)
    {
      //// Десериализация данных (формат json) из входного параметра - Json                         
      string json = (string)Report.GetParameterValue(&quot;JsonDoc&quot;);
      Newtonsoft.Json.JsonSerializerSettings settings = new Newtonsoft.Json.JsonSerializerSettings();
      settings.TypeNameHandling = TypeNameHandling.All;
         
      doc = JsonConvert.DeserializeObject&lt;TN.Doc.Doc&gt;(json, settings);
      General = (TN.DocData.General) doc.Doc.Settings.General;
      Header = (TN.Doc.HeaderDoc) doc.Doc.Settings.Header;
      SettingsData = (TN.Doc.DataDoc) doc.Doc.Settings.Data;
      Footer = (TN.Doc.FooterDoc) doc.Doc.Settings.Footer;
      Dictionarys = (TN.Doc.DictionarysDoc) doc.Doc.Settings.Dictionarys;  
      DataIVK = (TN.Doc.DataIVKDoc) doc.Doc.DataIVK;
          
      KMH_TYPE = DataIVK.TableKMH_PW.KMH_TYPE; 
      NefType = General.NefType;
                                       
      //// === Настройки страницы 
      // Ширина и высота (в мм)
         
      Page.PaperHeight = General.PageSettings.PaperHeight;
      Page.PaperWidth = General.PageSettings.PaperWidth;
         
      // Поля/отступы от краёв (в мм)
      Page.TopMargin = General.PageSettings.TopMargin;
      Page.BottomMargin = General.PageSettings.BottomMargin;
      Page.LeftMargin = General.PageSettings.LeftMargin;
      Page.RightMargin = General.PageSettings.RightMargin;
         
      //Definition for which device create the protocol
      protocolNumber = General.ProtocolNumber;
         
      // Запуск отрисовки таблиц на странице отчета
      DrawTableHeader();
      DrawTableSourceData();
      DrawTableResults(); 
      DrawTableConclusion();
    }
      
    public void DrawTableHeader()
    {
      // Setup Column  &amp;nbsp;
      TableHeader01Column.Width= (Page.PaperWidth-Page.LeftMargin-Page.RightMargin)*Units.Millimeters;

      // Fill table with data   
      ProtokolNum.Text =string.Format(&quot;&lt;b&gt;Протокол № &lt;u&gt;{0}&quot;, DataIVK.TableKMH_PW.AdditionalInfo.PW_AddInfo[protocolNumber-1].ProtokolNum);  
      Laboratory_Name.Text =string.Format(&quot;по результатам испытаний точечной пробы в &lt;u&gt;{0}&quot;, DataIVK.TableKMH_PW.AdditionalInfo.Laboratory_Name);
        
      Place_Factory.Text = $&quot;{Header.FieldSIKN}{DataIVK.TableKMH_PW.AdditionalInfo.Place_SIKN_Name} {DataIVK.TableKMH_PW.AdditionalInfo.Place_PSP}&quot;;         
      PW_Type.Text = DataIVK.TableKMH_PW.AdditionalInfo.PW_AddInfo[protocolNumber-1].PW_Type;  
      PW_ManufNum.Text = DataIVK.TableKMH_PW.AdditionalInfo.PW_AddInfo[protocolNumber-1].PW_ManufNum;
      var pwCheckDate = DataIVK.TableKMH_PW.AdditionalInfo.PW_AddInfo[protocolNumber-1].PW_CheckDate;
      if(!string.IsNullOrEmpty(pwCheckDate) &amp;&amp; DateTime.TryParse(pwCheckDate, out _))
        PW_CheckDate.Text = pwCheckDate;  
      else
        PW_CheckDate.Text = &quot;-&quot;;  
      LAB_Type.Text = DataIVK.TableKMH_PW.AdditionalInfo.LAB_Type ; 
      LAB_ManufNum.Text = DataIVK.TableKMH_PW.AdditionalInfo.LAB_ManufNum;
      var labCheckDate = DataIVK.TableKMH_PW.AdditionalInfo.LAB_CheckDate;
      if(!string.IsNullOrEmpty(labCheckDate) &amp;&amp; DateTime.TryParse(labCheckDate, out _))
        LAB_CheckDate.Text = labCheckDate;  
      else
        LAB_CheckDate.Text = &quot;-&quot;;
      Laboratory_Name1.Text = $&quot;{DataIVK.TableKMH_PW.AdditionalInfo.Laboratory_Name} {DataIVK.TableKMH_PW.AdditionalInfo.Place_PSP} {DataIVK.TableKMH_PW.AdditionalInfo.Place_Factory}&quot;;
    }
               
    public void  DrawTableSourceData()
    {
      // Setup Columns         
         
      int sumDynamicCols=2;
         
      float widthDynamicCol=(Page.PaperWidth-Page.LeftMargin-Page.RightMargin-(TableSourceData.Columns[0].Width/Units.Millimeters))/sumDynamicCols;                  
         
      for (int w = 1; w &lt; (TableSourceData.ColumnCount); w++)                 
      {
        TableSourceData.Columns[w].Width = widthDynamicCol * Units.Millimeters;
      }
      // Fill table with text &amp; data
      FlowMeterColHeader.Text = Dictionarys.FlowMeterColHeader[KMH_TYPE];
      LabMethodColHeader.Text = Dictionarys.LabMethodColHeader[KMH_TYPE];
      ParameterName.Text = Dictionarys.ParameterName[KMH_TYPE];    
      Delta_PW.Text =tools.GetNormalizedValue(DataIVK.TableKMH_PW.Protocol.Protokol[protocolNumber-1].Table1.Delta_PW);    
      Delta_LAB.Text =tools.GetNormalizedValue(DataIVK.TableKMH_PW.Protocol.Protokol[protocolNumber-1].Table1.Delta_LAB);  
      ControlConditions.Text =string.Format(&quot;{0}{1}  %&quot;,
        Dictionarys.ControlConditions[KMH_TYPE], 
        tools.GetNormalizedValue(DataIVK.TableKMH_PW.Protocol.Protokol[protocolNumber-1].KMX_Condition));
    }
      
    public void  DrawTableResults()
    {
      // Setup Columns
      //TableResults.Columns[6].Width =  35f*Units.Millimeters; // Set Width for last column
                
      int sumDynamicCols=TableResults.ColumnCount;
      float widthDynamicCol=(Page.PaperWidth-Page.LeftMargin-Page.RightMargin)/sumDynamicCols;                  
      for (int w = 0; w &lt; (TableResults.ColumnCount); w++)                 
      {
        TableResults.Columns[w].Width = widthDynamicCol*Units.Millimeters;
      }
                          
      // Fill table with text      
      NeftType.Text = Dictionarys.OilTechParams[NefType];
      FlowMeterUnitMeasurement.Text = Dictionarys.FlowMeterUnitMeasurement[KMH_TYPE];
      LabMethodUnitMeasurement.Text = Dictionarys.LabMethodUnitMeasurement[KMH_TYPE];
      ControlResult.Text = Dictionarys.ControlResult[KMH_TYPE];
        
      P.Text = tools.GetNormalizedValue(DataIVK.TableKMH_PW.Protocol.Protokol[protocolNumber-1].Table2.P);
      t.Text = tools.GetNormalizedValue(DataIVK.TableKMH_PW.Protocol.Protokol[protocolNumber-1].Table2.t);
      Dens.Text = tools.GetNormalizedValue(DataIVK.TableKMH_PW.Protocol.Protokol[protocolNumber-1].Table2.Dens);
      Water.Text = tools.GetNormalizedValue(DataIVK.TableKMH_PW.Protocol.Protokol[protocolNumber-1].Table2.Water);                             
      Water_LAB.Text = tools.GetNormalizedValue(DataIVK.TableKMH_PW.Protocol.Protokol[protocolNumber-1].Table2.Water_LAB); 
      Delta.Text = tools.GetNormalizedValue(DataIVK.TableKMH_PW.Protocol.Protokol[protocolNumber-1].Table2.Delta); 
    }
      
    public void  DrawTableConclusion()
    {  
      Conclusion.Text =string.Format(&quot;     &lt;b&gt;Заключение:&lt;/b&gt; поточный влагомер &lt;u&gt;{0}&quot;,
      DataIVK.TableKMH_PW.AdditionalInfo.PW_AddInfo[protocolNumber-1].PW_Type);
      PW_ManufNum1.Text = DataIVK.TableKMH_PW.AdditionalInfo.PW_AddInfo[protocolNumber-1].PW_ManufNum;
      ARM_KMH_Result.Text = DataIVK.TableKMH_PW.AdditionalInfo.PW_AddInfo[protocolNumber-1].ARM_KMH_Result;
         
      DateTimeLong.Text = string.Format(&quot;Дата проведения КМХ:&lt;u&gt; {0:dd.MM.yyyy} г.&quot;,tools.UnixTimestampToDatetime(DataIVK.TableKMH_PW.DateTimeLong));
      ServiceStaffData.Text= DataIVK.TableKMH_PW.AdditionalInfo.ServiceStaffData;
      DeliveryStaffData.Text= DataIVK.TableKMH_PW.AdditionalInfo.DeliveryStaffData;
      RecievingStaffData.Text= DataIVK.TableKMH_PW.AdditionalInfo.RecievingStaffData;
    }  
  }    
}

</ScriptText>
