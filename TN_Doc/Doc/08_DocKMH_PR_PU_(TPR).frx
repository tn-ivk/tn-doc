          <TableCell Name="Cell616" Border.Lines="All" Text="β&lt;sub&gt;&lt;i&gt; ж &lt;/i&gt;&lt;/sub&gt;, °С&lt;sup&gt;-1&lt;/sup&gt;" HorzAlign="Center" VertAlign="Center" Font="Arial, 8pt" FontWidthRatio="0.85" LineHeight="13" TextRenderType="HtmlTags"/>
