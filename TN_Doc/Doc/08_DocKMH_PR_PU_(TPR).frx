using FastReport;
using FastReport.Data;
using FastReport.Dialog;
using FastReport.Barcode;
using FastReport.Table;
using FastReport.Utils;
using System.Linq;
using Newtonsoft.Json;
using TN.DocData;

namespace FastReport
{
   public class ReportScript
   {
      TN_ToolsFastReport.Tools tools = new TN_ToolsFastReport.Tools();  // классы отчета
      TN.Doc.Doc doc; // данные из входного параметра
      TN.DocData.General General;
      TN.Doc.HeaderDoc Header;
      TN.Doc.DataDoc SettingsData;
      TN.Doc.FooterDoc Footer;
      TN.Doc.DictionarysDoc Dictionarys;
      TN.Doc.DataIVKDoc DataIVK;
    
      List &lt;string&gt; listDetectors;
      int tempCounter;
      int tempColNum;
      
      private void Page_StartPage(object sender, EventArgs e)
      {
         //using (var sr = new StreamReader(&quot;C:/SVN/FastReport/Входящие данные от Алексея (классы и json)/08_TableKMH_PR_PU/DocKMH_PR_PU.json&quot;))
         //{
            // Read the stream as a string
         //   Report.SetParameterValue(&quot;Protocol&quot;, sr.ReadToEnd());
         //}
         
         //// Десериализация данных (формат json) из входного параметра - Json                         
         string json = (string)Report.GetParameterValue(&quot;JsonDoc&quot;);
         Newtonsoft.Json.JsonSerializerSettings settings = new Newtonsoft.Json.JsonSerializerSettings();
         settings.TypeNameHandling = TypeNameHandling.All;
         
         doc = JsonConvert.DeserializeObject&lt;TN.Doc.Doc&gt;(json, settings);
         General = (TN.DocData.General) doc.Doc.Settings.General;
         Header = (TN.Doc.HeaderDoc) doc.Doc.Settings.Header;
         SettingsData = (TN.Doc.DataDoc) doc.Doc.Settings.Data;
         Footer = (TN.Doc.FooterDoc) doc.Doc.Settings.Footer;
         Dictionarys = (TN.Doc.DictionarysDoc) doc.Doc.Settings.Dictionarys;  
         DataIVK = (TN.Doc.DataIVKDoc) doc.Doc.DataIVK;
         
         //// === Настройки страницы 
         // Ширина и высота (в мм)
         
         Page.PaperHeight = General.PageSettings.PaperHeight;
         Page.PaperWidth = General.PageSettings.PaperWidth;
         //Page.Border.Lines = BorderLines.All;
         
         // Поля/отступы от краёв (в мм)
         Page.TopMargin = General.PageSettings.TopMargin;
         Page.BottomMargin = General.PageSettings.BottomMargin;
         Page.LeftMargin = General.PageSettings.LeftMargin;
         Page.RightMargin = General.PageSettings.RightMargin;
         
         // Запуск отрисовки таблиц на странице отчета
         DrawTableHeader();
         DrawTableSourceData();
         //DrawTableResults(); 
         DrawTableConclusion();
      }
      
      public void DrawTableHeader()
      {
         //MessageBox.Show(&quot;DrawTableHeader()&quot;);
         
         // Setup Columns
         float widthDynamicCols=(Page.PaperWidth-Page.LeftMargin-Page.RightMargin)/TableHeader.ColumnCount;         
         for (int i = 0; i &lt; (TableHeader.ColumnCount); i++)                 
         {
            TableHeader.Columns[i].Width = widthDynamicCols*Units.Millimeters;
         }

         // Fill table with data   
            PR_Type.Text = string.Format(&quot;Тип ПР: &lt;u&gt;{0}&lt;/u&gt; Заводской №: &lt;u&gt;{1}&lt;/u&gt; &lt;br&gt;Место проведения КМХ: &lt;u&gt;{2}&lt;/u&gt; (СИКН, НГДУ, ПСП)&quot;, 
               DataIVK.TableKMH_PR_PU.AdditionalInfo.PR_Type, 
               DataIVK.TableKMH_PR_PU.AdditionalInfo.PR_FactoryNumber,
               DataIVK.TableKMH_PR_PU.AdditionalInfo.Place); 
            
            PU_Type.Text = string.Format(&quot;Тип ПУ: &lt;u&gt;{0}&lt;/u&gt; Заводской №: &lt;u&gt;{1}&lt;/u&gt; Дата поверки ПУ: &lt;u&gt;{2}&lt;br&gt;&lt;/u&gt;Вязкость нефти при КМХ, сСт: &lt;u&gt;{3}&quot;,
               DataIVK.TableKMH_PR_PU.AdditionalInfo.PU_Type,
               DataIVK.TableKMH_PR_PU.AdditionalInfo.PU_FactoryNumber,
               DataIVK.TableKMH_PR_PU.AdditionalInfo.PU_CheckDate,
               tools.GetNormalizedValue(DataIVK.TableKMH_PR_PU.Protokol.Visc));         
        
      }
               
      #region  // Имхо лишний метод
      private void PrintTable(TableObject table)
      {
         for (int i=0;i&lt;table.RowCount;i++)
         {       
            table.PrintRow(i);
            table.PrintColumns();
         }    
      } 
      #endregion
      
      private void DrawTableSourceData()
      {
         listDetectors = DataIVK.TableKMH_PR_PU.Protokol.Table1.DetName.Where(i =&gt; ! i.Contains(&quot;-&quot;) | i.Length  &gt; 1).ToList();
         List &lt;string&gt; sumPointsQ =DataIVK.TableKMH_PR_PU.Protokol.Table1.Q.Where(i =&gt; ! i.Contains(&quot;-&quot;) &amp; i.Length  &gt; 0).ToList();
         tempCounter =listDetectors.Count;          
         
         if (Engine.FinalPass == true)
         {
            ////=== Insert Columns for Volumes  (V0) &amp; fill them headers with text
            for (int i=0; i &lt;listDetectors.Count ; i++)
            {
               TableColumn column = new TableColumn();  
               TableSourceData.Columns.Insert(0,column);
                      
               for (int j=0;j&lt;TableSourceData.RowCount;j++)
               {
                  TableSourceData[0,j].AssignAll(TableSourceData[1,j]);
               }
                        
               TableSourceData[0,2].Text=string.Format(&quot;&lt;i&gt;V&lt;sub&gt;0 &lt;/i&gt; ({0})&lt;/sub&gt;,&lt;br&gt;м&lt;sup&gt;3&lt;/sup&gt;&quot;,listDetectors[tempCounter-1]);
               TableSourceData[0,3].Text=tempCounter.ToString();
               tempCounter--;
            }
            
            ////=== Insert Columns for Flow Points  (Q0) &amp; fill them headers with text
            tempCounter=listDetectors.Count+7;
            for (int i=0; i &lt;sumPointsQ.Count ; i++)
            {
               TableColumn column = new TableColumn();  
               TableSourceData.Columns.Add(column);
               
               for (int j=0;j&lt;TableSourceData.RowCount;j++)
               {
                  TableSourceData[(TableSourceData.ColumnCount-1),j].AssignAll(TableSourceData[(TableSourceData.ColumnCount-2),j]);
               }
               
               TableSourceData[tempCounter,2].Text=String.Format(&quot;&lt;i&gt;Q&lt;sub&gt;&lt;/i&gt; {0}&lt;/sub&gt;,&lt;br&gt;&lt;i&gt;(f/v)&lt;/i&gt;&lt;sub&gt; {1}&lt;/sub&gt;&quot;, (i+1), (i+1));
               TableSourceData[tempCounter,3].Text=tempCounter.ToString();
               tempCounter++;
            }
            
            TableSourceData[(TableSourceData.ColumnCount-sumPointsQ.Count),1].Text=&quot;Точки расходов (м&lt;sup&gt;3&lt;/sup&gt;/ч) или &lt;i&gt;f/v&lt;/i&gt; (Гц/сСт) для ПР&quot;;
            
            //// Span Columns
            TableSourceData[0,0].ColSpan=TableSourceData.ColumnCount;
            TableSourceData[0,1].ColSpan=listDetectors.Count+4;
            TableSourceData[(listDetectors.Count+7),1].ColSpan=sumPointsQ.Count;
            
            // Setup Columns         
            int sumDynamicCols=TableSourceData.ColumnCount;
            float widthDynamicCol=(Page.PaperWidth-Page.LeftMargin-Page.RightMargin)/sumDynamicCols;                  
            for (int w = 0; w &lt; (TableSourceData.ColumnCount); w++)                 
            {
               TableSourceData.Columns[w].Width = widthDynamicCol * Units.Millimeters;
            }
           
            //// Fill data 
            //For Columns for Detectors
            List &lt;string&gt; listV0 = DataIVK.TableKMH_PR_PU.Protokol.Table1.V0.Where(i =&gt; ! i.Contains(&quot;-&quot;)).ToList();
            for (int j = 0; j &lt; listDetectors.Count; j++)
            {
               TableSourceData[j,4].Text = tools.GetNormalizedValue(listV0[j]);
            } 
            
            // Columns for Line Params
            TableSourceData[listDetectors.Count,4].Text =  tools.GetNormalizedValue(DataIVK.TableKMH_PR_PU.Protokol.Table1.m_D);
            TableSourceData[listDetectors.Count+1,4].Text =  tools.GetNormalizedValue(DataIVK.TableKMH_PR_PU.Protokol.Table1.m_S);
            TableSourceData[listDetectors.Count+2,4].Text =  tools.GetNormalizedValue(DataIVK.TableKMH_PR_PU.Protokol.Table1.m_E);
            TableSourceData[listDetectors.Count+3,4].Text =  tools.GetNormalizedValue(DataIVK.TableKMH_PR_PU.Protokol.Table1.Alpha_t);
         
            // Columns for Q points
            for (int j = 0; j &lt; sumPointsQ.Count; j++)
            {
               TableSourceData[(listDetectors.Count+7+j),4].Text = tools.GetNormalizedValue(sumPointsQ[j]);
            }     
        
            //Fill Columns headers numeration
            for (int i = 0; i &lt; TableSourceData.ColumnCount; i++)
            {
               TableSourceData[i,3].Text = (i+1).ToString();
            }     
               TableSourceData[0,1].Text=&quot;Для поверочной установки (ПУ)&quot;;
         }
      }
                                        
      private void TableResults_ManualBuild(object sender, EventArgs e)
      {
         if (Engine.FirstPass == true)
         {
            tempCounter =  listDetectors.Count;
            //tempColNum = listDetectors.Count+6;
           tempColNum = 9;
            
            //Setup Dynamic Colums width
            float widthDynamicCols=(Page.PaperWidth-Page.LeftMargin-Page.RightMargin - (TableResults.Width/Units.Millimeters))/tempCounter;         
            
            // Insert Columns for V0
            for (int i=0; i &lt;listDetectors.Count ; i++)
            {
               TableColumn column = new TableColumn(); 
               column.Width =   widthDynamicCols*Units.Millimeters;
               TableResults.Columns.Insert(tempColNum,column);
               for (int j=1;j&lt;TableResults.RowCount;j++)
               {
                  TableResults[tempColNum,j].AssignAll(TableResults[tempColNum-1,j]);
               }
               TableResults[tempColNum,1].Text=&quot;&lt;i&gt;V&lt;sub&gt;ij &lt;/i&gt; (&quot; + listDetectors[tempCounter-1] + &quot;)&lt;/sub&gt;,&lt;br&gt;м&lt;sup&gt;3&lt;/sup&gt;&quot;;
               tempCounter--;
            }
            
                                 
         }
         
            for (int n = 0; n &lt; TableResults.FixedRows; n++)
            {
               TableResults.PrintRow(n);
               TableResults.PrintColumns();                                             
            } 
         
         //Fill Columns headers with numeration
         for (int i = 0; i &lt; TableResults.ColumnCount; i++)
         {
            TableResults[i,3].Text = (i+1).ToString();
         }
               
            var listTab2Measures = DataIVK.TableKMH_PR_PU.Protokol.Table2.Obj.Where(i =&gt;  i.Ser != &quot;-&quot;   &amp; String.IsNullOrEmpty(i.Ser) == false).ToList();
            var listTab2_1Points = DataIVK.TableKMH_PR_PU.Protokol.Table2_1.Obj.Where(i =&gt;  i.Point != &quot;-&quot;   &amp; String.IsNullOrEmpty(i.Point) == false).ToList();

            // Fill cells with data
            int sumPointMeasures =0;
            int numRowForSpan = 0;
            tempCounter = 0;
            for (int z = 0; z &lt; (listTab2_1Points.Count); z++)  
            {
               sumPointMeasures = listTab2Measures.Count(i =&gt; i.Ser == (z+1).ToString());
               for (int j = 0; j &lt; sumPointMeasures; j++)                    
               {
                  #region //Span Rows
                  //sumPointMeasures = listTab2Measures.Count(i =&gt; i.Ser == (z+1).ToString());
                  Ser.RowSpan =  sumPointMeasures;
                  TableResults[(11+listDetectors.Count),4].RowSpan =  sumPointMeasures;
                  TableResults[(12+listDetectors.Count),4].RowSpan =  sumPointMeasures;
                  TableResults[(13+listDetectors.Count),4].RowSpan =  sumPointMeasures;
                  //numRowForSpan=numRowForSpan+sumPointMeasures;                
                  #endregion
                  Ser.Text=listTab2Measures[j+tempCounter].Ser;   
                  Row.Text=listTab2Measures[j+tempCounter].Row;
                  Q_ji.Text=tools.GetNormalizedValue(listTab2Measures[j+tempCounter].Q_ji);
                  f_ji.Text=tools.GetNormalizedValue(listTab2Measures[j+tempCounter].f_ji);
                  t_PU_ji.Text=tools.GetNormalizedValue(listTab2Measures[j+tempCounter].t_PU_ji);
                  P_PU_ji.Text=tools.GetNormalizedValue(listTab2Measures[j+tempCounter].P_PU_ji);
                  t_PR_ji.Text=tools.GetNormalizedValue(listTab2Measures[j+tempCounter].t_PR_ji);
                  P_PR_ji.Text=tools.GetNormalizedValue(listTab2Measures[j+tempCounter].P_PR_ji);
                  k_tp_ji.Text=tools.GetNormalizedValue(listTab2Measures[j+tempCounter].k_tp_ji);
                  
                  #region // Seek Detector for assign value of the Volume
                  // Seek Detector for assign value of the Volume
                  
                  for (int i = 0; i&lt; listDetectors.Count; i ++)
                  {
                     if (listTab2Measures[j+tempCounter].Det == listDetectors[i])
                     {
                        TableResults[(9 + i),4].Text=tools.GetNormalizedValue(listTab2Measures[j+tempCounter].V_ji);
                     }
                     else
                     {
                        TableResults[(9 + i),4].Text=&quot;-&quot;;
                     }
                  }       
                  #endregion 
                  
                  N_ji.Text=tools.GetNormalizedValue(listTab2Measures[j+tempCounter].N_ji);
                  K_ji.Text=tools.GetNormalizedValue(listTab2Measures[j+tempCounter].K_ji);
                  K_j.Text=tools.GetNormalizedValue(listTab2_1Points[z].K_j);
                  K_rasch_j.Text=tools.GetNormalizedValue(listTab2_1Points[z].K_rasch_j);
                  Delta_j.Text=tools.GetNormalizedValue(listTab2_1Points[z].Delta_j);
                  
                  TableResults.PrintRow(4);
                  TableResults.PrintColumns();
                  
               }
                tempCounter=tempCounter+sumPointMeasures;   
               
               Ser.RowSpan=1;
               TableResults[(11+listDetectors.Count),4].RowSpan =  1;
               TableResults[(12+listDetectors.Count),4].RowSpan =  1;
               TableResults[(13+listDetectors.Count),4].RowSpan =  1;
               
               float initialHeight = BaseRow.Height;
               BaseRow.Height = 0;
               TableResults.PrintRow(4);
               TableResults.PrintColumns();
               BaseRow.Height= initialHeight;
            }
            
            #region // Setup columns headers in depend from Protocol type
            if (DataIVK.TableKMH_PR_PU.Protokol.IsUSR==0) // тип протокола для ТПР
            {  
               // Table headers text
               // Table columns widht
            }
            else
            {
               TableResults[0,0].HorzAlign = HorzAlign.Left;
            }
            #endregion        
      }

      public void  DrawTableConclusion()
      {
         //// ===  Fill table with data
         DateTimeLong.Text = string.Format(&quot;Дата проведения КМХ: &lt;u&gt;{0:dd.MM.yyyy} г.&quot;,
            tools.UnixTimestampToDatetime(DataIVK.TableKMH_PR_PU.DateTimeLong));               
         ServiceStaffDescription.Text =&quot;&lt;i&gt;От сервисной организации:&quot;;
         DeliveryStaffDescription.Text =&quot;&lt;i&gt;От сдающей стороны:&quot;;
         RecievingStaffDescription.Text =&quot;&lt;i&gt;От принимающей стороны:&quot;;                                              
         Conclusion.Text =string.Format(&quot;&lt;b&gt;3. Заключение: δ &lt;sub&gt;mах &lt;/sub&gt; = {0}%. {1}&quot;,                                                     
            tools.GetNormalizedValue(DataIVK.TableKMH_PR_PU.Protokol.Delta_KMH_Max),                                        
            DataIVK.TableKMH_PR_PU.AdditionalInfo.ARM_KMH_Result);                                                 
         ServiceStaffData.Text= string.Format(&quot;{0}                              &quot;,DataIVK.TableKMH_PR_PU.AdditionalInfo.ServiceStaffData);     
         DeliveryStaffData.Text= string.Format(&quot;{0}                              &quot;,DataIVK.TableKMH_PR_PU.AdditionalInfo.DeliveryStaffData);                
         RecievingStaffData.Text= string.Format(&quot;{0}                              &quot;,DataIVK.TableKMH_PR_PU.AdditionalInfo.RecievingStaffData);
      }  
      
      private void PageFooter_BeforeLayout(object sender, EventArgs e)
      {
         if((Int32)Report.GetVariableValue(&quot;TotalPages&quot;) &lt; 2) 
         { 
            PageFooter.Visible = false; 
         }
         else
         {
            PageNumeration.Width = (Page.PaperWidth-Page.LeftMargin-Page.RightMargin)*Units.Millimeters;
         }
      }
   }    
}

