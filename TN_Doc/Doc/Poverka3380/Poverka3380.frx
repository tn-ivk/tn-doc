    private void Table4_1Results_ManualBuild(object sender, EventArgs e)
    {
      if (DataIVK.TablePoverka3380.Protokol.CfgTables.Table4_921 == 1)
      {
        Dictionary&lt;string,string&gt; dictTable4_921 = new Dictionary&lt;string,string&gt; ();
        foreach (var propertyInfo in DataIVK.TablePoverka3380.Protokol.Table4_921.GetType().GetProperties())
        {
          var propertyValue = propertyInfo.GetValue(DataIVK.TablePoverka3380.Protokol.Table4_921);                 
                   
          dictTable4_921.Add(propertyInfo.Name, propertyInfo.GetValue(DataIVK.TablePoverka3380.Protokol.Table4_921 , null).ToString());
        }

        //Drawing Fixed rows
        for (int n = 0; n &lt; Table4_1Results.FixedRows; n++)                                                            
        {                                                                                                                    
          Table4_1Results.PrintRow(n);
          Table4_1Results.PrintColumns();                                             
        }
                  
        //Filling table with data                                                                             
        Q_min.Text = tools.GetNormalizedValue(dictTable4_921[&quot;Q_min&quot;]);                                             
        Q_max.Text = tools.GetNormalizedValue(dictTable4_921[&quot;Q_max&quot;]);                                                          
        SKO.Text = tools.GetNormalizedValue(dictTable4_921[&quot;SKO&quot;]);                                                          
        K.Text = tools.GetNormalizedValue(dictTable4_921[&quot;K&quot;]);                                                          
        e1.Text = tools.GetNormalizedValue(dictTable4_921[&quot;e&quot;]);       
        Teta_A.Text = tools.GetNormalizedValue(dictTable4_921[&quot;Teta_A&quot;]);                                                          
        Teta_Sum1.Text = tools.GetNormalizedValue(dictTable4_921[&quot;Teta_Sum&quot;]);                                                          
        Delta1.Text = tools.GetNormalizedValue(dictTable4_921[&quot;Delta&quot;]);                                                          
        
        if (SettingsData.HighlightError &amp;&amp; dictTable4_921[&quot;SKO_ERROR&quot;] == ErrorValue)
          SKO.FillColor = ErrorColor;
        if (SettingsData.HighlightError &amp;&amp; dictTable4_921[&quot;Delta_ERROR&quot;] == ErrorValue)
          Delta1.FillColor = ErrorColor;
        
        Table4_1Results.PrintRow(3);                                                     
        Table4_1Results.PrintColumns();                                                
      }
    }              
      
    private void Table4_2Results_ManualBuild(object sender, EventArgs e)
    {
         
      if (DataIVK.TablePoverka3380.Protokol.CfgTables.Table4_922 == 1)
      {
        List &lt;TN.Doc.Table4_922&gt; listPointsTable4_2;      
        listPointsTable4_2 =DataIVK.TablePoverka3380.Protokol.Table4_922.Where(i =&gt; ! i.Point.Contains(&quot;-&quot;) &amp; String.IsNullOrEmpty(i.Point) == false).ToList();
        //Drawing Fixed rows
        for (int n = 0; n &lt; Table4_2Results.FixedRows; n++)                                                            
        {                                                                                                                    
          Table4_2Results.PrintRow(n);
          Table4_2Results.PrintColumns();                                             
        }
                  
        //Filling table with data                                                                             
        for (int n = 0; n &lt; (listPointsTable4_2.Count); n++)                                                 
        {                                                                                                                            
          Point2.Text = listPointsTable4_2[n].Point;        
          Q_min2.Text = tools.GetNormalizedValue(listPointsTable4_2[n].Q_min);                                                          
          Q_max2.Text =  tools.GetNormalizedValue(listPointsTable4_2[n].Q_max); 
          SKO2.Text =  tools.GetNormalizedValue(listPointsTable4_2[n].SKO); 
          K2.Text =  tools.GetNormalizedValue(listPointsTable4_2[n].K); 
          E2.Text =  tools.GetNormalizedValue(listPointsTable4_2[n].e); 
          Teta_A2.Text =  tools.GetNormalizedValue(listPointsTable4_2[n].Teta_A); 
          Teta_Sum2.Text =  tools.GetNormalizedValue(listPointsTable4_2[n].Teta_Sum); 
          Delta2.Text =  tools.GetNormalizedValue(listPointsTable4_2[n].Delta); 

          if (SettingsData.HighlightError &amp;&amp; listPointsTable4_2[n].SKO_ERROR == ErrorValue)
            SKO2.FillColor = ErrorColor;
          if (SettingsData.HighlightError &amp;&amp; listPointsTable4_2[n].Delta_ERROR == ErrorValue)
            Delta2.FillColor = ErrorColor;
          
          Table4_2Results.PrintRow(3);                                                     
          Table4_2Results.PrintColumns();                                                
        }                 
      }          
    }
      
    private void Table4_3Results_ManualBuild(object sender, EventArgs e)
    {                
      if (DataIVK.TablePoverka3380.Protokol.CfgTables.Table4_923 == 1)
      {
        List &lt;TN.Doc.Points&gt; listPointsTable4_3;      
        List &lt;TN.Doc.Subranges&gt; listSubrangesTable4_3;      
            
        listPointsTable4_3 =DataIVK.TablePoverka3380.Protokol.Table4_923.Points.Where(i =&gt; ! i.Point.Contains(&quot;-&quot;) &amp; String.IsNullOrEmpty(i.Point) == false).ToList();
        listSubrangesTable4_3 =DataIVK.TablePoverka3380.Protokol.Table4_923.Subranges.Where(i =&gt; ! i.Point.Contains(&quot;-&quot;) &amp; String.IsNullOrEmpty(i.Point) == false).ToList();

        //Drawing Fixed rows
        for (int n = 0; n &lt; Table4_3Results.FixedRows; n++)                                                            
        {                                                                                                                    
          Table4_3Results.PrintRow(n);
          Table4_3Results.PrintColumns();                                             
        }
             
        if (DataIVK.TablePoverka3380.Protokol.UseFV == 1)
          T4_3_f.Text = &quot;&lt;i&gt;f &lt;sub&gt;j&lt;/sub&gt; / ν &lt;sub&gt;j&lt;/sub&gt; ,&lt;/i&gt;&lt;br&gt;Гц / сСт&quot;;
        else
          T4_3_f.Text = &quot;&lt;i&gt;f &lt;sub&gt;j&lt;/sub&gt;, &lt;/i&gt;Гц&quot;;          
        
        if (listPointsTable4_3.Count == 0) return;
        
        //Filling table with data for subranges                                                                            
        for (int n = 0; n &lt; (listSubrangesTable4_3.Count); n++)                                                 
        {                                                                                                                            
          Point3.Text = listPointsTable4_3[n].Point;      
          Q_j3.Text = tools.GetNormalizedValue(listPointsTable4_3[n].Q_j);                                                          
          f_j.Text =  tools.GetNormalizedValue(listPointsTable4_3[n].f_j); 
          K_j.Text =  tools.GetNormalizedValue(listPointsTable4_3[n].K_j); 
               
          Subranges.Text =  tools.GetNormalizedValue(listSubrangesTable4_3[n].Point); 
          Q_min3.Text =  tools.GetNormalizedValue(listSubrangesTable4_3[n].Q_min); 
          Q_max3.Text =  tools.GetNormalizedValue(listSubrangesTable4_3[n].Q_max); 
          SKO3.Text =  tools.GetNormalizedValue(listSubrangesTable4_3[n].SKO); 
          E3.Text =  tools.GetNormalizedValue(listSubrangesTable4_3[n].e); 
          Teta_A3.Text =  tools.GetNormalizedValue(listSubrangesTable4_3[n].Teta_A); 
          Teta_Sum3.Text =  tools.GetNormalizedValue(listSubrangesTable4_3[n].Teta_Sum); 
          Delta3.Text =  tools.GetNormalizedValue(listSubrangesTable4_3[n].Delta); 

          Table4_3Results.PrintRow(3);                                                     
          Table4_3Results.PrintColumns();                                                
        }              
            
        //Filling table with data for last measure point 
        if (Engine.FinalPass == true)
        {
          Point3.Text = listPointsTable4_3[listPointsTable4_3.Count-1].Point;      
          Q_j3.Text = tools.GetNormalizedValue(listPointsTable4_3[listPointsTable4_3.Count-1].Q_j);                                                          
          f_j.Text =  tools.GetNormalizedValue(listPointsTable4_3[listPointsTable4_3.Count-1].f_j); 
          K_j.Text =  tools.GetNormalizedValue(listPointsTable4_3[listPointsTable4_3.Count-1].K_j); 
               
          for (int i = 0; i &lt; (Table4_3Results.ColumnCount); i++)
          {          
            switch(i)
            {
              case 4:
              case 5:  
              case 6:     
              case 7:                                                                
              case 8:                                                                
              case 9:   
              case 10:              
              case 11:              
                Table4_3Results[i,3].Border.Lines = BorderLines.None;
                Table4_3Results[i,3].Text = &quot;&quot;;
                break;  
            }
          } 
          Table4_3Results.PrintRow(3);                                                     
          Table4_3Results.PrintColumns();
        }
            
      }                    
    }
      
