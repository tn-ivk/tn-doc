    private void Table3Results_ManualBuild(object sender, EventArgs e)
    {            
      List &lt;TN.Doc.Table3&gt; listTable3CoeffValue;
      listTable3CoeffValue =DataIVK.TablePoverka3380.Protokol.Table3.Where(i =&gt; ! i.t_P_n.Contains(&quot;-&quot;) &amp; String.IsNullOrEmpty(i.t_P_n) == false).ToList();

