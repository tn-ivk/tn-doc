    private void Table6ApproximationEquations_ManualBuild(object sender, EventArgs e)
    {
      if (DataIVK.TablePoverka3380.Protokol.CfgTables.Parabola == 1)
      {
        List &lt;TN.Doc.Parabola&gt; listParabolaTable6;      
        listParabolaTable6 = DataIVK.TablePoverka3380.Protokol.Parabola.Where(i =&gt; ! i.fv_begin.Contains(&quot;-&quot;) | ! i.fv_begin.Contains(&quot;&quot;)).ToList();

        //Drawing Fixed rows
        for (int n = 0; n &lt; Table6ApproximationEquations.FixedRows; n++)                                                            
        {                                                                                                                    
          Table6ApproximationEquations.PrintRow(n);
          Table6ApproximationEquations.PrintColumns();                                             
        }
            
        //Filling table with data for subranges                                                                            
        for (int n = 0; n &lt; (listParabolaTable6.Count); n++)                                                 
        {                                                                                                                            
          fv_begin.Text =  tools.GetNormalizedValue(listParabolaTable6[n].fv_begin);      
          fv_end.Text =  tools.GetNormalizedValue(listParabolaTable6[n].fv_end);      
          A.Text =  tools.GetNormalizedValue(listParabolaTable6[n].A);      
          B.Text =  tools.GetNormalizedValue(listParabolaTable6[n].B);      
          C.Text =  tools.GetNormalizedValue(listParabolaTable6[n].C);      
          Delta6.Text =  tools.GetNormalizedValue(listParabolaTable6[n].Delta);      
               
          Table6ApproximationEquations.PrintRow(4);                                                     
          Table6ApproximationEquations.PrintColumns();                                                
        }       
      }  
    }
     
    public void  DrawTableConclusion()
    {                                                    
      // Setup Cols width    
      ColumnDateTimeLong.Width=(Page.PaperWidth-Page.LeftMargin-Page.RightMargin)  * Units.Millimeters;
         
      // Filling Table with data
      ARM_Poverka_Result.Text = DataIVK.TablePoverka3380.AdditionalInfo.ARM_Poverka_Result;
      ARM_Result_Type.Text = DataIVK.TablePoverka3380.AdditionalInfo.ARM_Poverka_Result_Type;       
      if (ARM_Poverka_Result.Text == &quot;годен&quot;)
        Permitting.Text = &quot;допущен&quot;;       
      else if (ARM_Poverka_Result.Text == &quot;не годен&quot;)
        Permitting.Text = &quot;не допущен&quot;;       
      else
        Permitting.Text = &quot;&quot;;       
         
      StaffData_company.Text = DataIVK.TablePoverka3380.AdditionalInfo.StaffData_company;       
      StaffData_fio.Text = DataIVK.TablePoverka3380.AdditionalInfo.StaffData_fio;       
      DateTimeLong.Text = string.Format(&quot;Дата поверки: &lt;u&gt;{0:dd.MM.yyyy} г.&quot;,(tools.UnixTimestampToDatetime(DataIVK.TablePoverka3380.DateTimeLong)));               
    }  
      
    //// Setup heights of the all objects on the Page
    private void PageFooter_BeforeLayout(object sender, EventArgs e)
    {
      if((Int32)Report.GetVariableValue(&quot;TotalPages&quot;) &lt; 2) 
      { 
        PageFooter.Visible = false; 
      }
      else
      {
        PageNumeration.Width = (Page.PaperWidth-Page.LeftMargin-Page.RightMargin)*Units.Millimeters;
      }
    }
  }    
}

