    private void Page_StartPage(object sender, EventArgs e)
    {
      //using (var sr = new StreamReader(&quot;D:/!_Work/!_Транснефть/SVN/Work/Sources/Reports/FRX/Входящие данные от Алексея (классы и json)/14_TablePoverka3380/DocPoverka3380.json&quot;))
      //{
      //   // Read the stream as a string
      //   Report.SetParameterValue(&quot;JsonDoc&quot;, sr.ReadToEnd());
      //}
         
      //// Десериализация данных (формат json) из входного параметра - Json                         
      string json = (string)Report.GetParameterValue(&quot;JsonDoc&quot;);
      Newtonsoft.Json.JsonSerializerSettings settings = new Newtonsoft.Json.JsonSerializerSettings();
      settings.TypeNameHandling = TypeNameHandling.All;
         
      doc = JsonConvert.DeserializeObject&lt;TN.Doc.Doc&gt;(json, settings);
      General = (TN.DocData.General) doc.Doc.Settings.General;
      Header = (TN.Doc.HeaderDoc) doc.Doc.Settings.Header;
      SettingsData = (TN.Doc.DataDoc) doc.Doc.Settings.Data;
      Footer = (TN.Doc.FooterDoc) doc.Doc.Settings.Footer;
      Dictionarys = (TN.Doc.DictionarysDoc) doc.Doc.Settings.Dictionarys;  
      DataIVK = (TN.Doc.DataIVKDoc) doc.Doc.DataIVK;
      
      //// === Настройки страницы 
      // Ширина и высота (в мм)
         
      Page.PaperHeight = General.PageSettings.PaperHeight;
      Page.PaperWidth = General.PageSettings.PaperWidth;
      //Page.Border.Lines = BorderLines.All;
         
      // Поля/отступы от краёв (в мм)
      Page.TopMargin = General.PageSettings.TopMargin;
      Page.BottomMargin = General.PageSettings.BottomMargin;
      Page.LeftMargin = General.PageSettings.LeftMargin;
      Page.RightMargin = General.PageSettings.RightMargin;
                                                                
      // Load Data from classes
      listTable2Results = DataIVK.TablePoverka3380.Protokol.Table2.Where(i =&gt; i.Activated==1).ToList();
         
      // Запуск отрисовки таблиц на странице отчета
      DrawTableHeader();    
      DrawTableConclusion();
    }
      
    public void DrawTableHeader()
    {
      //Setup Columns width
      TableHeader01.Columns[0].Width =  (Page.PaperWidth-Page.LeftMargin-Page.RightMargin)/Units.Millimeters;

      // Filling table with data   
      ProtokolNum.Text = string.Format( &quot;П Р О Т О К О Л   П О В Е Р К И № {0}&quot;, DataIVK.TablePoverka3380.AdditionalInfo.ProtokolNum); 
      PR_Type.Text = string.Format(&quot;преобразователя объемного расхода модели (типа) {0} по МИ 3380-2012&quot;,  
        DataIVK.TablePoverka3380.AdditionalInfo.PR_Model); 
      PoverkaPlace.Text = string.Format( &quot;{0} {1}&quot;, DataIVK.TablePoverka3380.AdditionalInfo.PoverkaPlace,
        DataIVK.TablePoverka3380.AdditionalInfo.PlaceFactory);    
      PR_Model_Top.Text = DataIVK.TablePoverka3380.AdditionalInfo.PR_Model_Top;    
      PR_DN.Text = DataIVK.TablePoverka3380.AdditionalInfo.PR_DN;
      PR_PN.Text = DataIVK.TablePoverka3380.AdditionalInfo.PR_PN;
      PR_FactoryNumber.Text = DataIVK.TablePoverka3380.AdditionalInfo.PR_FactoryNumber;
      PlaceSIKN.Text = DataIVK.TablePoverka3380.AdditionalInfo.PlaceSIKN;
      LineName.Text = DataIVK.TablePoverka3380.AdditionalInfo.LineName;
      Oil.Text = DataIVK.TablePoverka3380.AdditionalInfo.Oil;
      PU.Text = DataIVK.TablePoverka3380.AdditionalInfo.PU;
      PU_Category.Text = DataIVK.TablePoverka3380.AdditionalInfo.PU_Category;
      PU_FactoryNumber.Text = DataIVK.TablePoverka3380.AdditionalInfo.PU_FactoryNumber;
      PU_PN.Text = DataIVK.TablePoverka3380.AdditionalInfo.PU_PN;
      PU_Poverka_Date.Text = DataIVK.TablePoverka3380.AdditionalInfo.PU_Poverka_Date;
    }
              
    private void Table1SourceData_ManualBuild(object sender, EventArgs e)
    {   
      List &lt;string&gt; listTable1Detectors =DataIVK.TablePoverka3380.Protokol.Table1.DetName.Where(i =&gt; i.Length &gt; 1 | ! i.Contains(&quot;&quot;)).ToList();
      List &lt;string&gt; listTable1V0 =DataIVK.TablePoverka3380.Protokol.Table1.V0.Where(i =&gt; ! i.Contains(&quot;-&quot;) | ! i.Contains(&quot;&quot;)).ToList();
         
      Dictionary&lt;string,string&gt; dictTable1SourceData = new Dictionary&lt;string,string&gt; ();
      foreach (var propertyInfo in DataIVK.TablePoverka3380.Protokol.Table1.GetType().GetProperties())
      {
        var propertyValue = propertyInfo.GetValue(DataIVK.TablePoverka3380.Protokol.Table1);
        if (propertyValue is string)
        {
          dictTable1SourceData.Add(propertyInfo.Name, propertyInfo.GetValue(DataIVK.TablePoverka3380.Protokol.Table1 , null).ToString());
        }
      }
         
      //Setup Columns width
  
      //Drawing Fixed rows
      for (int n = 0; n &lt; Table1SourceData.FixedRows; n++)
      {
        Table1SourceData.PrintRow(n);
        Table1SourceData.PrintColumns();                                             
      }
         
      //Filling table with data
      for (int n = 0; n &lt; (listTable1Detectors.Count); n++)
      {
        DetName.Text =  listTable1Detectors[n];
        V0.Text =  tools.GetNormalizedValue(listTable1V0[n]);     
        Delta_PU.Text = tools.GetNormalizedValue(dictTable1SourceData[&quot;Delta_PU&quot;]);    
        m_D.Text = tools.GetNormalizedValue(dictTable1SourceData[&quot;m_D&quot;]);  
        m_S.Text = tools.GetNormalizedValue(dictTable1SourceData[&quot;m_S&quot;]);    
        m_E.Text = tools.GetNormalizedValue(dictTable1SourceData[&quot;m_E&quot;]);
        Alpha_t_PU.Text = tools.GetNormalizedValue(dictTable1SourceData[&quot;Alpha_t_PU&quot;]); 
        Alpha_t_cm.Text = tools.GetNormalizedValue(dictTable1SourceData[&quot;Alpha_t_cm&quot;]); 
        Delta_t_PU.Text = tools.GetNormalizedValue(dictTable1SourceData[&quot;Delta_t_PU&quot;]); 
        Delta_k_soi.Text = tools.GetNormalizedValue(dictTable1SourceData[&quot;Delta_k_soi&quot;]); 
        Delta_t_PR.Text = tools.GetNormalizedValue(dictTable1SourceData[&quot;Delta_t_PR&quot;]); 
              
        //RowsSpans
           
        for (int i = 0; i &lt; (Table1SourceData.ColumnCount); i++)
        {          
          switch(i)
          {
            case 2:
            case 3:  
            case 4:
            case 5:  
            case 6:     
            case 7:                                                                
            case 8:                                                                
            case 9:                                                            
            case 10:                                                          
              Table1SourceData[i,4].RowSpan =  listTable1Detectors.Count;
              break;  
          }
        }
             
        Table1SourceData.PrintRow(4);     
        Table1SourceData.PrintColumns();  
      }
    }

    private void Table2Results_ManualBuild(object sender, EventArgs e)
    {     
      //Setup Columns width
      int sumDynamicCols=Table2Results.ColumnCount;
      float widthDynamicCol=(Page.PaperWidth-Page.LeftMargin-Page.RightMargin)/sumDynamicCols;                  
      for (int w = 0; w &lt; (Table2Results.ColumnCount); w++)                 
      {
        Table2Results.Columns[w].Width = widthDynamicCol * Units.Millimeters;
      }      
         
      //Draw Fixed rows
      for (int n = 0; n &lt; Table2Results.FixedRows; n++)
      {
        Table2Results.PrintRow(n);
        Table2Results.PrintColumns();                                             
      }
        
      //Filling table with data
      for (int n = 0; n &lt; (listTable2Results.Count); n++)
      {
        SerRow.Text =  String.Format(&quot;{0}/{1}&quot;, listTable2Results[n].Ser, listTable2Results[n].Row);
        Q_ji.Text = tools.GetNormalizedValue(listTable2Results[n].Q_ji);                   
        Det.Text =  tools.GetNormalizedValue(listTable2Results[n].Det);   
        T_ji.Text = tools.GetNormalizedValue(listTable2Results[n].T_ji);        
        t_PU_ji.Text = tools.GetNormalizedValue(listTable2Results[n].t_PU_ji); 
        P_PU_ji.Text = tools.GetNormalizedValue(listTable2Results[n].P_PU_ji);  
        t_cm_ji.Text =  tools.GetNormalizedValue(listTable2Results[n].t_cm_ji);          
        f_ji.Text =  tools.GetNormalizedValue(listTable2Results[n].f_ji);          
        t_PR_ji.Text =  tools.GetNormalizedValue(listTable2Results[n].t_PR_ji);          
        P_PR_ji.Text =  tools.GetNormalizedValue(listTable2Results[n].P_PR_ji);          
        N_ji.Text =  tools.GetNormalizedValue(listTable2Results[n].N_ji);          
        Table2Results.PrintRow(4);     
        Table2Results.PrintColumns();  
      }          
    }

