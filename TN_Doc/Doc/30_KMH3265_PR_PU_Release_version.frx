using TN.DocData;

namespace FastReport
{
   public class ReportScript
   {
      TN_ToolsFastReport.Tools tools = new TN_ToolsFastReport.Tools();  // классы отчета
      TN.Doc.Doc doc; // данные из входного параметра
      TN.DocData.General General;
      TN.Doc.HeaderDoc Header;
      TN.Doc.DataDoc SettingsData;
      TN.Doc.FooterDoc Footer;
      TN.Doc.DictionarysDoc Dictionarys;
      TN.Doc.DataIVKDoc DataIVK;
      
      List &lt;string&gt; listTable1Detectors;
      List &lt;string&gt; listTable1V0;
      List &lt;string&gt; listTable1Teta_Sum_0;
      List &lt;string&gt; listTable1Teta_V_0;
      
      Dictionary&lt;string,string&gt; dictTable1SourceData;
      List &lt;TN.Doc.Table2&gt; listTable2Results;
      List &lt;TN.Doc.Points&gt; listTable3Results;
      Dictionary&lt;string,string&gt; dictTable4Results;

      private void Page_StartPage(object sender, EventArgs e)
      {
         //using (var sr = new StreamReader(&quot;D:/!_Work/!_Транснефть/SVN/Work/Sources/Reports/FRX/Входящие данные от Алексея (классы и json)/30_TableKMH3265_PR_PU/DocKMH3265_PR_PU.json&quot;))
         //{
            // Read the stream as a string
         //   Report.SetParameterValue(&quot;Protocol&quot;, sr.ReadToEnd());
         //}
         
         //// Десериализация данных (формат json) из входного параметра - Json                         
         string json = (string)Report.GetParameterValue(&quot;JsonDoc&quot;);
         Newtonsoft.Json.JsonSerializerSettings settings = new Newtonsoft.Json.JsonSerializerSettings();
         settings.TypeNameHandling = TypeNameHandling.All;
         
         doc = JsonConvert.DeserializeObject&lt;TN.Doc.Doc&gt;(json, settings);
         General = (TN.DocData.General) doc.Doc.Settings.General;
         Header = (TN.Doc.HeaderDoc) doc.Doc.Settings.Header;
         SettingsData = (TN.Doc.DataDoc) doc.Doc.Settings.Data;
         Footer = (TN.Doc.FooterDoc) doc.Doc.Settings.Footer;
         Dictionarys = (TN.Doc.DictionarysDoc) doc.Doc.Settings.Dictionarys;  
         DataIVK = (TN.Doc.DataIVKDoc) doc.Doc.DataIVK; 
         
         //// === Настройки страницы 
         // Ширина и высота (в мм)
         
         Page.PaperHeight = General.PageSettings.PaperHeight;
         Page.PaperWidth = General.PageSettings.PaperWidth;
         
         // Поля/отступы от краёв (в мм)
         Page.TopMargin = General.PageSettings.TopMargin;
         Page.BottomMargin = General.PageSettings.BottomMargin;
         Page.LeftMargin = General.PageSettings.LeftMargin;
         Page.RightMargin = General.PageSettings.RightMargin;
                                                                
         //// ==== Get Data from classes
         listTable1Detectors = DataIVK.TableKMH3265_PR_PU.Protokol.Table1.DetName.Where(i =&gt; i.Length &gt; 1 &amp; String.IsNullOrEmpty(i) == false).ToList();
         listTable1V0 = DataIVK.TableKMH3265_PR_PU.Protokol.Table1.V0.Where(i =&gt; ! i.Contains(&quot;-&quot;) &amp; String.IsNullOrEmpty(i) == false).ToList();
         listTable1Teta_Sum_0 = DataIVK.TableKMH3265_PR_PU.Protokol.Table1.Teta_Sum_0.Where(i =&gt; ! i.Contains(&quot;-&quot;) &amp; String.IsNullOrEmpty(i) == false).ToList();
         listTable1Teta_V_0 = DataIVK.TableKMH3265_PR_PU.Protokol.Table1.Teta_V_0.Where(i =&gt; ! i.Contains(&quot;-&quot;) &amp; String.IsNullOrEmpty(i) == false).ToList();
         
         // Get data for Table ! to Dictionary
         dictTable1SourceData = new Dictionary&lt;string,string&gt; ();
         
         //TODO dictTable1SourceData = typeof(TN_DocPover_MI3189.Table1).GetProperties().Where(x =&gt;! x.Name.Contains(&quot;DetName&quot;)) &amp; (z =&gt;! z.Name.Contains(&quot;V0&quot;)).ToDictionary(x =&gt; x.Name, x =&gt; x.GetValue(protocol.Doc.DataIVK.TablePoverka3189.Protokol.Table1));
         foreach (var propertyInfo in DataIVK.TableKMH3265_PR_PU.Protokol.Table1.GetType().GetProperties())
         {
            var propertyValue = propertyInfo.GetValue(DataIVK.TableKMH3265_PR_PU.Protokol.Table1);
            if (propertyValue is string)
            {
               dictTable1SourceData.Add(propertyInfo.Name, propertyInfo.GetValue(DataIVK.TableKMH3265_PR_PU.Protokol.Table1).ToString());
            }
         }                       
         listTable2Results = DataIVK.TableKMH3265_PR_PU.Protokol.Table2.Where(i =&gt; ! i.Ser.Contains(&quot;-&quot;) &amp; String.IsNullOrEmpty(i.Ser) == false).ToList();
         listTable3Results = DataIVK.TableKMH3265_PR_PU.Protokol.Table3.Point.Where(i =&gt; ! i.Point.Contains(&quot;-&quot;) &amp; String.IsNullOrEmpty(i.Point) == false).ToList();
    
         // Запуск отрисовки таблиц на странице отчета
         DrawTableHeader();    
         DrawTableConclusion();
      }
      #region //Имхо лишний метод
      private void PrintTable(TableObject table)
      {
         for (int i=0;i&lt;table.RowCount;i++)
         {       
            table.PrintRow(i);
            table.PrintColumns();
         }    
      } 
      #endregion
      
      //// ======================== //// ======================== //// ======================== ////
      public void DrawTableHeader()
      {
         //Setup Columns width
         TableHeader01.Columns[0].Width = (Page.PaperWidth-Page.LeftMargin-Page.RightMargin)*Units.Millimeters;
         
         // Fill table with data   
         ProtokolNum.Text = &quot;П Р О Т О К О Л  № &quot;  +  DataIVK.TableKMH3265_PR_PU.AdditionalInfo.ProtokolNum;
         Place.Text = DataIVK.TableKMH3265_PR_PU.AdditionalInfo.Place;
         PR_Type.Text = DataIVK.TableKMH3265_PR_PU.AdditionalInfo.PR_Type;
         PR_FactoryNumber.Text = DataIVK.TableKMH3265_PR_PU.AdditionalInfo.PR_FactoryNumber;
         PR_LineName.Text = DataIVK.TableKMH3265_PR_PU.AdditionalInfo.PR_LineName;
         PU_Type.Text = DataIVK.TableKMH3265_PR_PU.AdditionalInfo.PU_Type;
         PU_FactoryNumber.Text = DataIVK.TableKMH3265_PR_PU.AdditionalInfo.PU_FactoryNumber;
         IVK_Type.Text = DataIVK.TableKMH3265_PR_PU.AdditionalInfo.IVK_Type;
         IVK_FactoryNumber.Text = DataIVK.TableKMH3265_PR_PU.AdditionalInfo.IVK_FactoryNumber;
         OilType.Text = DataIVK.TableKMH3265_PR_PU.Protokol.OilType;
         AvgLineTemp.Text = tools.GetNormalizedValue(DataIVK.TableKMH3265_PR_PU.Protokol.AvgLineTemp);
         Visc.Text = tools.GetNormalizedValue(DataIVK.TableKMH3265_PR_PU.Protokol.Visc);
      }
              
      //// ======================== //// ======================== //// ======================== ////
      private void Table1SourceData_ManualBuild(object sender, EventArgs e)
      {
            //Setup Columns width
            int sumDynamicCols=Table1SourceData.ColumnCount;
            float widthDynamicCol=(Page.PaperWidth-Page.LeftMargin-Page.RightMargin)/sumDynamicCols;                  
 
            for (int w = 0; w &lt; (Table1SourceData.ColumnCount); w++)                 
            {
               Table1SourceData.Columns[w].Width = widthDynamicCol * Units.Millimeters;
            }      
                            
            //Draw Fixed rows
            for (int n = 0; n &lt; Table1SourceData.FixedRows; n++)
            {
               Table1SourceData.PrintRow(n);
               Table1SourceData.PrintColumns();                                             
            }
                                                     
            //Fill table with data
            for (int n = 0; n &lt; (listTable1Detectors.Count); n++)
            {
               DetName.Text =  listTable1Detectors[n];
               V0.Text =  tools.GetNormalizedValue(listTable1V0[n]);        
               m_D.Text = tools.GetNormalizedValue(DataIVK.TableKMH3265_PR_PU.Protokol.Table1.m_D);
               m_S.Text = tools.GetNormalizedValue(DataIVK.TableKMH3265_PR_PU.Protokol.Table1.m_S);
               m_E.Text = tools.GetNormalizedValue(DataIVK.TableKMH3265_PR_PU.Protokol.Table1.m_E);
               Alpha_t.Text = tools.GetNormalizedValue(DataIVK.TableKMH3265_PR_PU.Protokol.Table1.Alpha_t);
               Alpha_k1.Text = tools.GetNormalizedValue(DataIVK.TableKMH3265_PR_PU.Protokol.Table1.Alpha_k1);
               Alpha_D.Text = tools.GetNormalizedValue(DataIVK.TableKMH3265_PR_PU.Protokol.Table1.Alpha_D);
                           
               //RowSpans
               for (int i = 0; i &lt; (Table1SourceData.ColumnCount); i++)
               {          
                  switch(i)
                  {
                     case 2:
                     case 3:  
                     case 4:
                     case 5:  
                     case 6:     
                     case 7:      
                        Table1SourceData[i,3].RowSpan =  listTable1Detectors.Count;
                        break;  
                  }
               }
               Table1SourceData.PrintRow(3);     
               Table1SourceData.PrintColumns();  
            }                             
      }
      
      //// ======================== //// ======================== //// ======================== ////
      private void Table1SourceDataEnding_ManualBuild(object sender, EventArgs e)
      {               
            //Setup Columns width as in the previous table
            for (int i = 0; i &lt; (Table1SourceDataEnding.ColumnCount); i++)
            {          
               Table1SourceDataEnding.Columns[i].Width =  Table1SourceData.Columns[i].Width;
            }
         
            //Draw Fixed rows
            for (int n = 0; n &lt; Table1SourceDataEnding.FixedRows; n++)
            {
               Table1SourceDataEnding.PrintRow(n);
               Table1SourceDataEnding.PrintColumns();                                             
            }
             
         //Fill table with data
         for (int n = 0; n &lt; (listTable1Detectors.Count); n++)
         {
            Teta_Sum_0.Text = tools.GetNormalizedValue(DataIVK.TableKMH3265_PR_PU.Protokol.Table1.Teta_Sum_0[n]);
            Teta_V_0.Text = tools.GetNormalizedValue(DataIVK.TableKMH3265_PR_PU.Protokol.Table1.Teta_V_0[n]);                               
            Delta_t_PU.Text = tools.GetNormalizedValue(DataIVK.TableKMH3265_PR_PU.Protokol.Table1.Delta_t_PU);                                   
            Delta_t_PR.Text = tools.GetNormalizedValue(DataIVK.TableKMH3265_PR_PU.Protokol.Table1.Delta_t_PR);                                    
            Delta_IVK.Text = tools.GetNormalizedValue(DataIVK.TableKMH3265_PR_PU.Protokol.Table1.Delta_IVK);
             
            //RowSpans
            for (int i = 0; i &lt; (Table1SourceDataEnding.ColumnCount); i++)
            {          
               switch(i)
               {
                  case 2:
                  case 3:  
                  case 4:   
                     Table1SourceDataEnding[i,3].RowSpan =  listTable1Detectors.Count;
                     break;  
               }
            }
         Table1SourceDataEnding.PrintRow(3);     
         Table1SourceDataEnding.PrintColumns();           
         }                           
      }
      //// ======================== //// ======================== //// ======================== ////
      private void Table2Results_ManualBuild(object sender, EventArgs e)
      {           
         //Setup Columns width
         int sumDynamicCols=Table2Results.ColumnCount;
         float widthDynamicCol=(Page.PaperWidth-Page.LeftMargin-Page.RightMargin)/sumDynamicCols;                  
         for (int w = 0; w &lt; (Table2Results.ColumnCount); w++)                 
         {
            Table2Results.Columns[w].Width = widthDynamicCol * Units.Millimeters;
         }      
         
         //Draw Fixed rows
         for (int n = 0; n &lt; Table2Results.FixedRows; n++)
         {
            Table2Results.PrintRow(n);
            Table2Results.PrintColumns();                                             
         }
                                
         //Fill table with data
         for (int n = 0; n &lt; (listTable2Results.Count); n++)
         {
            SerRow.Text =  String.Format(&quot;{0}/{1}&quot;, listTable2Results[n].Ser, listTable2Results[n].Row);//+ &quot; | &quot; + (n+1).ToString();
            Q_ji.Text = tools.GetNormalizedValue(listTable2Results[n].Q_ji);
            Detector.Text =  tools.GetNormalizedValue(listTable2Results[n].Detector);
            T_ji.Text = tools.GetNormalizedValue(listTable2Results[n].T_ji);
            t_PU_ji.Text = tools.GetNormalizedValue(listTable2Results[n].t_PU_ji);
            P_PU_ji.Text = tools.GetNormalizedValue(listTable2Results[n].P_PU_ji);
            t_D_ji.Text = tools.GetNormalizedValue(listTable2Results[n].t_D_ji);
            Dens_ji.Text = tools.GetNormalizedValue(listTable2Results[n].Dens_ji);
            DensTemp_ji.Text =  tools.GetNormalizedValue(listTable2Results[n].DensTemp_ji);
            
            Table2Results.PrintRow(3);     
            Table2Results.PrintColumns();  
         }                  
      }
      //// ======================== //// ======================== //// ======================== ////
      private void Table2ResultsEnding_ManualBuild(object sender, EventArgs e)
      {
        
         //Setup Columns widths as previous table
         for (int i = 0; i &lt; (Table2ResultsEnding.ColumnCount); i++)
         {          
            Table2ResultsEnding.Columns[i].Width =  Table2Results.Columns[i].Width;
         }
         //Draw Fixed rows
         for (int n = 0; n &lt; Table2ResultsEnding.FixedRows; n++)
         {
            Table2ResultsEnding.PrintRow(n);
            Table2ResultsEnding.PrintColumns();                                             
         }
         //Fill table with data
         for (int n = 0; n &lt; (listTable2Results.Count); n++)
         {
            SerRow2.Text =  String.Format(&quot;{0}/{1}&quot;, listTable2Results[n].Ser, listTable2Results[n].Row);//+ &quot; | &quot; + (n+1).ToString();
            DensPress_ji.Text =  tools.GetNormalizedValue(listTable2Results[n].DensPress_ji);
            Beta_ji.Text = tools.GetNormalizedValue(listTable2Results[n].Beta_ji);
            v_ji.Text = tools.GetNormalizedValue(listTable2Results[n].v_ji);
            t_PR_ji.Text = tools.GetNormalizedValue(listTable2Results[n].t_PR_ji);
            P_PR_ji.Text = tools.GetNormalizedValue(listTable2Results[n].P_PR_ji);
            N_ji.Text = tools.GetNormalizedValue(listTable2Results[n].N_ji);
            K_ji.Text = tools.GetNormalizedValue(listTable2Results[n].K_ji);
            
            Table2ResultsEnding.PrintRow(3);     
            Table2ResultsEnding.PrintColumns();  
         }
      }
      //// ======================== //// ======================== //// ======================== ////
      
      private void Table3Results_ManualBuild(object sender, EventArgs e)
      {
         //Setup Columns width
         int sumDynamicCols=Table3Results.ColumnCount;
         float widthDynamicCol=(Page.PaperWidth-Page.LeftMargin-Page.RightMargin)/sumDynamicCols;                  
         for (int w = 0; w &lt; (Table3Results.ColumnCount); w++)                 
         {
            Table3Results.Columns[w].Width = widthDynamicCol * Units.Millimeters;
         }      
         
         //Draw Fixed rows 
         for (int n = 0; n &lt; Table3Results.FixedRows; n++)
         {
            Table3Results.PrintRow(n);
            Table3Results.PrintColumns();                                             
         }
             
         //Fill table with data
         for (int n = 0; n &lt; (listTable3Results.Count); n++)
         {
            Point_3_1.Text =  listTable3Results[n].Point;
            Q_j.Text = tools.GetNormalizedValue(listTable3Results[n].Q_j);
            K_j.Text = tools.GetNormalizedValue(listTable3Results[n].K_j);
            S_j.Text =tools.GetNormalizedValue( listTable3Results[n].S_j);
            n_j.Text = tools.GetNormalizedValue(listTable3Results[n].n_j);
            S0_j.Text = tools.GetNormalizedValue(listTable3Results[n].S0_j);
            t095_j.Text = tools.GetNormalizedValue(listTable3Results[n].t095_j);
            e_j.Text =  tools.GetNormalizedValue(listTable3Results[n].e_j);
            
            Table3Results.PrintRow(3);     
            Table3Results.PrintColumns();  
         }
      }
      //// ======================== //// ======================== //// ======================== ////
      private void Table3ResultsEnding_ManualBuild(object sender, EventArgs e)
      {     
         //Setup Columns widths as previous table
         for (int i = 0; i &lt; (Table3ResultsEnding.ColumnCount); i++)
         {          
            Table3ResultsEnding.Columns[i].Width =  Table3Results.Columns[i].Width;
         }
            //Draw Fixed rows
            for (int n = 0; n &lt; Table3ResultsEnding.FixedRows; n++)
            {
               Table3ResultsEnding.PrintRow(n);
               Table3ResultsEnding.PrintColumns();                                             
            }
         //Fill table with data                                                  
         for (int n = 0; n &lt; (listTable3Results.Count); n++)
         {
            Point_3_2.Text =  listTable3Results[n].Point;
            Teta_t.Text = tools.GetNormalizedValue(DataIVK.TableKMH3265_PR_PU.Protokol.Table3.Teta_t);
            Teta_Sum.Text = tools.GetNormalizedValue(DataIVK.TableKMH3265_PR_PU.Protokol.Table3.Teta_Sum);
            Delta_j.Text =  tools.GetNormalizedValue(listTable3Results[n].Delta_j);
            Delta.Text = tools.GetNormalizedValue(DataIVK.TableKMH3265_PR_PU.Protokol.Table3.Delta);
            //RowSpans
            for (int i = 0; i &lt; (Table3ResultsEnding.ColumnCount); i++)
            {          
               switch(i)
               {
                  case 1:
                  case 2:                                          
                  case 4:   
                     Table3ResultsEnding[i,3].RowSpan =  listTable3Results.Count;
                     break;  
               }
            }
            Table3ResultsEnding.PrintRow(3);                                                                                                                                                                                  
            Table3ResultsEnding.PrintColumns();
         }
      }
      //// ======================== //// ======================== //// ======================== ////
      public void  DrawTableConclusion()
      {                                                    
         // Setup Cols width    
         TableConclusion3.Columns[0].Width=(Page.PaperWidth-Page.LeftMargin-Page.RightMargin)  * Units.Millimeters;
        
         // Fill Table with data
         StaffData.Text = DataIVK.TableKMH3265_PR_PU.AdditionalInfo.StaffData;
         DateTimeLong.Text = string.Format(&quot;Дата: &lt;u&gt;{0:dd.MM.yyyy} г.&quot;,
            (tools.UnixTimestampToDatetime(DataIVK.TableKMH3265_PR_PU.DateTimeLong)));               
         PageNumeration.Width = (Page.PaperWidth-Page.LeftMargin-Page.RightMargin)*Units.Millimeters; 
      }  
      
      //// ======================== //// ======================== //// ======================== ////
      //// Setup heights of the all objects on the Page

      private void PageFooter_BeforeLayout(object sender, EventArgs e)
      {
         if((Int32)Report.GetVariableValue(&quot;TotalPages&quot;) &lt; 2) 
         { 
            PageFooter.Visible = false; 
         }
         else
         {
            PageNumeration.Width = (Page.PaperWidth-Page.LeftMargin-Page.RightMargin)*Units.Millimeters;
         }
      }
   }    
}

