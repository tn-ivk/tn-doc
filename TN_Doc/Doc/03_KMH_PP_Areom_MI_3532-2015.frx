          <TableCell Name="Cell33" Border.Lines="All" Text="Дата последней поверки" Padding="3, 3, 3, 3" VertAlign="Center" Font="Arial, 8pt" FontWidthRatio="0.85" TextRenderType="HtmlTags"/>
