<Report ScriptLanguage="CSharp" ReferencedAssemblies="System.dll&#13;&#10;System.Drawing.dll&#13;&#10;System.Windows.Forms.dll&#13;&#10;System.Data.dll&#13;&#10;System.Xml.dll&#13;&#10;Newtonsoft.Json.dll&#13;&#10;System.Collections.dll&#13;&#10;System.Core.dll&#13;&#10;TN_DocGeneral.dll&#13;&#10;KMH_PP_Areom.dll" DoublePass="true" ReportInfo.Created="03/25/2020 12:46:46" ReportInfo.Modified="05/21/2025 09:28:18" ReportInfo.CreatorVersion="2024.2.20.0">
  <ScriptText>using System;
using System.Reflection;
using System.Collections;
using System.Collections.Generic;
using System.ComponentModel;         
using System.Drawing;
using System.Data;
using System.IO;
using FastReport;
using FastReport.Data;
using FastReport.Dialog;
using FastReport.Barcode;
using FastReport.Table;
using FastReport.Utils;
using System.Linq;
using Newtonsoft.Json.Linq;
         
namespace FastReport
{
  public class ReportScript
  {
    JToken JDoc;
    JToken JSettings;
    JToken JTableKMH_PP_Areom;
    JToken JProtokol;
    JToken JAdditionalInfo;
    
    int ProtocolNumber;
    int KMH_TYPE; 
    int OilType; 
      
    private void Page_StartPage(object sender, EventArgs e)
    {
      JDoc = JToken.Parse(Report.GetParameterValue(&quot;JsonDoc&quot;).ToString());
      JSettings = JDoc[&quot;Doc&quot;][&quot;Settings&quot;];
      JTableKMH_PP_Areom = JDoc[&quot;Doc&quot;][&quot;DataArm&quot;][&quot;TableKMH_PP_Areom&quot;];
      JProtokol = JDoc[&quot;Doc&quot;][&quot;DataArm&quot;][&quot;TableKMH_PP_Areom&quot;][&quot;Protokol&quot;];
      JAdditionalInfo = JDoc[&quot;Doc&quot;][&quot;DataArm&quot;][&quot;TableKMH_PP_Areom&quot;][&quot;AdditionalInfo&quot;];
         
      Page.PaperHeight = (int)JSettings[&quot;General&quot;][&quot;PageSettings&quot;][&quot;PaperHeight&quot;];
      Page.PaperWidth = (int)JSettings[&quot;General&quot;][&quot;PageSettings&quot;][&quot;PaperWidth&quot;];
         
      Page.TopMargin = (int)JSettings[&quot;General&quot;][&quot;PageSettings&quot;][&quot;TopMargin&quot;];
      Page.BottomMargin = (int)JSettings[&quot;General&quot;][&quot;PageSettings&quot;][&quot;BottomMargin&quot;];
      Page.LeftMargin = (int)JSettings[&quot;General&quot;][&quot;PageSettings&quot;][&quot;LeftMargin&quot;];
      Page.RightMargin = (int)JSettings[&quot;General&quot;][&quot;PageSettings&quot;][&quot;RightMargin&quot;];
         
      ProtocolNumber = (int)JSettings[&quot;General&quot;][&quot;ProtocolNumber&quot;];
      KMH_TYPE = (int)JTableKMH_PP_Areom[&quot;KMH_TYPE&quot;]; 
      OilType = (int)JSettings[&quot;General&quot;][&quot;NefType&quot;];
         
      // Запуск отрисовки таблиц на странице отчета
      DrawTableHeader();
      DrawTableSourceData();
      DrawTableConclusion();
    }
      
    public void DrawTableHeader()
    {
      // Setup Columns
      float widthDynamicCols=(Page.PaperWidth-Page.LeftMargin-Page.RightMargin)/TableHeader.ColumnCount;         
      for (int i = 0; i &lt; (TableHeader.ColumnCount); i++)                 
      {
        TableHeader.Columns[i].Width = widthDynamicCols*Units.Millimeters;
      }
            
      ProtocolType.Text = JSettings[&quot;Dictionarys&quot;][&quot;ProtocolType&quot;][KMH_TYPE.ToString()].ToString();
      
      switch (ProtocolNumber)
      {
        case 2:
          SIKN_Num.Text = JSettings[&quot;Header&quot;][&quot;FieldSIKN&quot;].ToString() + &quot; &quot; + JAdditionalInfo[&quot;PP2_AddInfo&quot;][&quot;SIKN_Num&quot;];
          PSP_Name.Text = JSettings[&quot;Header&quot;][&quot;FieldPSP&quot;].ToString() + JAdditionalInfo[&quot;PP2_AddInfo&quot;][&quot;PSP_Name&quot;];                               
          break;
        default:
          SIKN_Num.Text = JSettings[&quot;Header&quot;][&quot;FieldSIKN&quot;].ToString() + &quot; &quot; + JAdditionalInfo[&quot;PP1_AddInfo&quot;][&quot;SIKN_Num&quot;];
          PSP_Name.Text = JSettings[&quot;Header&quot;][&quot;FieldPSP&quot;].ToString() + JAdditionalInfo[&quot;PP1_AddInfo&quot;][&quot;PSP_Name&quot;];                
          break;
      }
    }
               
    public void  DrawTableSourceData()
    {
      int sumDynamicCols=2;
      float widthDynamicCol=(Page.PaperWidth-Page.LeftMargin-Page.RightMargin-
        ((TableSourceData.Columns[0].Width + TableSourceData.Columns[1].Width)/Units.Millimeters))/sumDynamicCols;                  
         
      for (int w = 2; w &lt; (TableSourceData.ColumnCount); w++)                 
      {
        TableSourceData.Columns[w].Width = widthDynamicCol * Units.Millimeters;
      }
         
      JToken jsonTable1;
      JToken jsonPP_AddInfo;
      
      switch (ProtocolNumber)
      {
        case 2:
          jsonTable1 = JProtokol[&quot;Table1_2&quot;];
          jsonPP_AddInfo = JAdditionalInfo[&quot;PP2_AddInfo&quot;];
          break;
            
        default:
          jsonTable1 = JProtokol[&quot;Table1_1&quot;];
          jsonPP_AddInfo = JAdditionalInfo[&quot;PP1_AddInfo&quot;];
          break;
      }
      
      // Column 3
      SensName_Oper.Text = jsonPP_AddInfo[&quot;SensName_Oper&quot;].ToString();
      ManufNum_Oper.Text = jsonPP_AddInfo[&quot;ManufNum_Oper&quot;].ToString();
      CheckDate_Oper.Text = jsonPP_AddInfo[&quot;CheckDate_Oper&quot;].ToString();
      Delta_PP.Text = jsonTable1[&quot;Delta_PP&quot;].ToString().Replace('.',',');
      Delta_Syst.Text = jsonTable1[&quot;Delta_Syst&quot;].ToString().Replace('.',',');
      Delta_Meth.Text = jsonTable1[&quot;Delta_Meth&quot;].ToString().Replace('.',',');
      // Column 4
      SensName_Areom.Text = jsonPP_AddInfo[&quot;SensName_Areom&quot;].ToString();
      ManufNum_Areom.Text = jsonPP_AddInfo[&quot;ManufNum_Areom&quot;].ToString();
      CheckDate_Areom.Text = jsonPP_AddInfo[&quot;CheckDate_Areom&quot;].ToString();
      AbsError_Areom.Text = jsonPP_AddInfo[&quot;AbsError_Areom&quot;].ToString().Replace('.',',');
      
      // Column 4
      DensityMeterType.Text = JSettings[&quot;Dictionarys&quot;][&quot;DensityMeterType&quot;][KMH_TYPE.ToString()].ToString();
      if (OilType == 1) Report.SetParameterValue(&quot;TextOil&quot;, &quot;нефти&quot;);
      else Report.SetParameterValue(&quot;TextOil&quot;, &quot;нефтепродукта&quot;);
         
      if (KMH_TYPE == 0) Report.SetParameterValue(&quot;TextDensityMeter&quot;, &quot;лабораторным плотномером&quot;);
      else Report.SetParameterValue(&quot;TextDensityMeter&quot;, &quot;ареометром&quot;);
    }
      
    private void TableResults_ManualBuild(object sender, EventArgs e)
    {
      if(Engine.FinalPass)
      {
        int sumDynamicCols=TableResults.ColumnCount;
        float widthDynamicCol=(Page.PaperWidth-Page.LeftMargin-Page.RightMargin)/sumDynamicCols;                  
        
        for (int w = 0; w &lt; (TableResults.ColumnCount); w++)                 
        {
          TableResults.Columns[w].Width = widthDynamicCol * Units.Millimeters;
        }      
           
        NefType.Text = JSettings[&quot;Dictionarys&quot;][&quot;OilTechParams&quot;][OilType.ToString()].ToString();
        JToken jsonTable2;
        switch (ProtocolNumber)
        {
          case 2:
            jsonTable2 = JProtokol[&quot;Table2_2&quot;];       
            break;
          default:
            jsonTable2 = JProtokol[&quot;Table2_1&quot;];
            break;             
        }
        List&lt;JToken&gt; listTable2 = jsonTable2.Where(x =&gt; (int)x[&quot;Activated&quot;] != 0).ToList();
        List&lt;TableRow&gt; rows = new List&lt;TableRow&gt;();
        var useTwoRow = (bool)JProtokol[&quot;DisplayTwoRow&quot;];
        
        for (int i = 0; i &lt; listTable2.Count; i++)                 
        {
          CounterMeasure.Text = (i + 1).ToString();
          Q.Text = listTable2[i][&quot;Q&quot;].ToString().Replace('.',',');
          t.Text = listTable2[i][&quot;t&quot;].ToString().Replace('.',',');
          P.Text = listTable2[i][&quot;P&quot;].ToString().Replace('.',',');
          Dens_PP.Text = listTable2[i][&quot;Dens_PP&quot;].ToString().Replace('.',',');
          
          CounterMeasure.RowSpan = useTwoRow ? 2 : 1;
          Q.RowSpan = useTwoRow ? 2 : 1;
          t.RowSpan = useTwoRow ? 2 : 1;
          P.RowSpan = useTwoRow ? 2 : 1;
          Dens_PP.RowSpan = useTwoRow ? 2 : 1;
          
          DensLab_1.Text = listTable2[i][&quot;DensLab&quot;][0].ToString().Replace('.',',');
          tempLab_1.Text = listTable2[i][&quot;TempLab&quot;][0].ToString().Replace('.',',');
          BetaLab_1.Text = listTable2[i][&quot;BetaLab&quot;][0].ToString().Replace('.',',');
          GamaLab_1.Text = listTable2[i][&quot;GamaLab&quot;][0].ToString().Replace('.',',');
            
          Dens_Priv.Text = listTable2[i][&quot;Dens_Priv&quot;].ToString().Replace('.',',');
          Delta.Text = listTable2[i][&quot;Delta&quot;].ToString().Replace('.',',');
          
          Dens_Priv.RowSpan = useTwoRow ? 2 : 1;
          Delta.RowSpan = useTwoRow ? 2 : 1;
          
          TableRow row1 = new TableRow();
          row1.AssignAll(Table2_RowData1);
          row1.Visible=true;
          rows.Add(row1);         
            
          if(useTwoRow)
          {
            DensLab_2.Text = listTable2[i][&quot;DensLab&quot;][1].ToString().Replace('.',',');
            tempLab_2.Text = listTable2[i][&quot;TempLab&quot;][1].ToString().Replace('.',',');
            BetaLab_2.Text = listTable2[i][&quot;BetaLab&quot;][1].ToString().Replace('.',',');
            GamaLab_2.Text = listTable2[i][&quot;GamaLab&quot;][1].ToString().Replace('.',',');
  
            TableRow row2 = new TableRow();
            row2.AssignAll(Table2_RowData2);
            row2.Visible=true;
            
            rows.Add(row2);
          }
        }
        
        if (KMH_TYPE == 0)
          tempLabHeader.Text=@&quot;&lt;i&gt;t&lt;sub&gt; лаб i&lt;/i&gt;&lt;/sub&gt;, °С&quot;;             
        else
          tempLabHeader.Text=@&quot;&lt;i&gt;t&lt;sub&gt; ар i&lt;/i&gt;&lt;/sub&gt;, °С&quot;;
            
        TableResults.Rows.AddRange(rows.ToArray());
        PrintTable(TableResults);
      }
    }
     
    public void  DrawTableConclusion()
    {
      // Setup width for last Column
      TableConclusion.Columns[4].Width=(Page.PaperWidth-Page.LeftMargin-Page.RightMargin - 
        ((TableConclusion.Columns[0].Width + TableConclusion.Columns[1].Width + TableConclusion.Columns[2].Width + TableConclusion.Columns[3].Width)/Units.Millimeters))*Units.Millimeters;
  
      JToken jsonPP_AddInfo;
      
      if (ProtocolNumber == 1)
        jsonPP_AddInfo = JAdditionalInfo[&quot;PP1_AddInfo&quot;];
      else
        jsonPP_AddInfo = JAdditionalInfo[&quot;PP2_AddInfo&quot;];      
      
      ARM_KMH_Result.Text =string.Format(&quot;Поточный ПП зав. № &lt;u&gt; {0}&lt;/u&gt; {1} к дальнейшей эксплуатации&quot;, 
        jsonPP_AddInfo[&quot;ManufNum_Oper&quot;].ToString(), 
        jsonPP_AddInfo[&quot;ARM_KMH_Result&quot;].ToString());
      
      DateTime date = new DateTime(1970, 1, 1, 0, 0, 0, DateTimeKind.Utc).AddSeconds((long)JTableKMH_PP_Areom[&quot;DateTimeLong&quot;]);   
      DateTimeLong.Text = string.Format(&quot;Дата проведения КМХ: &lt;u&gt;{0:dd.MM.yyyy} г.&quot;, date);               
      
      ServiceStaffData.Text=jsonPP_AddInfo[&quot;ServiceStaffData&quot;].ToString();
      DeliveryStaffData.Text= jsonPP_AddInfo[&quot;DeliveryStaffData&quot;].ToString();
      RecievingStaffData.Text= jsonPP_AddInfo[&quot;RecievingStaffData&quot;].ToString();
    }  

    private void PageFooter_BeforeLayout(object sender, EventArgs e)
    {
      if((Int32)Report.GetVariableValue(&quot;TotalPages&quot;) &lt; 2) 
      { 
        PageFooter.Visible = false; 
      }
      else
      {
        PageNumeration.Width = (Page.PaperWidth-Page.LeftMargin-Page.RightMargin)*Units.Millimeters;
      }
    }
    
    private void PrintTable(TableObject table)
    {
      for (int i=0;i&lt;table.RowCount;i++)
      {       
        table.PrintRow(i);
        table.PrintColumns();
      }    
    }    
  }    
}




</ScriptText>
