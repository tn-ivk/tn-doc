          <TableCell Name="Cell36" Border.Lines="All" Text="Предел допускаемой абсолютной погрешности  (Δ, кг/м&lt;sup&gt;3&lt;/sup&gt;)" Padding="3, 3, 3, 3" VertAlign="Center" Font="Arial, 8pt" FontWidthRatio="0.85" TextRenderType="HtmlTags"/>
          <TableCell Name="Delta_PP" Border.Lines="All" Text="Delta_PP" Padding="3, 3, 3, 3" HorzAlign="Center" VertAlign="Center" Font="Arial, 8pt" FontWidthRatio="0.85" TextRenderType="HtmlTags"/>
