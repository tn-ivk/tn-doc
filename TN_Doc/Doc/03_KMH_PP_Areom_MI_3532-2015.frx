        </TableRow>
        <TableRow Name="Row10" Height="56.7" AutoSize="true">
          <TableCell Name="Cell126" Border.Lines="All" Text="5" Padding="3, 3, 3, 3" HorzAlign="Center" Font="Arial, 8pt" FontWidthRatio="0.85" TextRenderType="HtmlTags"/>
          <TableCell Name="Cell39" Border.Lines="All" Text="Систематическая погрешность метода определения плотности [TextOil] [TextDensityMeter] (&lt;b&gt;обязательно со знаком «+» или «-»&lt;/b&gt;) - из свидетельства о метрологической аттестации МИ плотности на данную СИКН, (Δ&lt;sub&gt;&lt;i&gt; сист&lt;/i&gt;&lt;/sub&gt;, кг/м&lt;sup&gt;3&lt;/sup&gt;)" Padding="3, 3, 3, 3" HorzAlign="Justify" VertAlign="Center" Font="Arial, 8pt" FontWidthRatio="0.85" TextRenderType="HtmlTags"/>
          <TableCell Name="Delta_Syst" Border.Lines="All" Text="Delta_Syst" Padding="3, 3, 3, 3" HorzAlign="Center" VertAlign="Center" Font="Arial, 8pt" FontWidthRatio="0.85" TextRenderType="HtmlTags" ColSpan="2"/>
          <TableCell Name="Cell41" Border.Lines="All" Padding="3, 3, 3, 3" HorzAlign="Center" VertAlign="Center" Font="Arial, 8pt" FontWidthRatio="0.85" TextRenderType="HtmlTags"/>
        </TableRow>
