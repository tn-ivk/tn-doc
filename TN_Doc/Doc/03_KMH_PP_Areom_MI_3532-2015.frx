  <ScriptText>using System;
using System.Reflection;
using System.Collections;
using System.Collections.Generic;
using System.ComponentModel;         
using System.Drawing;
using System.Data;
using System.IO;
using FastReport;
using FastReport.Data;
using FastReport.Dialog;
using FastReport.Barcode;
using FastReport.Table;
using FastReport.Utils;
using System.Linq;
using Newtonsoft.Json;
using TN.DocData;
         
namespace FastReport
{
  public class ReportScript
  {
    TN_ToolsFastReport.Tools tools = new TN_ToolsFastReport.Tools();  // классы отчета
    TN.Doc.Doc doc; // данные из входного параметра
    TN.DocData.General General;
    TN.Doc.HeaderDoc Header;
    TN.Doc.DataDoc SettingsData;
    TN.Doc.FooterDoc Footer;
    TN.Doc.DictionarysDoc Dictionarys;
    TN.Doc.DataIVKDoc DataIVK;

    
    List &lt;TN.Doc.Table2&gt; tableResultsParams;
    int protocolNumber;
      
    private void Page_StartPage(object sender, EventArgs e)
    {
      //// Десериализация данных (формат json) из входного параметра - Json                         
      string json = (string)Report.GetParameterValue(&quot;JsonDoc&quot;);
      Newtonsoft.Json.JsonSerializerSettings settings = new Newtonsoft.Json.JsonSerializerSettings();
      settings.TypeNameHandling = TypeNameHandling.All;
         
      doc = JsonConvert.DeserializeObject&lt;TN.Doc.Doc&gt;(json, settings);
      General = (TN.DocData.General) doc.Doc.Settings.General;
      Header = (TN.Doc.HeaderDoc) doc.Doc.Settings.Header;
      SettingsData = (TN.Doc.DataDoc) doc.Doc.Settings.Data;
      Footer = (TN.Doc.FooterDoc) doc.Doc.Settings.Footer;
      Dictionarys = (TN.Doc.DictionarysDoc) doc.Doc.Settings.Dictionarys;  
      DataIVK = (TN.Doc.DataIVKDoc) doc.Doc.DataIVK;

      
      //// === Настройки страницы 
      // Ширина и высота (в мм)
      Page.PaperHeight = General.PageSettings.PaperHeight;
      Page.PaperWidth = General.PageSettings.PaperWidth;
      //Page.Border.Lines = BorderLines.All;
         
      // Поля/отступы от краёв (в мм)
      Page.TopMargin = General.PageSettings.TopMargin;
      Page.BottomMargin = General.PageSettings.BottomMargin;
      Page.LeftMargin = General.PageSettings.LeftMargin;
      Page.RightMargin = General.PageSettings.RightMargin;
         
      //Definition for which device create the protocol
      protocolNumber = General.ProtocolNumber;
         
      // Запуск отрисовки таблиц на странице отчета
      DrawTableHeader();
      DrawTableSourceData();
      DrawTableConclusion();
    }
      
    // Имхо лишний метод
    private void PrintTable(TableObject table)
    {
      for (int i=0;i&lt;table.RowCount;i++)
      {       
        table.PrintRow(i);
        table.PrintColumns();
      }    
    }    

    public void DrawTableHeader()
    {
      // Setup Columns
      float widthDynamicCols=(Page.PaperWidth-Page.LeftMargin-Page.RightMargin)/TableHeader.ColumnCount;         
      for (int i = 0; i &lt; (TableHeader.ColumnCount); i++)                 
      {
        TableHeader.Columns[i].Width = widthDynamicCols*Units.Millimeters;
      }
         
      // Fill table with data         
      ProtocolType.Text = Dictionarys.ProtocolType[DataIVK.TableKMH_PP_Areom.KMH_TYPE];
         
      switch (protocolNumber)
      {
        case 2:
          SIKN_Num.Text = Header.FieldSIKN +&quot; &quot;+ DataIVK.TableKMH_PP_Areom.AdditionalInfo.PP2_AddInfo.SIKN_Num;
          PSP_Name.Text = Header.FieldPSP + DataIVK.TableKMH_PP_Areom.AdditionalInfo.PP2_AddInfo.PSP_Name;                               
          break;
        default:
          SIKN_Num.Text = Header.FieldSIKN +&quot; &quot;+ DataIVK.TableKMH_PP_Areom.AdditionalInfo.PP1_AddInfo.SIKN_Num;
          PSP_Name.Text = Header.FieldPSP + DataIVK.TableKMH_PP_Areom.AdditionalInfo.PP1_AddInfo.PSP_Name;                
          break;
      }
    }
               
    public void  DrawTableSourceData()
    {
      int sumDynamicCols=2;
      float widthDynamicCol=(Page.PaperWidth-Page.LeftMargin-Page.RightMargin-
        ((TableSourceData.Columns[0].Width + TableSourceData.Columns[1].Width)/Units.Millimeters))/sumDynamicCols;                  
         
      for (int w = 2; w &lt; (TableSourceData.ColumnCount); w++)                 
      {
        TableSourceData.Columns[w].Width = widthDynamicCol * Units.Millimeters;
      }
         
      //// ===  Fill table with data
      switch (protocolNumber)
      {
        case 2:
          // Column 3
          SensName_Oper.Text = DataIVK.TableKMH_PP_Areom.AdditionalInfo.PP2_AddInfo.SensName_Oper;
          ManufNum_Oper.Text = DataIVK.TableKMH_PP_Areom.AdditionalInfo.PP2_AddInfo.ManufNum_Oper;
          CheckDate_Oper.Text = DataIVK.TableKMH_PP_Areom.AdditionalInfo.PP2_AddInfo.CheckDate_Oper;
          Delta_PP.Text = tools.GetNormalizedValue(DataIVK.TableKMH_PP_Areom.Protokol.Table1_2.Delta_PP);
          Delta_Syst.Text = tools.GetNormalizedValue(DataIVK.TableKMH_PP_Areom.Protokol.Table1_2.Delta_Syst);
          Delta_Meth.Text = tools.GetNormalizedValue(DataIVK.TableKMH_PP_Areom.Protokol.Table1_2.Delta_Meth);
               
          // Column 4
          SensName_Areom.Text = DataIVK.TableKMH_PP_Areom.AdditionalInfo.PP2_AddInfo.SensName_Areom;
          ManufNum_Areom.Text = DataIVK.TableKMH_PP_Areom.AdditionalInfo.PP2_AddInfo.ManufNum_Areom;
          CheckDate_Areom.Text = DataIVK.TableKMH_PP_Areom.AdditionalInfo.PP2_AddInfo.CheckDate_Areom;
          AbsError_Areom.Text = tools.GetNormalizedValue(DataIVK.TableKMH_PP_Areom.AdditionalInfo.PP2_AddInfo.AbsError_Areom);
          break;
            
        default:
          // Column 3
          SensName_Oper.Text = DataIVK.TableKMH_PP_Areom.AdditionalInfo.PP1_AddInfo.SensName_Oper;
          ManufNum_Oper.Text = DataIVK.TableKMH_PP_Areom.AdditionalInfo.PP1_AddInfo.ManufNum_Oper;
          CheckDate_Oper.Text = DataIVK.TableKMH_PP_Areom.AdditionalInfo.PP1_AddInfo.CheckDate_Oper;
          Delta_PP.Text = tools.GetNormalizedValue(DataIVK.TableKMH_PP_Areom.Protokol.Table1_1.Delta_PP);
          Delta_Syst.Text = tools.GetNormalizedValue(DataIVK.TableKMH_PP_Areom.Protokol.Table1_1.Delta_Syst);
          Delta_Meth.Text = tools.GetNormalizedValue(DataIVK.TableKMH_PP_Areom.Protokol.Table1_1.Delta_Meth);
               
          // Column 4
          SensName_Areom.Text = DataIVK.TableKMH_PP_Areom.AdditionalInfo.PP1_AddInfo.SensName_Areom;
          ManufNum_Areom.Text = DataIVK.TableKMH_PP_Areom.AdditionalInfo.PP1_AddInfo.ManufNum_Areom;
          CheckDate_Areom.Text = DataIVK.TableKMH_PP_Areom.AdditionalInfo.PP1_AddInfo.CheckDate_Areom;
          AbsError_Areom.Text = tools.GetNormalizedValue(DataIVK.TableKMH_PP_Areom.AdditionalInfo.PP1_AddInfo.AbsError_Areom);
          break;
      }
      // Column 4
      DensityMeterType.Text =Dictionarys.DensityMeterType[DataIVK.TableKMH_PP_Areom.KMH_TYPE];
      if (General.NefType == 1) Report.SetParameterValue(&quot;TextOil&quot;, &quot;нефти&quot;);
      else Report.SetParameterValue(&quot;TextOil&quot;, &quot;нефтепродукта&quot;);
         
      if (DataIVK.TableKMH_PP_Areom.KMH_TYPE == 0) Report.SetParameterValue(&quot;TextDensityMeter&quot;, &quot;лабораторным плотномером&quot;);
      else Report.SetParameterValue(&quot;TextDensityMeter&quot;, &quot;ареометром&quot;);
    }
      
    private void TableResults_ManualBuild(object sender, EventArgs e)
    {
      //Setup Columns width
      int sumDynamicCols=TableResults.ColumnCount;
      float widthDynamicCol=(Page.PaperWidth-Page.LeftMargin-Page.RightMargin)/sumDynamicCols;                  
 
      for (int w = 0; w &lt; (TableResults.ColumnCount); w++)                 
      {
        TableResults.Columns[w].Width = widthDynamicCol * Units.Millimeters;
      }      
      //Draw Fixed rows
      for (int n = 0; n &lt; TableResults.FixedRows; n++)
      {
        TableResults.PrintRow(n);
        TableResults.PrintColumns();                                             
      }
         
      NefType.Text = Dictionarys.OilTechParams[General.NefType];
      
      //Fill table with data
      switch (protocolNumber)
      {
        case 2:
          tableResultsParams = DataIVK.TableKMH_PP_Areom.Protokol.Table2_2.Where(y =&gt; y.Activated == 1).ToList();       
          break;
        default:
          tableResultsParams = DataIVK.TableKMH_PP_Areom.Protokol.Table2_1.Where(y =&gt; y.Activated == 1).ToList();
          break;             
      }
         
      int spanRows =0;         
      for (int i = 0; i &lt; (tableResultsParams.Count); i++)                 
      {
        for (int j = 0; j &lt; (tableResultsParams[i].LabMeas.Count); j++)                 
        {
          spanRows = tableResultsParams[i].LabMeas.Count;
          CounterMeasure.RowSpan=spanRows;
          Q.RowSpan=spanRows;
          t.RowSpan=spanRows;
          P.RowSpan=spanRows;
          Dens_PP.RowSpan=spanRows;
          Dens_Priv.RowSpan=spanRows;
          Delta.RowSpan=spanRows;
               
          CounterMeasure.Text=(i+1).ToString();               
          Q.Text=tools.GetNormalizedValue(tableResultsParams[i].Q);               
          t.Text=tools.GetNormalizedValue(tableResultsParams[i].t);
          P.Text=tools.GetNormalizedValue(tableResultsParams[i].P);
          Dens_PP.Text=tools.GetNormalizedValue(tableResultsParams[i].Dens_PP);
          DensLab.Text=tools.GetNormalizedValue(tableResultsParams[i].LabMeas[j].DensLab);
          
          if (DataIVK.TableKMH_PP_Areom.KMH_TYPE == 0)
            tempLabHeader.Text=@&quot;&lt;i&gt;t&lt;sub&gt; лаб i&lt;/i&gt;&lt;/sub&gt;, °С&quot;;             
          else
            tempLabHeader.Text=@&quot;&lt;i&gt;t&lt;sub&gt; ар i&lt;/i&gt;&lt;/sub&gt;, °С&quot;;
          
          tempLab.Text=tools.GetNormalizedValue(tableResultsParams[i].LabMeas[j].tempLab);
          
          BetaLab.Text=tools.GetNormalizedValue(tableResultsParams[i].LabMeas[j].BetaLab);
          GamaLab.Text=tools.GetNormalizedValue(tableResultsParams[i].LabMeas[j].GamaLab);
          Dens_Priv.Text=tools.GetNormalizedValue(tableResultsParams[i].Dens_Priv);
          Delta.Text= tools.GetNormalizedValue(tableResultsParams[i].Delta);
               
          TableResults.PrintRow(3);     
          TableResults.PrintColumns();  
        }  
        CounterMeasure.RowSpan=1;
        Q.RowSpan=1;
        t.RowSpan=1;
        P.RowSpan=1;
        Dens_PP.RowSpan=1;
        Dens_Priv.RowSpan=1;
        Delta.RowSpan=1;
            
        float initialHeight = DataFromJson.Height;
        DataFromJson.Height = 0;
        TableResults.PrintRow(3);
        TableResults.PrintColumns();
        DataFromJson.Height= initialHeight;
      }
    }
     
    public void  DrawTableConclusion()
    {
      // Setup width for last Column
      TableConclusion.Columns[4].Width=(Page.PaperWidth-Page.LeftMargin-Page.RightMargin - 
        ((TableConclusion.Columns[0].Width + TableConclusion.Columns[1].Width + TableConclusion.Columns[2].Width + TableConclusion.Columns[3].Width)/Units.Millimeters))*Units.Millimeters;
  
      //// ===  Fill table with data
      Dictionary&lt;string,string&gt; dictAdditionalInfo = new Dictionary&lt;string,string&gt; ();
      switch (protocolNumber)
      {
        case 2:
          foreach (var propertyInfo in DataIVK.TableKMH_PP_Areom.AdditionalInfo.PP2_AddInfo.GetType().GetProperties())
          {
            var propertyValue = propertyInfo.GetValue(DataIVK.TableKMH_PP_Areom.AdditionalInfo.PP2_AddInfo);
            dictAdditionalInfo.Add(propertyInfo.Name, propertyInfo.GetValue(DataIVK.TableKMH_PP_Areom.AdditionalInfo.PP2_AddInfo, null).ToString());
          }
          break;
        default:
          foreach (var propertyInfo in DataIVK.TableKMH_PP_Areom.AdditionalInfo.PP1_AddInfo.GetType().GetProperties())
          {
            var propertyValue = propertyInfo.GetValue(DataIVK.TableKMH_PP_Areom.AdditionalInfo.PP1_AddInfo);
            dictAdditionalInfo.Add(propertyInfo.Name, propertyInfo.GetValue(DataIVK.TableKMH_PP_Areom.AdditionalInfo.PP1_AddInfo, null).ToString());
          }
          break;
      }
           
      ARM_KMH_Result.Text =string.Format(&quot;Поточный ПП зав. № &lt;u&gt; {0}&lt;/u&gt; {1} к дальнейшей эксплуатации&quot;, 
        dictAdditionalInfo[&quot;ManufNum_Oper&quot;], 
        dictAdditionalInfo[&quot;ARM_KMH_Result&quot;]);
           
      DateTimeLong.Text = string.Format(&quot;Дата проведения КМХ: &lt;u&gt;{0:dd.MM.yyyy} г.&quot;,(tools.UnixTimestampToDatetime(DataIVK.TableKMH_PP_Areom.DateTimeLong)));               
      ServiceStaffData.Text=dictAdditionalInfo[&quot;ServiceStaffData&quot;];
      DeliveryStaffData.Text= dictAdditionalInfo[&quot;DeliveryStaffData&quot;];
      RecievingStaffData.Text= dictAdditionalInfo[&quot;RecievingStaffData&quot;];
    }  

    private void PageFooter_BeforeLayout(object sender, EventArgs e)
    {
      if((Int32)Report.GetVariableValue(&quot;TotalPages&quot;) &lt; 2) 
      { 
        PageFooter.Visible = false; 
      }
      else
      {
        PageNumeration.Width = (Page.PaperWidth-Page.LeftMargin-Page.RightMargin)*Units.Millimeters;
      }
    }
  }    
}




