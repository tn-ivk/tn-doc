  public class ReportScript
  {
    TN_ToolsFastReport.Tools tools = new TN_ToolsFastReport.Tools();      
    TN.Doc.Doc doc;
    TN.Doc.DataIVKDoc DataIVK;
    TN.Doc.HeaderDoc Header;
    TN.Doc.DataDoc SettingsData;
    TN.Doc.FooterDoc Footer;
    TN.Doc.DictionarysDoc Dictionarys;
    
    DateTime Begin;
     
    private void Page_StartPage(object sender, EventArgs e)
    {
      string json = (string)Report.GetParameterValue(&quot;JsonDoc&quot;);
      Newtonsoft.Json.JsonSerializerSettings settings = new Newtonsoft.Json.JsonSerializerSettings();
      settings.TypeNameHandling = TypeNameHandling.All;         
         
      doc = JsonConvert.DeserializeObject&lt;TN.Doc.Doc&gt;(json, settings);
      DataIVK = (TN.Doc.DataIVKDoc)doc.Doc.DataIVK;
      Header = (TN.Doc.HeaderDoc)doc.Doc.Settings.Header;
      SettingsData = (TN.Doc.DataDoc)doc.Doc.Settings.Data;
      Footer = (TN.Doc.FooterDoc)doc.Doc.Settings.Footer;
      Dictionarys = (TN.Doc.DictionarysDoc)doc.Doc.Settings.Dictionarys;      
      
      // Настройки страницы 
      // Ширина и высота (в мм)
      Page.PaperHeight = doc.Doc.Settings.General.PageSettings.PaperHeight;
      Page.PaperWidth= doc.Doc.Settings.General.PageSettings.PaperWidth;
      //Page.Border.Lines = BorderLines.All;
         
      // Поля/отступы от краёв (в мм)
      Page.TopMargin=doc.Doc.Settings.General.PageSettings.TopMargin;
      Page.BottomMargin=doc.Doc.Settings.General.PageSettings.BottomMargin;
      Page.LeftMargin=doc.Doc.Settings.General.PageSettings.LeftMargin;
      Page.RightMargin=doc.Doc.Settings.General.PageSettings.RightMargin;
       
      Begin =  tools.UnixTimestampToDatetime((long)DataIVK.TableResultActAndPassport.Begin);
      
      // Запуск отрисовки таблиц на странице отчета
      DrawPageHeader();
      DrawTableHeader();
      //DrawTableTotal();
      DrawTableSigners();
    }
      
    public void DrawPageHeader()
    {            
      PageHeaderText.Text = Header.NameIVK;
    }
    
    public void DrawTableHeader()
    {            
      ActNumberAndDate.Text = string.Format(&quot;Акт приема-сдачи нефти №&lt;u&gt; {0}&lt;/u&gt; от &lt;u&gt;{1:dd.MM.yyyy}&lt;/u&gt; г. {2}&quot;,  
        DataIVK.TableResultActAndPassport.AdditionalInfo.ActNumber,
        Begin,
        Header.NameIVK.Contains(&quot;РСУ&quot;)?&quot;(сдача по РСУ)&quot;:&quot;(сдача по СИКН)&quot;); 
      TextHelper1.Text = &quot;(для валовых объемов нефти)&quot;;
      
      ActNumberAndDate_China.Text = string.Format(&quot;原油交接单 №&lt;u&gt; {0}&lt;/u&gt; 年 &lt;u&gt;{1:yyyy}&lt;/u&gt;年&lt;u&gt;{1:MM}&lt;/u&gt;月&lt;u&gt;{1:dd}&lt;/u&gt;日 {2}&quot;,  
        DataIVK.TableResultActAndPassport.AdditionalInfo.ActNumber,
        Begin,
        Header.NameIVK.Contains(&quot;РСУ&quot;)?&quot;(根据石油备用计量线交付)&quot;:&quot;(根据石油数量和品质指标测量系统交付)&quot;);     
      
      DelivePoint.Text = DataIVK.TableResultActAndPassport.AdditionalInfo.DelivePoint + &quot;	加林达&quot;; 
      Factory.Text = DataIVK.TableResultActAndPassport.AdditionalInfo.Factory + &quot;&lt;br&gt;东方管道输油有限责任公司&quot;; 
      SIKN_Number.Text = DataIVK.TableResultActAndPassport.AdditionalInfo.SIKN_Number; 
      
      Delive_FIO.Text = DataIVK.TableResultActAndPassport.AdditionalInfo.Delive_FIO; 
      
      DateTime DeliveLicenseDate;
      if (DateTime.TryParse(DataIVK.TableResultActAndPassport.AdditionalInfo.Delive_Lic_Date, out DeliveLicenseDate))
        Delive_License.Text = string.Format(&quot;от {1:dd.MM.yyyy} №{0}&lt;br&gt;{1:yyyy}年{1:MM}月{1:dd}日签发的 № {0} 委托书&quot;,DataIVK.TableResultActAndPassport.AdditionalInfo.Delive_Lic_Number,DeliveLicenseDate); 
      else
        Delive_License.Text = &quot;&quot;;
      
      Receive_FIO.Text = DataIVK.TableResultActAndPassport.AdditionalInfo.Receive_FIO; 
      
      DateTime ReceiveLicenseDate;
      if (DateTime.TryParse(DataIVK.TableResultActAndPassport.AdditionalInfo.Receive_Lic_Date, out ReceiveLicenseDate))
        Receive_License.Text = string.Format(&quot;от {1:dd.MM.yyyy} №{0}&lt;br&gt;{1:yyyy}年{1:MM}月{1:dd}日中管法授字第{0}号&quot;,DataIVK.TableResultActAndPassport.AdditionalInfo.Receive_Lic_Number,ReceiveLicenseDate); 
      else
        Receive_License.Text = &quot;&quot;;
     }    
      
      private void TableAct_ManualBuild(object sender, EventArgs e)
      {
      bool ShowResultColumn = SettingsData.ShowResultColumn;
      int ColumnsCount = 0; 
      List&lt;TN.Doc.Act&gt; listShiftsData;
      listShiftsData = DataIVK.TableResultActAndPassport.ResultActAndPassport.Act.Where(i =&gt; ! i.Vol_LastShift.Contains(&quot;-&quot;)  &amp; String.IsNullOrEmpty(i.Vol_LastShift) == false).ToList();
         
      if (Engine.FinalPass == true)
      {
        if (ShowResultColumn)
        {
          ColumnsCount = listShiftsData.Count + 1;
        }
        else
        {
          TableAct.Columns.Remove(ColumnResult);
          ColumnsCount = listShiftsData.Count;
        }           
                                                    
        // Calculate Dynamic Columns width
        float widthDynamicCols=(
          Page.PaperWidth-
          Page.LeftMargin-
          Page.RightMargin-
          TableAct.Columns[0].Width/Units.Millimeters-  
          TableAct.Columns[1].Width/Units.Millimeters-
          TableAct.Columns[2].Width/Units.Millimeters)
          /ColumnsCount;         

        // Insert Columns for Volumes  (V0) &amp; fill them headers with text
        int indexColTemplate = ColumnTemplate.Index;
        for (int i=1; i&lt;listShiftsData.Count; i++)
        {
          TableAct.Columns.Insert(indexColTemplate+1, new TableColumn());
          
          foreach(TableRow row in TableAct.Rows)
            row[indexColTemplate+1].AssignAll(row[indexColTemplate]);
        }
            
        // Setup Dynamic Columns Width
        for (int i = indexColTemplate; i &lt; TableAct.ColumnCount; i++)                 
        {
          TableAct.Columns[i].Width = widthDynamicCols*Units.Millimeters;
        }
            
        // Span Columns
        TableAct[indexColTemplate,0].ColSpan=listShiftsData.Count;
            
        // Fill TableAct with data
            
        for (int i = 0; i &lt; (listShiftsData.Count); i++)                 
        {
          for (int j=1;j&lt;TableAct.RowCount;j++)
          {
            TableAct[(3+i),1].Text = Begin.ToString(&quot;dd.MM.yyyy&quot;);
            
            TableAct[(3+i),2].Text = string.Format(&quot;{0} смена&quot;,( i+1)); 
            
          //  string begin = DateTimeOffset.FromUnixTimeSeconds(DataIVK.TableResultActAndPassport.ResultActAndPassport.PassportPeriodDT[i].Begin).DateTime.ToString(&quot;HH:mm&quot;);
          //  string end = DateTimeOffset.FromUnixTimeSeconds(DataIVK.TableResultActAndPassport.ResultActAndPassport.PassportPeriodDT[i].End).DateTime.ToString(&quot;HH:mm&quot;).Replace(&quot;00:00&quot;, &quot;24:00&quot;);
          //  TableAct[(3+i),3].Text = $&quot;{begin}-{end}&quot;;            
            
            TableAct[(3+i),5].Text = tools.GetNormalizedValue(listShiftsData[i].Vol_LastShift);
            TableAct[(3+i),6].Text = tools.GetNormalizedValue(listShiftsData[i].Mass_LastShift);         
            TableAct[(3+i),8].Text = tools.GetNormalizedValue(listShiftsData[i].Vol_CurrShift);           
            TableAct[(3+i),9].Text = tools.GetNormalizedValue(listShiftsData[i].Mass_CurrShift);     
            TableAct[(3+i),11].Text = tools.GetNormalizedValue(listShiftsData[i].Vol_Gross);     
            TableAct[(3+i),12].Text = tools.GetNormalizedValue(listShiftsData[i].Mass_Gross);     
            TableAct[(3+i),13].Text = tools.GetNormalizedValue(listShiftsData[i].Temp);     
            TableAct[(3+i),14].Text = tools.GetNormalizedValue(listShiftsData[i].Press);     
            TableAct[(3+i),15].Text = tools.GetNormalizedValue(listShiftsData[i].Density);     
            TableAct[(3+i),16].Text = tools.GetNormalizedValue(listShiftsData[i].Density_correction);     
            TableAct[(3+i),17].Text = tools.GetNormalizedValue(listShiftsData[i].PassportID);     
            TableAct[(3+i),18].Text = tools.GetNormalizedValue(listShiftsData[i].Balast_Mass_Frac);             
            TableAct[(3+i),19].Text = tools.GetNormalizedValue(listShiftsData[i].Balast.Water);             
            TableAct[(3+i),20].Text = tools.GetNormalizedValue(listShiftsData[i].Balast.Chlorides);             
            TableAct[(3+i),21].Text = tools.GetNormalizedValue(listShiftsData[i].Balast.Impurity);             
            TableAct[(3+i),22].Text = tools.GetNormalizedValue(listShiftsData[i].Sulfur);             
            TableAct[(3+i),23].Text = tools.GetNormalizedValue(listShiftsData[i].Chloride_Salts);             
            TableAct[(3+i),24].Text = tools.GetNormalizedValue(listShiftsData[i].Balast_Mass);             
            TableAct[(3+i),25].Text = tools.GetNormalizedValue(listShiftsData[i].Net_Mass );     
          }
        }
      }
         
      Gross_Vol.Text =  tools.GetNormalizedValue(DataIVK.TableResultActAndPassport.ResultActAndPassport.Common.Gross_Vol);
      Gross_Mass.Text =  tools.GetNormalizedValue(DataIVK.TableResultActAndPassport.ResultActAndPassport.Common.Gross_Mass);
      Balast_Mass.Text =  tools.GetNormalizedValue(DataIVK.TableResultActAndPassport.ResultActAndPassport.Common.Balast_Mass);
      Net_Mass.Text =  tools.GetNormalizedValue(DataIVK.TableResultActAndPassport.ResultActAndPassport.Common.Net_Mass);
      
      //Draw rows                                                             
      for (int n = 0; n &lt; TableAct.RowCount; n++)
      {
        TableAct.PrintRow(n);
        TableAct.PrintColumns();                                             
      }
    }      
      
      private void TableAdditionlInfo_ManualBuild(object sender, EventArgs e)
      {
      // Setup Last Column width
      TableAdditionlInfo.Columns[0].Width=(Page.PaperWidth-Page.LeftMargin-Page.RightMargin)*Units.Millimeters;
      
      string wholePart = DataIVK.TableResultActAndPassport.ResultActAndPassport.Common.ValueInWords.WholePart;
      int startIndexTon = wholePart.IndexOf(&quot; тон&quot;);
      
      if (startIndexTon != -1)
        wholePart = wholePart.Remove(startIndexTon);        
        
      WholePart.Text =  string.Format(&quot;Масса нефти нетто (прописью) 石油净质量（大写） &lt;u&gt; {0}&lt;/u&gt; т., t&quot;, wholePart);
         
      //Draw static Rows
      TableAdditionlInfo.PrintRow(0);
      TableAdditionlInfo.PrintColumns();                                             
         
      //Fill &amp; Draw dynamic Rows
      List &lt;string&gt; listGostIndex51858 = DataIVK.TableResultActAndPassport.ResultActAndPassport.Common.ExtendGostIndex51858.Where(i =&gt; ! i.Contains(&quot;-&quot;)  &amp; String.IsNullOrEmpty(i) == false).ToList();
      List &lt;string&gt; distListGostIndex51858 = listGostIndex51858.Distinct().ToList();
      List &lt;string&gt; resultListGostIndex51858 = distListGostIndex51858.Count == 1 ? distListGostIndex51858 : listGostIndex51858;     
      
      for (int n = 0; n &lt; resultListGostIndex51858.Count; n++)
      {
        GostIndex51858.Text = string.Format(&quot;Обозначение нефти: 石油标识: &lt;u&gt; {0}&lt;/u&gt; по 按 ГОСТ Р 51858.&quot;,  listGostIndex51858[n]);
        TableAdditionlInfo.PrintRow(1);
        TableAdditionlInfo.PrintColumns();                                             
      }
      }
      
      public void  DrawTableSigners()
      {
      if (Page.PaperWidth == 297)
      {
        if (Engine.FinalPass == true)
        {  
          for (int n = 0; n &lt; TableSigners.ColumnCount; n++)
          {
            TableSigners.Columns[n].Width=(TableSigners.Columns[n].Width*(float)1.455);//*Units.Millimeters;
          }       
        }
      }
      if (!string.IsNullOrEmpty(DataIVK.TableResultActAndPassport.AdditionalInfo.Delive_FIO)) {
        if (DataIVK.TableResultActAndPassport.AdditionalInfo.Delive_FIO.Contains(&quot;&lt;br&gt;&quot;)) {
          string FIO = DataIVK.TableResultActAndPassport.AdditionalInfo.Delive_FIO.Split(&quot;&lt;br&gt;&quot;)[0];
          if (FIO.Contains(&quot;.&quot;) &amp;&amp; FIO.Contains(&quot; &quot;))
            Delive_IOF.Text = $&quot;{FIO.Substring(FIO.IndexOf(' ')+1)} {FIO.Substring(0, FIO.IndexOf(' '))}&quot;;
          else
            Delive_IOF.Text = FIO; }}
      else    
        Delive_IOF.Text = DataIVK.TableResultActAndPassport.AdditionalInfo.Delive_FIO; 
      
      if (!string.IsNullOrEmpty(DataIVK.TableResultActAndPassport.AdditionalInfo.Receive_FIO)) {
        if (DataIVK.TableResultActAndPassport.AdditionalInfo.Receive_FIO.Contains(&quot;&lt;br&gt;&quot;))
          Receive_IOF.Text = DataIVK.TableResultActAndPassport.AdditionalInfo.Receive_FIO.Split(&quot;&lt;br&gt;&quot;)[0]; }
      else  
        Receive_IOF.Text = DataIVK.TableResultActAndPassport.AdditionalInfo.Receive_IOF;
      
      
      if (!string.IsNullOrEmpty(Footer.LabMIDensity))
        LabMIDensity.Text = $&quot;*) заполняют при отказе поточного преобразователя плотности (определяют по {Footer.LabMIDensity})&quot;;
      }  
      
      private void PageFooter_BeforeLayout(object sender, EventArgs e)
      {
      if((Int32)Report.GetVariableValue(&quot;TotalPages&quot;) &lt; 2) 
      { 
        PageFooter.Visible = false; 
      }
      else
      {
        PageNumeration.Width = (Page.PaperWidth-Page.LeftMargin-Page.RightMargin)*Units.Millimeters;
      }
      }
      }    
}

