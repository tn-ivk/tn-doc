<Report ScriptLanguage="CSharp" ReferencedAssemblies="System.dll&#13;&#10;System.Drawing.dll&#13;&#10;System.Windows.Forms.dll&#13;&#10;System.Data.dll&#13;&#10;System.Xml.dll&#13;&#10;Newtonsoft.Json.dll&#13;&#10;System.Collections.dll&#13;&#10;System.Core.dll&#13;&#10;TN_ToolsFastReport.dll&#13;&#10;TN_DocGeneral.dll&#13;&#10;KMH_MI2816.dll" DoublePass="true" ReportInfo.Created="03/25/2020 12:46:46" ReportInfo.Modified="08/29/2024 14:55:44" ReportInfo.CreatorVersion="2024.2.0.0">
  <ScriptText>using System;
using System.Reflection;
using System.Collections;
using System.Collections.Generic;
using System.ComponentModel;         
using System.Drawing;
using System.Data;
using System.IO;
using FastReport;
using FastReport.Data;
using FastReport.Dialog;
using FastReport.Barcode;
using FastReport.Table;
using FastReport.Utils;
using System.Linq;
using Newtonsoft.Json;
using TN.DocData;

namespace FastReport
{
  public class ReportScript
  {
    TN_ToolsFastReport.Tools tools = new TN_ToolsFastReport.Tools();  // классы отчета
    TN.Doc.Doc doc; // данные из входного параметра
    TN.DocData.General General;
    TN.Doc.HeaderDoc Header;
    TN.Doc.DataDoc SettingsData;
    TN.Doc.FooterDoc Footer;
    TN.Doc.DictionarysDoc Dictionarys;
    TN.Doc.DataIVKDoc DataIVK; 
    
    int protocolNumber;       
      
    // Collecting Properties of the class to the List
    List &lt;string&gt; GetProps&lt;T&gt;(T inputClass, out List&lt;string&gt; listProps)
    {
      listProps = new List&lt;string&gt;();
      PropertyInfo[] props =  inputClass.GetType().GetProperties();
      foreach (var prop in props)
      {
        listProps.Add(prop.GetValue(inputClass).ToString());
      }
      //            MessageBox.Show(listPicn[0].ToString());  
      return listProps; 
    }  
      
    private void Page_StartPage(object sender, EventArgs e)
    {
      //using (var sr = new StreamReader
      //      (&quot;D:/!_Work/!_Транснефть/SVN/Work/Sources/Reports/FRX/Входящие данные от Алексея (классы и json)/06_TableKMH_MI2816/DocKMH_MI2816.json&quot;))
      //{
      // Read the stream as a string
      //   Report.SetParameterValue(&quot;Protocol&quot;, sr.ReadToEnd());
      //}
         
      //// Десериализация данных (формат json) из входного параметра - Json                         
      string json = (string)Report.GetParameterValue(&quot;JsonDoc&quot;);
      Newtonsoft.Json.JsonSerializerSettings settings = new Newtonsoft.Json.JsonSerializerSettings();
      settings.TypeNameHandling = TypeNameHandling.All;
      
      doc = JsonConvert.DeserializeObject&lt;TN.Doc.Doc&gt;(json, settings);
      General = (TN.DocData.General) doc.Doc.Settings.General;
      Header = (TN.Doc.HeaderDoc) doc.Doc.Settings.Header;
      SettingsData = (TN.Doc.DataDoc) doc.Doc.Settings.Data;
      Footer = (TN.Doc.FooterDoc) doc.Doc.Settings.Footer;
      Dictionarys = (TN.Doc.DictionarysDoc) doc.Doc.Settings.Dictionarys;  
      DataIVK = (TN.Doc.DataIVKDoc) doc.Doc.DataIVK;
         
      //// === Настройки страницы 
      // Ширина и высота (в мм)
         
      Page.PaperHeight = General.PageSettings.PaperHeight;
      Page.PaperWidth = General.PageSettings.PaperWidth;
      //Page.Border.Lines = BorderLines.All;
         
      // Поля/отступы от краёв (в мм)
      Page.TopMargin = General.PageSettings.TopMargin;
      Page.BottomMargin = General.PageSettings.BottomMargin;
      Page.LeftMargin = General.PageSettings.LeftMargin;
      Page.RightMargin = General.PageSettings.RightMargin;
         
      //Definition for which device create the protocol
      protocolNumber = General.ProtocolNumber;
      
      // Запуск отрисовки таблиц на странице отчета
      DrawTableHeader();
      DrawTableSourceData();
      DrawTableResults(); 
      DrawTableConclusion();
    }
      
    public void DrawTableHeader()
    {
      // Setup Columns
      float widthDynamicCols=(Page.PaperWidth-Page.LeftMargin-Page.RightMargin)/TableHeader.ColumnCount;         
      for (int i = 0; i &lt; (TableHeader.ColumnCount); i++)                 
      {
        TableHeader.Columns[i].Width = widthDynamicCols*Units.Millimeters;
      }
         
      switch (protocolNumber)
      {
        case 2:
          SIKN_Name.Text = string.Format(&quot;{0}{1}&quot;,Header.FieldSIKN,DataIVK.TableKMH_MI2816.AdditionalInfo.PP2_AdditionalInfo.SIKN_Name);
          PSP_Name.Text = string.Format(&quot;{0} {1}&quot;,Header.FieldPSP,DataIVK.TableKMH_MI2816.AdditionalInfo.PP2_AdditionalInfo.PSP_Name);        
          break;
        default:
          SIKN_Name.Text = string.Format(&quot;{0}{1}&quot;,Header.FieldSIKN,DataIVK.TableKMH_MI2816.AdditionalInfo.PP1_AdditionalInfo.SIKN_Name);
          PSP_Name.Text = string.Format(&quot;{0} {1}&quot;,Header.FieldPSP,DataIVK.TableKMH_MI2816.AdditionalInfo.PP1_AdditionalInfo.PSP_Name);        
          break;
      }        
    }
               
    public void  DrawTableSourceData()
    {
      ////Create lists for Classes properties values
      List &lt;string&gt; listPicn1Params = new List &lt;string&gt;();
      List &lt;string&gt; listPicn2Params = new List &lt;string&gt;();
      List &lt;string&gt; listWeigherParams = new List &lt;string&gt;();
      List &lt;string&gt; listTempParams = new List &lt;string&gt;();
      List &lt;string&gt; listPressParams = new List &lt;string&gt;();
      string delta_Picn;
         
      if (DataIVK.TableKMH_MI2816.ARMData ==null)
      {
        for (int i = 0; i &lt; 11; i++)
        {
          listPicn1Params.Add(&quot;&quot;);
          listPicn2Params.Add(&quot;&quot;);
        }
        for (int i = 0; i &lt; 5; i++)
        {
          listWeigherParams.Add(&quot;&quot;);
          listTempParams.Add(&quot;&quot;);
          listPressParams.Add(&quot;&quot;);
        }
        delta_Picn = &quot;&quot;;            
      }
      else
      {                                                                                    
        GetProps(DataIVK.TableKMH_MI2816.ARMData.Picn1, out listPicn1Params);
        GetProps(DataIVK.TableKMH_MI2816.ARMData.Picn2, out listPicn2Params);
        GetProps(DataIVK.TableKMH_MI2816.ARMData.Weigher, out listWeigherParams);
        GetProps(DataIVK.TableKMH_MI2816.ARMData.Temp, out listTempParams);
        GetProps(DataIVK.TableKMH_MI2816.ARMData.Press, out listPressParams);
        delta_Picn = tools.GetNormalizedValue(DataIVK.TableKMH_MI2816.ARMData.Delta_Picn);
      }
         
      // Setup Columns         
      int sumDynamicCols=2;
      float widthDynamicCol=((Page.PaperWidth-Page.LeftMargin-Page.RightMargin-(Col1.Width+Col2.Width)/Units.Millimeters)/sumDynamicCols);                  
      for (int w = sumDynamicCols; w &lt; (TableSourceData.ColumnCount); w++)                 
      {
        TableSourceData.Columns[w].Width = widthDynamicCol * Units.Millimeters;
      }

      //// ===  Fill table with data
      // Column 3, rows for Section 1         
      for (int i = 0; i &lt; listPicn1Params.Count; i++)
      {
        if (i==2) TableSourceData[2,i+5].Text = listPicn1Params[i];          
        else TableSourceData[2,i+5].Text = tools.GetNormalizedValue(listPicn1Params[i]);      
      }
      
      //PicnInit1_V.Text = DataIVK.TableKMH_MI2816.AdditionalInfo.PP1_AdditionalInfo.PicnInit[0].V.ToString();
      //PicnInit1_FP.Text = DataIVK.TableKMH_MI2816.AdditionalInfo.PP1_AdditionalInfo.PicnInit[0].FP.ToString();
      //PicnInit1_Ft.Text = DataIVK.TableKMH_MI2816.AdditionalInfo.PP1_AdditionalInfo.PicnInit[0].Ft.ToString();
      //PicnInit1_t0.Text = DataIVK.TableKMH_MI2816.AdditionalInfo.PP1_AdditionalInfo.PicnInit[0].t0.ToString();
      
      // Column 4, rows for Section 1         
      for (int i = 0; i &lt; listPicn2Params.Count; i++)
      {
        if (i==2) TableSourceData[3,i+5].Text = listPicn2Params[i];
        else TableSourceData[3,i+5].Text = tools.GetNormalizedValue(listPicn2Params[i]);        
      }
      
      //PicnInit2_V.Text = DataIVK.TableKMH_MI2816.AdditionalInfo.PP1_AdditionalInfo.PicnInit[1].V.ToString();
      //PicnInit2_FP.Text = DataIVK.TableKMH_MI2816.AdditionalInfo.PP1_AdditionalInfo.PicnInit[1].FP.ToString();
      //PicnInit2_Ft.Text = DataIVK.TableKMH_MI2816.AdditionalInfo.PP1_AdditionalInfo.PicnInit[1].Ft.ToString();
      //PicnInit2_t0.Text = DataIVK.TableKMH_MI2816.AdditionalInfo.PP1_AdditionalInfo.PicnInit[1].t0.ToString();
      
      // Column 3, rows for Section 2
      for (int i = 0; i &lt; listWeigherParams.Count; i++)
      {
        TableSourceData[2,i+17].Text =  tools.GetNormalizedValue(listWeigherParams[i]);
      }
      // Column 3, rows for Section 3
      for (int i = 0; i &lt; listTempParams.Count; i++)
      {
        TableSourceData[2,i+23].Text =  tools.GetNormalizedValue(listTempParams[i]);
      }
      // Column 3, rows for Section 4
      for (int i = 0; i &lt; listPressParams.Count; i++)
      {
        TableSourceData[2,i+29].Text =  tools.GetNormalizedValue(listPressParams[i]);
      }
         
      //Предел допускаемой абсолютной погрешности, Раздел 1.5
      Delta_Picn.Text = delta_Picn;
         
      // Column 3, rows for Sensor data
      switch (protocolNumber)
      {
        case 2:
          DensSensor_Name.Text = DataIVK.TableKMH_MI2816.AdditionalInfo.PP2_AdditionalInfo.DensSensor_Name;
          DensSensor_FactoryNumber.Text = DataIVK.TableKMH_MI2816.AdditionalInfo.PP2_AdditionalInfo.DensSensor_FactoryNumber;
          DensSensor_CheckDate.Text = DataIVK.TableKMH_MI2816.AdditionalInfo.PP2_AdditionalInfo.DensSensor_CheckDate;
          
          if (DataIVK.TableKMH_MI2816.AdditionalInfo.PP2_AdditionalInfo.Delta_PP == 0.0)
          { 
            Delta_PP.Text = &quot;0,0&quot;;
          }                                    
          else 
          {
            Delta_PP.Text = string.Format(&quot;{0}&quot;, tools.GetNormalizedValue(DataIVK.TableKMH_MI2816.AdditionalInfo.PP2_AdditionalInfo.Delta_PP));
          }
          
          break;
        default:
          DensSensor_Name.Text = DataIVK.TableKMH_MI2816.AdditionalInfo.PP1_AdditionalInfo.DensSensor_Name;
          DensSensor_FactoryNumber.Text = DataIVK.TableKMH_MI2816.AdditionalInfo.PP1_AdditionalInfo.DensSensor_FactoryNumber;
          DensSensor_CheckDate.Text = DataIVK.TableKMH_MI2816.AdditionalInfo.PP1_AdditionalInfo.DensSensor_CheckDate;
          
          if (DataIVK.TableKMH_MI2816.AdditionalInfo.PP1_AdditionalInfo.Delta_PP == 0.0)
          { 
            Delta_PP.Text = &quot;0,0&quot;;
          }                                    
          else 
          {
            Delta_PP.Text = string.Format(&quot;{0}&quot;, tools.GetNormalizedValue(DataIVK.TableKMH_MI2816.AdditionalInfo.PP1_AdditionalInfo.Delta_PP));
          }

          break;
      }     
    }
      
    public void  DrawTableResults()
    {
      var listTable1ParamsNames = typeof(TN.Doc.Table1).GetProperties().Select(x=&gt;x.Name).ToList();
      var listTable1_1ParamsNames = typeof(TN.Doc.Table1_1).GetProperties().Select(x=&gt;x.Name).ToList();
         
      Dictionary&lt;string, string&gt; dictTable1Params;
      switch (protocolNumber)
      {
        case 2:
          dictTable1Params =  typeof(TN.Doc.Table1)
            .GetProperties()
            .ToDictionary(prop =&gt; prop.Name, prop =&gt; (string)prop.GetValue(DataIVK.TableKMH_MI2816.Protokol.Table1[1] , null));
          break;
        default:
          dictTable1Params =  typeof(TN.Doc.Table1)
            .GetProperties()
            .ToDictionary(prop =&gt; prop.Name, prop =&gt; (string)prop.GetValue(DataIVK.TableKMH_MI2816.Protokol.Table1[0] , null));
          break;
      }            
         
      var dictTable1_1Pic1Params =  typeof(TN.Doc.Table1_1)
        .GetProperties()
      .ToDictionary(prop =&gt; prop.Name, prop =&gt; (string)prop.GetValue(DataIVK.TableKMH_MI2816.Protokol.Table1_1[0] , null));
         
      var dictTable1_1Pic2Params =  typeof(TN.Doc.Table1_1)
        .GetProperties()
        .ToDictionary(prop =&gt; prop.Name, prop =&gt; (string)prop.GetValue(DataIVK.TableKMH_MI2816.Protokol.Table1_1[1] , null));
         
      //// Fill table with the data
      //object TempValue = &quot;not found&quot;;
      string TempValue = &quot;&quot;;
      for (int j = 0; j &lt; (TableResults.RowCount); j++)                 
      {
        for (int i = 0; i &lt; (TableResults.ColumnCount); i++)                 
        {
          switch (i)
          {     
            case 0:
            case 1:   
            case 2:   
            case 3:
              dictTable1Params.TryGetValue(listTable1ParamsNames[i], out TempValue);                     
              TableResults[i,3].Text = tools.GetNormalizedValue(TempValue.ToString());   
              break;
            case 5:   
            case 6:   
            case 7:
            case 8:  
              switch (j)
              { 
                case 0:
                  dictTable1_1Pic1Params.TryGetValue(listTable1_1ParamsNames[i-4], out TempValue);
                  //tools.GetPropertyValue(dictTable1_1Pic1Params, listTable1_1ParamsNames[i-4], ref TempValue);
                  TableResults[i,j+3].Text =  tools.GetNormalizedValue(TempValue.ToString());
                  break;
                case 1:   
                  dictTable1_1Pic2Params.TryGetValue(listTable1_1ParamsNames[i-4], out TempValue);
                  //tools.GetPropertyValue(dictTable1_1Pic2Params, listTable1_1ParamsNames[i-4], ref TempValue);
                  TableResults[i,j+3].Text = tools.GetNormalizedValue(TempValue.ToString());
                  break;
              }
              break;
            case 9:   
            case 10:   
            case 11:
              dictTable1Params.TryGetValue(listTable1ParamsNames[i-5], out TempValue);
              TableResults[i,3].Text = tools.GetNormalizedValue(TempValue.ToString());
              break;
          }
        }
      }
    }
      
    public void  DrawTableConclusion()
    {
      string arm_KMH_Result = &quot;&quot;;
      string  serviceStaffData = &quot;&quot;;
      string  deliveryStaffData = &quot;&quot;;
      string recievingStaffData = &quot;&quot;;
         
         
      // Setup width for last Column
      TableConclusion.Columns[4].Width=(Page.PaperWidth-Page.LeftMargin-Page.RightMargin - 
        ((TableConclusion.Columns[0].Width + TableConclusion.Columns[1].Width + TableConclusion.Columns[2].Width + TableConclusion.Columns[3].Width)/Units.Millimeters))*Units.Millimeters;

      // ===  Fill table with data
         
      if (DataIVK.TableKMH_MI2816.ARMData ==null)
      {
        arm_KMH_Result=&quot;&quot;;
      }
      else
      {
        switch (protocolNumber)
        {
          case 2:
            arm_KMH_Result=DataIVK.TableKMH_MI2816.ARMData.ARM_KMH_Result2;
            break;
          default:
            arm_KMH_Result=DataIVK.TableKMH_MI2816.ARMData.ARM_KMH_Result1;
            break;
        }            
        
        serviceStaffData=DataIVK.TableKMH_MI2816.ARMData.ServiceStaffData;
        deliveryStaffData= DataIVK.TableKMH_MI2816.ARMData.DeliveryStaffData;
        recievingStaffData=DataIVK.TableKMH_MI2816.ARMData.RecievingStaffData;
      }
       
      switch (protocolNumber)
      {
        case 2:
          ARM_KMH_Result.Text =string.Format(&quot;Поточный ПП зав. № &lt;u&gt; {0}&lt;/u&gt; {1}&quot;, 
            DataIVK.TableKMH_MI2816.AdditionalInfo.PP2_AdditionalInfo.DensSensor_FactoryNumber,
            arm_KMH_Result + &quot; к дальнейшей эксплуатации&quot;);
          break;
        default:
          ARM_KMH_Result.Text =string.Format(&quot;Поточный ПП зав. № &lt;u&gt; {0}&lt;/u&gt; {1}&quot;, 
            DataIVK.TableKMH_MI2816.AdditionalInfo.PP1_AdditionalInfo.DensSensor_FactoryNumber,
            arm_KMH_Result + &quot; к дальнейшей эксплуатации&quot;);
          break;
      }            
         
      DateTimeLong.Text = string.Format(&quot;Дата проведения КМХ: &lt;u&gt;{0:dd.MM.yyyy} г.&quot;,(tools.UnixTimestampToDatetime(DataIVK.TableKMH_MI2816.DateTimeLong)));     
      ServiceStaffData.Text=serviceStaffData;
      DeliveryStaffData.Text= deliveryStaffData;
      RecievingStaffData.Text=recievingStaffData;
    }  
      
    private void PageFooter_BeforeLayout(object sender, EventArgs e)
    {
      if((Int32)Report.GetVariableValue(&quot;TotalPages&quot;) &lt; 2) 
      { 
        PageFooter.Visible = false; 
      }
      else
      {
        PageNumeration.Width = (Page.PaperWidth-Page.LeftMargin-Page.RightMargin)*Units.Millimeters;
      }
    }
  }    
}
