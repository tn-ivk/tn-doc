        <TableRow Name="Row90" Height="17.95">
          <TableCell Name="Cell555" Border.Lines="All" Text="&lt;i&gt;1.1." Padding="0, 0, 0, 0" HorzAlign="Center" VertAlign="Center" Font="Arial, 8pt" FontWidthRatio="0.9" TextRenderType="HtmlTags"/>
          <TableCell Name="Cell701" Border.Lines="All" Text="Напорный пикнометр" VertAlign="Center" Font="Arial, 8pt, style=Italic" FontWidthRatio="0.9" TextRenderType="HtmlTags" ColSpan="3"/>
