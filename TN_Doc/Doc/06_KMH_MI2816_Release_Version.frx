          <TableCell Name="Cell554" Border.Lines="All" Text="1 Комплект переносной пикнометрической установки" HorzAlign="Center" VertAlign="Center" Font="Arial, 8pt" FontWidthRatio="0.9" TextRenderType="HtmlTags" ColSpan="4"/>
