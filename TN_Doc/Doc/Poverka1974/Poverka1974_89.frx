    TN_ToolsFastReport.Tools tools = new TN_ToolsFastReport.Tools();  
    TN.Doc.Doc doc; 
    TN.DocData.General General;
    TN.Doc.HeaderDoc Header;
    TN.Doc.DataDoc SettingsData;
    TN.Doc.FooterDoc Footer;
    TN.Doc.DictionarysDoc Dictionarys;
    TN.Doc.DataIVKDoc DataIVK;   
    TN.Doc.Protocol Protocol;
    TN.Doc.AdditionalInfo AdditionalInfo;
    
    List&lt;string&gt; listTable1Detectors;
    List&lt;string&gt; listTable1V0;
    List&lt;string&gt; listTeta_Sum0;
    List&lt;string&gt; listTeta_V0;

    Dictionary&lt;string,string&gt; dictTable1SourceData;
      
    List&lt;Table3_SortedPoints&gt; listTable3SortedPoints;
    List&lt;Table3_Subrange&gt; listTable3Subrange;

    private void Page_StartPage(object sender, EventArgs e)
    {
      // Десериализация данных (формат json) из входного параметра - Json                         
      string json = (string)Report.GetParameterValue(&quot;JsonDoc&quot;);
      Newtonsoft.Json.JsonSerializerSettings settings = new Newtonsoft.Json.JsonSerializerSettings();
      settings.TypeNameHandling = TypeNameHandling.All;

      doc = JsonConvert.DeserializeObject&lt;TN.Doc.Doc&gt;(json, settings);
      General = (TN.DocData.General) doc.Doc.Settings.General;
      Header = (TN.Doc.HeaderDoc) doc.Doc.Settings.Header;
      SettingsData = (TN.Doc.DataDoc) doc.Doc.Settings.Data;
      Footer = (TN.Doc.FooterDoc) doc.Doc.Settings.Footer;
      Dictionarys = (TN.Doc.DictionarysDoc) doc.Doc.Settings.Dictionarys;  
      DataIVK = (TN.Doc.DataIVKDoc) doc.Doc.DataIVK;
      Protocol = DataIVK.TablePoverka1974.Protocol;
      AdditionalInfo = DataIVK.TablePoverka1974.AdditionalInfo;
      
      // === Настройки страницы 
      // Ширина и высота (в мм)  
      Page.PaperHeight = General.PageSettings.PaperHeight;
      Page.PaperWidth= General.PageSettings.PaperWidth;
      //Page.Border.Lines = BorderLines.All;
         
      // Поля/отступы от краёв (в мм)
      Page.TopMargin = General.PageSettings.TopMargin;
      Page.BottomMargin = General.PageSettings.BottomMargin;
      Page.LeftMargin = General.PageSettings.LeftMargin;
      Page.RightMargin = General.PageSettings.RightMargin;
      
      // Get data for Table 1 to Dictionary
      dictTable1SourceData = new Dictionary&lt;string,string&gt; ();
         
      foreach (var propertyInfo in DataIVK.TablePoverka1974.Protocol.Table1.GetType().GetProperties())
      {
        var propertyValue = propertyInfo.GetValue(DataIVK.TablePoverka1974.Protocol.Table1);
        if (propertyValue is string)
        {
          dictTable1SourceData.Add(propertyInfo.Name, propertyInfo.GetValue(DataIVK.TablePoverka1974.Protocol.Table1).ToString());
        }
      }
      //listTable3SortedPoints = Protocol.Table3_SortedPoints.Where(i =&gt; !String.IsNullOrEmpty(i.Point) &amp;&amp; !i.Point.Contains(&quot;-&quot;))?.ToList() ?? new List&lt;Table3_SortedPoints&gt;();
      //listTable3Subrange = Protocol.Table3_Subrange.Where(i =&gt; !String.IsNullOrEmpty(i.SubrangeIndx) &amp;&amp; !i.SubrangeIndx.Contains(&quot;-&quot;))?.ToList() ?? new List&lt;Table3_Subrange&gt;();
    
      // Запуск отрисовки таблиц на странице отчета
      DrawTableHeader();    
      DrawTableConclusion();
      
    }
      
    #region //Имхо лишний метод
    private void PrintTable(TableObject table)
    {
      for (int i=0;i&lt;table.RowCount;i++)
      {       
        table.PrintRow(i);
        table.PrintColumns();
      }    
    } 
    #endregion
      
    public void DrawTableHeader()
    {
      //Setup Columns width
      TableHeader01.Columns[0].Width = (Page.PaperWidth-Page.LeftMargin-Page.RightMargin)*Units.Millimeters;
         
      // Fill table with data   
      ProtocolNum.Text = &quot;П Р О Т О К О Л  № &quot; + AdditionalInfo.ProtocolNum;
      PR_Type.Text = AdditionalInfo.PR_Type;
      PR_FactoryNumber.Text = AdditionalInfo.PR_FactoryNumber;
      ViscBegin.Text = tools.GetNormalizedValue(Protocol.ViscBegin);
      ViscEnd.Text = tools.GetNormalizedValue(Protocol.ViscEnd);
      Place_SIKN.Text = $&quot;{AdditionalInfo.Place_SIKN} {AdditionalInfo.Place_PSP}&quot;;
      PU_Type.Text = $&quot;{AdditionalInfo.PU_Type} заводской №{AdditionalInfo.PU_FactoryNumber}&quot;;
      TempAvg.Text = tools.GetNormalizedValue(Protocol.Table3_TotalRange.TempAvg);
    }
              
    private void Table1SourceData_ManualBuild(object sender, EventArgs e)
    { 
      for (int n = 0; n &lt; Table1SourceData.FixedRows; n++)                                                                            
      {                                                                                                                                                                     
        Table1SourceData.PrintRow(n);                                                                                                                
        Table1SourceData.PrintColumns();                                                                                                           
      }
      
      if (Protocol.CfgTables.PUDetNum == 2)
      {
        //ТПУ имеет один калиброванный участок
        ShowSourceDataWithOneRow();
      }
      else if (Protocol.CfgTables.PUDetNum == 4)
      {
        //ТПУ имеет несколько калиброванный участок
        ShowSourceDataWithManyRow();
      }
      // В ином случае оставляем таблицу не заполненной
    }
      
    private void ShowSourceDataWithOneRow()
    {
      var v0 = Protocol.Table1.V0.FirstOrDefault(x =&gt; !string.IsNullOrEmpty(x)) ?? &quot;-&quot;;
      if (Protocol.CfgTables.PUType == 1)
      {
        V12.Text = tools.GetNormalizedValue(v0);
        V21.Text = &quot;-&quot;;
        V0.Text = &quot;-&quot;;
      }
      else
      {
        V12.Text = &quot;-&quot;;
        V21.Text = &quot;-&quot;;
        V0.Text = tools.GetNormalizedValue(v0);
      }
        
      // Заполнение общих параметров
      m_D.Text = tools.GetNormalizedValue(Protocol.Table1.m_D);                               
      m_S.Text = tools.GetNormalizedValue(Protocol.Table1.m_S);                                    
      m_E.Text = tools.GetNormalizedValue(Protocol.Table1.m_E);                                        
      Alpha_t.Text = tools.GetNormalizedValue(Protocol.Table1.Alpha_t);                                    
      Dens.Text = tools.GetNormalizedValue(Protocol.Table1.Dens);                                            
      Beta.Text = tools.GetNormalizedValue(Protocol.Table1.Beta);
      Gamma.Text = tools.GetNormalizedValue(Protocol.Table1.Gamma);
      Teta_Sum0.Text = tools.GetNormalizedValue(Protocol.Table1.Teta_Sum0.FirstOrDefault(x =&gt; !string.IsNullOrEmpty(x)) ?? &quot;-&quot;);
      Teta_t.Text = tools.GetNormalizedValue(Protocol.Table1.Teta_t);
      Teta_V0.Text = tools.GetNormalizedValue(Protocol.Table1.Teta_V0.FirstOrDefault(x =&gt; !string.IsNullOrEmpty(x)) ?? &quot;-&quot;);
      T095.Text = tools.GetNormalizedValue(Protocol.Table1.t095);
        
      // Печатаем одну строку данных
      Table1SourceData.PrintRow(3);     
      Table1SourceData.PrintColumns();
    }
    
    private void ShowSourceDataWithManyRow()
    {
      Table1FirstColTitle.Text = &quot;Детек-&lt;br&gt;торы&quot;;
      Table1SourceData.Columns[1].Visible = false;
      
      listTable1Detectors = Protocol.Table1.DetName.Where(i =&gt; !string.IsNullOrEmpty(i) &amp;&amp; !i.Contains(&quot;-&quot;)).ToList();
      listTable1V0 = Protocol.Table1.V0.Where(i =&gt; !string.IsNullOrEmpty(i) &amp;&amp; !i.Contains(&quot;-&quot;)).ToList();
      listTeta_Sum0 = Protocol.Table1.Teta_Sum0.Where(i =&gt; !string.IsNullOrEmpty(i) &amp;&amp; !i.Contains(&quot;-&quot;)).ToList();
      listTeta_V0 = Protocol.Table1.Teta_V0.Where(i =&gt; !string.IsNullOrEmpty(i) &amp;&amp; !i.Contains(&quot;-&quot;)).ToList();
        
      // Заполнение таблицы для каждого детектора
      for (int n = 0; n &lt; listTable1Detectors.Count; n++)                                                                     
      {                                                                                                                                                    
        V12.Text = listTable1Detectors[n];                                                                                       
        V0.Text = tools.GetNormalizedValue(listTable1V0[n]);
        m_D.Text = tools.GetNormalizedValue(Protocol.Table1.m_D);                               
        m_S.Text = tools.GetNormalizedValue(Protocol.Table1.m_S);                                    
        m_E.Text = tools.GetNormalizedValue(Protocol.Table1.m_E);                                        
        Alpha_t.Text = tools.GetNormalizedValue(Protocol.Table1.Alpha_t);                                    
        Dens.Text = tools.GetNormalizedValue(Protocol.Table1.Dens);                                            
        Beta.Text = tools.GetNormalizedValue(Protocol.Table1.Beta);
        Gamma.Text = tools.GetNormalizedValue(Protocol.Table1.Gamma);  
        Teta_Sum0.Text = (n &lt; listTeta_Sum0.Count) ? tools.GetNormalizedValue(listTeta_Sum0[n]) : &quot;-&quot;;    
        Teta_t.Text = tools.GetNormalizedValue(Protocol.Table1.Teta_t);
        Teta_V0.Text = (n &lt; listTeta_V0.Count) ? tools.GetNormalizedValue(listTeta_V0[n]) : &quot;-&quot;;
        T095.Text = tools.GetNormalizedValue(Protocol.Table1.t095);
          
        // RowSpans для общих параметров                                                                                                              
        for (int i = 0; i &lt; Table1SourceData.ColumnCount; i++)                                                              
        {                                                                                                                                                            
          switch(i)                                                                                                                                                  
          {                                                                                                                                                                
            case 2:  // m_D
            case 3:  // m_S                                                                                                           
            case 4:  // m_E                                                                                                                  
            case 5:  // Alpha_t
            case 8:  // Beta
            case 9:  // Gamma 
            case 10: // (другое общее поле)
            case 11: // (другое общее поле)
            case 12: // (другое общее поле)
            case 13: // T095
              Table1SourceData[i,4].RowSpan = listTable1Detectors.Count;
            break;  
          }
        }
              
        Table1SourceData.PrintRow(4);     
        Table1SourceData.PrintColumns();  
      }
    }
    
    private void Table2Results_ManualBuild(object sender, EventArgs e)
    {
      //Setup Columns width
      //int sumDynamicCols=Table2Results.ColumnCount;
      //float widthDynamicCol=(Page.PaperWidth-Page.LeftMargin-Page.RightMargin)/sumDynamicCols;                  
      //for (int w = 0; w &lt; (Table2Results.ColumnCount); w++)                 
      //{
      //  Table2Results.Columns[w].Width = widthDynamicCol * Units.Millimeters;
      //}      
         
      //Draw Fixed rows
      for (int n = 0; n &lt; Table2Results.FixedRows; n++)
      {
        Table2Results.PrintRow(n);
        Table2Results.PrintColumns();                                             
      }
          
      var listTable2 = Protocol.Table2.Where(i =&gt; i.Activated == 1)?.ToList() ?? new List&lt;Table2&gt;();
      if(!listTable2.Any())
        return;
      var dicTable2 = listTable2.GroupBy(x =&gt; x.Ser).ToDictionary(g =&gt; g.Key, g =&gt; g.ToList());
      var listTable2Series = Protocol.Table2_Series.Where(i =&gt; !string.IsNullOrEmpty(i.Ser))?.ToList() ?? new List&lt;Table2_Series&gt;();
      
      foreach (var seriesGroup in dicTable2)
      {
        var seriesKey = seriesGroup.Key;
        var seriesData = seriesGroup.Value;
        PrintTable2NumRow();
        foreach (var measurement in seriesData)  
          PrintTable2PointRow(measurement);
        var seriesSummary = listTable2Series.FirstOrDefault(s =&gt; s.Ser == seriesKey) ?? new Table2_Series();
        PrintTable2SeriesSummeryRow(seriesSummary);
      }
    }

    private void PrintTable2NumRow()
    {
      for (int col = 0; col &lt; Table2Results.ColumnCount; col++)
      {
        Table2Results[col, 4].Text = (col + 1).ToString();
        Table2Results[col, 4].ColSpan = 1;
        Table2Results[col, 4].Border.Lines = BorderLines.All;
      }  

      Table2Results.PrintRow(4);     
      Table2Results.PrintColumns();
    }
    
    private void PrintTable2PointRow(Table2 row)
    {
      Q_ji.Text = tools.GetNormalizedValue(row.Q_ji);
      SerRow.Text =  String.Format(&quot;{0}/{1}&quot;, row.Ser, row.Row);
      Det.Text =  tools.GetNormalizedValue(row.Det);
      t_PU_ji.Text = tools.GetNormalizedValue(row.t_PU_ji);
      P_PU_ji.Text = tools.GetNormalizedValue(row.P_PU_ji);                          
      t_PR_ji.Text = tools.GetNormalizedValue(row.t_PR_ji);
      P_PR_ji.Text = tools.GetNormalizedValue(row.P_PR_ji);
      N_ji.Text = tools.GetNormalizedValue(row.N_ji);
      Delta_ji.Text = tools.GetNormalizedValue(row.Delta_ji);
      K_ji.Text = tools.GetNormalizedValue(row.K_ji);
      
      Table2Results.PrintRow(4);     
      Table2Results.PrintColumns();  
    }
    
    private void PrintTable2SeriesSummeryRow(Table2_Series row)
    {
      
      Q_ji.Text = $&quot;t&lt;sub&gt;y&lt;/sub&gt; = {tools.GetNormalizedValue(row.t_PU_j)}\t\t&quot; +
                  $&quot;P&lt;sub&gt;y&lt;/sub&gt; = {tools.GetNormalizedValue(row.P_PU_j)}\t&quot; +
                  $&quot;t&lt;sub&gt;пр&lt;/sub&gt; = {tools.GetNormalizedValue(row.t_PR_j)}\t\t&quot; +
                  $&quot;P&lt;sub&gt;пр&lt;/sub&gt; = {tools.GetNormalizedValue(row.P_PR_j)}\t&quot; +
                  $&quot;N&lt;sub&gt;m&lt;/sub&gt; = {tools.GetNormalizedValue(row.N_j)} \t&quot; +
                  $&quot;K&lt;sub&gt;tp{row.Ser}&lt;/sub&gt; = {tools.GetNormalizedValue(row.Delta_j)}&quot;;
      Q_ji.ColSpan = Table2Results.ColumnCount;
      Q_ji.Height = 2;
      Q_ji.Border.Lines = BorderLines.None;
      
      Table2Results.PrintRow(4);     
      Table2Results.PrintColumns();
    }
    
