  public class ReportScript
  {
    TN_ToolsFastReport.Tools tools = new TN_ToolsFastReport.Tools();  // классы отчета    
    TN.Doc.Doc doc; // данные из входного параметра
    TN.DocData.General General;
    TN.Doc.HeaderDoc Header;
    TN.Doc.DataDoc SettingsData;
    TN.Doc.FooterDoc Footer;
    TN.Doc.DictionarysDoc Dictionarys;
    TN.Doc.DataIVKDoc DataIVK;   
      
    List &lt;string&gt; listTable1Detectors;
    List &lt;string&gt; listTable1V0;
    List &lt;string&gt; listTeta_Sum0;
    List &lt;string&gt; listTeta_V0;

    Dictionary&lt;string,string&gt; dictTable1SourceData;
      
    List &lt;TN.Doc.Table2&gt; listTable2Results;
    List &lt;TN.Doc.Table3&gt; listTable3Results;
    List &lt;TN.Doc.Table4&gt; listTable4Results;

    private void Page_StartPage(object sender, EventArgs e)
    {
      // Десериализация данных (формат json) из входного параметра - Json                         
      string json = (string)Report.GetParameterValue(&quot;JsonDoc&quot;);
      Newtonsoft.Json.JsonSerializerSettings settings = new Newtonsoft.Json.JsonSerializerSettings();
      settings.TypeNameHandling = TypeNameHandling.All;

      doc = JsonConvert.DeserializeObject&lt;TN.Doc.Doc&gt;(json, settings);
      General = (TN.DocData.General) doc.Doc.Settings.General;
      Header = (TN.Doc.HeaderDoc) doc.Doc.Settings.Header;
      SettingsData = (TN.Doc.DataDoc) doc.Doc.Settings.Data;
      Footer = (TN.Doc.FooterDoc) doc.Doc.Settings.Footer;
      Dictionarys = (TN.Doc.DictionarysDoc) doc.Doc.Settings.Dictionarys;  
      DataIVK = (TN.Doc.DataIVKDoc) doc.Doc.DataIVK;
      
      //// === Настройки страницы 
      // Ширина и высота (в мм)
         
      Page.PaperHeight = General.PageSettings.PaperHeight;
      Page.PaperWidth= General.PageSettings.PaperWidth;
      //Page.Border.Lines = BorderLines.All;
         
      // Поля/отступы от краёв (в мм)
      Page.TopMargin = General.PageSettings.TopMargin;
      Page.BottomMargin = General.PageSettings.BottomMargin;
      Page.LeftMargin = General.PageSettings.LeftMargin;
      Page.RightMargin = General.PageSettings.RightMargin;
                                                                
      //// ==== Get Data from classes
      listTable1Detectors = DataIVK.TablePoverka1974.Protokol.Table1.DetName.Where(i =&gt; i.Length &gt; 1 | ! i.Contains(&quot;&quot;)).ToList();
      listTable1V0 = DataIVK.TablePoverka1974.Protokol.Table1.V0.Where(i =&gt; ! i.Contains(&quot;-&quot;) | ! i.Contains(&quot;&quot;)).ToList();
      listTeta_Sum0 = DataIVK.TablePoverka1974.Protokol.Table1.Teta_Sum0.Where(i =&gt; ! i.Contains(&quot;-&quot;) | ! i.Contains(&quot;&quot;)).ToList();
      listTeta_V0 = DataIVK.TablePoverka1974.Protokol.Table1.Teta_V0.Where(i =&gt; ! i.Contains(&quot;-&quot;) | ! i.Contains(&quot;&quot;)).ToList();
         
      // Get data for Table 1 to Dictionary
      dictTable1SourceData = new Dictionary&lt;string,string&gt; ();
         
      //TODO dictTable1SourceData = typeof(TN_DocPover_MI3189.Table1).GetProperties().Where(x =&gt;! x.Name.Contains(&quot;DetName&quot;)) &amp; (z =&gt;! z.Name.Contains(&quot;V0&quot;)).ToDictionary(x =&gt; x.Name, x =&gt; x.GetValue(protocol.Doc.DataIVK.TablePoverka3189.Protokol.Table1));
      foreach (var propertyInfo in DataIVK.TablePoverka1974.Protokol.Table1.GetType().GetProperties())
      {
        var propertyValue = propertyInfo.GetValue(DataIVK.TablePoverka1974.Protokol.Table1);
        if (propertyValue is string)
        {
          dictTable1SourceData.Add(propertyInfo.Name, propertyInfo.GetValue(DataIVK.TablePoverka1974.Protokol.Table1).ToString());
        }
      }
      listTable2Results = DataIVK.TablePoverka1974.Protokol.Table2.Where(i =&gt; i.Activated==1).ToList();
      listTable3Results = DataIVK.TablePoverka1974.Protokol.Table3.Where(i =&gt; ! i.Point.Contains(&quot;-&quot;)  &amp; String.IsNullOrEmpty(i.Point) == false).ToList();
      listTable4Results = DataIVK.TablePoverka1974.Protokol.Table4.Where(i =&gt; ! i.Point.Contains(&quot;-&quot;)  &amp; String.IsNullOrEmpty(i.Point) == false).ToList();
    
      // Запуск отрисовки таблиц на странице отчета
      DrawTableHeader();    
      DrawTableConclusion();
    }
    #region //Имхо лишний метод
    private void PrintTable(TableObject table)
    {
      for (int i=0;i&lt;table.RowCount;i++)
      {       
        table.PrintRow(i);
        table.PrintColumns();
      }    
    } 
    #endregion
      
    public void DrawTableHeader()
    {
      //Setup Columns width
      TableHeader01.Columns[0].Width = (Page.PaperWidth-Page.LeftMargin-Page.RightMargin)*Units.Millimeters;
         
      // Fill table with data   
      ProtokolNum.Text = &quot;П Р О Т О К О Л  № &quot; + DataIVK.TablePoverka1974.AdditionalInfo.ProtokolNum;
      Place_SIKN.Text = DataIVK.TablePoverka1974.AdditionalInfo.Place_SIKN;
      Place_PSP.Text = DataIVK.TablePoverka1974.AdditionalInfo.Place_PSP;
      PR_Type.Text = DataIVK.TablePoverka1974.AdditionalInfo.PR_Type;
      PR_FactoryNumber.Text = DataIVK.TablePoverka1974.AdditionalInfo.PR_FactoryNumber;
      PR_LineName.Text = DataIVK.TablePoverka1974.AdditionalInfo.PR_LineName;
      Place_FactoryPR.Text = DataIVK.TablePoverka1974.AdditionalInfo.Place_Factory;
      PU_Type.Text = DataIVK.TablePoverka1974.AdditionalInfo.PU_Type;
      PU_Category.Text = DataIVK.TablePoverka1974.AdditionalInfo.PU_Category;
      PU_FactoryNumber.Text = DataIVK.TablePoverka1974.AdditionalInfo.PU_FactoryNumber;
      Place_FactoryPU.Text = DataIVK.TablePoverka1974.AdditionalInfo.Place_Factory; 
      OilType.Text = DataIVK.TablePoverka1974.AdditionalInfo.OilType;
      ViscMin.Text = DataIVK.TablePoverka1974.Protokol.ViscMin;
      ViscMax.Text = DataIVK.TablePoverka1974.Protokol.ViscMax;
      Water.Text = &quot;-&quot;;     
    }
              
    private void Table1SourceData_ManualBuild(object sender, EventArgs e)
    {                                                                                                                          
      //Setup Columns width                                                                                           
      //int sumDynamicCols=Table1SourceData.ColumnCount;                                                                                                                                
      //float widthDynamicCol=(Page.PaperWidth-Page.LeftMargin-Page.RightMargin)/sumDynamicCols;                                                       
      //for (int w = 0; w &lt; (Table1SourceData.ColumnCount); w++)                                                                                                                                     
      //{                                                                                                                                                                                                                                           
      //  Table1SourceData.Columns[w].Width = widthDynamicCol * Units.Millimeters;                                                                                                     
      //}      
                                                                                                               
      //Draw Fixed rows                                                                               
      for (int n = 0; n &lt; Table1SourceData.FixedRows; n++)                                                                            
      {                                                                                                                                                                     
        Table1SourceData.PrintRow(n);                                                                                                                
        Table1SourceData.PrintColumns();                                                                                                           
      }
                                                                                                                                                                                        
      //Fill table with data                                                                                                                                              
      for (int n = 0; n &lt; (listTable1Detectors.Count); n++)                                                                     
      {                                                                                                                                                    
        DetName.Text =  listTable1Detectors[n];                                                                                       
        V0.Text =  tools.GetNormalizedValue(listTable1V0[n]);                                                                        
        //TODO change to dictionary from class property value (see code below)                                                                 
        m_D.Text = tools.GetNormalizedValue(DataIVK.TablePoverka1974.Protokol.Table1.m_D);                               
        m_S.Text = tools.GetNormalizedValue(DataIVK.TablePoverka1974.Protokol.Table1.m_S);                                    
        m_E.Text = tools.GetNormalizedValue(DataIVK.TablePoverka1974.Protokol.Table1.m_E);                                        
        Alpha_t.Text = tools.GetNormalizedValue(DataIVK.TablePoverka1974.Protokol.Table1.Alpha_t);                                    
        Teta_Sum0.Text = tools.GetNormalizedValue(listTeta_Sum0[n]);                                                                                                                
        Teta_V0.Text = tools.GetNormalizedValue(listTeta_V0[n]);  
        Delta_t_PU.Text = tools.GetNormalizedValue(DataIVK.TablePoverka1974.Protokol.Table1.Delta_t_PU);                                    
        t_kernel.Text = tools.GetNormalizedValue(DataIVK.TablePoverka1974.Protokol.Table1.t_kernel);                                    
        Delta_k_soi.Text = tools.GetNormalizedValue(DataIVK.TablePoverka1974.Protokol.Table1.Delta_k_soi);                                    
        Delta_t_PR.Text = tools.GetNormalizedValue(DataIVK.TablePoverka1974.Protokol.Table1.Delta_t_PR);                                    
        Dens.Text = tools.GetNormalizedValue(DataIVK.TablePoverka1974.Protokol.Table1.Dens);                                    
        Dens_temp.Text = tools.GetNormalizedValue(DataIVK.TablePoverka1974.Protokol.Table1.Dens_temp);                                    

        //RowSpans                                                                                                              
        for (int i = 0; i &lt; (Table1SourceData.ColumnCount); i++)                                                              
        {                                                                                                                                                            
          switch(i)                                                                                                                                                  
          {                                                                                                                                                                
            case 2:                                                                                                                                                       
            case 3:                                                                                                           
            case 4:                                                                                                                  
            case 5:  
            case 8:  
            case 9:  
            case 10:  
            case 11:  
            case 12:  
            case 13:  
              Table1SourceData[i,4].RowSpan =  listTable1Detectors.Count;
              break;  
          }
        }
            
        Table1SourceData.PrintRow(4);     
        Table1SourceData.PrintColumns();  
      }         
      // MessageBox.Show(&quot;Here&quot;);

    }
      
    private void Table2Results_ManualBuild(object sender, EventArgs e)
    {           
      //Setup Columns width
      int sumDynamicCols=Table2Results.ColumnCount;
      float widthDynamicCol=(Page.PaperWidth-Page.LeftMargin-Page.RightMargin)/sumDynamicCols;                  
      for (int w = 0; w &lt; (Table2Results.ColumnCount); w++)                 
      {
        Table2Results.Columns[w].Width = widthDynamicCol * Units.Millimeters;
      }      
         
      //Draw Fixed rows
      for (int n = 0; n &lt; Table2Results.FixedRows; n++)
      {
        Table2Results.PrintRow(n);
        Table2Results.PrintColumns();                                             
      }
                      
      //Fill table with data
      for (int n = 0; n &lt; (listTable2Results.Count); n++)
      {
        Ser2_1.Text =  String.Format(&quot;{0}/{1}&quot;, listTable2Results[n].Ser, listTable2Results[n].Row);
        Q_ji.Text = tools.GetNormalizedValue(listTable2Results[n].Q_ji);
        Det.Text =  tools.GetNormalizedValue(listTable2Results[n].Det);
        T_ji.Text = tools.GetNormalizedValue(listTable2Results[n].T_ji);
        t_PU_ji.Text = tools.GetNormalizedValue(listTable2Results[n].t_PU_ji);
        P_PU_ji.Text = tools.GetNormalizedValue(listTable2Results[n].P_PU_ji);                          
        V_ji.Text = tools.GetNormalizedValue(listTable2Results[n].V_ji);
        f_ji.Text = tools.GetNormalizedValue(listTable2Results[n].f_ji);
        t_PR_ji.Text = tools.GetNormalizedValue(listTable2Results[n].t_PR_ji);
        P_PR_ji.Text = tools.GetNormalizedValue(listTable2Results[n].P_PR_ji);
        N_ji.Text = tools.GetNormalizedValue(listTable2Results[n].N_ji);
        K_ji.Text = tools.GetNormalizedValue(listTable2Results[n].K_ji);

            
        Table2Results.PrintRow(4);     
        Table2Results.PrintColumns();  
      }
    }

    private void Table2ResultsEnding_ManualBuild(object sender, EventArgs e)
    {
     
      //Setup Columns widths as previous table
         
      for (int i = 0; i &lt; (Table2ResultsEnding.ColumnCount-1); i++)
      {          
        Table2ResultsEnding.Columns[i].Width =  Table2Results.Columns[i].Width;
      }
         
         
      //Draw Fixed rows
      for (int n = 0; n &lt; Table2ResultsEnding.FixedRows; n++)
      {
        Table2ResultsEnding.PrintRow(n);
        Table2ResultsEnding.PrintColumns();                                             
      }
              
      //Fill table with data
      for (int n = 0; n &lt; (listTable2Results.Count); n++)
      {
        Ser2_2.Text =  String.Format(&quot;{0}/{1}&quot;, listTable2Results[n].Ser, listTable2Results[n].Row);
        Dens_ji.Text = tools.GetNormalizedValue(listTable2Results[n].Dens_ji);
        DensTemp_ji.Text =  tools.GetNormalizedValue(listTable2Results[n].DensTemp_ji);                                                                     
        KinVisc_ji.Text =  tools.GetNormalizedValue(listTable2Results[n].KinVisc_ji);
  
        Table2ResultsEnding.PrintRow(4);     
        Table2ResultsEnding.PrintColumns();  
      }
              
    }
      
    private void Table3Results_ManualBuild(object sender, EventArgs e)
    {
      //Setup Columns width
      int sumDynamicCols=Table3Results.ColumnCount;
      float widthDynamicCol=(Page.PaperWidth-Page.LeftMargin-Page.RightMargin)/sumDynamicCols;                  
      for (int w = 0; w &lt; (Table3Results.ColumnCount); w++)                 
      {
        Table3Results.Columns[w].Width = widthDynamicCol * Units.Millimeters;
      }      
         
      //Draw Fixed rows 
      for (int n = 0; n &lt; Table3Results.FixedRows; n++)
      {
        Table3Results.PrintRow(n);
        Table3Results.PrintColumns();                                             
      }
             
      //Fill table with data
      for (int n = 0; n &lt; (listTable3Results.Count); n++)
      {
        Point3.Text =  listTable3Results[n].Point;
        Q_j.Text = tools.GetNormalizedValue(listTable3Results[n].Q_j);
        f_j.Text = tools.GetNormalizedValue(listTable3Results[n].f_j);
        K_j.Text = tools.GetNormalizedValue(listTable3Results[n].K_j);
        S_j.Text =tools.GetNormalizedValue( listTable3Results[n].S_j);
        e_j.Text =tools.GetNormalizedValue( listTable3Results[n].e_j);
        Teta_Sum_j.Text =tools.GetNormalizedValue( listTable3Results[n].Teta_Sum_j);
        Delta_j.Text =tools.GetNormalizedValue( listTable3Results[n].Delta_j);            

        Table3Results.PrintRow(3);     
        Table3Results.PrintColumns();  
      }
         
    }

    private void DataBandTable3Results_BeforePrint(object sender, EventArgs e)
    {
      var rowHeight = 15.12f; // Высота строки данных
      var fixedRowsHeight = Table3Results.FixedRows * rowHeight;
      var remainingSpace = Engine.FreeSpace;
      // Проверяем, достаточно ли места хотя бы для фиксированных строк (хедера)
      if (remainingSpace &lt; fixedRowsHeight)
      {
        Engine.StartNewPage(); // Если хедер не помещается, начинаем новую страницу
      }
    }
    
    private void Table4Results_ManualBuild(object sender, EventArgs e)
    {     
      //Setup Columns width
      int sumDynamicCols=Table4Results.ColumnCount;
      float widthDynamicCol=(Page.PaperWidth-Page.LeftMargin-Page.RightMargin)/sumDynamicCols;                  
      for (int w = 0; w &lt; (Table4Results.ColumnCount); w++)                 
      {
        Table4Results.Columns[w].Width = widthDynamicCol * Units.Millimeters;
      }      
         
      //Draw Fixed rows
      for (int n = 0; n &lt; Table4Results.FixedRows; n++)
      {
        Table4Results.PrintRow(n);
        Table4Results.PrintColumns();                                             
      }           

      //Fill table with data            
      for (int n = 0; n &lt; (listTable4Results.Count); n++)
      {
            
        Point4.Text =  listTable4Results[n].Point;
        Q_min4.Text =  tools.GetNormalizedValue(listTable4Results[n].Q_min);                                                                
        Q_max4.Text =  tools.GetNormalizedValue(listTable4Results[n].Q_max);                                                                
        e4.Text =  tools.GetNormalizedValue(listTable4Results[n].e);                                                                
        Teta_A4.Text =  tools.GetNormalizedValue(listTable4Results[n].Teta_A);                                                                
        Teta_Sum4.Text =  tools.GetNormalizedValue(listTable4Results[n].Teta_Sum);                                                                
        Delta4.Text =  tools.GetNormalizedValue(listTable4Results[n].Delta);                                                                
        K4.Text =  tools.GetNormalizedValue(listTable4Results[n].K);                                                                
            
        Table4Results.PrintRow(3);                                                                                                                                                                                  
        Table4Results.PrintColumns();       
      }
         
    }
      
    private void Table5Results_ManualBuild(object sender, EventArgs e)
    {
      
      if (DataIVK.TablePoverka1974.Protokol.CfgTables.GHType==1)
      
      {
        int sumDynamicCols=Table5Results.ColumnCount;
        float widthDynamicCol=(Page.PaperWidth-Page.LeftMargin-Page.RightMargin)/sumDynamicCols;                  
        for (int w = 0; w &lt; (Table5Results.ColumnCount); w++)                 
        {
          Table5Results.Columns[w].Width = widthDynamicCol * Units.Millimeters;
        }      
         
        //Draw Fixed rows
        for (int n = 0; n &lt; Table5Results.FixedRows; n++)
        {
          Table5Results.PrintRow(n);
          Table5Results.PrintColumns();                                             
        }
         
        Q_min5.Text =  tools.GetNormalizedValue(DataIVK.TablePoverka1974.Protokol.Table5.Q_min);        
        Q_max5.Text =  tools.GetNormalizedValue(DataIVK.TablePoverka1974.Protokol.Table5.Q_max);        
        e5.Text =  tools.GetNormalizedValue(DataIVK.TablePoverka1974.Protokol.Table5.e);        
        Theta_A5.Text =  tools.GetNormalizedValue(DataIVK.TablePoverka1974.Protokol.Table5.Theta_A);        
        Theta_Sum5.Text =  tools.GetNormalizedValue(DataIVK.TablePoverka1974.Protokol.Table5.Theta_Sum);        
        Delta5.Text =  tools.GetNormalizedValue(DataIVK.TablePoverka1974.Protokol.Table5.Delta);        
        K5.Text =  tools.GetNormalizedValue(DataIVK.TablePoverka1974.Protokol.Table5.K);        
         
        Table5Results.PrintRow(3);                                                                                                                                                                                  
        Table5Results.PrintColumns();      
      }    
    }

    private void Table6ApproximationEquations_ManualBuild(object sender, EventArgs e)
    { 
      if (DataIVK.TablePoverka1974.Protokol.CfgTables.Parabola!=0)
      {
        List &lt;TN.Doc.Parabola&gt; listParabolaTable6;      
        listParabolaTable6 = DataIVK.TablePoverka1974.Protokol.Parabola.Where(i =&gt; ! i.fv_begin.Contains(&quot;-&quot;)  &amp; String.IsNullOrEmpty(i.fv_begin) == false).ToList();

        //Drawing Fixed rows
        for (int n = 0; n &lt; Table6ApproximationEquations.FixedRows; n++)                                                            
        {                                                                                                                    
          Table6ApproximationEquations.PrintRow(n);
          Table6ApproximationEquations.PrintColumns();                                             
        }
            
        //Filling table with data for subranges                                                                            
        for (int n = 0; n &lt; (listParabolaTable6.Count); n++)                                                 
        {                                                                                                                            
          fv_begin.Text =  tools.GetNormalizedValue(listParabolaTable6[n].fv_begin);      
          fv_end.Text =  tools.GetNormalizedValue(listParabolaTable6[n].fv_end);      
          A.Text =  tools.GetNormalizedValue(listParabolaTable6[n].A);      
          B.Text =  tools.GetNormalizedValue(listParabolaTable6[n].B);      
          C.Text =  tools.GetNormalizedValue(listParabolaTable6[n].C);      
          Delta6.Text =  tools.GetNormalizedValue(listParabolaTable6[n].Delta);      
               
          Table6ApproximationEquations.PrintRow(4);                                                     
          Table6ApproximationEquations.PrintColumns();                                                
        }       
      }
    }

    public void  DrawTableConclusion()
    {                                                    
      // Setup Cols width    
      TableConclusion3.Columns[0].Width=(Page.PaperWidth-Page.LeftMargin-Page.RightMargin)  * Units.Millimeters;
         
      // Fill Table with data
      ARM_Poverka_Result.Text = DataIVK.TablePoverka1974.AdditionalInfo.ARM_Poverka_Result;
      StaffData.Text = DataIVK.TablePoverka1974.AdditionalInfo.StaffData;
      DateTimeLong.Text = string.Format(&quot;Дата поверки: &lt;u&gt;{0:dd.MM.yyyy} г.&quot;,(tools.UnixTimestampToDatetime(DataIVK.TablePoverka1974.DateTimeLong)));               
      PageNumeration.Width = (Page.PaperWidth-Page.LeftMargin-Page.RightMargin)*Units.Millimeters; 
    }  
      
    //// Setup heights of the all objects on the Page
    private void PageFooter_BeforeLayout(object sender, EventArgs e)
    {
      if((Int32)Report.GetVariableValue(&quot;TotalPages&quot;) &lt; 2) 
      { 
        PageFooter.Visible = false; 
      }
      else
      {
        PageNumeration.Width = (Page.PaperWidth-Page.LeftMargin-Page.RightMargin)*Units.Millimeters;
      }
    }
  }    
}

