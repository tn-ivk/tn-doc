using TN.DocData;

namespace FastReport
{
  public class ReportScript
  {
    TN_ToolsFastReport.Tools tools = new TN_ToolsFastReport.Tools();  // классы отчета
    TN.Doc.Doc doc; // данные из входного параметра
    TN.DocData.General General;
    TN.Doc.HeaderDoc Header;
    TN.Doc.DataDoc SettingsData;
    TN.Doc.FooterDoc Footer;
    TN.Doc.DictionarysDoc Dictionarys;   
    TN.Doc.DataIVKDoc DataIVK;

    string oilName;
      
    private void Page_StartPage(object sender, EventArgs e)
    {
      //using (var sr = new StreamReader(&quot;D:/!_Work/!_Транснефть/SVN/Work/Sources/Reports/FRX/Входящие данные от Алексея (классы и json)/23_TableKMH_MPR_PU/DocKMH_MPR_PU.json&quot;))
      //{
      // Read the stream as a string
      //   Report.SetParameterValue(&quot;JsonDoc&quot;, sr.ReadToEnd());
      //}
      //// Десериализация данных (формат json) из входного параметра - Json                         
      string json = (string)Report.GetParameterValue(&quot;JsonDoc&quot;);
      Newtonsoft.Json.JsonSerializerSettings settings = new Newtonsoft.Json.JsonSerializerSettings();
      settings.TypeNameHandling = TypeNameHandling.All;
         
      doc = JsonConvert.DeserializeObject&lt;TN.Doc.Doc&gt;(json, settings);
      General = (TN.DocData.General) doc.Doc.Settings.General;
      Header = (TN.Doc.HeaderDoc) doc.Doc.Settings.Header;
      SettingsData = (TN.Doc.DataDoc) doc.Doc.Settings.Data;
      Footer = (TN.Doc.FooterDoc) doc.Doc.Settings.Footer;
      Dictionarys = (TN.Doc.DictionarysDoc) doc.Doc.Settings.Dictionarys;  
      DataIVK = (TN.Doc.DataIVKDoc) doc.Doc.DataIVK;
         
      //// === Настройки страницы 
      // Ширина и высота (в мм)
         
      Page.PaperHeight = General.PageSettings.PaperHeight;
      Page.PaperWidth = General.PageSettings.PaperWidth;
      //Page.Border.Lines = BorderLines.All;
         
      // Поля/отступы от краёв (в мм)
      Page.TopMargin = General.PageSettings.TopMargin;
      Page.BottomMargin = General.PageSettings.BottomMargin;
      Page.LeftMargin = General.PageSettings.LeftMargin;
      Page.RightMargin = General.PageSettings.RightMargin;
         
      // Запуск отрисовки таблиц на странице отчета
      DrawTableHeader();
      DrawTableConclusion();
    }
      
    public void DrawTableHeader()
    {
      oilName = General.NefType == 1 ? &quot;Вязкость нефти при КМХ, сСт:&quot; : &quot;Вязкость нефтепродукта при КМХ, сСт:&quot;;
      
      // Setup Columns
      float widthDynamicCols=(Page.PaperWidth-Page.LeftMargin-Page.RightMargin)/TableHeader.ColumnCount;         
      for (int i = 0; i &lt; (TableHeader.ColumnCount); i++)                 
      {
        TableHeader.Columns[i].Width = widthDynamicCols*Units.Millimeters;
      }
      // Fill table with data   
      ProtocolType.Text = string.Format(&quot;Протокол № {0}&lt;br&gt;КMX рабочего массового ПР&amp;nbsp;по поверочной установке&quot;,
        DataIVK.TableKMH_MPR_PU.AdditionalInfo.ProtokolNum);
         
      MPR_Type.Text= string.Format(&quot;Тип МПР: &lt;u&gt;{0}&lt;/u&gt; Зав. №:&lt;u&gt;{1}&lt;/u&gt; &lt;br&gt;&lt;br&gt;Место проведения КМХ: &lt;u&gt;{2} &lt;/u&gt; (СИКН, НГДУ, ПСП) Линия №:&lt;u&gt; {3}&quot;, 
        DataIVK.TableKMH_MPR_PU.AdditionalInfo.PR_Type, 
        DataIVK.TableKMH_MPR_PU.AdditionalInfo.PR_FactoryNumber,
        DataIVK.TableKMH_MPR_PU.AdditionalInfo.SIKN, 
        DataIVK.TableKMH_MPR_PU.IL); 
         
      MPR_CTRL_Type.Text = string.Format(&quot;Тип ПУ: &lt;u&gt;{0}&lt;/u&gt; Зав. №: &lt;u&gt;{1}&lt;/u&gt;&lt;br&gt;Дата поверки ПУ: &lt;u&gt;{2}&lt;/u&gt;&lt;br&gt;{4} &lt;u&gt; {3}&quot;,
        DataIVK.TableKMH_MPR_PU.AdditionalInfo.PU_Type,
        DataIVK.TableKMH_MPR_PU.AdditionalInfo.PU_FactoryNumber,
        DataIVK.TableKMH_MPR_PU.AdditionalInfo.PU_CheckDate,
        tools.GetNormalizedValue(DataIVK.TableKMH_MPR_PU.Protokol.Visc),
        oilName);                      
    }

    private void Table1SourceData_ManualBuild(object sender, EventArgs e)
    {
      //// ==== Get Data from classes
      List &lt;string&gt; listTable1Detectors=
        DataIVK.TableKMH_MPR_PU.Protokol.Table1.DetName.Where
      (i =&gt; i.Length &gt; 1 &amp; String.IsNullOrEmpty(i) == false).ToList();
         
      List &lt;string&gt; listTable1V0=
        DataIVK.TableKMH_MPR_PU.Protokol.Table1.V0.Where
      (i =&gt; ! i.Contains(&quot;-&quot;)  &amp; String.IsNullOrEmpty(i) == false).ToList();
         
      //Setup Columns width                                                                                           
      //int sumDynamicCols=Table1SourceData.ColumnCount;                                                                                                                                
      //float widthDynamicCol=(Page.PaperWidth-Page.LeftMargin-Page.RightMargin)/sumDynamicCols;                                                       
        
      //for (int w = 0; w &lt; (Table1SourceData.ColumnCount); w++)                                                                                                                                     
      //{                                                                                                                                                                                                                                           
      //  Table1SourceData.Columns[w].Width = widthDynamicCol * Units.Millimeters;                                                                                                     
      //}  
      
      switch ((int)Page.PaperWidth)
      {
        case 297: 
          DetectorsDescription.Text=&quot;Детекторы&quot;;
          SerDescription.Text = &quot;Номер&lt;br&gt;поддиапазона&quot;;
          RowDescription.Text = &quot;Номер&lt;br&gt;измерения&quot;;
          break;
        default:                                                     
          DetectorsDescription.Text=&quot;Детекто-&lt;br&gt;ры&quot;;
          SerDescription.Text = &quot;Номер&lt;br&gt;поддиа-&lt;br&gt;пазона&quot;;
          RowDescription.Text = &quot;Номер&lt;br&gt;измере-&lt;br&gt;ния&quot;;
          break;
      } 
         
      //Draw Fixed rows
      for (int n = 0; n &lt; Table1SourceData.FixedRows; n++)
      {
        Table1SourceData.PrintRow(n);
        Table1SourceData.PrintColumns();                                             
      }
         
      //Fill table with data
      for (int n = 0; n &lt; (listTable1Detectors.Count); n++)
      {
        DetName.Text =  listTable1Detectors[n];
        V0.Text =  tools.GetNormalizedValue(listTable1V0[n]);        
        Delta_PU.Text = tools.GetNormalizedValue(DataIVK.TableKMH_MPR_PU.Protokol.Table1.Delta_PU);
        m_D.Text = tools.GetNormalizedValue(DataIVK.TableKMH_MPR_PU.Protokol.Table1.m_D);
        m_S.Text = tools.GetNormalizedValue(DataIVK.TableKMH_MPR_PU.Protokol.Table1.m_S);
        m_E.Text = tools.GetNormalizedValue(DataIVK.TableKMH_MPR_PU.Protokol.Table1.m_E);
        Alpha_t_PU.Text = tools.GetNormalizedValue(DataIVK.TableKMH_MPR_PU.Protokol.Table1.Alpha_t_PU);
        Delta_t_PU.Text = tools.GetNormalizedValue(DataIVK.TableKMH_MPR_PU.Protokol.Table1.Delta_t_PU);
        Delta_PP.Text = tools.GetNormalizedValue(DataIVK.TableKMH_MPR_PU.Protokol.Table1.Delta_PP);
        Delta_t_PP.Text = tools.GetNormalizedValue(DataIVK.TableKMH_MPR_PU.Protokol.Table1.Delta_t_PP);
        Delta_k_UOI.Text = tools.GetNormalizedValue(DataIVK.TableKMH_MPR_PU.Protokol.Table1.Delta_k_UOI);
        KF_konf.Text = tools.GetNormalizedValue(DataIVK.TableKMH_MPR_PU.Protokol.Table1.KF_konf);
        ZS.Text = tools.GetNormalizedValue(DataIVK.TableKMH_MPR_PU.Protokol.Table1.ZS);
        Alpha_k1_PU.Text = tools.GetNormalizedValue(DataIVK.TableKMH_MPR_PU.Protokol.Table1.Alpha_k1_PU);
        Alpha_t_cm.Text = tools.GetNormalizedValue(DataIVK.TableKMH_MPR_PU.Protokol.Table1.Alpha_t_cm);
                           
        //RowSpans
        for (int i = 0; i &lt; (Table1SourceData.ColumnCount); i++)
        {          
          switch(i)
          {
            case 2:
            case 3:  
            case 4:
            case 5:  
            case 6:     
            case 7:      
            case 8: 
            case 9: 
            case 10: 
            case 11: 
            case 12: 
            case 13: 
            case 14: 
              Table1SourceData[i,4].RowSpan =  listTable1Detectors.Count;
              break;  
          }
        }
        Table1SourceData.PrintRow(4);     
        Table1SourceData.PrintColumns();  
      }       
    }

    private void Table2Results_ManualBuild(object sender, EventArgs e)
    {
      List &lt;TN.Doc.Table2&gt; listTable2Relults;
      listTable2Relults = DataIVK.TableKMH_MPR_PU.Protokol.Table2.Where(i =&gt; ! i.Ser.Contains(&quot;-&quot;) &amp; String.IsNullOrEmpty(i.Ser) == false).ToList();            
      float initialHeight = 0;
      int tempCounter =0;
      int sumPointMeasures =0;
         
      //Setup Columns width                                                                                           
      int sumDynamicCols=Table2Results.ColumnCount;                                                                                                                                
      float widthDynamicCol=(Page.PaperWidth-Page.LeftMargin-Page.RightMargin)/sumDynamicCols;                                                       
        
      for (int w = 0; w &lt; (Table2Results.ColumnCount); w++)                                                                                                                                     
      {                                                                                                                                                                                                                                           
        Table2Results.Columns[w].Width = widthDynamicCol * Units.Millimeters;                                                                                                     
      }  
                 
      //Draw Fixed rows
      for (int n = 0; n &lt; Table2Results.FixedRows; n++)
      {
        Table2Results.PrintRow(n);
        Table2Results.PrintColumns();                                             
      }
                               
      for (int i = 0; i &lt; (listTable2Relults.Count); i++)  
      {
        sumPointMeasures = listTable2Relults.Count(z =&gt; z.Ser == (i+1).ToString());
        for (int j = 0; j &lt; sumPointMeasures; j++)                    
        {
          Ser.RowSpan =  sumPointMeasures;
          Ser.Text=listTable2Relults[j+tempCounter].Ser; 
          Row.Text=listTable2Relults[j+tempCounter].Row;    
          Q_ji.Text=tools.GetNormalizedValue(listTable2Relults[j+tempCounter].Q_ji);
          T_ji.Text=tools.GetNormalizedValue(listTable2Relults[j+tempCounter].T_ji);
          t_PU_ji.Text=tools.GetNormalizedValue(listTable2Relults[j+tempCounter].t_PU_ji);
          P_PU_ji.Text=tools.GetNormalizedValue(listTable2Relults[j+tempCounter].P_PU_ji);
          Dens_ji.Text=tools.GetNormalizedValue(listTable2Relults[j+tempCounter].Dens_ji);
          DensTemp_ji.Text=tools.GetNormalizedValue(listTable2Relults[j+tempCounter].DensTemp_ji);
          DensPress_ji.Text=tools.GetNormalizedValue(listTable2Relults[j+tempCounter].DensPress_ji);
          N_ji.Text=tools.GetNormalizedValue(listTable2Relults[j+tempCounter].N_ji);
          V_PU_PR_ji.Text=tools.GetNormalizedValue(listTable2Relults[j+tempCounter].V_PU_PR_ji);
          Dens_PP_PR_ji.Text=tools.GetNormalizedValue(listTable2Relults[j+tempCounter].Dens_PP_PR_ji);
          M_RA_ji.Text=tools.GetNormalizedValue(listTable2Relults[j+tempCounter].M_RA_ji);
          M_from_GH_ji.Text=tools.GetNormalizedValue(listTable2Relults[j+tempCounter].M_from_GH_ji);
          Delta_KMH_ji.Text=tools.GetNormalizedValue(listTable2Relults[j+tempCounter].Delta_KMH_ji);
               
          Table2Results.PrintRow(Table2Results.RowCount-1);
          Table2Results.PrintColumns();
        }
        tempCounter=tempCounter+sumPointMeasures;   

        Ser.RowSpan = 1;
        initialHeight = BaseRow.Height;
        BaseRow.Height = 0;
        Table2Results.PrintRow(Table2Results.RowCount-1);
        Table2Results.PrintColumns();
        BaseRow.Height= initialHeight;
      }                                                            
    }

    public void  DrawTableConclusion()
    {
      string result = DataIVK.TableKMH_MPR_PU.AdditionalInfo.ARM_KMH_Result == &quot;годен&quot; ? &quot;МПР   годен к дальнейшей эксплуатации&quot; : &quot;МПР   не годен и подлежит внеочередной поверке&quot;;
      Conclusion.Text =string.Format(&quot;&lt;b&gt;3 Заключение: δ &lt;sub&gt;ij mах &lt;/sub&gt; = {0}%. {1}&quot;,                                                     
        tools.GetNormalizedValue(DataIVK.TableKMH_MPR_PU.Protokol.Delta_max),                                        
        result);      
         
      TableConclusion[0,2].Text = string.Format(&quot;Дата проведения КМХ: &lt;u&gt;{0:dd.MM.yyyy} г.&quot;,
        tools.UnixTimestampToDatetime(DataIVK.TableKMH_MPR_PU.DateTimeLong));               
                                            
      ServiceStaffData.Text = DataIVK.TableKMH_MPR_PU.AdditionalInfo.ServiceStaffData;     
      DeliveryStaffData.Text = DataIVK.TableKMH_MPR_PU.AdditionalInfo.DeliveryStaffData;                
      RecievingStaffData.Text= DataIVK.TableKMH_MPR_PU.AdditionalInfo.RecievingStaffData;
    }  
      
    private void PageFooter_BeforeLayout(object sender, EventArgs e)
    {
      if((Int32)Report.GetVariableValue(&quot;TotalPages&quot;) &lt; 2) 
      { 
        PageFooter.Visible = false; 
      }
      else
      {
        PageNumeration.Width = (Page.PaperWidth-Page.LeftMargin-Page.RightMargin)*Units.Millimeters;
      }
    }      
  }    
}

