          <TableCell Name="MassWaterFracResult_Desc" Border.Lines="All" Border.Width="0.75" Text="MassWaterFracResult_Desc" Padding="1, 0, 4, 0" HorzAlign="Center" VertAlign="Center" Font="Arial, 9pt" FontWidthRatio="0.85" TextRenderType="HtmlTags"/>
