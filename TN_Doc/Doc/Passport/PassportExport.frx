namespace FastReport
{
  public class ReportScript
  {
    TN_ToolsFastReport.Tools tools = new TN_ToolsFastReport.Tools();
    JToken JDoc;
    JToken JSettings;
    JToken JTablePassport;
    JToken JResult;
    JToken JMethod;
    JToken JAdditionalData;
    JToken JDataARM;
      
    private void Page_StartPage(object sender, EventArgs e)
    {
      JDoc = JToken.Parse(Report.GetParameterValue(&quot;JsonDoc&quot;).ToString());
      JSettings = JDoc[&quot;Doc&quot;][&quot;Settings&quot;];
      JTablePassport = JDoc[&quot;Doc&quot;][&quot;DataIVK&quot;][&quot;TablePassport&quot;];
      JAdditionalData = JDoc[&quot;Doc&quot;][&quot;DataIVK&quot;][&quot;TablePassport&quot;][&quot;AdditionalData&quot;];
      JResult = JDoc[&quot;Doc&quot;][&quot;DataIVK&quot;][&quot;TablePassport&quot;][&quot;PassportResult&quot;];
      JMethod = JDoc[&quot;Doc&quot;][&quot;DataIVK&quot;][&quot;TablePassport&quot;][&quot;TableActAndPassport&quot;][&quot;Passport&quot;];
      JDataARM = JDoc[&quot;Doc&quot;][&quot;DataIVK&quot;][&quot;TablePassport&quot;][&quot;DataARM&quot;]; 
      
      // Настройки страницы 
      // Ширина и высота (в мм)
      Page.PaperHeight = (int)JSettings[&quot;General&quot;][&quot;PageSettings&quot;][&quot;PaperHeight&quot;];
      Page.PaperWidth = (int)JSettings[&quot;General&quot;][&quot;PageSettings&quot;][&quot;PaperWidth&quot;];
         
      // Поля/отступы от краёв (в мм)
      Page.TopMargin = (int)JSettings[&quot;General&quot;][&quot;PageSettings&quot;][&quot;TopMargin&quot;];
      Page.BottomMargin = (int)JSettings[&quot;General&quot;][&quot;PageSettings&quot;][&quot;BottomMargin&quot;];
      Page.LeftMargin = (int)JSettings[&quot;General&quot;][&quot;PageSettings&quot;][&quot;LeftMargin&quot;];
      Page.RightMargin = (int)JSettings[&quot;General&quot;][&quot;PageSettings&quot;][&quot;RightMargin&quot;];
         
      // Запуск отрисовки таблиц на странице отчета
      DrawTableHeader();
      DrawTableMain();
      DrawTableSigners();
    }
      
    public void DrawTableHeader()
    {               
      DateTime Begin = new DateTime(1970, 1, 1, 0, 0, 0, DateTimeKind.Utc).AddSeconds((long)JTablePassport[&quot;Begin&quot;]);
      DateTime End = new DateTime(1970, 1, 1, 0, 0, 0, DateTimeKind.Utc).AddSeconds((long)JTablePassport[&quot;End&quot;]);
      
      NumberAndDatePassport.Text = string.Format(&quot;№ &lt;u&gt;{0}&lt;/u&gt; от &lt;u&gt;{1:dd.MM.yyyy}&lt;/u&gt; г.&quot;,
        JResult[&quot;PassportId&quot;], 
        End.ToShortDateString());

      DelivePoint.Text = $&quot;{JAdditionalData[&quot;DelivePoint&quot;]}&quot;;
      Permit.Text = $&quot;{JDataARM[&quot;ExportPermit&quot;]}&quot;;
      Sample.Text = $&quot;{JDataARM[&quot;Sample&quot;]}&quot;;
      DataOfLoaded.Text = string.Format(&quot;{0:dd.MM.yyyy}&quot;, End.ToShortDateString());
      TankerName.Text = $&quot;{JAdditionalData[&quot;TankerName&quot;]}&quot;;
      //Gross.Text = DataIVK.TablePassport.TableActAndPassport.Act.Mass_Gross_Raw.Value.ToString();
      
      if (JResult[&quot;Mass_Gross&quot;] == null)
        Gross.Text = &quot;-&quot;;
      else
        Gross.Text = tools.GetNormalizedValue(JResult[&quot;Mass_Gross&quot;]);
    }

    public void  DrawTableMain()
    {
      string result, secondResult;
      JToken metod, secondMetod;
      JToken metods = JDataARM[&quot;LabInfo&quot;];
      
      //Filling &quot;method&quot; column rows with data
      Dens20Result_Desc.Text = $&quot;{JMethod[&quot;Dens20Result&quot;][&quot;Desc&quot;]}&quot;;
      Dens15Result_Desc.Text = $&quot;{JMethod[&quot;Dens15Result&quot;][&quot;Desc&quot;]}&quot;;
      MassWaterFracResult_Desc.Text = $&quot;{JMethod[&quot;MassWaterFracResult&quot;][&quot;Desc&quot;]}&quot;;
      Chloride_Salts_Concentration_Desc.Text = $&quot;{JMethod[&quot;Chloride_Salts&quot;][&quot;Concentration&quot;][&quot;Desc&quot;]}&quot;;
      Impurity_Desc.Text = $&quot;{JMethod[&quot;Impurity&quot;][&quot;Desc&quot;]}&quot;;
      SulfurResult_Desc.Text = $&quot;{JMethod[&quot;SulfurResult&quot;][&quot;Desc&quot;]}&quot;;
      DNP_kPa_Desc.Text = $&quot;{JMethod[&quot;DNP&quot;][&quot;kPa&quot;][&quot;Desc&quot;]}&quot;;
      Yield_fractions_Desc.Text =string.Format(&quot;&lt;br&gt;&lt;br&gt;{0}&lt;br&gt;{1}&quot;, 
        $&quot;{JMethod[&quot;Yield_fraction_200&quot;][&quot;Desc&quot;]}&quot;,
        $&quot;{JMethod[&quot;Yield_fraction_300&quot;][&quot;Desc&quot;]}&quot;,
        $&quot;{JMethod[&quot;Yield_fraction_350&quot;][&quot;Desc&quot;]}&quot;);
      Mass_fraction_of_paraffin_Desc.Text = $&quot;{JMethod[&quot;Mass_fraction_of_paraffin&quot;][&quot;Desc&quot;]}&quot;;
      Mass_fraction_of_hydrogen_sulfide_Desc.Text = $&quot;{JMethod[&quot;Mass_fraction_of_hydrogen_sulfide&quot;][&quot;Desc&quot;]}&quot;;
      Mass_fraction_of_methyl_and_ethyl_mercaptan_Desc.Text = $&quot;{JMethod[&quot;Mass_fraction_of_methyl_and_ethyl_mercaptan&quot;][&quot;Desc&quot;]}&quot;;
      Mass_fraction_of_organic_chlorides_Desc.Text = $&quot;{JMethod[&quot;Mass_fraction_of_organic_chlorides&quot;][&quot;Desc&quot;]}&quot;;
      
      //Filling &quot;result&quot; column rows with data
      metod = GetMetod(metods, &quot;Dens20Correction&quot;);
      result = $&quot;{JResult[&quot;Dens20Result&quot;]}&quot;;
      Dens20Result.Text = metod == null ? result : GetResult(metod, result);
      
      metod = GetMetod(metods, &quot;Dens15Correction&quot;);
      result = $&quot;{JResult[&quot;Dens15Result&quot;]}&quot;;
      Dens15Result.Text = metod == null ? result : GetResult(metod, result);
      
      metod = GetMetod(metods, &quot;MassWaterFracCorrection&quot;);
      result = $&quot;{JResult[&quot;MassWaterFracResult&quot;]}&quot;;
      MassWaterFracResult.Text = metod == null ? result : GetResult(metod, result);
      
      metod = GetMetod(metods, &quot;Chloride_Salts.Concentration&quot;);
      secondMetod = GetMetod(metods, &quot;Chloride_Salts.MassFraction&quot;);
      result = $&quot;{JResult[&quot;Chloride_Salts&quot;][&quot;Concentration&quot;]}&quot;;
      secondResult = $&quot;{JResult[&quot;Chloride_Salts&quot;][&quot;MassFraction&quot;]}&quot;;
      Chloride_Salts_Concentration.Text = $&quot;{(metod == null ? result : GetResult(metod, result))} ({(secondMetod == null ? secondResult : GetResult(secondMetod, secondResult))})&quot;;
      
      metod = GetMetod(metods, &quot;Impurity&quot;);
      result = $&quot;{JResult[&quot;Impurity&quot;]}&quot;;
      Impurity.Text = metod == null ? result : GetResult(metod, result);
      
      metod = GetMetod(metods, &quot;SulfurCorrection&quot;);
      result = $&quot;{JResult[&quot;SulfurResult&quot;]}&quot;;
      SulfurResult.Text = metod == null ? result : GetResult(metod, result);
      
      metod = GetMetod(metods, &quot;DNP.kPa&quot;);
      secondMetod = GetMetod(metods, &quot;DNP.mercury_mm&quot;);
      result = $&quot;{JResult[&quot;DNP&quot;][&quot;kPa&quot;]}&quot;;
      secondResult = $&quot;{JResult[&quot;DNP&quot;][&quot;mercury_mm&quot;]}&quot;;
      DNP_kPa.Text = $&quot;{(metod == null ? result : GetResult(metod, result))} ({(secondMetod == null ? secondResult : GetResult(secondMetod, secondResult))})&quot;;
      
      metod = GetMetod(metods, &quot;Yield_fraction_200&quot;);
      result = $&quot;{JResult[&quot;Yield_fraction_200&quot;]}&quot;;
      string fraction_200 = metod == null ? result : GetResult(metod, result);

      metod = GetMetod(metods, &quot;Yield_fraction_300&quot;);
      result = $&quot;\n{JResult[&quot;Yield_fraction_300&quot;]}&quot;;
      string fraction_300 = metod == null ? result : GetResult(metod, result);

      metod = GetMetod(metods, &quot;Yield_fraction_350&quot;);
      result = $&quot;\n{JResult[&quot;Yield_fraction_350&quot;]}&quot;;
      string fraction_350 = metod == null ? result : GetResult(metod, result);

      Yield_fractions.Text =string.Format(&quot;&lt;br&gt;&lt;br&gt;{0}&lt;br&gt;{1}&quot;, 
        fraction_200,
        fraction_300,
        fraction_350);
         
      metod = GetMetod(metods, &quot;Mass_fraction_of_paraffin&quot;);
      result = $&quot;{JResult[&quot;Mass_fraction_of_paraffin&quot;]}&quot;;
      Mass_fraction_of_paraffin.Text = metod == null ? result : GetResult(metod, result);

      metod = GetMetod(metods, &quot;Mass_fraction_of_hydrogen_sulfide&quot;);
      result = $&quot;{JResult[&quot;Mass_fraction_of_hydrogen_sulfide&quot;]}&quot;;
      Mass_fraction_of_hydrogen_sulfide.Text = metod == null ? result : GetResult(metod, result);

      metod = GetMetod(metods, &quot;Mass_fraction_of_methyl_and_ethyl_mercaptan&quot;);
      result = $&quot;{JResult[&quot;Mass_fraction_of_methyl_and_ethyl_mercaptan&quot;]}&quot;;
      Mass_fraction_of_methyl_and_ethyl_mercaptan.Text = metod == null ? result : GetResult(metod, result);

      metod = GetMetod(metods, &quot;Mass_fraction_of_organic_chlorides&quot;);
      result = $&quot;{JResult[&quot;Mass_fraction_of_organic_chlorides&quot;]}&quot;;
      Mass_fraction_of_organic_chlorides.Text = metod == null ? result : GetResult(metod, result);
       
    }
      
    private static JToken GetMetod(JToken metods, string parameterKey) =&gt; metods.FirstOrDefault(x =&gt; x[&quot;ParameterKey&quot;].ToString() == parameterKey);

    private static string GetResult(JToken metod, string result)
    {
      result = result.Replace('.', ',');

      if ((bool)metod[&quot;Metod&quot;][&quot;LimitValueActivate&quot;])
      {
        if (!float.TryParse(result, out float value)) return result; //value = 0.0f;

        float limitValue = (float)metod[&quot;Metod&quot;][&quot;LimitValue&quot;];

        result = value &lt; limitValue ? $&quot;{metod[&quot;Metod&quot;][&quot;LimitValueString&quot;]}&quot; : result;
      }

      return result;
    }
    
    public void  DrawTableSigners()
    {     
      GOSTIndexResult.Text = string.Format(&quot;Обозначение нефти по ГОСТ Р 51858&lt;br&gt;/Classification according to GOST R 51858/&lt;br&gt;&lt;u&gt;{0}&quot;, JResult[&quot;ExtendGostIndexResult&quot;].ToString().Replace('X','-'));
      Laboratory_IOF.Text = $&quot;{JAdditionalData[&quot;Laboratory_IOF&quot;]}&quot;;
    }  
      
    private void PageFooter_BeforeLayout(object sender, EventArgs e)
    {
      if((Int32)Report.GetVariableValue(&quot;TotalPages&quot;) &lt; 2) 
      { 
        PageFooter.Visible = false; 
      }
      else
      {
        PageNumeration.Width = (Page.PaperWidth-Page.LeftMargin-Page.RightMargin)*Units.Millimeters;
      }
    }
  }    
}</ScriptText>
