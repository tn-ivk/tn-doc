          <TableCell Name="NameParameter" Border.Lines="All" Border.Width="0.75" Text="&lt;b&gt;Плотность нефти при 20 °С, кг/м³&lt;/b&gt;&#13;&#10;Density at 20 °С, kg/m³" Padding="1, 0, 4, 0" VertAlign="Center" Font="Arial, 9pt" FontWidthRatio="0.85" TextRenderType="HtmlTags"/>
