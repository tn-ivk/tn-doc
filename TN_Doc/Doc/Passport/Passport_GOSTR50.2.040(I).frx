          <TableCell Name="Cell1578" Border.Lines="All" HorzAlign="Center" VertAlign="Center" Font="Arial, 10pt"/>
        </TableRow>
        <TableRow Name="RowMass_fraction_of_hydrogen_sulfide" Height="17.39" AutoSize="true">
          <TableCell Name="Cell1587" Border.Lines="All" Text="11" HorzAlign="Center" VertAlign="Center" Font="Arial, 10pt"/>
          <TableCell Name="Cell1588" Border.Lines="All" Text="Массовая доля сероводорода, млнˉ¹ (ppm)" VertAlign="Center" Font="Arial, 10pt"/>
          <TableCell Name="Cell1589" Border.Lines="All" HorzAlign="Center" VertAlign="Center" Font="Arial, 10pt"/>
          <TableCell Name="Cell1590" Border.Lines="All" HorzAlign="Center" VertAlign="Center" Font="Arial, 10pt"/>
