<?xml version="1.0" encoding="utf-8"?>
<Report ScriptLanguage="CSharp" ReferencedAssemblies="System.dll&#13;&#10;System.Drawing.dll&#13;&#10;System.Data.dll&#13;&#10;System.Xml.dll&#13;&#10;FastReport.Compat.dll&#13;&#10;System.Windows.Forms.dll&#13;&#10;FastReport.DataVisualization.dll&#13;&#10;Newtonsoft.Json.dll&#13;&#10;System.Core.dll&#13;&#10;" DoublePass="true" FinishReportEvent="_FinishReport" ReportInfo.Created="03/25/2020 12:46:46" ReportInfo.Modified="07/20/2023 13:59:03" ReportInfo.CreatorVersion="2021.4.4.0">
  <ScriptText>using System;
using FastReport;
using FastReport.Data;
using FastReport.Dialog;
using FastReport.Barcode;
using FastReport.Table;  
using FastReport.Utils;
using Newtonsoft.Json.Linq;

namespace FastReport
{
   public class ReportScript
   {
      JToken JDoc;
      JToken JSettings;
      JToken JTablePassport;
      JToken JResult;
      JToken JMethod;
      JToken JAdditionalData;
      
      private void Page_StartPage(object sender, EventArgs e)
      {
        JDoc = JToken.Parse(Report.GetParameterValue(&quot;JsonDoc&quot;).ToString());
        JSettings = JDoc[&quot;Doc&quot;][&quot;Settings&quot;];
        JTablePassport = JDoc[&quot;Doc&quot;][&quot;DataIVK&quot;][&quot;TablePassport&quot;];
        JAdditionalData = JDoc[&quot;Doc&quot;][&quot;DataIVK&quot;][&quot;TablePassport&quot;][&quot;AdditionalData&quot;];
        JResult = JDoc[&quot;Doc&quot;][&quot;DataIVK&quot;][&quot;TablePassport&quot;][&quot;PassportResult&quot;];
        JMethod = JDoc[&quot;Doc&quot;][&quot;DataIVK&quot;][&quot;TablePassport&quot;][&quot;TableActAndPassport&quot;][&quot;Passport&quot;];    
      
        //Настройки страницы 
        //Ширина и высота (в мм)
        Page.PaperHeight = (int)JSettings[&quot;General&quot;][&quot;PageSettings&quot;][&quot;PaperHeight&quot;];
        Page.PaperWidth = (int)JSettings[&quot;General&quot;][&quot;PageSettings&quot;][&quot;PaperWidth&quot;];
         
        //Поля/отступы от краёв (в мм)
        Page.TopMargin = (int)JSettings[&quot;General&quot;][&quot;PageSettings&quot;][&quot;TopMargin&quot;];
        Page.BottomMargin = (int)JSettings[&quot;General&quot;][&quot;PageSettings&quot;][&quot;BottomMargin&quot;];
        Page.LeftMargin = (int)JSettings[&quot;General&quot;][&quot;PageSettings&quot;][&quot;LeftMargin&quot;];
        Page.RightMargin = (int)JSettings[&quot;General&quot;][&quot;PageSettings&quot;][&quot;RightMargin&quot;];
         
        //Запуск отрисовки таблиц на странице отчета
        DrawTableHeader();
        DrawTablePassport();
        DrawTableSigners();
      }
      
      public void DrawTableHeader()
      {         
        DateTime Begin = new DateTime(1970, 1, 1, 0, 0, 0, DateTimeKind.Utc).AddSeconds((long)JTablePassport[&quot;Begin&quot;]);
        DateTime End = new DateTime(1970, 1, 1, 0, 0, 0, DateTimeKind.Utc).AddSeconds((long)JTablePassport[&quot;End&quot;]);
         
        DateTime SamplingPeriodBegin = new DateTime(1970, 1, 1, 0, 0, 0, DateTimeKind.Utc).AddSeconds((long)JAdditionalData[&quot;PassportPeriodDt&quot;][&quot;Begin&quot;]);
        DateTime SamplingPeriodEnd = new DateTime(1970, 1, 1, 0, 0, 0, DateTimeKind.Utc).AddSeconds((long)JAdditionalData[&quot;PassportPeriodDt&quot;][&quot;End&quot;]);
      
        NumberAndDatePassport.Text = string.Format(&quot;№ &lt;u&gt;{0}&lt;/u&gt; от &lt;u&gt;{1:dd.MM.yyyy}&lt;/u&gt; г.&quot;, JResult[&quot;PassportId&quot;], Begin.ToShortDateString());
        DelivePoint.Text = $&quot;{JAdditionalData[&quot;DelivePoint&quot;]}&quot;;
        Laboratory.Text = $&quot;{JAdditionalData[&quot;Laboratory&quot;]}&quot;;
        AccrSertifNumber.Text = $&quot;{JAdditionalData[&quot;AccrSertifNumber&quot;]}&quot;;
        SIKN_Number.Text = $&quot;{JAdditionalData[&quot;SIKN_Number&quot;]}&quot;;
        Reservoir.Text = &quot;&quot;;
      
      //DateTimeSampling.Text = string.Format(&quot;{0:dd.MM.yyyy} г. с {1:HH:mm} до {2:HH:mm}&quot;, SamplingPeriodBegin, SamplingPeriodBegin, SamplingPeriodEnd);
      
      if ((int)JTablePassport[&quot;PeriodType&quot;] == 5)
      {
        string dateTimeEnd = SamplingPeriodEnd.ToString(&quot;HH:mm&quot;) == &quot;00:00&quot; ? SamplingPeriodEnd.AddDays(-1).ToString(&quot;dd.MM.yyyy HH:mm&quot;).Replace(&quot;00:00&quot;, &quot;24:00&quot;): SamplingPeriodEnd.ToString(&quot;dd.MM.yyyy HH:mm&quot;);
        DateTimeSampling.Text = $&quot;с {SamplingPeriodBegin.ToString(&quot;dd.MM.yyyy HH:mm&quot;)} до {dateTimeEnd}&quot;;      
      }      
      else
      {
        DateTimeSampling.Text = $&quot;{SamplingPeriodBegin.ToString(&quot;dd.MM.yyyy&quot;)} г. с {SamplingPeriodBegin.ToString(&quot;HH:mm&quot;)} до {SamplingPeriodEnd.ToString(&quot;HH:mm&quot;).Replace(&quot;00:00&quot;, &quot;24:00&quot;)}&quot;;
      }
    }
             
      private void DrawTablePassport()
      {
        //Заполняем колонку результат испытаний
        RowTempResult[3].Text = $&quot;{JResult[&quot;TempResult&quot;]}&quot;; 
        RowPressResult[3].Text = $&quot;{JResult[&quot;PressResult&quot;]}&quot;;
        RowDensResult[3].Text = $&quot;{JResult[&quot;DensResult&quot;]}&quot;;
        RowDens20Result[3].Text = $&quot;{JResult[&quot;Dens20Result&quot;]}&quot;;
        RowDens15Result[3].Text = $&quot;{JResult[&quot;Dens15Result&quot;]}&quot;;
        RowMassWaterFracResult[3].Text = $&quot;{JResult[&quot;MassWaterFracResult&quot;]}&quot;;
        RowChloride_Salts[3].Text = $&quot;{JResult[&quot;Chloride_Salts&quot;][&quot;Concentration&quot;]} ({JResult[&quot;Chloride_Salts&quot;][&quot;MassFraction&quot;]})&quot;;
        RowImpurity[3].Text = $&quot;{JResult[&quot;Impurity&quot;]}&quot;;
        RowSulfurResult[3].Text = $&quot;{JResult[&quot;SulfurResult&quot;]}&quot;;
        RowDNP[3].Text = $&quot;{JResult[&quot;DNP&quot;][&quot;kPa&quot;]} ({JResult[&quot;DNP&quot;][&quot;mercury_mm&quot;]})&quot;;

        float result;                          
      
        if (float.TryParse(JResult[&quot;Mass_fraction_of_hydrogen_sulfide&quot;].ToString().Replace('.',','), out result) &amp;&amp; result &lt; float.Parse(&quot;2,0&quot;))
          RowMass_fraction_of_hydrogen_sulfide[3].Text = $&quot;менее 2&quot;;
        else
          RowMass_fraction_of_hydrogen_sulfide[3].Text = $&quot;{JResult[&quot;Mass_fraction_of_hydrogen_sulfide&quot;]}&quot;;  
      
        if (float.TryParse(JResult[&quot;Mass_fraction_of_methyl_and_ethyl_mercaptan&quot;].ToString().Replace('.',','), out result) &amp;&amp; result &lt; float.Parse(&quot;2,0&quot;))
          RowMass_fraction_of_methyl_and_ethyl_mercaptan[3].Text = $&quot;менее 2&quot;;
        else
          RowMass_fraction_of_methyl_and_ethyl_mercaptan[3].Text = $&quot;{JResult[&quot;Mass_fraction_of_methyl_and_ethyl_mercaptan&quot;]}&quot;;  

        if (float.TryParse(JResult[&quot;Mass_fraction_of_organic_chlorides&quot;].ToString().Replace('.',','), out result) &amp;&amp; result &lt; float.Parse(&quot;5,0&quot;))
          RowMass_fraction_of_organic_chlorides[3].Text = $&quot;менее 5,0&quot;;
        else
          RowMass_fraction_of_organic_chlorides[3].Text = $&quot;{JResult[&quot;Mass_fraction_of_organic_chlorides&quot;]}&quot;;       
      
        //Заполняем колонку метод испытаний
        RowTempResult[2].Text = $&quot;{JMethod[&quot;TempResult&quot;][&quot;Desc&quot;]}&quot;; 
        RowPressResult[2].Text = $&quot;{JMethod[&quot;PressResult&quot;][&quot;Desc&quot;]}&quot;;
        RowDensResult[2].Text = $&quot;{JMethod[&quot;DensResult&quot;][&quot;Desc&quot;]}&quot;;
        RowDens20Result[2].Text = $&quot;{JMethod[&quot;Dens20Result&quot;][&quot;Desc&quot;]}&quot;;
        RowDens15Result[2].Text = $&quot;{JMethod[&quot;Dens15Result&quot;][&quot;Desc&quot;]}&quot;;
        RowMassWaterFracResult[2].Text = $&quot;{JMethod[&quot;MassWaterFracResult&quot;][&quot;Desc&quot;]}&quot;;       
        RowChloride_Salts[2].Text = $&quot;{JMethod[&quot;Chloride_Salts&quot;][&quot;Concentration&quot;][&quot;Desc&quot;]}&quot;;       
        RowImpurity[2].Text = $&quot;{JMethod[&quot;Impurity&quot;][&quot;Desc&quot;]}&quot;;
        RowSulfurResult[2].Text = $&quot;{JMethod[&quot;SulfurResult&quot;][&quot;Desc&quot;]}&quot;;
        RowDNP[2].Text = $&quot;{JMethod[&quot;DNP&quot;][&quot;kPa&quot;][&quot;Desc&quot;]}&quot;;
        RowMass_fraction_of_hydrogen_sulfide[2].Text = $&quot;{JMethod[&quot;Mass_fraction_of_hydrogen_sulfide&quot;][&quot;Desc&quot;]}&quot;;
        RowMass_fraction_of_methyl_and_ethyl_mercaptan[2].Text = $&quot;{JMethod[&quot;Mass_fraction_of_methyl_and_ethyl_mercaptan&quot;][&quot;Desc&quot;]}&quot;;
        RowMass_fraction_of_organic_chlorides[2].Text = $&quot;{JMethod[&quot;Mass_fraction_of_organic_chlorides&quot;][&quot;Desc&quot;]}&quot;;      
      }      
     
      public void  DrawTableSigners()
      {
        GOSTIndexResult.Text = string.Format(&quot;Обозначение нефти по ГОСТ Р 51858: &lt;u&gt;{0}&quot;, JResult[&quot;GostIndexResult&quot;].ToString().Replace('X','-'));
        Laboratory_IOF.Text = $&quot;{JAdditionalData[&quot;Laboratory_IOF&quot;]}&quot;;
        Delive_Post.Text = $&quot;{JAdditionalData[&quot;Delive_Post&quot;]}&quot;;
        Delive_Factory.Text = $&quot;{JAdditionalData[&quot;Delive_Factory&quot;]}&quot;;
        Delive_IOF.Text = $&quot;{JAdditionalData[&quot;Delive_IOF&quot;]}&quot;;
        Receive_Post.Text = $&quot;{JAdditionalData[&quot;Receive_Post&quot;]}&quot;;
        Receive_Factory.Text = $&quot;{JAdditionalData[&quot;Receive_Factory&quot;]}&quot;;
        Receive_IOF.Text = $&quot;{JAdditionalData[&quot;Receive_IOF&quot;]}&quot;;
      } 
   }    
}</ScriptText>
