  <ScriptText>using System;
using System.Reflection;
using System.IO;
using System.Collections;
using System.Collections.Generic;
using System.ComponentModel;
using System.Windows.Forms;
using System.Drawing;
using System.Data;
using FastReport;
using FastReport.Data;
using FastReport.Dialog;
using FastReport.Barcode;
using FastReport.Table;  
using FastReport.Utils;
using System.Linq;
using Newtonsoft.Json;
using Newtonsoft.Json.Linq;
using Newtonsoft.Json.Converters;
using System.Globalization;
using TN.DocData;

namespace FastReport
{
  public class ReportScript
  {
    TN_ToolsFastReport.Tools com = new TN_ToolsFastReport.Tools();    
    TN.Doc.Doc doc;
    TN.Doc.DataIVKDoc DataIVK;
    TN.Doc.HeaderDoc Header;
    TN.Doc.DataDoc SettingsData;
    TN.Doc.FooterDoc Footer;
    TN.Doc.DictionarysDoc Dictionarys;
    
    JObject json;
    
    private void Page1_StartPage(object sender, EventArgs e)
    {
      //using (var sr = new StreamReader(&quot;C:/SVN/FastReport/Входящие данные от Алексея (классы и json)/12_Passport/DocPassport.json&quot;))
      //{
      //  Report.SetParameterValue(&quot;JsonDoc&quot;, sr.ReadToEnd());
      //}              
      
      string jsonDoc = (string)Report.GetParameterValue(&quot;JsonDoc&quot;);
      json = JObject.Parse(jsonDoc);      
      
      Newtonsoft.Json.JsonSerializerSettings settingsReport = new Newtonsoft.Json.JsonSerializerSettings();
      settingsReport.TypeNameHandling = TypeNameHandling.All;
      
      doc = JsonConvert.DeserializeObject&lt;TN.Doc.Doc&gt;(jsonDoc, settingsReport);
      DataIVK = (TN.Doc.DataIVKDoc)doc.Doc.DataIVK;
      Header = (TN.Doc.HeaderDoc)doc.Doc.Settings.Header;
      SettingsData = (TN.Doc.DataDoc)doc.Doc.Settings.Data;
      Footer = (TN.Doc.FooterDoc)doc.Doc.Settings.Footer;
      Dictionarys = (TN.Doc.DictionarysDoc)doc.Doc.Settings.Dictionarys;
      
      _TableSummary2();
    }
    
    private void PrintTable(TableObject table)
    {
      for (int i=0;i&lt;table.RowCount;i++)
      {       
        table.PrintRow(i);
        table.PrintColumns();
      }    
    } 
    
    private void TableHeader_ManualBuild(object sender, EventArgs e)
    {      
      DateTime Begin = new DateTime(1970, 1, 1, 0, 0, 0, DateTimeKind.Utc).AddSeconds(DataIVK.TablePassport.Begin);
      DateTime End = new DateTime(1970, 1, 1, 0, 0, 0, DateTimeKind.Utc).AddSeconds(DataIVK.TablePassport.End);
      
      NumberAndDatePassport.Text = string.Format(&quot;№ &lt;u&gt;{0}&lt;/u&gt; от &lt;u&gt;{1}&lt;/u&gt; г.&quot;,DataIVK.TablePassport.PassportResult.PassportId, Begin.ToShortDateString());
      Laboratory.Text = DataIVK.TablePassport.AdditionalData.Laboratory;
      AccrSertifNumber.Text = DataIVK.TablePassport.AdditionalData.AccrSertifNumber;
      SIKN_Number.Text = DataIVK.TablePassport.AdditionalData.SIKN_Number;
      Reservoir.Text = &quot;&quot;;
      
      Period.Text = Begin.ToShortDateString() + 
        &quot; г. с &quot; +
        Begin.ToString(&quot;HH:mm&quot;) +
        &quot; до &quot; +
        End.ToString(&quot;HH:mm&quot;).Replace(&quot;00:00&quot;, &quot;24:00&quot;);

      PrintTable(TableHeader); 
    }

    private void TableData_ManualBuild(object sender, EventArgs e)
    {
      TableRow rowTemplate = new TableRow();
      
      List &lt;TN.Doc.Parameter&gt; param = SettingsData.Parameters.Where(x =&gt; x.Use == true).ToList();
      
      for (int i=0;i&lt;param.Count;i++)
      {
        object result;
        rowTemplate = new TableRow();
        rowTemplate.AssignAll(TableDataRowTemplat);        
        rowTemplate.Name = &quot;TableDataRow&quot; + (i+1).ToString();
        rowTemplate.Visible = true;
        TableData.Rows.Add(rowTemplate);
        
        //Порядковый номер
        rowTemplate[0].Text = (i+1).ToString();
        
        //Название параметра
        rowTemplate[1].Text = param[i].Name + &quot;, &quot; + param[i].SI;
        
        //Метод
        result = &quot;&quot;;
        //rowTemplate[2].Text = (string)json.SelectToken(&quot;Doc.DataIVK.TablePassport.TableActAndPassport.Passport.&quot; + param[i].KeyPassportResult + &quot;.Desc&quot;);
        com.GetPropertyValue(DataIVK.TablePassport.TableActAndPassport.Passport, param[i].KeyPassportResult, ref result);
        rowTemplate[2].Text = ((TN.Doc.ParameterProperties)result).Desc;
          
        //Результат
        result = &quot;&quot;;
        com.GetPropertyValue(DataIVK.TablePassport.PassportResult, param[i].KeyPassportResult, ref result);
        rowTemplate[3].Text = com.GetNormalizedValue(result);
      }
      
      PrintTable(TableData);      
    }       

    private void TableSummary1_ManualBuild(object sender, EventArgs e)
    {
      GOSTIndexResult.Text = &quot;Обозначение нефти по ГОСТ Р 51858 &quot; + DataIVK.TablePassport.PassportResult.GostIndexResult.Replace('X','-');
      
      PrintTable(TableSummary1);
    }

    private void _TableSummary2()
    {
      DelivePoint.Text = DataIVK.TablePassport.AdditionalData.DelivePoint;
      Laboratory_IOF.Text = DataIVK.TablePassport.AdditionalData.Laboratory_IOF;
      Delive_Post.Text = DataIVK.TablePassport.AdditionalData.Delive_Post;
      Delive_Factory.Text = DataIVK.TablePassport.AdditionalData.Delive_Factory;
      Delive_IOF.Text = DataIVK.TablePassport.AdditionalData.Delive_IOF;
      Receive_Post.Text = DataIVK.TablePassport.AdditionalData.Receive_Post;
      Receive_Factory.Text = DataIVK.TablePassport.AdditionalData.Receive_Factory;
      Receive_IOF.Text = DataIVK.TablePassport.AdditionalData.Receive_IOF;
    }  
  }
}
</ScriptText>
