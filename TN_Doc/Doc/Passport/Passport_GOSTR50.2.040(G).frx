    <DataBand Name="DataBandTablePassport" Top="148.35" Width="718.2" Height="349.65" CanGrow="true" CanShrink="true" AfterPrintEvent="DataBandTableAct_AfterPrint" CanBreak="true">
      <TableObject Name="TablePassport" Top="9.45" Width="718.2" Height="340.2" Border.Lines="All" GrowToBottom="true" FixedRows="1">
        <TableColumn Name="Column22" Width="30.24"/>
        <TableColumn Name="Column8" Width="434.7"/>
        <TableColumn Name="Column9" Width="153.09"/>
        <TableColumn Name="Column28" Width="100.17"/>
        <TableRow Name="RowHeader" Height="30.24">
          <TableCell Name="Cell475" Border.Lines="All" Text="№" HorzAlign="Center" VertAlign="Center" Font="Arial, 9pt"/>
          <TableCell Name="Cell476" Border.Lines="All" Text="Наименование показателя" HorzAlign="Center" VertAlign="Center" Font="Arial, 9pt"/>
          <TableCell Name="Cell477" Border.Lines="All" Text="Метод испытаний" HorzAlign="Center" VertAlign="Center" Font="Arial, 9pt"/>
          <TableCell Name="Cell478" Border.Lines="All" Text="Результат испытаний" HorzAlign="Center" VertAlign="Center" Font="Arial, 9pt"/>
        </TableRow>
        <TableRow Name="RowTempResult" Height="17.01" AutoSize="true">
          <TableCell Name="Num" Border.Lines="All" Text="1." HorzAlign="Center" VertAlign="Center" Font="Arial, 9pt"/>
          <TableCell Name="NameParameter" Border.Lines="All" Text="Температура нефти при условиях измерений объема, °C" VertAlign="Center" Font="Arial, 9pt"/>
          <TableCell Name="Method" Border.Lines="All" HorzAlign="Center" VertAlign="Center" Font="Arial, 9pt"/>
          <TableCell Name="Result" Border.Lines="All" HorzAlign="Center" VertAlign="Center" Font="Arial, 9pt"/>
        </TableRow>
        <TableRow Name="RowPressResult" Height="17.01" AutoSize="true">
          <TableCell Name="Cell1543" Border.Lines="All" Text="2." HorzAlign="Center" VertAlign="Center" Font="Arial, 9pt"/>
          <TableCell Name="Cell1544" Border.Lines="All" Text="Давление нефти при условиях измерений объема, МПа" VertAlign="Center" Font="Arial, 9pt"/>
          <TableCell Name="Cell1545" Border.Lines="All" HorzAlign="Center" VertAlign="Center" Font="Arial, 9pt"/>
          <TableCell Name="Cell1546" Border.Lines="All" HorzAlign="Center" VertAlign="Center" Font="Arial, 9pt"/>
        </TableRow>
        <TableRow Name="RowDensResult" Height="30.24" AutoSize="true">
          <TableCell Name="Cell1547" Border.Lines="All" Text="3." HorzAlign="Center" VertAlign="Center" Font="Arial, 9pt"/>
          <TableCell Name="Cell1548" Border.Lines="All" Text="Плотность нефти при температуре и давлении в условиях&#13;&#10;измерений объема, кг/м³" VertAlign="Center" Font="Arial, 9pt"/>
          <TableCell Name="Cell1549" Border.Lines="All" HorzAlign="Center" VertAlign="Center" Font="Arial, 9pt"/>
          <TableCell Name="Cell1550" Border.Lines="All" HorzAlign="Center" VertAlign="Center" Font="Arial, 9pt"/>
        </TableRow>
        <TableRow Name="RowDens20Result" Height="17.01" AutoSize="true">
          <TableCell Name="Cell1551" Border.Lines="All" Text="4." HorzAlign="Center" VertAlign="Center" Font="Arial, 9pt"/>
          <TableCell Name="Cell1552" Border.Lines="All" Text="Плотность нефти при 20 °C, кг/м³" VertAlign="Center" Font="Arial, 9pt"/>
          <TableCell Name="Cell1553" Border.Lines="All" HorzAlign="Center" VertAlign="Center" Font="Arial, 9pt"/>
          <TableCell Name="Cell1554" Border.Lines="All" HorzAlign="Center" VertAlign="Center" Font="Arial, 9pt"/>
        </TableRow>
        <TableRow Name="RowDens15Result" Height="17.01" AutoSize="true">
          <TableCell Name="Cell1555" Border.Lines="All" Text="5." HorzAlign="Center" VertAlign="Center" Font="Arial, 9pt"/>
          <TableCell Name="Cell1556" Border.Lines="All" Text="Плотность нефти при 15 °C, кг/м³" VertAlign="Center" Font="Arial, 9pt"/>
          <TableCell Name="Cell1557" Border.Lines="All" HorzAlign="Center" VertAlign="Center" Font="Arial, 9pt"/>
          <TableCell Name="Cell1558" Border.Lines="All" HorzAlign="Center" VertAlign="Center" Font="Arial, 9pt"/>
        </TableRow>
        <TableRow Name="RowMassWaterFracResult" Height="17.01" AutoSize="true">
          <TableCell Name="Cell1559" Border.Lines="All" Text="6." HorzAlign="Center" VertAlign="Center" Font="Arial, 9pt"/>
          <TableCell Name="Cell1560" Border.Lines="All" Text="Массовая доля воды, %" VertAlign="Center" Font="Arial, 9pt"/>
          <TableCell Name="Cell1561" Border.Lines="All" HorzAlign="Center" VertAlign="Center" Font="Arial, 9pt"/>
          <TableCell Name="Cell1562" Border.Lines="All" HorzAlign="Center" VertAlign="Center" Font="Arial, 9pt"/>
        </TableRow>
        <TableRow Name="RowChloride_Salts" Height="17.01" AutoSize="true">
          <TableCell Name="Cell1563" Border.Lines="All" Text="7." HorzAlign="Center" VertAlign="Center" Font="Arial, 9pt"/>
          <TableCell Name="Cell1564" Border.Lines="All" Text="Массовая концентрация хлористых солей, мг/дм³ (%)" VertAlign="Center" Font="Arial, 9pt"/>
          <TableCell Name="Cell1565" Border.Lines="All" HorzAlign="Center" VertAlign="Center" Font="Arial, 9pt"/>
