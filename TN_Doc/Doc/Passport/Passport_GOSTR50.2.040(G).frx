          <TableCell Name="Cell1526" Text="ПАСПОРТ КАЧЕСТВА НЕФТИ" HorzAlign="Center" VertAlign="Center" Font="Arial, 12pt, style=Bold" TextRenderType="HtmlTags" ColSpan="2"/>
