          <TableCell Name="AccrSertifNumber" Border.Lines="Bottom" Border.BottomLine.Width="0.75" Text="AccrSertifNumber" Padding="0, 0, 0, 0" VertAlign="Center" Font="Arial, 9pt"/>
        </TableRow>
        <TableRow Name="Row04" Height="15.12" AutoSize="true">
          <TableCell Name="Cell351" Text="СИКН №" Padding="0, 0, 0, 0" VertAlign="Center" Font="Arial, 9pt"/>
          <TableCell Name="SIKN_Number" Border.Lines="Bottom" Border.BottomLine.Width="0.75" Text="SIKN_Number" Padding="0, 0, 0, 0" VertAlign="Center" Font="Arial, 9pt"/>
        </TableRow>
        <TableRow Name="Row05" Height="15.12" AutoSize="true">
          <TableCell Name="Cell356" Text="Резервуар (мера вместимости)" Padding="0, 0, 0, 0" VertAlign="Center" Font="Arial, 9pt"/>
          <TableCell Name="Reservoir" Border.Lines="Bottom" Border.BottomLine.Width="0.75" Text="Reservoir" Padding="0, 0, 0, 0" VertAlign="Center" Font="Arial, 9pt"/>
        </TableRow>
        <TableRow Name="Row06" Height="15.12" AutoSize="true">
          <TableCell Name="Cell359" Text="Дата и время отбора пробы" Padding="0, 0, 0, 0" VertAlign="Center" Font="Arial, 9pt"/>
          <TableCell Name="DateTimeSampling" Border.Lines="Bottom" Border.BottomLine.Width="0.75" Text="DateTimeSampling" Padding="0, 0, 0, 0" VertAlign="Center" Font="Arial, 9pt"/>
        </TableRow>
      </TableObject>
