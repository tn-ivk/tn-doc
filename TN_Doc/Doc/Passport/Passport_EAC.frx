<?xml version="1.0" encoding="utf-8"?>
<Report ScriptLanguage="CSharp" ReferencedAssemblies="System.dll&#13;&#10;System.Drawing.dll&#13;&#10;System.Data.dll&#13;&#10;System.Xml.dll&#13;&#10;FastReport.Compat.dll&#13;&#10;System.Windows.Forms.dll&#13;&#10;FastReport.DataVisualization.dll&#13;&#10;Newtonsoft.Json.dll&#13;&#10;System.Core.dll&#13;&#10;" DoublePass="true" FinishReportEvent="_FinishReport" ReportInfo.Created="03/25/2020 12:46:46" ReportInfo.Modified="04/23/2024 15:57:53" ReportInfo.CreatorVersion="2023.2.0.0">
  <ScriptText>using System;
using System.Linq;
using FastReport;
using FastReport.Data;
using FastReport.Dialog;
using FastReport.Barcode;
using FastReport.Table;  
using FastReport.Utils;
using Newtonsoft.Json.Linq;

namespace FastReport
{
  public class ReportScript
  {
    JToken JDoc;
    JToken JSettings;
    JToken JTablePassport;
    JToken JResult;
    JToken JMethod;
    JToken JAdditionalData;
    JToken JDataARM;
    
    bool resultEAC = true;
      
    private void Page_StartPage(object sender, EventArgs e)
    {
      JDoc = JToken.Parse(Report.GetParameterValue(&quot;JsonDoc&quot;).ToString());
      JSettings = JDoc[&quot;Doc&quot;][&quot;Settings&quot;];
      JTablePassport = JDoc[&quot;Doc&quot;][&quot;DataIVK&quot;][&quot;TablePassport&quot;];
      JAdditionalData = JDoc[&quot;Doc&quot;][&quot;DataIVK&quot;][&quot;TablePassport&quot;][&quot;AdditionalData&quot;];
      JResult = JDoc[&quot;Doc&quot;][&quot;DataIVK&quot;][&quot;TablePassport&quot;][&quot;PassportResult&quot;];
      JMethod = JDoc[&quot;Doc&quot;][&quot;DataIVK&quot;][&quot;TablePassport&quot;][&quot;TableActAndPassport&quot;][&quot;Passport&quot;];
      JDataARM = JDoc[&quot;Doc&quot;][&quot;DataIVK&quot;][&quot;TablePassport&quot;][&quot;DataARM&quot;];    
      
      //Настройки страницы 
      //Ширина и высота (в мм)
      Page.PaperHeight = (int)JSettings[&quot;General&quot;][&quot;PageSettings&quot;][&quot;PaperHeight&quot;];
      Page.PaperWidth = (int)JSettings[&quot;General&quot;][&quot;PageSettings&quot;][&quot;PaperWidth&quot;];
         
      //Поля/отступы от краёв (в мм)
      Page.TopMargin = (int)JSettings[&quot;General&quot;][&quot;PageSettings&quot;][&quot;TopMargin&quot;];
      Page.BottomMargin = (int)JSettings[&quot;General&quot;][&quot;PageSettings&quot;][&quot;BottomMargin&quot;];
      Page.LeftMargin = (int)JSettings[&quot;General&quot;][&quot;PageSettings&quot;][&quot;LeftMargin&quot;];
      Page.RightMargin = (int)JSettings[&quot;General&quot;][&quot;PageSettings&quot;][&quot;RightMargin&quot;];
         
      //Запуск отрисовки таблиц на странице отчета
      DrawTableHeader();
      DrawTablePassport();
      DrawTableSigners();
    }
      
    public void DrawTableHeader()
    {         
      DateTime Begin = new DateTime(1970, 1, 1, 0, 0, 0, DateTimeKind.Utc).AddSeconds((long)JTablePassport[&quot;Begin&quot;]);
      DateTime End = new DateTime(1970, 1, 1, 0, 0, 0, DateTimeKind.Utc).AddSeconds((long)JTablePassport[&quot;End&quot;]);
         
      DateTime SamplingPeriodBegin = new DateTime(1970, 1, 1, 0, 0, 0, DateTimeKind.Utc).AddSeconds((long)JAdditionalData[&quot;PassportPeriodDt&quot;][&quot;Begin&quot;]);
      DateTime SamplingPeriodEnd = new DateTime(1970, 1, 1, 0, 0, 0, DateTimeKind.Utc).AddSeconds((long)JAdditionalData[&quot;PassportPeriodDt&quot;][&quot;End&quot;]);
      
      NumberPassport.Text = $&quot;№ {JResult[&quot;PassportId&quot;]}&quot;; 
      DatePassport.Text = $&quot;Дата выдачи: {Begin.ToShortDateString()} г.&quot;; //&quot;dd.MM.yyyy&quot;
      
      NameCompanyAndLocationImporter.Text = $&quot;{JDataARM[&quot;Passport_EAC&quot;][&quot;NameCompanyAndLocationImporter&quot;]}&quot;;
      PlaceProductionOil.Text = $&quot;{JDataARM[&quot;Passport_EAC&quot;][&quot;PlaceProductionOil&quot;]}&quot;;
      NameDocumentForProducedOil.Text = $&quot;{JDataARM[&quot;Passport_EAC&quot;][&quot;NameDocumentForProducedOil&quot;]}&quot;;
      NameLaboratory.Text = $&quot;{JDataARM[&quot;Passport_EAC&quot;][&quot;NameLaboratory&quot;]}&quot;;
      NumberPartyAndDateManufacture.Text = $&quot;{JDataARM[&quot;Passport_EAC&quot;][&quot;NumberPartyAndDateManufacture&quot;]}&quot;;
      NameDocumentForOilSample.Text = $&quot;{JDataARM[&quot;Passport_EAC&quot;][&quot;NameDocumentForOilSample&quot;]}&quot;;
      SIKN_Number.Text = $&quot;СИКН № {JAdditionalData[&quot;SIKN_Number&quot;]}&quot;;
      
      if ((int)JTablePassport[&quot;PeriodType&quot;] == 5)
      {
        string dateTimeEnd = SamplingPeriodEnd.ToString(&quot;HH:mm&quot;) == &quot;00:00&quot; ? SamplingPeriodEnd.AddDays(-1).ToString(&quot;dd.MM.yyyy HH:mm&quot;).Replace(&quot;00:00&quot;, &quot;24:00&quot;): SamplingPeriodEnd.ToString(&quot;dd.MM.yyyy HH:mm&quot;);
        DateTimeSampling.Text = $&quot;с {SamplingPeriodBegin.ToString(&quot;dd.MM.yyyy HH:mm&quot;)} до {dateTimeEnd}&quot;;      
      }      
      else
      {
        DateTimeSampling.Text = $&quot;{SamplingPeriodBegin.ToString(&quot;dd.MM.yyyy&quot;)} {SamplingPeriodBegin.ToString(&quot;HH:mm&quot;)}-{SamplingPeriodEnd.ToString(&quot;HH:mm&quot;).Replace(&quot;00:00&quot;, &quot;24:00&quot;)}&quot;;
      }
    }
             
    private void DrawTablePassport()
    {
      string result, secondResult;
      JToken metod, secondMetod;
      JToken metods = JDataARM[&quot;LabInfo&quot;];
      
      metod = GetMetod(metods, &quot;TempCorrection&quot;);
      result = $&quot;{JResult[&quot;TempResult&quot;]}&quot;;
      RowTempResult[5].Text = metod == null ? result : GetResult(metod, result);

      metod = GetMetod(metods, &quot;PressCorrection&quot;);
      result = $&quot;{JResult[&quot;PressResult&quot;]}&quot;;
      RowPressResult[5].Text = metod == null ? result : GetResult(metod, result);

      metod = GetMetod(metods, &quot;DensCorrection&quot;);
      result = $&quot;{JResult[&quot;DensResult&quot;]}&quot;;
      RowDensResult[5].Text = metod == null ? result : GetResult(metod, result);

      metod = GetMetod(metods, &quot;Dens20Correction&quot;);
      result = $&quot;{JResult[&quot;Dens20Result&quot;]}&quot;;
      RowDens20Result[5].Text = metod == null ? result : GetResult(metod, result);

      metod = GetMetod(metods, &quot;Dens15Correction&quot;);
      result = $&quot;{JResult[&quot;Dens15Result&quot;]}&quot;;
      RowDens15Result[5].Text = metod == null ? result : GetResult(metod, result);

      metod = GetMetod(metods, &quot;MassWaterFracCorrection&quot;);
      result = $&quot;{JResult[&quot;MassWaterFracResult&quot;]}&quot;;
      RowMassWaterFracResult[5].Text = metod == null ? result : GetResult(metod, result);
      if (!ComparisonResult(&quot;0.5&quot;, result)) resultEAC = false;

      metod = GetMetod(metods, &quot;Chloride_Salts.Concentration&quot;);
      secondMetod = GetMetod(metods, &quot;Chloride_Salts.MassFraction&quot;);
      result = $&quot;{JResult[&quot;Chloride_Salts&quot;][&quot;Concentration&quot;]}&quot;;
      secondResult = $&quot;{JResult[&quot;Chloride_Salts&quot;][&quot;MassFraction&quot;]}&quot;;
      RowChloride_Salts_Concentration[5].Text = metod == null ? result : GetResult(metod, result);
      if (!ComparisonResult(&quot;100&quot;, result)) resultEAC = false;
      RowChloride_Salts_MassFraction[5].Text = metod == null ? secondResult : GetResult(metod, secondResult);
      
      metod = GetMetod(metods, &quot;Impurity&quot;);
      result = $&quot;{JResult[&quot;Impurity&quot;]}&quot;;
      RowImpurity[5].Text = metod == null ? result : GetResult(metod, result);

      metod = GetMetod(metods, &quot;SulfurCorrection&quot;);
      result = $&quot;{JResult[&quot;SulfurResult&quot;]}&quot;;
      RowSulfurResult[5].Text = metod == null ? result : GetResult(metod, result);

      metod = GetMetod(metods, &quot;DNP.kPa&quot;);
      secondMetod = GetMetod(metods, &quot;DNP.mercury_mm&quot;);
      result = $&quot;{JResult[&quot;DNP&quot;][&quot;kPa&quot;]}&quot;;
      secondResult = $&quot;{JResult[&quot;DNP&quot;][&quot;mercury_mm&quot;]}&quot;;
      RowDNP[5].Text = $&quot;{(metod == null ? result : GetResult(metod, result))} ({(metod == null ? secondResult : GetResult(metod, secondResult))})&quot;;
      if (!ComparisonResult(&quot;66.7&quot;, result)) resultEAC = false;    
      if (!ComparisonResult(&quot;500&quot;, secondResult)) resultEAC = false;


      metod = GetMetod(metods, &quot;Yield_fraction_200&quot;);
      result = $&quot;{JResult[&quot;Yield_fraction_200&quot;]}&quot;;
      RowYield_fraction_200[5].Text = metod == null ? result : GetResult(metod, result);

      metod = GetMetod(metods, &quot;Yield_fraction_300&quot;);
      result = $&quot;{JResult[&quot;Yield_fraction_300&quot;]}&quot;;
      RowYield_fraction_300[5].Text = metod == null ? result : GetResult(metod, result);

      metod = GetMetod(metods, &quot;Mass_fraction_of_paraffin&quot;);
      result = $&quot;{JResult[&quot;Mass_fraction_of_paraffin&quot;]}&quot;;
      RowMass_fraction_of_paraffin[5].Text = metod == null ? result : GetResult(metod, result);

      metod = GetMetod(metods, &quot;Mass_fraction_of_hydrogen_sulfide&quot;);
      result = $&quot;{JResult[&quot;Mass_fraction_of_hydrogen_sulfide&quot;]}&quot;;
      RowMass_fraction_of_hydrogen_sulfide[5].Text = metod == null ? result : GetResult(metod, result);
      if (!ComparisonResult(&quot;20&quot;, result)) resultEAC = false;    


      metod = GetMetod(metods, &quot;Mass_fraction_of_methyl_and_ethyl_mercaptan&quot;);
      result = $&quot;{JResult[&quot;Mass_fraction_of_methyl_and_ethyl_mercaptan&quot;]}&quot;;
      RowMass_fraction_of_methyl_and_ethyl_mercaptan[5].Text = metod == null ? result : GetResult(metod, result);
      if (!ComparisonResult(&quot;40&quot;, result)) resultEAC = false;    


      metod = GetMetod(metods, &quot;Mass_fraction_of_organic_chlorides&quot;);
      result = $&quot;{JResult[&quot;Mass_fraction_of_organic_chlorides&quot;]}&quot;;
      RowMass_fraction_of_organic_chlorides[5].Text = metod == null ? result : GetResult(metod, result);
      if (!ComparisonResult(&quot;6&quot;, result)) resultEAC = false;    

      //Заполняем колонку метод испытаний
      RowTempResult[3].Text = $&quot;{JMethod[&quot;TempResult&quot;][&quot;Desc&quot;]}&quot;;
      RowPressResult[3].Text = $&quot;{JMethod[&quot;PressResult&quot;][&quot;Desc&quot;]}&quot;;
      RowDensResult[3].Text = $&quot;{JMethod[&quot;DensResult&quot;][&quot;Desc&quot;]}&quot;;
      RowDens20Result[3].Text = $&quot;{JMethod[&quot;Dens20Result&quot;][&quot;Desc&quot;]}&quot;;
      RowDens15Result[3].Text = $&quot;{JMethod[&quot;Dens15Result&quot;][&quot;Desc&quot;]}&quot;;
      RowMassWaterFracResult[3].Text = $&quot;{JMethod[&quot;MassWaterFracResult&quot;][&quot;Desc&quot;]}&quot;;
      RowChloride_Salts_Concentration[3].Text = $&quot;{JMethod[&quot;Chloride_Salts&quot;][&quot;Concentration&quot;][&quot;Desc&quot;]}&quot;;
      RowImpurity[3].Text = $&quot;{JMethod[&quot;Impurity&quot;][&quot;Desc&quot;]}&quot;;
      RowSulfurResult[3].Text = $&quot;{JMethod[&quot;SulfurResult&quot;][&quot;Desc&quot;]}&quot;;
      RowDNP[3].Text = $&quot;{JMethod[&quot;DNP&quot;][&quot;kPa&quot;][&quot;Desc&quot;]}&quot;;
      RowYield_fraction_200[3].Text = $&quot;{JMethod[&quot;Yield_fraction_200&quot;][&quot;Desc&quot;]}&quot;;
      RowYield_fraction_300[3].Text = $&quot;{JMethod[&quot;Yield_fraction_200&quot;][&quot;Desc&quot;]}&quot;;
      RowMass_fraction_of_paraffin[3].Text = $&quot;{JMethod[&quot;Mass_fraction_of_paraffin&quot;][&quot;Desc&quot;]}&quot;;
      RowMass_fraction_of_hydrogen_sulfide[3].Text = $&quot;{JMethod[&quot;Mass_fraction_of_hydrogen_sulfide&quot;][&quot;Desc&quot;]}&quot;;
      RowMass_fraction_of_methyl_and_ethyl_mercaptan[3].Text = $&quot;{JMethod[&quot;Mass_fraction_of_methyl_and_ethyl_mercaptan&quot;][&quot;Desc&quot;]}&quot;;
      RowMass_fraction_of_organic_chlorides[3].Text = $&quot;{JMethod[&quot;Mass_fraction_of_organic_chlorides&quot;][&quot;Desc&quot;]}&quot;;
    }      
     
    private static JToken GetMetod(JToken metods, string parameterKey) =&gt; metods.FirstOrDefault(x =&gt; x[&quot;ParameterKey&quot;].ToString() == parameterKey);

    private static string GetResult(JToken metod, string result)
    {
      result = result.Replace('.', ',');

      if ((bool)metod[&quot;Metod&quot;][&quot;LimitValueActivate&quot;])
      {
        if (!float.TryParse(result, out float value)) return result; //value = 0.0f;

        float limitValue = (float)metod[&quot;Metod&quot;][&quot;LimitValue&quot;];

        result = value &lt; limitValue ? $&quot;{metod[&quot;Metod&quot;][&quot;LimitValueString&quot;]}&quot; : result;
      }

      return result;
    }
    
    private static bool ComparisonResult(string valueEAC, string valueIVK)
    {
      float convertValueIVK, convertValueEAC;
      
      if (!float.TryParse(valueEAC.Replace('.', ','), out convertValueEAC))
        return false;
      
      if (!float.TryParse(valueIVK.Replace('.', ','), out convertValueIVK))
        return false;
      
      if (convertValueEAC &gt; convertValueIVK)
        return true;
      else
        return false;
    }
    
    public void  DrawTableSigners()
    {
      if (resultEAC)
        ResultEAC.Text = @&quot;Заключение: Нефть соответствует требованиям технического регламента Евразийского&lt;br&gt;экономического союза (ЕАЭС) «О безопасности нефти, подготовленной к транспортировке и (или) использованию» ТР ЕАЭС 045/2017.&quot;;
      else
        ResultEAC.Text = @&quot;Заключение: Нефть не соответствует требованиям технического регламента Евразийского&lt;br&gt;экономического союза (ЕАЭС) «О безопасности нефти, подготовленной к транспортировке и (или) использованию» ТР ЕАЭС 045/2017.&quot;;
        
      Delive_Post_Factory.Text = $&quot;{JAdditionalData[&quot;Delive_Post&quot;]}\n{JAdditionalData[&quot;Delive_Factory&quot;]}&quot;;
      Delive_FIO.Text = $&quot;{JAdditionalData[&quot;Delive_IOF&quot;]}&quot;;
      Receive_Post_Factory.Text = $&quot;{JAdditionalData[&quot;Receive_Post&quot;]}\n{JAdditionalData[&quot;Receive_Factory&quot;]}&quot;;
      Receive_FIO.Text = $&quot;{JAdditionalData[&quot;Receive_IOF&quot;]}&quot;;
    } 
  }    
}</ScriptText>
