          <TableCell Name="Cell1525" HorzAlign="Center" VertAlign="Center" Font="Arial, 11pt" FontWidthRatio="0.85" TextRenderType="HtmlTags"/>
        </TableRow>
        <TableRow Name="Row193" Height="15.12">
          <TableCell Name="Cell1607" Text="К акту приема-сдачи нефти № / 石油交接单编号" Padding="0, 0, 0, 0" VertAlign="Center" Font="Arial, 9pt" FontWidthRatio="0.85"/>
