          <TableCell Name="Cell478" Border.Lines="All" Text="Результат&#13;&#10;испытаний&#13;&#10;化验结果" Padding="0, 0, 0, 0" HorzAlign="Center" VertAlign="Center" Font="Arial, 9pt, style=Bold" FontWidthRatio="0.85" TextRenderType="HtmlTags"/>
        </TableRow>
