        <TableColumn Name="Column28" Width="100.17"/>
        <TableRow Name="RowHeader" Height="45.36">
          <TableCell Name="Cell475" Border.Lines="All" Text="&lt;b&gt;№&lt;/b&gt;" Padding="0, 0, 4, 0" HorzAlign="Center" VertAlign="Center" Font="Arial, 9pt" FontWidthRatio="0.85" TextRenderType="HtmlTags"/>
          <TableCell Name="Cell476" Border.Lines="All" Text="Наименование показателя&#13;&#10;指标名称" Padding="0, 0, 0, 0" HorzAlign="Center" VertAlign="Center" Font="Arial, 9pt, style=Bold" FontWidthRatio="0.85"/>
