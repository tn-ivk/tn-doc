    <DataBand Name="DataBandTablePassport" Top="168.17" Width="718.2" Height="468.72" CanGrow="true" CanShrink="true" AfterPrintEvent="DataBandTableAct_AfterPrint" CanBreak="true">
      <TableObject Name="TablePassport" Top="9.45" Width="718.2" Height="459.27" Border.Lines="All" GrowToBottom="true" FixedRows="1">
