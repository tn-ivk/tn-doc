<?xml version="1.0" encoding="utf-8"?>
<Report ScriptLanguage="CSharp" ReferencedAssemblies="System.dll&#13;&#10;System.Drawing.dll&#13;&#10;System.Data.dll&#13;&#10;System.Xml.dll&#13;&#10;FastReport.Compat.dll&#13;&#10;System.Windows.Forms.dll&#13;&#10;FastReport.DataVisualization.dll&#13;&#10;Newtonsoft.Json.dll&#13;&#10;System.Core.dll&#13;&#10;TN_ToolsFastReport.dll" DoublePass="true" FinishReportEvent="_FinishReport" ReportInfo.Created="03/25/2020 12:46:46" ReportInfo.Modified="08/11/2025 16:49:26" ReportInfo.CreatorVersion="2024.2.20.0">
  <ScriptText>using System;
using System.Linq;
using FastReport;
using FastReport.Data;
using FastReport.Dialog;
using FastReport.Barcode;
using FastReport.Table;  
using FastReport.Utils;
using Newtonsoft.Json.Linq;

namespace FastReport
{
  public class ReportScript
  {
    TN_ToolsFastReport.Tools tools = new TN_ToolsFastReport.Tools();
    JToken JDoc;
    JToken JSettings;
    JToken JTablePassport;
    JToken JResult;
    JToken JMethod;
    JToken JAdditionalData;
    JToken JDataARM;
    
    private void Page_StartPage(object sender, EventArgs e)
    {
      JDoc = JToken.Parse(Report.GetParameterValue(&quot;JsonDoc&quot;).ToString());
      JSettings = JDoc[&quot;Doc&quot;][&quot;Settings&quot;];
      JTablePassport = JDoc[&quot;Doc&quot;][&quot;DataIVK&quot;][&quot;TablePassport&quot;];
      JAdditionalData = JDoc[&quot;Doc&quot;][&quot;DataIVK&quot;][&quot;TablePassport&quot;][&quot;AdditionalData&quot;];
      JResult = JDoc[&quot;Doc&quot;][&quot;DataIVK&quot;][&quot;TablePassport&quot;][&quot;PassportResult&quot;];
      JMethod = JDoc[&quot;Doc&quot;][&quot;DataIVK&quot;][&quot;TablePassport&quot;][&quot;TableActAndPassport&quot;][&quot;Passport&quot;];
      JDataARM = JDoc[&quot;Doc&quot;][&quot;DataIVK&quot;][&quot;TablePassport&quot;][&quot;DataARM&quot;];    
      
      //Настройки страницы 
      //Ширина и высота (в мм)
      Page.PaperHeight = (int)JSettings[&quot;General&quot;][&quot;PageSettings&quot;][&quot;PaperHeight&quot;];
      Page.PaperWidth = (int)JSettings[&quot;General&quot;][&quot;PageSettings&quot;][&quot;PaperWidth&quot;];
         
      //Поля/отступы от краёв (в мм)
      Page.TopMargin = (int)JSettings[&quot;General&quot;][&quot;PageSettings&quot;][&quot;TopMargin&quot;];
      Page.BottomMargin = (int)JSettings[&quot;General&quot;][&quot;PageSettings&quot;][&quot;BottomMargin&quot;];
      Page.LeftMargin = (int)JSettings[&quot;General&quot;][&quot;PageSettings&quot;][&quot;LeftMargin&quot;];
      Page.RightMargin = (int)JSettings[&quot;General&quot;][&quot;PageSettings&quot;][&quot;RightMargin&quot;];
         
      //Запуск отрисовки таблиц на странице отчета
      DrawPageHeader();
      DrawTableHeader();
      DrawTablePassport();
      DrawTableSigners();
    }
    
    public void DrawPageHeader()
    {            
      PageHeaderText.Text = $&quot;{JSettings[&quot;Header&quot;][&quot;NameIVK&quot;]}&quot;; //(string)JSettings[&quot;Header&quot;][&quot;NameIVK&quot;];
    }
      
    public void DrawTableHeader()
    {         
      DateTime Begin = tools.UnixTimestampToDatetime((long)JTablePassport[&quot;Begin&quot;]);
      DateTime End = tools.UnixTimestampToDatetime((long)JTablePassport[&quot;End&quot;]);
         
      DateTime SamplingPeriodBegin = tools.UnixTimestampToDatetime((long)JAdditionalData[&quot;PassportPeriodDt&quot;][&quot;Begin&quot;]);
      DateTime SamplingPeriodEnd = tools.UnixTimestampToDatetime((long)JAdditionalData[&quot;PassportPeriodDt&quot;][&quot;End&quot;]);
      
      NumberAndDatePassport.Text = string.Format(&quot;№ &lt;u&gt;{0}&lt;/u&gt; от 日期 &lt;u&gt;{1:dd.MM.yyyy}&lt;/u&gt; г.&quot;, JResult[&quot;PassportId&quot;], Begin.ToShortDateString());
      ProtokolNumAct.Text = $&quot;{JDoc[&quot;Doc&quot;][&quot;DataIVK&quot;][&quot;TablePassport&quot;][&quot;DataARM&quot;][&quot;ProtokolNumAct&quot;]}&quot;;
      DelivePoint.Text = $&quot;{JAdditionalData[&quot;DelivePoint&quot;]} 加林达&quot;;
      //Laboratory.Text = $&quot;{JAdditionalData[&quot;Laboratory&quot;]}&quot;;
      AccrSertifNumber.Text = $&quot;{JAdditionalData[&quot;AccrSertifNumber&quot;]}&quot;;
      SIKN_Number.Text = $&quot;{JAdditionalData[&quot;SIKN_Number&quot;]}&quot;;
      //Reservoir.Text = &quot;&quot;;
      
      var correctedSamplingEnd = string.Empty; 
      if(SamplingPeriodEnd &gt; SamplingPeriodBegin &amp;&amp; SamplingPeriodEnd.ToString(&quot;HH:mm&quot;) == &quot;00:00&quot;)
        correctedSamplingEnd = SamplingPeriodEnd.AddDays(-1).ToString(&quot;dd.MM.yyyy HH:mm&quot;).Replace(&quot;00:00&quot;, &quot;24:00&quot;);
      var samplingEnd = string.IsNullOrEmpty(correctedSamplingEnd) ? SamplingPeriodEnd.ToString(&quot;dd.MM.yyyy HH:mm&quot;) : correctedSamplingEnd; 
      DateTimeSampling.Text = $&quot;{SamplingPeriodBegin.ToString(&quot;dd.MM.yyyy HH:mm&quot;)} - {samplingEnd}&quot;;      
    }
             
    private void DrawTablePassport()
    {
      string result, secondResult;
      JToken metod, secondMetod;
      JToken metods = JDataARM[&quot;LabInfo&quot;];
      
      metod = GetMetod(metods, &quot;TempCorrection&quot;);
      result = $&quot;{JResult[&quot;TempResult&quot;]}&quot;;
      RowTempResult[3].Text = metod == null ? result : GetResult(metod, result);

      metod = GetMetod(metods, &quot;PressCorrection&quot;);
      result = $&quot;{JResult[&quot;PressResult&quot;]}&quot;;
      RowPressResult[3].Text = metod == null ? result : GetResult(metod, result);

      metod = GetMetod(metods, &quot;DensCorrection&quot;);
      result = $&quot;{JResult[&quot;DensResult&quot;]}&quot;;
      RowDensResult[3].Text = metod == null ? result : GetResult(metod, result);

      metod = GetMetod(metods, &quot;Dens20Correction&quot;);
      result = $&quot;{JResult[&quot;Dens20Result&quot;]}&quot;;
      RowDens20Result[3].Text = metod == null ? result : GetResult(metod, result);

      metod = GetMetod(metods, &quot;Dens15Correction&quot;);
      result = $&quot;{JResult[&quot;Dens15Result&quot;]}&quot;;
      RowDens15Result[3].Text = metod == null ? result : GetResult(metod, result);

      metod = GetMetod(metods, &quot;MassWaterFracCorrection&quot;);
      result = $&quot;{JResult[&quot;MassWaterFracResult&quot;]}&quot;;
      RowMassWaterFracResult[3].Text = metod == null ? result : GetResult(metod, result);

      metod = GetMetod(metods, &quot;Chloride_Salts.Concentration&quot;);
      secondMetod = GetMetod(metods, &quot;Chloride_Salts.MassFraction&quot;);
      result = $&quot;{JResult[&quot;Chloride_Salts&quot;][&quot;Concentration&quot;]}&quot;;
      secondResult = $&quot;{JResult[&quot;Chloride_Salts&quot;][&quot;MassFraction&quot;]}&quot;;
      RowChloride_Salts[3].Text = $&quot;{(metod == null ? result : GetResult(metod, result))} ({(secondMetod == null ? secondResult : GetResult(secondMetod, secondResult))})&quot;;

      metod = GetMetod(metods, &quot;Impurity&quot;);
      result = $&quot;{JResult[&quot;Impurity&quot;]}&quot;;
      RowImpurity[3].Text = metod == null ? result : GetResult(metod, result);

      metod = GetMetod(metods, &quot;SulfurCorrection&quot;);
      result = $&quot;{JResult[&quot;SulfurResult&quot;]}&quot;;
      RowSulfurResult[3].Text = metod == null ? result : GetResult(metod, result);

      metod = GetMetod(metods, &quot;DNP.kPa&quot;);
      secondMetod = GetMetod(metods, &quot;DNP.mercury_mm&quot;);
      result = $&quot;{JResult[&quot;DNP&quot;][&quot;kPa&quot;]}&quot;;
      secondResult = $&quot;{JResult[&quot;DNP&quot;][&quot;mercury_mm&quot;]}&quot;;
      RowDNP[3].Text = $&quot;{(metod == null ? result : GetResult(metod, result))} ({(secondMetod == null ? secondResult : GetResult(secondMetod, secondResult))})&quot;;

      metod = GetMetod(metods, &quot;Yield_fraction_200&quot;);
      result = $&quot;{JResult[&quot;Yield_fraction_200&quot;]}&quot;;
      RowYield_fraction[3].Text = metod == null ? result : GetResult(metod, result);

      metod = GetMetod(metods, &quot;Yield_fraction_300&quot;);
      result = $&quot;\n{JResult[&quot;Yield_fraction_300&quot;]}&quot;;
      RowYield_fraction[3].Text += metod == null ? result : GetResult(metod, result);

      //metod = GetMetod(metods, &quot;Yield_fraction_350&quot;);
      //result = $&quot;\n{JResult[&quot;Yield_fraction_350&quot;]}&quot;;
      //RowYield_fraction[3].Text += metod == null ? result : GetResult(metod, result);

      metod = GetMetod(metods, &quot;Mass_fraction_of_paraffin&quot;);
      result = $&quot;{JResult[&quot;Mass_fraction_of_paraffin&quot;]}&quot;;
      RowMass_fraction_of_paraffin[3].Text = metod == null ? result : GetResult(metod, result);

      metod = GetMetod(metods, &quot;Mass_fraction_of_hydrogen_sulfide&quot;);
      result = $&quot;{JResult[&quot;Mass_fraction_of_hydrogen_sulfide&quot;]}&quot;;
      RowMass_fraction_of_hydrogen_sulfide[3].Text = metod == null ? result : GetResult(metod, result);

      metod = GetMetod(metods, &quot;Mass_fraction_of_methyl_and_ethyl_mercaptan&quot;);
      result = $&quot;{JResult[&quot;Mass_fraction_of_methyl_and_ethyl_mercaptan&quot;]}&quot;;
      RowMass_fraction_of_methyl_and_ethyl_mercaptan[3].Text = metod == null ? result : GetResult(metod, result);

      metod = GetMetod(metods, &quot;Mass_fraction_of_organic_chlorides&quot;);
      result = $&quot;{JResult[&quot;Mass_fraction_of_organic_chlorides&quot;]}&quot;;
      RowMass_fraction_of_organic_chlorides[3].Text = metod == null ? result : GetResult(metod, result);

      //Заполняем колонку метод испытаний
      RowTempResult[2].Text = $&quot;{JMethod[&quot;TempResult&quot;][&quot;Desc&quot;]}&quot;;
      RowPressResult[2].Text = $&quot;{JMethod[&quot;PressResult&quot;][&quot;Desc&quot;]}&quot;;
      RowDensResult[2].Text = $&quot;{JMethod[&quot;DensResult&quot;][&quot;Desc&quot;]}&quot;;
      RowDens20Result[2].Text = $&quot;{JMethod[&quot;Dens20Result&quot;][&quot;Desc&quot;]}&quot;;
      RowDens15Result[2].Text = $&quot;{JMethod[&quot;Dens15Result&quot;][&quot;Desc&quot;]}&quot;;
      RowMassWaterFracResult[2].Text = $&quot;{JMethod[&quot;MassWaterFracResult&quot;][&quot;Desc&quot;]}&quot;;
      RowChloride_Salts[2].Text = $&quot;{JMethod[&quot;Chloride_Salts&quot;][&quot;Concentration&quot;][&quot;Desc&quot;]}&quot;;
      RowImpurity[2].Text = $&quot;{JMethod[&quot;Impurity&quot;][&quot;Desc&quot;]}&quot;;
      RowSulfurResult[2].Text = $&quot;{JMethod[&quot;SulfurResult&quot;][&quot;Desc&quot;]}&quot;;
      RowDNP[2].Text = $&quot;{JMethod[&quot;DNP&quot;][&quot;kPa&quot;][&quot;Desc&quot;]}&quot;;
      RowYield_fraction[2].Text = $&quot;{JMethod[&quot;Yield_fraction_200&quot;][&quot;Desc&quot;]}&quot;;
      //RowYield_fraction[2].Text = $&quot;{JMethod[&quot;Yield_fraction_200&quot;][&quot;Desc&quot;]}\n{JMethod[&quot;Yield_fraction_300&quot;][&quot;Desc&quot;]}\n{JMethod[&quot;Yield_fraction_350&quot;][&quot;Desc&quot;]}&quot;;
      RowMass_fraction_of_paraffin[2].Text = $&quot;{JMethod[&quot;Mass_fraction_of_paraffin&quot;][&quot;Desc&quot;]}&quot;;
      RowMass_fraction_of_hydrogen_sulfide[2].Text = $&quot;{JMethod[&quot;Mass_fraction_of_hydrogen_sulfide&quot;][&quot;Desc&quot;]}&quot;;
      RowMass_fraction_of_methyl_and_ethyl_mercaptan[2].Text = $&quot;{JMethod[&quot;Mass_fraction_of_methyl_and_ethyl_mercaptan&quot;][&quot;Desc&quot;]}&quot;;
      RowMass_fraction_of_organic_chlorides[2].Text = $&quot;{JMethod[&quot;Mass_fraction_of_organic_chlorides&quot;][&quot;Desc&quot;]}&quot;;
    }      
     
    private static JToken GetMetod(JToken metods, string parameterKey) =&gt; metods.FirstOrDefault(x =&gt; x[&quot;ParameterKey&quot;].ToString() == parameterKey);

    private static string GetResult(JToken metod, string result)
    {
      result = result.Replace('.', ',');

      if ((bool)metod[&quot;Metod&quot;][&quot;LimitValueActivate&quot;])
      {
        if (!float.TryParse(result, out float value)) return result; //value = 0.0f;

        float limitValue = (float)metod[&quot;Metod&quot;][&quot;LimitValue&quot;];

        result = value &lt; limitValue ? $&quot;{metod[&quot;Metod&quot;][&quot;LimitValueString&quot;]}&quot; : result;
      }

      return result;
    }
    
    private static string GetFIO(JToken users, string parameterKey)
    {
      return users.FirstOrDefault(x =&gt; x[&quot;F&quot;].ToString().Replace(&quot;&lt;br&gt;&quot;,&quot;&quot;) == parameterKey)?[&quot;F&quot;].ToString();
    }

    public void  DrawTableSigners()
    {
      GOSTIndexResult.Text = string.Format(&quot;Обозначение нефти по ГОСТ Р 51858 /石油的标识/ &lt;u&gt;{0}&quot;, JResult[&quot;ExtendGostIndexResult&quot;].ToString().Replace('X','-'));
      Laboratory_IOF.Text = $&quot;{JAdditionalData[&quot;Laboratory_IOF&quot;]}&quot;;
      //Laboratory_Factory.Text = $&quot;{JAdditionalData[&quot;Laboratory_Factory&quot;]}&quot;;  
      Delive_Factory.Text = $&quot;{JAdditionalData[&quot;Delive_Factory&quot;]}&quot;;
      //Delive_IOF.Text = $&quot;{JAdditionalData[&quot;Delive_IOF&quot;]}&quot;;
      Receive_Factory.Text = $&quot;{JAdditionalData[&quot;Receive_Factory&quot;]}&quot;;
      //Receive_IOF.Text = $&quot;{JAdditionalData[&quot;Receive_IOF&quot;]}&quot;;
      
      string DeliveFIO = GetFIO(JSettings[&quot;Dictionarys&quot;][&quot;Users&quot;],$&quot;{JAdditionalData[&quot;Delive_IOF&quot;]}&quot;);
      string ReceiveFIO = GetFIO(JSettings[&quot;Dictionarys&quot;][&quot;Users&quot;],$&quot;{JAdditionalData[&quot;Receive_IOF&quot;]}&quot;);
      
      
      if (!string.IsNullOrEmpty(DeliveFIO)) {
        if (DeliveFIO.Contains(&quot;&lt;br&gt;&quot;)) {
          string FIO = DeliveFIO.Split(&quot;&lt;br&gt;&quot;)[0];
          if (FIO.Contains(&quot;.&quot;) &amp;&amp; FIO.Contains(&quot; &quot;))
            Delive_IOF.Text = $&quot;{FIO.Substring(FIO.IndexOf(' ')+1)} {FIO.Substring(0, FIO.IndexOf(' '))}&quot;;
          else
            Delive_IOF.Text = FIO; }}
      else    
        Delive_IOF.Text = $&quot;{JAdditionalData[&quot;Delive_IOF&quot;]}&quot;; 
      
      if (!string.IsNullOrEmpty(ReceiveFIO)) {
        if (ReceiveFIO.Contains(&quot;&lt;br&gt;&quot;))
          Receive_IOF.Text = ReceiveFIO.Split(&quot;&lt;br&gt;&quot;)[0]; }
      else  
        Receive_IOF.Text = $&quot;{JAdditionalData[&quot;Receive_IOF&quot;]}&quot;;
      
      
    } 
  }    
}</ScriptText>
