          <TableCell Name="Num" Border.Lines="All" Text="1." Padding="0, 0, 4, 0" HorzAlign="Center" VertAlign="Center" Font="Arial, 9pt" FontWidthRatio="0.85"/>
          <TableCell Name="NameParameter" Border.Lines="All" Text="Температура нефти при условиях измерений объема, °C&#13;&#10;体积计量下的温度, °С" Padding="0, 0, 0, 0" VertAlign="Center" Font="Arial, 9pt" FontWidthRatio="0.85"/>
          <TableCell Name="Method" Border.Lines="All" Padding="0, 0, 0, 0" HorzAlign="Center" VertAlign="Center" Font="Arial, 9pt" FontWidthRatio="0.85"/>
          <TableCell Name="Result" Border.Lines="All" Padding="0, 0, 0, 0" HorzAlign="Center" VertAlign="Center" Font="Arial, 9pt" FontWidthRatio="0.85"/>
        </TableRow>
        <TableRow Name="RowPressResult" Height="30.24" AutoSize="true">
          <TableCell Name="Cell1543" Border.Lines="All" Text="2." HorzAlign="Center" VertAlign="Center" Font="Arial, 9pt"/>
          <TableCell Name="Cell1544" Border.Lines="All" Text="Давление нефти при условиях измерений объема, МПа&#13;&#10;体积计量压力, Mpa" Padding="0, 0, 0, 0" VertAlign="Center" Font="Arial, 9pt"/>
          <TableCell Name="Cell1545" Border.Lines="All" Padding="0, 0, 0, 0" HorzAlign="Center" VertAlign="Center" Font="Arial, 9pt"/>
          <TableCell Name="Cell1546" Border.Lines="All" Padding="0, 0, 0, 0" HorzAlign="Center" VertAlign="Center" Font="Arial, 9pt"/>
