          <TableCell Name="Cell1576" Border.Lines="All" Text="&lt;b&gt;Давление насыщенных паров, кПа (мм рт. ст.)&lt;/b&gt;&lt;br&gt;&lt;i&gt;Vapor pressure, kPa (mm Hg)&lt;/i&gt;" Padding="0, 0, 0, 0" VertAlign="Center" Font="Arial, 9pt" TextRenderType="HtmlTags"/>
