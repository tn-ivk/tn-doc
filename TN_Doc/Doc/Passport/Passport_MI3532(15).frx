        <TableRow Name="Row187" Height="37.8" AutoSize="true">
          <TableCell Name="Cell1526" Text="ПАСПОРТ КАЧЕСТВА НЕФТИ&#13;&#10;CERTIFICATE OF QUALITY" HorzAlign="Center" VertAlign="Center" Font="Arial, 12pt, style=Bold" TextRenderType="HtmlTags" ColSpan="2"/>
          <TableCell Name="Cell1528" HorzAlign="Center" VertAlign="Center" Font="Arial, 11pt" TextRenderType="HtmlTags"/>
        </TableRow>
        <TableRow Name="Row186" Height="26.46" AutoSize="true">
