        <TableColumn Name="Column33" Width="224.91"/>
        <TableRow Name="Row189" Height="86.94" AutoSize="true">
          <TableCell Name="Cell1534" Text="    Пункт 3 заполняют по показаниям поточного плотномера (средневзвешенное значение &#13;&#10;плотности нефти за смену).&#13;&#10;    Пункты 4 и 5 заполняют по показаниям поточного плотномера (средневзвешенное &#13;&#10;значение плотности нефти за смену), приведенным к стандартным условиям.&#13;&#10;    При отказе поточного плотномера плотность нефти определяют в испытательной &#13;&#10;лаборатории." Padding="0, 0, 0, 0" VertAlign="Bottom" Font="Arial, 9pt" TextRenderType="HtmlTags" ColSpan="4"/>
          <TableCell Name="Cell1536" Padding="0, 0, 0, 0" VertAlign="Bottom" Font="Arial, 8pt" TextRenderType="HtmlTags"/>
