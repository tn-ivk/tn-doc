          <TableCell Name="Cell346" Text="&lt;b&gt;Номер аттестата аккредитации&lt;/b&gt; /certificate of accreditation/" Padding="0, 0, 0, 0" VertAlign="Center" Font="Arial, 9pt" TextRenderType="HtmlTags"/>
          <TableCell Name="AccrSertifNumber" Border.Lines="Bottom" Border.BottomLine.Width="0.75" Text="AccrSertifNumber" Padding="0, 0, 0, 0" VertAlign="Center" Font="Arial, 9pt" TextRenderType="HtmlTags"/>
        </TableRow>
        <TableRow Name="Row04" Height="15.12" AutoSize="true">
          <TableCell Name="Cell351" Text="&lt;b&gt;СИКН №&lt;/b&gt; /Oil measurement station/" Padding="0, 0, 0, 0" VertAlign="Center" Font="Arial, 9pt" TextRenderType="HtmlTags"/>
          <TableCell Name="SIKN_Number" Border.Lines="Bottom" Border.BottomLine.Width="0.75" Text="SIKN_Number" Padding="0, 0, 0, 0" VertAlign="Center" Font="Arial, 9pt" TextRenderType="HtmlTags"/>
        </TableRow>
        <TableRow Name="Row05" Height="15.12" AutoSize="true">
          <TableCell Name="Cell356" Text="&lt;b&gt;Мера вместимости&lt;/b&gt; /Measure of storage/" Padding="0, 0, 0, 0" VertAlign="Center" Font="Arial, 9pt" TextRenderType="HtmlTags"/>
          <TableCell Name="Reservoir" Border.Lines="Bottom" Border.BottomLine.Width="0.75" Text="Reservoir" Padding="0, 0, 0, 0" VertAlign="Center" Font="Arial, 9pt" TextRenderType="HtmlTags"/>
        </TableRow>
        <TableRow Name="Row06" Height="15.12" AutoSize="true">
          <TableCell Name="Cell359" Text="&lt;b&gt;Дата и время отбора пробы&lt;/b&gt; /Date and time of sampling/" Padding="0, 0, 0, 0" VertAlign="Center" Font="Arial, 9pt" TextRenderType="HtmlTags"/>
          <TableCell Name="DateTimeSampling" Border.Lines="Bottom" Border.BottomLine.Width="0.75" Text="DateTimeSampling" Padding="0, 0, 0, 0" VertAlign="Center" Font="Arial, 9pt" TextRenderType="HtmlTags"/>
        </TableRow>
      </TableObject>
    </ReportTitleBand>
    <DataBand Name="DataBandTablePassport" Top="158.21" Width="718.2" Height="478.17" CanGrow="true" CanShrink="true" AfterPrintEvent="DataBandTableAct_AfterPrint" CanBreak="true">
      <TableObject Name="TablePassport" Top="9.45" Width="718.2" Height="468.72" Border.Lines="All" GrowToBottom="true" FixedRows="1">
        <TableColumn Name="Column22" Width="30.24"/>
        <TableColumn Name="Column8" Width="415.8"/>
        <TableColumn Name="Column9" Width="171.99"/>
        <TableColumn Name="Column28" Width="100.17"/>
        <TableRow Name="RowHeader" Height="45.36">
          <TableCell Name="Cell475" Border.Lines="All" Text="&lt;b&gt;№&lt;/b&gt;" Padding="0, 0, 4, 0" HorzAlign="Center" VertAlign="Center" Font="Arial, 9pt" TextRenderType="HtmlTags"/>
          <TableCell Name="Cell476" Border.Lines="All" Text="&lt;b&gt;Наименование показателя&lt;/b&gt;&#13;&#10;Quality characteristics" Padding="0, 0, 0, 0" HorzAlign="Center" VertAlign="Center" Font="Arial, 9pt" TextRenderType="HtmlTags"/>
          <TableCell Name="Cell477" Border.Lines="All" Text="&lt;b&gt;Метод испытаний&lt;/b&gt;&#13;&#10;standard measurement&#13;&#10;method" Padding="0, 0, 0, 0" HorzAlign="Center" VertAlign="Center" Font="Arial, 9pt" TextRenderType="HtmlTags"/>
          <TableCell Name="Cell478" Border.Lines="All" Text="&lt;b&gt;Результат&#13;&#10;испытаний&lt;/b&gt;&#13;&#10;test result" Padding="0, 0, 0, 0" HorzAlign="Center" VertAlign="Center" Font="Arial, 9pt" TextRenderType="HtmlTags"/>
        </TableRow>
        <TableRow Name="RowTempResult" Height="30.24" AutoSize="true">
          <TableCell Name="Num" Border.Lines="All" Text="1." Padding="0, 0, 4, 0" HorzAlign="Center" Font="Arial, 9pt" TextRenderType="HtmlTags"/>
          <TableCell Name="NameParameter" Border.Lines="All" Text="&lt;b&gt;Температура нефти при условиях измерений объема, °C&lt;/b&gt;&lt;br&gt;&lt;i&gt;Temperature of oil volume measuring, °С&lt;/i&gt;" Padding="0, 0, 0, 0" VertAlign="Center" Font="Arial, 9pt" TextRenderType="HtmlTags"/>
          <TableCell Name="Method" Border.Lines="All" Padding="0, 0, 0, 0" HorzAlign="Center" VertAlign="Center" Font="Arial, 9pt"/>
          <TableCell Name="Result" Border.Lines="All" Padding="0, 0, 0, 0" HorzAlign="Center" VertAlign="Center" Font="Arial, 9pt"/>
        </TableRow>
        <TableRow Name="RowPressResult" Height="30.24" AutoSize="true">
          <TableCell Name="Cell1543" Border.Lines="All" Text="2." HorzAlign="Center" Font="Arial, 9pt"/>
          <TableCell Name="Cell1544" Border.Lines="All" Text="&lt;b&gt;Давление нефти при условиях измерений объема, МПа&lt;/b&gt;&lt;br&gt;&lt;i&gt;Pressure of oil volume measuring, Mpa&lt;/i&gt;" Padding="0, 0, 0, 0" VertAlign="Center" Font="Arial, 9pt" TextRenderType="HtmlTags"/>
          <TableCell Name="Cell1545" Border.Lines="All" Padding="0, 0, 0, 0" HorzAlign="Center" VertAlign="Center" Font="Arial, 9pt"/>
          <TableCell Name="Cell1546" Border.Lines="All" Padding="0, 0, 0, 0" HorzAlign="Center" VertAlign="Center" Font="Arial, 9pt"/>
        </TableRow>
        <TableRow Name="RowDensResult" Height="60.48" AutoSize="true">
          <TableCell Name="Cell1547" Border.Lines="All" Text="3." HorzAlign="Center" Font="Arial, 9pt"/>
          <TableCell Name="Cell1548" Border.Lines="All" Text="&lt;b&gt;Плотность нефти при температуре и давлении в&lt;br&gt;условиях измерений объема, кг/м³&lt;/b&gt;&lt;br&gt;&lt;i&gt;Density at the temperature and pressure of oil volume&lt;br&gt;measuring, kg/m³&lt;/i&gt;" Padding="0, 0, 0, 0" VertAlign="Center" Font="Arial, 9pt" TextRenderType="HtmlTags"/>
          <TableCell Name="Cell1549" Border.Lines="All" Padding="0, 0, 0, 0" HorzAlign="Center" VertAlign="Center" Font="Arial, 9pt"/>
          <TableCell Name="Cell1550" Border.Lines="All" Padding="0, 0, 0, 0" HorzAlign="Center" VertAlign="Center" Font="Arial, 9pt"/>
        </TableRow>
        <TableRow Name="RowDens20Result" Height="15.12" AutoSize="true">
