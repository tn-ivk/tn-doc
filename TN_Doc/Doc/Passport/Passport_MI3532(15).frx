          <TableCell Name="ProtokolNumAct" Border.Lines="Bottom" Border.BottomLine.Width="0.75" Text="ProtokolNumAct" Padding="0, 0, 0, 0" VertAlign="Center" Font="Arial, 9pt" TextRenderType="HtmlTags"/>
        </TableRow>
        <TableRow Name="Row01" Height="15.12" AutoSize="true">
