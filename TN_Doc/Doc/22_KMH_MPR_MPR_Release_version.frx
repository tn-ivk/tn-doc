  <ScriptText>using System;
using System.Reflection;
using System.Collections;
using System.Collections.Generic;
using System.ComponentModel;         
using System.Drawing;
using System.Data;
using System.IO;
using FastReport;
using FastReport.Data;
using FastReport.Dialog;
using FastReport.Barcode;
using FastReport.Table;
using FastReport.Utils;
using System.Linq;
using Newtonsoft.Json;
using TN.DocData;

namespace FastReport
{
  public class ReportScript
  {
    TN_ToolsFastReport.Tools tools = new TN_ToolsFastReport.Tools();  // классы отчета
    TN.Doc.Doc doc; // данные из входного параметра
    TN.DocData.General General;
    TN.Doc.HeaderDoc Header;
    TN.Doc.DataDoc SettingsData;
    TN.Doc.FooterDoc Footer;
    TN.Doc.DictionarysDoc Dictionarys;
    
    TN.Doc.DataIVKDoc DataIVK;        
    List &lt;TN.Doc.Table1&gt; listTable1Relults;
    
    string oilName;
      
    private void Page_StartPage(object sender, EventArgs e)
    {
      //using (var sr = new StreamReader(&quot;D:/!_Work/!_Транснефть/SVN/Work/Sources/Reports/FRX/Входящие данные от Алексея (классы и json)/22_TableKMH_MPR_MPR/DocKMH_MPR_MPR.json&quot;))
      //{
      // Read the stream as a string
      //   Report.SetParameterValue(&quot;Protocol&quot;, sr.ReadToEnd());
      //}
      //// Десериализация данных (формат json) из входного параметра - Json                         
      string json = (string)Report.GetParameterValue(&quot;JsonDoc&quot;);
      Newtonsoft.Json.JsonSerializerSettings settings = new Newtonsoft.Json.JsonSerializerSettings();
      settings.TypeNameHandling = TypeNameHandling.All;
         
      doc = JsonConvert.DeserializeObject&lt;TN.Doc.Doc&gt;(json, settings);
      General = (TN.DocData.General) doc.Doc.Settings.General;
      Header = (TN.Doc.HeaderDoc) doc.Doc.Settings.Header;
      SettingsData = (TN.Doc.DataDoc) doc.Doc.Settings.Data;
      Footer = (TN.Doc.FooterDoc) doc.Doc.Settings.Footer;
      Dictionarys = (TN.Doc.DictionarysDoc) doc.Doc.Settings.Dictionarys;  
      DataIVK = (TN.Doc.DataIVKDoc) doc.Doc.DataIVK;
         
      //// === Настройки страницы 
      // Ширина и высота (в мм)
         
      Page.PaperHeight = General.PageSettings.PaperHeight;
      Page.PaperWidth= General.PageSettings.PaperWidth;
      //Page.Border.Lines = BorderLines.All;
         
      // Поля/отступы от краёв (в мм)
      Page.TopMargin=General.PageSettings.TopMargin;
      Page.BottomMargin=General.PageSettings.BottomMargin;
      Page.LeftMargin=General.PageSettings.LeftMargin;
      Page.RightMargin=General.PageSettings.RightMargin;
         
      // Запуск отрисовки таблиц на странице отчета
      DrawTableHeader();
      DrawTableConclusion();
    }
      
    public void DrawTableHeader()
    {
      oilName = General.NefType == 1 ? &quot;Вязкость нефти при КМХ, мм&lt;sup&gt;2&lt;/sup&gt;/с (сСт):&quot; : &quot;Вязкость нефтепродукта при КМХ, мм&lt;sup&gt;2&lt;/sup&gt;/с (сСт):&quot;;
      
      // Setup Columns
      float widthDynamicCols=(Page.PaperWidth-Page.LeftMargin-Page.RightMargin)/TableHeader.ColumnCount;         
      for (int i = 0; i &lt; (TableHeader.ColumnCount); i++)                 
      {
        TableHeader.Columns[i].Width = widthDynamicCols*Units.Millimeters;
      }
      // Fill table with data   
      ProtocolType.Text = string.Format(&quot;Протокол № {0}&lt;br&gt;контроля МХ рабочего массового ПР&amp;nbsp;по контрольному массовому ПР&quot;,
        DataIVK.TableKMH_MPR_MPR.AdditionalInfo.ProtokolNum);
         
      MPR_Type.Text= string.Format(&quot;Тип ПР: &lt;u&gt;{0}&lt;/u&gt;&lt;br&gt;Заводской №:&lt;u&gt;{1}&lt;/u&gt; &lt;br&gt;Место проведения КМХ: &lt;u&gt;{2} &lt;/u&gt; (СИКН, НГДУ, ПСП)&lt;br&gt;Линия №:&lt;u&gt; {3}&quot;, 
        DataIVK.TableKMH_MPR_MPR.AdditionalInfo.MPR_Type, 
        DataIVK.TableKMH_MPR_MPR.AdditionalInfo.MPR_FactoryNum,
        DataIVK.TableKMH_MPR_MPR.AdditionalInfo.Place_SIKN_Name, 
        DataIVK.TableKMH_MPR_MPR.IL); 
         
      MPR_CTRL_Type.Text = string.Format(&quot;Тип контрольного ПР: &lt;u&gt;{0}&lt;/u&gt;&lt;br&gt;Заводской №: &lt;u&gt;{1}&lt;/u&gt;&lt;br&gt;Дата поверки ПУ: &lt;u&gt;{2}&lt;/u&gt;&lt;br&gt;{4} &lt;u&gt; {3}&quot;,
        DataIVK.TableKMH_MPR_MPR.AdditionalInfo.MPR_CTRL_Type,
        DataIVK.TableKMH_MPR_MPR.AdditionalInfo.MPR_CTRL_Factory,
        DataIVK.TableKMH_MPR_MPR.AdditionalInfo.MPR_CTRL_CheckDate,
        tools.GetNormalizedValue(DataIVK.TableKMH_MPR_MPR.Protokol.Visc),
        oilName);                      
    }

    private void TableResults_ManualBuild(object sender, EventArgs e)
    {
      listTable1Relults =DataIVK.TableKMH_MPR_MPR.Protokol.Table1.Where(i =&gt; ! i.Ser.Contains(&quot;-&quot;) &amp; String.IsNullOrEmpty(i.Ser) == false).ToList();            
      float initialHeight = 0;
      int tempCounter =0;
      int sumPointMeasures =0;
         
      //Setup Columns width                                                                                           
      int sumDynamicCols=TableResults.ColumnCount;                                                                                                                                
      float widthDynamicCol=(Page.PaperWidth-Page.LeftMargin-Page.RightMargin)/sumDynamicCols;                                                       
        
      for (int w = 0; w &lt; (TableResults.ColumnCount); w++)                                                                                                                                     
      {                                                                                                                                                                                                                                           
        TableResults.Columns[w].Width = widthDynamicCol * Units.Millimeters;                                                                                                     
      }  
      //Draw Fixed rows
      for (int n = 0; n &lt; TableResults.FixedRows; n++)
      {
        TableResults.PrintRow(n);
        TableResults.PrintColumns();                                             
      }
         
      //Calculating count of points &amp; measures
      for (int i = 0; i &lt; (listTable1Relults.Count); i++)  
      {
        sumPointMeasures = listTable1Relults.Count(z =&gt; z.Ser == (i+1).ToString());
        for (int j = 0; j &lt; sumPointMeasures; j++)                    
        {
          Ser.RowSpan =  sumPointMeasures;
          Ser.Text=listTable1Relults[j+tempCounter].Ser; 
          Row.Text=listTable1Relults[j+tempCounter].Row;    
          Q_K_ji.Text=tools.GetNormalizedValue(listTable1Relults[j+tempCounter].Q_K_ji);
          t_K_ji.Text=tools.GetNormalizedValue(listTable1Relults[j+tempCounter].t_K_ji);
          P_K_ji.Text=tools.GetNormalizedValue(listTable1Relults[j+tempCounter].P_K_ji);
          Q_P_ji.Text=tools.GetNormalizedValue(listTable1Relults[j+tempCounter].Q_P_ji);
          t_P_ji.Text=tools.GetNormalizedValue(listTable1Relults[j+tempCounter].t_P_ji);
          P_P_ji.Text=tools.GetNormalizedValue(listTable1Relults[j+tempCounter].P_P_ji);
          M_K_ji.Text=tools.GetNormalizedValue(listTable1Relults[j+tempCounter].M_K_ji);
          M_P_ji.Text=tools.GetNormalizedValue(listTable1Relults[j+tempCounter].M_P_ji);
          Delta_ji.Text=tools.GetNormalizedValue(listTable1Relults[j+tempCounter].Delta_ji);
               
          TableResults.PrintRow(4);
          TableResults.PrintColumns();
        }
        tempCounter=tempCounter+sumPointMeasures;   

        Ser.RowSpan = 1;
        initialHeight = BaseRow.Height;
        BaseRow.Height = 0;
        TableResults.PrintRow(4);
        TableResults.PrintColumns();
        BaseRow.Height= initialHeight;
      }
    }

    public void  DrawTableConclusion()
    {
      string result = DataIVK.TableKMH_MPR_MPR.AdditionalInfo.ARM_KMH_Result == &quot;годен&quot; ? &quot;МПР   годен к дальнейшей эксплуатации&quot; : &quot;МПР   не годен и подлежит внеочередной поверке&quot;;
      Conclusion.Text =string.Format(&quot;&lt;b&gt;2 Заключение: δ &lt;sub&gt;ij mах &lt;/sub&gt; = {0}%. {1}&quot;,                                                     
        tools.GetNormalizedValue(DataIVK.TableKMH_MPR_MPR.Protokol.Delta_Max),                                        
        result);    
         
      TableConclusion[0,2].Text = string.Format(&quot;Дата проведения КМХ: &lt;u&gt;{0:dd.MM.yyyy} г.&quot;,
        tools.UnixTimestampToDatetime(DataIVK.TableKMH_MPR_MPR.DateTimeLong));               
                                            
      ServiceStaffData.Text= DataIVK.TableKMH_MPR_MPR.AdditionalInfo.ServiceStaffData;     
      DeliveryStaffData.Text= DataIVK.TableKMH_MPR_MPR.AdditionalInfo.DeliveryStaffData;                
      RecievingStaffData.Text= DataIVK.TableKMH_MPR_MPR.AdditionalInfo.RecievingStaffData;
    }  
      
    private void PageFooter_BeforeLayout(object sender, EventArgs e)
    {
      if((Int32)Report.GetVariableValue(&quot;TotalPages&quot;) &lt; 2) 
      { 
        PageFooter.Visible = false; 
      }
      else
      {
        PageNumeration.Width = (Page.PaperWidth-Page.LeftMargin-Page.RightMargin)*Units.Millimeters;
      }
    }
  }    
}

