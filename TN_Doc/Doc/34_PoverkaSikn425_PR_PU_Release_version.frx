using FastReport.Dialog;
using FastReport.Barcode;
using FastReport.Table;
using FastReport.Utils;
using System.Linq;
using Newtonsoft.Json;
using TN.DocData;

namespace FastReport
{
  public class ReportScript
  {
    TN_ToolsFastReport.Tools tools = new TN_ToolsFastReport.Tools();  // классы отчета
    TN.Doc.Doc doc; // данные из входного параметра
    TN.DocData.General General;
    TN.Doc.HeaderDoc Header;
    TN.Doc.DataDoc SettingsData;
    TN.Doc.FooterDoc Footer;
    TN.Doc.DictionarysDoc Dictionarys;
    TN.Doc.DataIVKDoc DataIVK;
      
    List &lt;string&gt; listTable1Detectors;
    List &lt;string&gt; listTable1V0;
    List &lt;string&gt; listTable1Teta_Sum_0;
    List &lt;string&gt; listTable1Teta_V_0;
    List &lt;TN.Doc.Table2&gt; listTable2Results;
    List &lt;TN.Doc.Points&gt; listPointsTable3;      
      
    private void Page_StartPage(object sender, EventArgs e)
    {
      //// Десериализация данных (формат json) из входного параметра - Json                         
      string json = (string)Report.GetParameterValue(&quot;JsonDoc&quot;);
      Newtonsoft.Json.JsonSerializerSettings settings = new Newtonsoft.Json.JsonSerializerSettings();
      settings.TypeNameHandling = TypeNameHandling.All;
      
      doc = JsonConvert.DeserializeObject&lt;TN.Doc.Doc&gt;(json, settings);
      General = (TN.DocData.General) doc.Doc.Settings.General;
      Header = (TN.Doc.HeaderDoc) doc.Doc.Settings.Header;
      SettingsData = (TN.Doc.DataDoc) doc.Doc.Settings.Data;
      Footer = (TN.Doc.FooterDoc) doc.Doc.Settings.Footer;
      Dictionarys = (TN.Doc.DictionarysDoc) doc.Doc.Settings.Dictionarys;  
      DataIVK = (TN.Doc.DataIVKDoc) doc.Doc.DataIVK;     
      
      //// === Настройки страницы 
      // Ширина и высота (в мм)
      Page.PaperHeight = General.PageSettings.PaperHeight;
      Page.PaperWidth = General.PageSettings.PaperWidth;
      //Page.Border.Lines = BorderLines.All;
         
      // Поля/отступы от краёв (в мм)
      Page.TopMargin = General.PageSettings.TopMargin;
      Page.BottomMargin = General.PageSettings.BottomMargin;
      Page.LeftMargin = General.PageSettings.LeftMargin;
      Page.RightMargin = General.PageSettings.RightMargin;

      // Load data into global lists
      listTable2Results = DataIVK.TablePoverkaSikn425_PR_PU.Protokol.Table2.Where(i =&gt; ! i.ser.Contains(&quot;-&quot;) &amp; String.IsNullOrEmpty(i.ser) == false).ToList();
      //listPointsTable3 = DataIVK.TablePoverkaSikn425_PR_PU.Protokol.Table3.Point.Where(i =&gt; ! i.Point.Contains(&quot;-&quot;)   &amp; String.IsNullOrEmpty(i.Point) == false).ToList();
      listPointsTable3 = DataIVK.TablePoverkaSikn425_PR_PU.Protokol.Table3.Point.Where(i =&gt; ! i.ser.Contains(&quot;-&quot;) &amp; String.IsNullOrEmpty(i.ser) == false).ToList();
    
      // Запуск отрисовки таблиц на странице отчета
      DrawTableHeader();    
      DrawTableConclusion();
    }
    #region //Имхо лишний метод
    private void PrintTable(TableObject table)
    {
      for (int i=0;i&lt;table.RowCount;i++)
      {       
        table.PrintRow(i);
        table.PrintColumns();
      }    
    } 
    #endregion
      
    public void DrawTableHeader()
    {
      //Setup Columns width
      TableHeader01.Columns[0].Width = (Page.PaperWidth-Page.LeftMargin-Page.RightMargin)*Units.Millimeters;
         
      // Fill table with data   
      ProtokolNum.Text = &quot;П Р О Т О К О Л  № &quot; + DataIVK.TablePoverkaSikn425_PR_PU.AdditionalInfo.ProtokolNum;
      Place_SIKN.Text = string.Format(&quot;СИКН №{0}, {1}, {2}&quot;, 
        DataIVK.TablePoverkaSikn425_PR_PU.AdditionalInfo.PlaceSikn, 
        DataIVK.TablePoverkaSikn425_PR_PU.AdditionalInfo.PlacePsp,
        DataIVK.TablePoverkaSikn425_PR_PU.AdditionalInfo.PlaceFactory);
      MM_Sensor_Type.Text = DataIVK.TablePoverkaSikn425_PR_PU.AdditionalInfo.MprInfo.Sensor.DevType;
      MM_Sensor_FactoryNumber.Text = DataIVK.TablePoverkaSikn425_PR_PU.AdditionalInfo.MprInfo.Sensor.DevNumb;
      PR_LineName.Text = DataIVK.TablePoverkaSikn425_PR_PU.AdditionalInfo.MprInfo.LineName;
         
      MM_PEP.Text = DataIVK.TablePoverkaSikn425_PR_PU.AdditionalInfo.MprInfo.Pep.DevType;
      MM_PEP_FactoryNumber.Text = DataIVK.TablePoverkaSikn425_PR_PU.AdditionalInfo.MprInfo.Pep.DevNumb;
         
      PU_Type.Text = DataIVK.TablePoverkaSikn425_PR_PU.AdditionalInfo.PuInfo.DevType;
      PU_FactoryNumber.Text = DataIVK.TablePoverkaSikn425_PR_PU.AdditionalInfo.PuInfo.DevNumb;
      PP_Type.Text = DataIVK.TablePoverkaSikn425_PR_PU.AdditionalInfo.PpInfo.DevType;
      PP_FactoryNumber.Text = DataIVK.TablePoverkaSikn425_PR_PU.AdditionalInfo.PpInfo.DevNumb;
      IVK_Type.Text = DataIVK.TablePoverkaSikn425_PR_PU.AdditionalInfo.IvkInfo.DevType;
      IVK_FactoryNumber.Text = DataIVK.TablePoverkaSikn425_PR_PU.AdditionalInfo.IvkInfo.DevNumb;
      Oil_Type.Text = DataIVK.TablePoverkaSikn425_PR_PU.Protokol.OilType;
    }
              
    private void Table1SourceData_ManualBuild(object sender, EventArgs e)
    {
      // Get data for Table
      listTable1Detectors = DataIVK.TablePoverkaSikn425_PR_PU.Protokol.Table1.DetName.Where(i =&gt; i.Length &gt; 1 &amp; String.IsNullOrEmpty(i) == false).ToList();
      listTable1V0 = DataIVK.TablePoverkaSikn425_PR_PU.Protokol.Table1.V0.Where(i =&gt; ! i.Contains(&quot;-&quot;)  &amp; String.IsNullOrEmpty(i) == false).ToList();
      listTable1Teta_Sum_0 = DataIVK.TablePoverkaSikn425_PR_PU.Protokol.Table1.TetaSum0.Where(i =&gt; ! i.Contains(&quot;-&quot;) &amp; String.IsNullOrEmpty(i) == false).ToList();
      listTable1Teta_V_0 = DataIVK.TablePoverkaSikn425_PR_PU.Protokol.Table1.TetaV0.Where(i =&gt; ! i.Contains(&quot;-&quot;) &amp; String.IsNullOrEmpty(i) == false).ToList();

      //Setup Columns width
      int sumDynamicCols=Table1SourceData.ColumnCount;
      float widthDynamicCol=(Page.PaperWidth-Page.LeftMargin-Page.RightMargin)/sumDynamicCols;                  
 
      for (int w = 0; w &lt; (Table1SourceData.ColumnCount); w++)                 
      {
        Table1SourceData.Columns[w].Width = widthDynamicCol * Units.Millimeters;
      }      
                            
      //Draw Fixed rows
      for (int n = 0; n &lt; Table1SourceData.FixedRows; n++)
      {
        Table1SourceData.PrintRow(n);
        Table1SourceData.PrintColumns();                                             
      }
                                                     
      //Fill table with data
      for (int n = 0; n &lt; (listTable1Detectors.Count); n++)
      {
        DetName.Text =  listTable1Detectors[n];
        V0.Text =  tools.GetNormalizedValue(listTable1V0[n]);        
        D_V0.Text = tools.GetNormalizedValue(DataIVK.TablePoverkaSikn425_PR_PU.Protokol.Table1.D_V0);
        S_V0.Text = tools.GetNormalizedValue(DataIVK.TablePoverkaSikn425_PR_PU.Protokol.Table1.S_V0);
        E_V0.Text = tools.GetNormalizedValue(DataIVK.TablePoverkaSikn425_PR_PU.Protokol.Table1.E_V0);
        Alpha_t.Text = tools.GetNormalizedValue(DataIVK.TablePoverkaSikn425_PR_PU.Protokol.Table1.alpha_t);
        Teta_Sum_0.Text = tools.GetNormalizedValue(listTable1Teta_Sum_0[n]);        
        Teta_V_0.Text = tools.GetNormalizedValue(listTable1Teta_V_0[n]);        
                           
        //RowSpans
        for (int i = 0; i &lt; (Table1SourceData.ColumnCount); i++)
        {          
          switch(i)
          {
            case 2:
            case 3:  
            case 4:
            case 5:  
              Table1SourceData[i,3].RowSpan =  listTable1Detectors.Count;
              break;  
          }
        }
                             
        Table1SourceData.PrintRow(3);     
        Table1SourceData.PrintColumns();  
      }                            
    }
      
    private void Table1SourceDataEnding_ManualBuild(object sender, EventArgs e)
    {                         
      //Setup Columns width as in the previous table
      for (int i = 0; i &lt; (Table1SourceDataEnding.ColumnCount); i++)
      {          
        Table1SourceDataEnding.Columns[i].Width =  Table1SourceData.Columns[i].Width;
      }
         
      //Draw Fixed rows
      for (int n = 0; n &lt; Table1SourceDataEnding.FixedRows; n++)
      {
        Table1SourceDataEnding.PrintRow(n);
        Table1SourceDataEnding.PrintColumns();                                             
      }           
         
      //Fill table with data                 
      Delta_t_PU.Text = tools.GetNormalizedValue(DataIVK.TablePoverkaSikn425_PR_PU.Protokol.Table1.Delta_tPU);
      Delta_t_PP.Text = tools.GetNormalizedValue(DataIVK.TablePoverkaSikn425_PR_PU.Protokol.Table1.Delta_tPP);                               
      Delta_Dens_PP.Text = tools.GetNormalizedValue(DataIVK.TablePoverkaSikn425_PR_PU.Protokol.Table1.Delta_DensPP);
      Delta_IVK.Text = tools.GetNormalizedValue(DataIVK.TablePoverkaSikn425_PR_PU.Protokol.Table1.deltaIVK);            
      ZSk.Text = tools.GetNormalizedValue(DataIVK.TablePoverkaSikn425_PR_PU.Protokol.Table1.ZSk);                                    

      Table1SourceDataEnding.PrintRow(3);     
      Table1SourceDataEnding.PrintColumns();           
    }

    private void Table2Results_ManualBuild(object sender, EventArgs e)
    {                                                                                                                               
      //Setup Columns width
      int sumDynamicCols=Table2Results.ColumnCount;
      float widthDynamicCol=(Page.PaperWidth-Page.LeftMargin-Page.RightMargin)/sumDynamicCols;                  
      for (int w = 0; w &lt; (Table2Results.ColumnCount); w++)                 
      {
        Table2Results.Columns[w].Width = widthDynamicCol * Units.Millimeters;
      }      
         
      //Draw Fixed rows
      for (int n = 0; n &lt; Table2Results.FixedRows; n++)
      {
        Table2Results.PrintRow(n);
        Table2Results.PrintColumns();                                             
      }
         
      //Fill table with data
      for (int n = 0; n &lt; (listTable2Results.Count); n++)
      {
        SerRow.Text =  String.Format(&quot;{0}/{1}&quot;, listTable2Results[n].ser, listTable2Results[n].row);//+ &quot; | &quot; + (n+1).ToString();
        Q_jik.Text = tools.GetNormalizedValue(listTable2Results[n].Q_jik);
        Detector.Text =  tools.GetNormalizedValue(listTable2Results[n].Det);
        T_jik.Text = tools.GetNormalizedValue(listTable2Results[n].T_jik);
        t_PU_jik.Text = tools.GetNormalizedValue(listTable2Results[n].t_PU_jik);
        P_PU_jik.Text = tools.GetNormalizedValue(listTable2Results[n].P_PU_jik);
        Dens_jik.Text = tools.GetNormalizedValue(listTable2Results[n].dens_PP_jik);
        DensTemp_jik.Text =  tools.GetNormalizedValue(listTable2Results[n].t_PP_jik);
            
        Table2Results.PrintRow(3);     
        Table2Results.PrintColumns();  
      }                  
    }

    private void Table2ResultsEnding_ManualBuild(object sender, EventArgs e)
    {
                              
      //Setup Columns widths as previous table
      for (int i = 0; i &lt; (Table2ResultsEnding.ColumnCount); i++)
      {          
        Table2ResultsEnding.Columns[i].Width =  Table2Results.Columns[i].Width;
      }
          
      //Draw Fixed rows
      for (int n = 0; n &lt; Table2ResultsEnding.FixedRows; n++)
      {
        Table2ResultsEnding.PrintRow(n);
        Table2ResultsEnding.PrintColumns();                                             
      }
         
      //Fill table with data
      for (int n = 0; n &lt; (listTable2Results.Count); n++)
      {
        SerRow2.Text =  String.Format(&quot;{0}/{1}&quot;, listTable2Results[n].ser, listTable2Results[n].row);//+ &quot; | &quot; + (n+1).ToString();
        DensPress_jik.Text =  tools.GetNormalizedValue(listTable2Results[n].P_PP_jik);
        Beta_jik.Text = tools.GetNormalizedValue(listTable2Results[n].beta_jik);
        N_jik.Text = tools.GetNormalizedValue(listTable2Results[n].N_jik);
        M_jik.Text = tools.GetNormalizedValue(listTable2Results[n].Mpu_jik);
        K_jik.Text = tools.GetNormalizedValue(listTable2Results[n].Kpm_jik);

        Table2ResultsEnding.PrintRow(3);     
        Table2ResultsEnding.PrintColumns();  
      }
    }
      
    private void Table3Results_ManualBuild(object sender, EventArgs e)
    {
      //Setup Columns width
      int sumDynamicCols=Table3Results.ColumnCount;
      float widthDynamicCol=(Page.PaperWidth-Page.LeftMargin-Page.RightMargin)/sumDynamicCols;                  
      for (int w = 0; w &lt; (Table3Results.ColumnCount); w++)                 
      {
        Table3Results.Columns[w].Width = widthDynamicCol * Units.Millimeters;
      }      
         
      //Draw Fixed rows 
      for (int n = 0; n &lt; Table3Results.FixedRows; n++)
      {
        Table3Results.PrintRow(n);
        Table3Results.PrintColumns();                                             
      }
             
      //Fill table with data
      for (int n = 0; n &lt; (listPointsTable3.Count); n++)
      {
        Point.Text =  listPointsTable3[n].ser;
        Q_jk.Text = tools.GetNormalizedValue(listPointsTable3[n].Q_jk);
        K_jk.Text = tools.GetNormalizedValue(listPointsTable3[n].Kpm_jk);
        S_jk.Text =tools.GetNormalizedValue( listPointsTable3[n].S_jk);
        n_jk.Text = tools.GetNormalizedValue(listPointsTable3[n].n_jk);
        S0_jk.Text = tools.GetNormalizedValue(listPointsTable3[n].S0_jk);
        t095_jk.Text = tools.GetNormalizedValue(listPointsTable3[n].t095_jk);
        e_jk.Text =  tools.GetNormalizedValue(listPointsTable3[n].e_jk);
           
        Table3Results.PrintRow(3);     
        Table3Results.PrintColumns();  
      }              
    }
      
    private void Table3ResultsEnding_ManualBuild(object sender, EventArgs e)
    {     
      //Setup Columns widths as previous table
      for (int i = 0; i &lt; (Table3ResultsEnding.ColumnCount); i++)
      {          
        Table3ResultsEnding.Columns[i].Width =  Table3Results.Columns[i].Width;
      }
          
      //Draw Fixed rows
      for (int n = 0; n &lt; Table3ResultsEnding.FixedRows; n++)
      {
        Table3ResultsEnding.PrintRow(n);
        Table3ResultsEnding.PrintColumns();                                             
      }                   
         
      Teta_tk.Text = tools.GetNormalizedValue(DataIVK.TablePoverkaSikn425_PR_PU.Protokol.Table3.Teta_t_k);
      Teta_pk.Text = tools.GetNormalizedValue(DataIVK.TablePoverkaSikn425_PR_PU.Protokol.Table3.Teta_p_k);
      Delta_k.Text = tools.GetNormalizedValue(DataIVK.TablePoverkaSikn425_PR_PU.Protokol.Table3.delta_k);
      
      //Fill table with data
      for (int n = 0; n &lt; (listPointsTable3.Count); n++)
      {
        Point2.Text =  listPointsTable3[n].ser;
        Teta_Z_jk.Text =tools.GetNormalizedValue(listPointsTable3[n].Teta_Z_jk);
        Teta_Sum_jk.Text =tools.GetNormalizedValue(listPointsTable3[n].Teta_Sum_jk);
        Delta_jk.Text =tools.GetNormalizedValue(listPointsTable3[n].delta_jk);
            
        //RowSpans
        for (int i = 0; i &lt; (Table3ResultsEnding.ColumnCount); i++)
        {          
          switch(i)
          {
            case 1:
            case 2:  
            case 6:
              Table3ResultsEnding[i,3].RowSpan =  listPointsTable3.Count;
              break;  
          }
        }
        Table3ResultsEnding.PrintRow(3);     
        Table3ResultsEnding.PrintColumns();  
      }      
    }

    public void  DrawTableConclusion()
    {                                                    
      // Setup Cols width    
      TableConclusion3.Columns[0].Width=(Page.PaperWidth-Page.LeftMargin-Page.RightMargin)  * Units.Millimeters;
        
      // Fill Table with data
      StaffData.Text = DataIVK.TablePoverkaSikn425_PR_PU.AdditionalInfo.StaffData;
      DateTimeLong.Text = string.Format(&quot;Дата: &lt;u&gt;{0:dd.MM.yyyy} г.&quot;,
        (tools.UnixTimestampToDatetime(DataIVK.TablePoverkaSikn425_PR_PU.DateTimeLong)));               
      PageNumeration.Width = (Page.PaperWidth-Page.LeftMargin-Page.RightMargin)*Units.Millimeters; 
    }  
      
    //// Setup heights of the all objects on the Page
    private void PageFooter_BeforeLayout(object sender, EventArgs e)
    {
      if((Int32)Report.GetVariableValue(&quot;TotalPages&quot;) &lt; 2) 
      { 
        PageFooter.Visible = false; 
      }
      else
      {
        PageNumeration.Width = (Page.PaperWidth-Page.LeftMargin-Page.RightMargin)*Units.Millimeters;
      }
    }
  }    
}

