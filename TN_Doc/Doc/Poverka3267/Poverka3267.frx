  <ScriptText>using System;
using System.Collections.Generic;
using System.Linq;
using FastReport;
using FastReport.Data;
using FastReport.Dialog;
using FastReport.Barcode;
using FastReport.Table;  
using FastReport.Utils;
using Newtonsoft.Json.Linq;

namespace FastReport
{
  public class ReportScript
  {
    JToken JDoc;
    JToken JSettings;    
    JToken JProtokol;
    JToken JAdditionalInfo;

    string ErrorValue = &quot;Ошибка&quot;; //&quot;Нет ошибки&quot;
    Color  ErrorColor = Color.LightCoral;
    
    private void Page_StartPage(object sender, EventArgs e)
    {
      JDoc = JToken.Parse(Report.GetParameterValue(&quot;JsonDoc&quot;).ToString());
      
      JSettings = JDoc[&quot;Doc&quot;][&quot;Settings&quot;];
      JProtokol = JDoc[&quot;Doc&quot;][&quot;DataIVK&quot;][&quot;TablePoverka3267&quot;][&quot;Protokol&quot;];
      JAdditionalInfo = JDoc[&quot;Doc&quot;][&quot;DataIVK&quot;][&quot;TablePoverka3267&quot;][&quot;AdditionalInfo&quot;];
      
      //Настройки страницы 
      //Ширина и высота (в мм)
      Page.PaperHeight = (int)JSettings[&quot;General&quot;][&quot;PageSettings&quot;][&quot;PaperHeight&quot;];
      Page.PaperWidth = (int)JSettings[&quot;General&quot;][&quot;PageSettings&quot;][&quot;PaperWidth&quot;];
         
      //Поля/отступы от краёв (в мм)
      Page.TopMargin = (int)JSettings[&quot;General&quot;][&quot;PageSettings&quot;][&quot;TopMargin&quot;];
      Page.BottomMargin = (int)JSettings[&quot;General&quot;][&quot;PageSettings&quot;][&quot;BottomMargin&quot;];
      Page.LeftMargin = (int)JSettings[&quot;General&quot;][&quot;PageSettings&quot;][&quot;LeftMargin&quot;];
      Page.RightMargin = (int)JSettings[&quot;General&quot;][&quot;PageSettings&quot;][&quot;RightMargin&quot;];
         
      DrawTableHeader();    
      DrawTableConclusion();
    }      
      
    public void DrawTableHeader()
    {
      ProtokolNum.Text =  $&quot;ПРОТОКОЛ № {JAdditionalInfo[&quot;ProtokolNum&quot;]}&quot;;
      Place.Text = $&quot;{JAdditionalInfo[&quot;Place_PSP&quot;]}&quot;;
      PR_Type.Text = $&quot;{JAdditionalInfo[&quot;PR_Type&quot;]}&quot;;
      PR_FactoryNumber.Text = $&quot;{JAdditionalInfo[&quot;PR_FactoryNumber&quot;]}&quot;;
      EPR_Type.Text = $&quot;{JAdditionalInfo[&quot;EPR_Type&quot;]}&quot;;
      EPR_FactoryNumber.Text = $&quot;{JAdditionalInfo[&quot;EPR_FactoryNumber&quot;]}&quot;;
      IVK_Type.Text = $&quot;{JAdditionalInfo[&quot;IVK_Type&quot;]}&quot;;
      IVK_FactoryNumber.Text = $&quot;{JAdditionalInfo[&quot;IVK_FactoryNumber&quot;]}&quot;;
      OilType.Text = $&quot;{JProtokol[&quot;OilType&quot;]}&quot;;
      Visc.Text = $&quot;{JProtokol[&quot;Visc&quot;]}&quot;.Replace('.',',');
      IL_Name.Text = $&quot;{JDoc[&quot;Doc&quot;][&quot;DataIVK&quot;][&quot;TablePoverka3267&quot;][&quot;IL_Name&quot;]}&quot;;
    }
              
    private void Table1_ManualBuild(object sender, EventArgs e)
    {
      //Setup Columns width
      int sumDynamicCols = Table1.ColumnCount;
      float widthDynamicCol = (Page.PaperWidth-Page.LeftMargin-Page.RightMargin)/sumDynamicCols;                  
 
      for (int w = 0; w &lt; (Table1.ColumnCount); w++)                 
      {
        Table1.Columns[w].Width = widthDynamicCol * Units.Millimeters;
      }      
                            
      //Draw Fixed rows
      for (int n = 0; n &lt; Table1.FixedRows; n++)
      {
        Table1.PrintRow(n);
        Table1.PrintColumns();                                             
      }
         
      //Fill table with data        
      Delta_EPR.Text =  $&quot;{JProtokol[&quot;Table1&quot;][&quot;Delta_EPR&quot;]}&quot;.Replace('.',',');
      Delt_t_EPR.Text = $&quot;{JProtokol[&quot;Table1&quot;][&quot;Delt_t_EPR&quot;]}&quot;.Replace('.',',');
      Delt_t_PR.Text = $&quot;{JProtokol[&quot;Table1&quot;][&quot;Delt_t_PR&quot;]}&quot;.Replace('.',',');
      Delt_IVK.Text = $&quot;{JProtokol[&quot;Table1&quot;][&quot;Delt_IVK&quot;]}&quot;.Replace('.',',');
      Delt_Visc.Text = $&quot;{JProtokol[&quot;Table1&quot;][&quot;Delt_Visc&quot;]}&quot;.Replace('.',',');

      Table1.PrintRow(3);     
      Table1.PrintColumns();  
    }        

    private void Table2_1_ManualBuild(object sender, EventArgs e)
    {      
      //Setup Columns width
      int sumDynamicCols = Table2_1.ColumnCount;
      float widthDynamicCol = (Page.PaperWidth-Page.LeftMargin-Page.RightMargin)/sumDynamicCols;                  
      for (int w = 0; w &lt; (Table2_1.ColumnCount); w++)                 
      {
        Table2_1.Columns[w].Width = widthDynamicCol * Units.Millimeters;
      }      
         
      //Draw Fixed rows
      for (int n = 0; n &lt; Table2_1.FixedRows; n++)
      {
        Table2_1.PrintRow(n);
        Table2_1.PrintColumns();                                             
      }
        
      foreach (var item in JProtokol[&quot;Table2&quot;])
      {
        if (item[&quot;Ser&quot;].ToString() == &quot;-&quot; ||
          item[&quot;Ser&quot;].ToString() == &quot;&quot;) continue;
        
        SerRow.Text =  $&quot;{item[&quot;Ser&quot;]}/{item[&quot;Row&quot;]}&quot;;        
        Q_ji.Text = $&quot;{item[&quot;Q_ji&quot;]}&quot;.Replace('.',',');
        T_ji.Text =  $&quot;{item[&quot;T_ji&quot;]}&quot;.Replace('.',',');
        t_EPR_ji.Text = $&quot;{item[&quot;t_EPR_ji&quot;]}&quot;.Replace('.',',');
        P_EPR_ji.Text = $&quot;{item[&quot;P_EPR_ji&quot;]}&quot;.Replace('.',',');
        N_EPR_ji.Text = $&quot;{item[&quot;N_EPR_ji&quot;]}&quot;.Replace('.',',');
        K_EPR_ji.Text = $&quot;{item[&quot;K_EPR_ji&quot;]}&quot;.Replace('.',',');
        Dens_ji.Text = $&quot;{item[&quot;Dens_ji&quot;]}&quot;.Replace('.',',');
        DensTemp_ji.Text = $&quot;{item[&quot;DensTemp_ji&quot;]}&quot;.Replace('.',',');
            
        Table2_1.PrintRow(3);     
        Table2_1.PrintColumns();        
      }
    }

    private void Table2_2_ManualBuild(object sender, EventArgs e)
    {
      //Setup Columns width
      int sumDynamicCols = Table2_2.ColumnCount;
      float widthDynamicCol = (Page.PaperWidth-Page.LeftMargin-Page.RightMargin)/sumDynamicCols;                  
      for (int w = 0; w &lt; (Table2_2.ColumnCount); w++)                 
      {
        Table2_2.Columns[w].Width = widthDynamicCol * Units.Millimeters;
      }      
         
      //Draw Fixed rows
      for (int n = 0; n &lt; Table2_2.FixedRows; n++)
      {
        Table2_2.PrintRow(n);
        Table2_2.PrintColumns();                                             
      }
      
      foreach (var item in JProtokol[&quot;Table2&quot;])
      {
        if (item[&quot;Ser&quot;].ToString() == &quot;-&quot; ||
          item[&quot;Ser&quot;].ToString() == &quot;&quot;) continue;
        
        SerRow2.Text =  $&quot;{item[&quot;Ser&quot;]}/{item[&quot;Row&quot;]}&quot;;        
        DensPress_ji.Text = $&quot;{item[&quot;DensPress_ji&quot;]}&quot;.Replace('.',',');
        Beta_ji.Text =  $&quot;{item[&quot;Beta_ji&quot;]}&quot;.Replace('.',',');
        v_ji.Text = $&quot;{item[&quot;v_ji&quot;]}&quot;.Replace('.',',');
        t_PR_ji.Text = $&quot;{item[&quot;t_PR_ji&quot;]}&quot;.Replace('.',',');
        P_PR_ji.Text = $&quot;{item[&quot;P_PR_ji&quot;]}&quot;.Replace('.',',');
        f_ji.Text = $&quot;{item[&quot;f_ji&quot;]}&quot;.Replace('.',',');
        N_ji.Text = $&quot;{item[&quot;N_ji&quot;]}&quot;.Replace('.',',');
        K_ji.Text = $&quot;{item[&quot;K_ji&quot;]}&quot;.Replace('.',',');
            
        Table2_2.PrintRow(3);     
        Table2_2.PrintColumns();  
      }
    }
      
    private void Table3_ManualBuild(object sender, EventArgs e)
    {
      //Setup Columns width
      int sumDynamicCols = Table3.ColumnCount;
      float widthDynamicCol = (Page.PaperWidth-Page.LeftMargin-Page.RightMargin)/sumDynamicCols;                  
      for (int w = 0; w &lt; (Table3.ColumnCount); w++)                 
      {
        Table3.Columns[w].Width = widthDynamicCol * Units.Millimeters;
      }      
         
      //Draw Fixed rows
      for (int n = 0; n &lt; Table3.FixedRows; n++)
      {
        Table3.PrintRow(n);
        Table3.PrintColumns();                                             
      }
       
      foreach (var item in JProtokol[&quot;Table3&quot;])
      {
        if (item[&quot;Point&quot;].ToString() == &quot;-&quot; ||
          item[&quot;Point&quot;].ToString() == &quot;&quot;) continue;
        
        Point.Text =  $&quot;{item[&quot;Point&quot;]}&quot;;        
        Q_j.Text = $&quot;{item[&quot;Q_j&quot;]}&quot;.Replace('.',',');
        f_j.Text =  $&quot;{item[&quot;f_j&quot;]}&quot;.Replace('.',',');
        K_j.Text = $&quot;{item[&quot;K_j&quot;]}&quot;.Replace('.',',');
        S_j.Text = $&quot;{item[&quot;S_j&quot;]}&quot;.Replace('.',',');
        n_j.Text = $&quot;{item[&quot;n_j&quot;]}&quot;.Replace('.',',');
        S0_j.Text = $&quot;{item[&quot;S0_j&quot;]}&quot;.Replace('.',',');
        t095_j.Text = $&quot;{item[&quot;t095_j&quot;]}&quot;.Replace('.',',');
        e_j.Text = $&quot;{item[&quot;e_j&quot;]}&quot;.Replace('.',',');
        
        if (SettingsData.HighlightError &amp;&amp; $&quot;{item[&quot;S_j_ERROR&quot;]}&quot; == ErrorValue)
          S_j.FillColor = ErrorColor;
        
        Table3.PrintRow(3);     
        Table3.PrintColumns();  
      }      
    }

    private void Table4_ManualBuild(object sender, EventArgs ea)
    {     
      int sumDynamicCols = Table4.ColumnCount;
      float widthDynamicCol = (Page.PaperWidth-Page.LeftMargin-Page.RightMargin)/sumDynamicCols;                  
      for (int w = 0; w &lt; (Table4.ColumnCount); w++)                 
      {
        Table4.Columns[w].Width = widthDynamicCol * Units.Millimeters;
      }      
         
      for (int n = 0; n &lt; Table4.FixedRows; n++)
      {
        Table4.PrintRow(n);
        Table4.PrintColumns();                                             
      }
        
      Q_min.Text =  $&quot;{JProtokol[&quot;Table4&quot;][&quot;Q_min&quot;]}&quot;.Replace('.',',');       
      Q_max.Text = $&quot;{JProtokol[&quot;Table4&quot;][&quot;Q_max&quot;]}&quot;.Replace('.',',');
      v_min.Text =  $&quot;{JProtokol[&quot;Table4&quot;][&quot;v_min&quot;]}&quot;.Replace('.',',');
      v_max.Text = $&quot;{JProtokol[&quot;Table4&quot;][&quot;v_max&quot;]}&quot;.Replace('.',',');
      S0.Text = $&quot;{JProtokol[&quot;Table4&quot;][&quot;S0&quot;]}&quot;.Replace('.',',');
      e.Text = $&quot;{JProtokol[&quot;Table4&quot;][&quot;e&quot;]}&quot;.Replace('.',',');
      Teta_A.Text = $&quot;{JProtokol[&quot;Table4&quot;][&quot;Teta_A&quot;]}&quot;.Replace('.',',');
      Teta_t.Text = $&quot;{JProtokol[&quot;Table4&quot;][&quot;Teta_t&quot;]}&quot;.Replace('.',',');
      Teta_Sum.Text = $&quot;{JProtokol[&quot;Table4&quot;][&quot;Teta_Sum&quot;]}&quot;.Replace('.',',');
      Delta.Text = $&quot;{JProtokol[&quot;Table4&quot;][&quot;Delta&quot;]}&quot;.Replace('.',',');
      
      if (SettingsData.HighlightError &amp;&amp; $&quot;{JProtokol[&quot;Table4&quot;][&quot;Delta_ERROR&quot;]}&quot; == ErrorValue)
        Delta.FillColor = ErrorColor;
      
      Table4.PrintRow(3);     
      Table4.PrintColumns();  
    }

    public void  DrawTableConclusion()
    { 
      TableConclusion3.Columns[0].Width=(Page.PaperWidth-Page.LeftMargin-Page.RightMargin)  * Units.Millimeters;
         
      ARM_Poverka_Result.Text = $&quot;{JAdditionalInfo[&quot;ARM_Poverka_Result&quot;]}&quot;;
      StaffData.Text = $&quot;{JAdditionalInfo[&quot;StaffData&quot;]}&quot;;
      
      long dateTimeLong = long.Parse($&quot;{JDoc[&quot;Doc&quot;][&quot;DataIVK&quot;][&quot;TablePoverka3267&quot;][&quot;DateTimeLong&quot;]}&quot;);     
      DateTimeLong.Text = string.Format(&quot;Дата проведения поверки: {0:dd.MM.yyyy} г.&quot;, DateTimeOffset.FromUnixTimeSeconds(dateTimeLong));             
      
      PageNumeration.Width = (Page.PaperWidth-Page.LeftMargin-Page.RightMargin)*Units.Millimeters; 
    } 

    private void PageFooter_BeforeLayout(object sender, EventArgs e)
    {
      if((Int32)Report.GetVariableValue(&quot;TotalPages&quot;) &lt; 2) 
      { 
        PageFooter.Visible = false; 
      }
      else
      {
        PageNumeration.Width = (Page.PaperWidth-Page.LeftMargin-Page.RightMargin)*Units.Millimeters;
      }
    }
  }    
}

