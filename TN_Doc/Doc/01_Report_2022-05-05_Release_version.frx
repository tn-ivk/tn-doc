        </TableRow>
        <TableRow Name="Row47" AutoSize="true">
          <TableCell Name="ReportType" Text="ReportType" HorzAlign="Center" VertAlign="Center" Font="Arial, 9pt, style=Bold" FontWidthRatio="0.85" ColSpan="2"/>
          <TableCell Name="Cell376" HorzAlign="Center" VertAlign="Center" Font="Arial, 9pt" FontWidthRatio="0.85"/>
        </TableRow>
        <TableRow Name="Row48" AutoSize="true">
          <TableCell Name="ReportTime" Text="ReportTime" HorzAlign="Center" VertAlign="Center" Font="Arial, 8pt" FontWidthRatio="0.85" ColSpan="2"/>
