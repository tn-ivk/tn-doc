          <TableCell Name="Prefix_SIKN_Name" Text="Prefix_SIKN_Name" VertAlign="Center" Font="Arial, 8pt" FontWidthRatio="0.85"/>
          <TableCell Name="NameIVK" Text="NameIVK" HorzAlign="Right" VertAlign="Center" Font="Arial, 8pt" FontWidthRatio="0.85"/>
        </TableRow>
        <TableRow Name="Row44" AutoSize="true">
          <TableCell Name="Factory" Text="Factory" VertAlign="Center" Font="Arial, 8pt" FontWidthRatio="0.85"/>
