    private void Table4_3Results_ManualBuild(object sender, EventArgs e)
    {
      if (DataIVK.TablePoverka3272.Protokol.ActivatedTables.Table4_3==1)
      {   
        //Setup Columns width
        int sumDynamicCols=Table4_3Results.ColumnCount;
        float widthDynamicCol=(Page.PaperWidth-Page.LeftMargin-Page.RightMargin)/sumDynamicCols;                  
        for (int w = 0; w &lt; (Table4_3Results.ColumnCount); w++)                 
        {
          Table4_3Results.Columns[w].Width = widthDynamicCol * Units.Millimeters;
        }      

        //Drawing Fixed rows
        for (int n = 0; n &lt; Table4_3Results.FixedRows; n++)                                                            
        {                                                                                                                    
          Table4_3Results.PrintRow(n);
          Table4_3Results.PrintColumns();                                             
        }
        //Filling table with data for subranges                                                                            
        for (int n = 0; n &lt; (listSubrangesTable4_3.Count); n++)                                                 
        {                                                                                                                            
          Point3.Text = listPointsTable4_3[n].Point;      
          Q_j3.Text = tools.GetNormalizedValue(listPointsTable4_3[n].Q_j);                                                          
          KF_j3.Text =  tools.GetNormalizedValue(listPointsTable4_3[n].KF_j); 
          Subranges.Text =  tools.GetNormalizedValue(listSubrangesTable4_3[n].Point); 
          Q_min.Text =  tools.GetNormalizedValue(listSubrangesTable4_3[n].Q_min); 
          Q_max.Text =  tools.GetNormalizedValue(listSubrangesTable4_3[n].Q_max); 
          SKO_KF3.Text =  tools.GetNormalizedValue(listSubrangesTable4_3[n].SKO_KF); 
          Delta_0_mas3.Text =  tools.GetNormalizedValue(listSubrangesTable4_3[n].Delta_0_mas); 
          Teta_KF3.Text =  tools.GetNormalizedValue(listSubrangesTable4_3[n].Teta_KF); 
          Epsilon.Text =  tools.GetNormalizedValue(listSubrangesTable4_3[n].Epsilon); 
          Teta_Sum3.Text =  tools.GetNormalizedValue(listSubrangesTable4_3[n].Teta_Sum); 
          Delta3.Text =  tools.GetNormalizedValue(listSubrangesTable4_3[n].Delta); 

          Table4_3Results.PrintRow(3);                                                     
          Table4_3Results.PrintColumns();                                                
        }              
        //Filling table with data for last measure point 
        if (Engine.FinalPass == true)
        {  
          if (listPointsTable4_3.Count &gt; 1)
          {
            Point3.Text = listPointsTable4_3[listPointsTable4_3.Count-1].Point;      
            Q_j3.Text = tools.GetNormalizedValue(listPointsTable4_3[listPointsTable4_3.Count-1].Q_j);                                                          
            KF_j3.Text =  tools.GetNormalizedValue(listPointsTable4_3[listPointsTable4_3.Count-1].KF_j); 
            
            for (int i = 0; i &lt; (Table4_3Results.ColumnCount); i++)
            {          
              switch(i)
              {
                case 3:  
                case 4:
                case 5:  
                case 6:     
                case 7:                                                                
                case 8:                                                                
                case 9:   
                case 10:              
                case 11:              
                  Table4_3Results[i,3].Border.Lines = BorderLines.None;
                  Table4_3Results[i,3].Text = &quot;&quot;;
                  break;  
              }
            } 
            Table4_3Results.PrintRow(3);                                                     
            Table4_3Results.PrintColumns();
          }
        } 
      }
      else
      {
        DataBandTable4_3Results.Visible=false;
      }
    }

    private void TableGHResults_ManualBuild(object sender, EventArgs e)
    {
        //Setup Columns width
        int sumDynamicCols = TableGHResults.ColumnCount;
        float widthDynamicCol=(Page.PaperWidth-Page.LeftMargin-Page.RightMargin)/sumDynamicCols;                  
        for (int w = 0; w &lt; TableGHResults.ColumnCount; w++)                 
        {
          TableGHResults.Columns[w].Width = widthDynamicCol * Units.Millimeters;
        }      

        //Drawing Fixed rows
        for (int n = 0; n &lt; TableGHResults.FixedRows; n++)                                                            
        {                                                                                                                    
          TableGHResults.PrintRow(n);
          TableGHResults.PrintColumns();                                             
        }
      
        var listSubrangesTableGH = DataIVK.TablePoverka3272.Protokol.TableGH.Where(i =&gt; !i.Point.Contains(&quot;-&quot;)).ToList();
      
        //Filling table with data for subranges                                                                            
        for (int n = 0; n &lt; listSubrangesTableGH.Count; n++)                                                 
        {                                                                                                                            
          Point4.Text = listSubrangesTableGH[n].Point;      
          Q_j4.Text = tools.GetNormalizedValue(listSubrangesTableGH[n].Q_j);                                                          
          f_j4.Text =  tools.GetNormalizedValue(listSubrangesTableGH[n].f_j); 
          K_j.Text =  tools.GetNormalizedValue(listSubrangesTableGH[n].K_j); 

          TableGHResults.PrintRow(3);                                                     
          TableGHResults.PrintColumns();                                                
        }             
    }
    
    public void  DrawTableConclusion()
    {                                                    
      // Setup Cols width    
      ColumnDateTimeLong.Width=(Page.PaperWidth-Page.LeftMargin-Page.RightMargin)  * Units.Millimeters;
      // Filling Table with data
      ARM_Poverka_Result.Text = DataIVK.TablePoverka3272.AdditionalInfo.ARM_Poverka_Result;
      ARM_Result_Type.Text = DataIVK.TablePoverka3272.AdditionalInfo.ARM_Result_Type;       
      Certificate_Num.Text = DataIVK.TablePoverka3272.AdditionalInfo.Certificate_Num;       
      Certificate_Date.Text = DataIVK.TablePoverka3272.AdditionalInfo.Certificate_Date;       
      StaffData_company.Text = DataIVK.TablePoverka3272.AdditionalInfo.StaffData_company;       
      StaffData_fio.Text = DataIVK.TablePoverka3272.AdditionalInfo.StaffData_fio;       
      DateTimeLong.Text = string.Format(&quot;Дата поверки: &lt;u&gt;{0:dd.MM.yyyy} г.&quot;,(tools.UnixTimestampToDatetime(DataIVK.TablePoverka3272.DateTimeLong)));               
    }  

    private void PageFooter_BeforeLayout(object sender, EventArgs e)
    {
      if((Int32)Report.GetVariableValue(&quot;TotalPages&quot;) &lt; 2) 
      { 
        PageFooter.Visible = false; 
      }
      else
      {
        PageNumeration.Width = (Page.PaperWidth-Page.LeftMargin-Page.RightMargin)*Units.Millimeters;
        
      }
    }
  }    
}

