          Teta_KF2.Text =  tools.GetNormalizedValue(DataIVK.TablePoverka3272.Protokol.Table4_2_Subr.Teta_KF);
          Epsilon2.Text =  tools.GetNormalizedValue(DataIVK.TablePoverka3272.Protokol.Table4_2_Subr.Epsilon);
          Teta_Sum2.Text =  tools.GetNormalizedValue(DataIVK.TablePoverka3272.Protokol.Table4_2_Subr.Teta_Sum);
          Delta2.Text =  tools.GetNormalizedValue(DataIVK.TablePoverka3272.Protokol.Table4_2_Subr.Delta);
          //RowsSpans
