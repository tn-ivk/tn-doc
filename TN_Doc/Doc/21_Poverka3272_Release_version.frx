          KF_j2.Text =  tools.GetNormalizedValue(listPointsTable4_2[n].KF_j); 
          SKO_KF2.Text =  tools.GetNormalizedValue(DataIVK.TablePoverka3272.Protokol.Table4_2_Subr.SKO_KF); 
          Delta_0_mas2.Text =  tools.GetNormalizedValue(DataIVK.TablePoverka3272.Protokol.Table4_2_Subr.Delta_0_mas);
