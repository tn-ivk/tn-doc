    private void Table4_1Results_ManualBuild(object sender, EventArgs e)
    {
      if (DataIVK.TablePoverka3272.Protokol.ActivatedTables.Table4_1==1)
      {
        //Setup Columns width
        int sumDynamicCols=Table4_1Results.ColumnCount;
        float widthDynamicCol=(Page.PaperWidth-Page.LeftMargin-Page.RightMargin)/sumDynamicCols;                  
        for (int w = 0; w &lt; (Table4_1Results.ColumnCount); w++)                 
        {
          Table4_1Results.Columns[w].Width = widthDynamicCol * Units.Millimeters;
        }      
        //Drawing Fixed rows
        for (int n = 0; n &lt; Table4_1Results.FixedRows; n++)                                                            
        {                                                                                                                    
          Table4_1Results.PrintRow(n);
          Table4_1Results.PrintColumns();                                             
        }
        //Filling table with data                                                                             
        for (int n = 0; n &lt; (listPointsTable4_1.Count); n++)                                                 
        {                                                                                                                            
          Point.Text = listPointsTable4_1[n].Point;                                                                
          Q_j.Text = tools.GetNormalizedValue(listPointsTable4_1[n].Q_j);                                                          
          MF_j.Text =  tools.GetNormalizedValue(listPointsTable4_1[n].MF_j); 
          SKO_MF.Text =  tools.GetNormalizedValue(DataIVK.TablePoverka3272.Protokol.Table4_1_Subr.SKO_MF); 
          Delta_0_mas.Text =  tools.GetNormalizedValue(DataIVK.TablePoverka3272.Protokol.Table4_1_Subr.Delta_0_mas); 
          MF.Text =  tools.GetNormalizedValue(DataIVK.TablePoverka3272.Protokol.Table4_1_Subr.MF); 
          K_GR.Text =  tools.GetNormalizedValue(DataIVK.TablePoverka3272.Protokol.Table4_1_Subr.K_GR); 
          Epsilon1.Text =  tools.GetNormalizedValue(DataIVK.TablePoverka3272.Protokol.Table4_1_Subr.Epsilon); 
          Teta_Sum.Text =  tools.GetNormalizedValue(DataIVK.TablePoverka3272.Protokol.Table4_1_Subr.Teta_Sum);                
          Delta.Text =  tools.GetNormalizedValue(DataIVK.TablePoverka3272.Protokol.Table4_1_Subr.Delta); 
          //RowsSpans
          for (int i = 0; i &lt; (Table4_1Results.ColumnCount); i++)
          {          
            switch(i)
            {
              case 3:  
              case 4:
              case 5:  
              case 6:     
              case 7:                                                                
              case 8:                                                                
              case 9:                                                            
                Table4_1Results[i,3].RowSpan =  listPointsTable4_1.Count;
                break;  
            }
          }
          Table4_1Results.PrintRow(3);                                                     
          Table4_1Results.PrintColumns();                                                
        }                 
      }     
      else
      {
        DataBandTable4_1Results.Visible=false;
      }
    }             
    
    private void Table4_2Results_ManualBuild(object sender, EventArgs e)
    {
      if (DataIVK.TablePoverka3272.Protokol.ActivatedTables.Table4_2==1)
      {         
