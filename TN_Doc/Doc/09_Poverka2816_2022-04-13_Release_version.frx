using FastReport.Dialog;
using FastReport.Barcode;
using FastReport.Table;
using FastReport.Utils;
using System.Linq;
using Newtonsoft.Json;
using TN.DocData;
   
namespace FastReport
{
  public class ReportScript
  {
    TN_ToolsFastReport.Tools tools = new TN_ToolsFastReport.Tools();  // классы отчета
    TN.Doc.Doc doc; // данные из входного параметра
    TN.DocData.General General;
    TN.Doc.HeaderDoc Header;
    TN.Doc.DataDoc SettingsData;
    TN.Doc.FooterDoc Footer;
    TN.Doc.DictionarysDoc Dictionarys;
    TN.Doc.DataIVKDoc DataIVK; 
    
    List &lt;TN.Doc.Table1&gt; listMeasures;
    List &lt;TN.Doc.KoefsSolartron&gt; listKoefsSolartron;
    List &lt;TN.Doc.KoefsSarasota&gt; listKoefsSarasota;
      
    float sumAllObjectsHeights=0;
    float sumTableRowsHeights =0;
    float tempRepSumHeight =0;
    int NefType;
    int protocolNumber;        
    
    private void Page_StartPage(object sender, EventArgs e)
    {               
      //using (var sr = new StreamReader(&quot;D:/!_Work/!_Транснефть/SVN/Work/Sources/Reports/FRX/Входящие данные от Алексея (классы и json)/09_TablePoverka2816/DocPoverka2816.json&quot;))
      //{
      // Read the stream as a string
      //   Report.SetParameterValue(&quot;Protocol&quot;, sr.ReadToEnd());
      //}
         
      //// Десериализация данных (формат json) из входного параметра - Json                         
      string json = (string)Report.GetParameterValue(&quot;JsonDoc&quot;);
      Newtonsoft.Json.JsonSerializerSettings settings = new Newtonsoft.Json.JsonSerializerSettings();
      settings.TypeNameHandling = TypeNameHandling.All;
         
      doc = JsonConvert.DeserializeObject&lt;TN.Doc.Doc&gt;(json, settings);
      General = (TN.DocData.General) doc.Doc.Settings.General;
      Header = (TN.Doc.HeaderDoc) doc.Doc.Settings.Header;
      SettingsData = (TN.Doc.DataDoc) doc.Doc.Settings.Data;
      Footer = (TN.Doc.FooterDoc) doc.Doc.Settings.Footer;
      Dictionarys = (TN.Doc.DictionarysDoc) doc.Doc.Settings.Dictionarys;  
      DataIVK = (TN.Doc.DataIVKDoc) doc.Doc.DataIVK;
      
      NefType = General.NefType;
         
      //// === Настройки страницы 
      // Ширина и высота (в мм)
         
      Page.PaperHeight = General.PageSettings.PaperHeight;
      Page.PaperWidth = General.PageSettings.PaperWidth;
      //Page.Border.Lines = BorderLines.All;
         
      // Поля/отступы от краёв (в мм)
      Page.TopMargin = General.PageSettings.TopMargin;
      Page.BottomMargin = General.PageSettings.BottomMargin;
      Page.LeftMargin = General.PageSettings.LeftMargin;
      Page.RightMargin = General.PageSettings.RightMargin;
         
      //Definition for which device create the protocol
      protocolNumber = General.ProtocolNumber;
      
      switch (protocolNumber)
      {
        case 2:
          listMeasures = DataIVK.TablePoverka2816.Protokol.PP2_Table1.Where(i =&gt; i.t_PP != &quot;-&quot; &amp; i.t_PP != &quot;-&quot;).ToList(); 
          break;
        default:
          listMeasures = DataIVK.TablePoverka2816.Protokol.PP1_Table1.Where(i =&gt; i.t_PP != &quot;-&quot; &amp; i.t_PP != &quot;-&quot;).ToList(); 
          break;
      }   
      
      // Запуск отрисовки таблиц на странице отчета
      DrawTableHeader();
      DrawTableConclusion();
    }
      
    public void DrawTableHeader()
    {
      // Setup Columns
      float widthDynamicCols=Page.PaperWidth-Page.LeftMargin-Page.RightMargin;  
      TableHeader.Columns[0].Width = widthDynamicCols*Units.Millimeters;
         
      switch (protocolNumber)
      {
        case 2:
          Protokol_Number.Text = &quot;&lt;b&gt;П Р О Т О К О Л № &lt;u&gt;&quot; + DataIVK.TablePoverka2816.AdditionalInfo.PP2_AdditionalInfo.Protokol_Number;
          Type_of_converter.Text = &quot;Тип преобразователя: &lt;u&gt;&quot; +  DataIVK.TablePoverka2816.AdditionalInfo.PP2_AdditionalInfo.Type_of_converter;
          Factory_number.Text = &quot;Заводской номер: &lt;u&gt;&quot; +  DataIVK.TablePoverka2816.AdditionalInfo.PP2_AdditionalInfo.Factory_number;
          SIKN_Factory.Text = &quot;Владелец: &lt;u&gt;&quot; +  DataIVK.TablePoverka2816.AdditionalInfo.PP2_AdditionalInfo.SIKN_Factory;
          SIKN_PSP.Text = &quot;Место поверки: &lt;u&gt;&quot; +  DataIVK.TablePoverka2816.AdditionalInfo.PP2_AdditionalInfo.SIKN_PSP;
          Environment_temperature.Text = &quot;Температура окружающего воздуха при взвешивании пикнометров: &lt;u&gt;&quot; +  
            DataIVK.TablePoverka2816.AdditionalInfo.PP2_AdditionalInfo.Environment_temperature + &quot; &lt;/u&gt;&lt;sup&gt;0&lt;/sup&gt;С&quot;;
          Atmosphere_pressure.Text = &quot;Атмосферное давление: &lt;u&gt;&quot; +  
            DataIVK.TablePoverka2816.AdditionalInfo.PP2_AdditionalInfo.Atmosphere_pressure + &quot; &lt;/u&gt;мм рт. ст.&quot;;          
          break;
        default:
          Protokol_Number.Text = &quot;&lt;b&gt;П Р О Т О К О Л № &lt;u&gt;&quot; + DataIVK.TablePoverka2816.AdditionalInfo.PP1_AdditionalInfo.Protokol_Number;
          Type_of_converter.Text = &quot;Тип преобразователя: &lt;u&gt;&quot; +  DataIVK.TablePoverka2816.AdditionalInfo.PP1_AdditionalInfo.Type_of_converter;
          Factory_number.Text = &quot;Заводской номер: &lt;u&gt;&quot; +  DataIVK.TablePoverka2816.AdditionalInfo.PP1_AdditionalInfo.Factory_number;
          SIKN_Factory.Text = &quot;Владелец: &lt;u&gt;&quot; +  DataIVK.TablePoverka2816.AdditionalInfo.PP1_AdditionalInfo.SIKN_Factory;
          SIKN_PSP.Text = &quot;Место поверки: &lt;u&gt;&quot; +  DataIVK.TablePoverka2816.AdditionalInfo.PP1_AdditionalInfo.SIKN_PSP;
          Environment_temperature.Text = &quot;Температура окружающего воздуха при взвешивании пикнометров: &lt;u&gt;&quot; +  
            DataIVK.TablePoverka2816.AdditionalInfo.PP1_AdditionalInfo.Environment_temperature + &quot; &lt;/u&gt;&lt;sup&gt;0&lt;/sup&gt;С&quot;;
          Atmosphere_pressure.Text = &quot;Атмосферное давление: &lt;u&gt;&quot; +  
            DataIVK.TablePoverka2816.AdditionalInfo.PP1_AdditionalInfo.Atmosphere_pressure + &quot; &lt;/u&gt;мм рт. ст.&quot;;          
          break;
      }         
    }
               
    private void TableResults_ManualBuild(object sender, EventArgs e)
    {
      var rand = new Random();
      TableResultsHeader.Width = (Page.PaperWidth-Page.LeftMargin-Page.RightMargin)*Units.Millimeters; 
         
      // Setup Columns
      int sumDynamicCols=TableResults.ColumnCount;
      float widthDynamicCol=(Page.PaperWidth-Page.LeftMargin-Page.RightMargin)/sumDynamicCols;                  
      for (int w = 0; w &lt; (TableResults.ColumnCount); w++)                 
      {
        TableResults.Columns[w].Width = widthDynamicCol * Units.Millimeters;
      }
         
      //Draw Fixed rows
      for (int n = 0; n &lt; TableResults.FixedRows; n++)
      {
        TableResults.PrintRow(n);
        TableResults.PrintColumns();                                             
      }

      //Fill table with data
      for (int n = 0; n &lt; (listMeasures.Count); n++)
      {
        t_PP.Text = tools.GetNormalizedValue(listMeasures[n].t_PP);  
        t_Pycn.Text = tools.GetNormalizedValue(listMeasures[n].t_Pycn);
        P_PP.Text = tools.GetNormalizedValue(listMeasures[n].P_PP);
        P_Pycn.Text = tools.GetNormalizedValue(listMeasures[n].P_Pycn);
        Dens_Pycn.Text = tools.GetNormalizedValue(listMeasures[n].Dens_Pycn);
        Dens_Pycn_Normalized.Text = tools.GetNormalizedValue(listMeasures[n].Dens_Pycn_Normalized);
        Period.Text = tools.GetNormalizedValue(listMeasures[n].Period);
        Dens_PP.Text = tools.GetNormalizedValue(listMeasures[n].Dens_PP);
        Delta.Text = tools.GetNormalizedValue(listMeasures[n].Delta);
         
        TableResults.PrintRow(TableResults.FixedRows);     
        TableResults.PrintColumns();  
      }  
    }
  
    public void  DrawTableConclusion()
    { 
      int isUsedKoefsSolartron;
      string gh;
      
      switch (protocolNumber)
      {
        case 2:

          TableConclusion.Columns[0].Width=(Page.PaperWidth-Page.LeftMargin-Page.RightMargin) * Units.Millimeters;
          
          gh = GH(DataIVK.TablePoverka2816.AdditionalInfo.PP2_AdditionalInfo);
          if (string.IsNullOrEmpty(gh))
            GradKoefs.Text = &quot;&quot;;
          else
            GradKoefs.Text = string.Format(&quot;Градуировочные коэффициенты: &lt;u&gt;{0}&lt;/u&gt; от &lt;u&gt;{1}&quot;, gh, DataIVK.TablePoverka2816.AdditionalInfo.PP2_AdditionalInfo.Koefs_CheckDate);
          
          StaffData.Text =string.Format(&quot;Должность, подпись, И.О. Фамилия лица, проводившего поверку: &lt;u&gt;                                                                                 &lt;/u&gt; &lt;u&gt;                           &lt;/u&gt; &lt;u&gt;{0}&quot;,
          DataIVK.TablePoverka2816.AdditionalInfo.PP2_AdditionalInfo.StaffData);
          DateTimeLong.Text = string.Format(&quot;Дата проведения поверки: &lt;u&gt;{0:dd.MM.yyyy} г.&quot;, tools.UnixTimestampToDatetime(DataIVK.TablePoverka2816.DateTimeLong));          
          break;
        
        default:

          TableConclusion.Columns[0].Width=(Page.PaperWidth-Page.LeftMargin-Page.RightMargin) * Units.Millimeters;
          
          gh = GH(DataIVK.TablePoverka2816.AdditionalInfo.PP1_AdditionalInfo);
          if (string.IsNullOrEmpty(gh))
            GradKoefs.Text = &quot;&quot;;
          else
            GradKoefs.Text = string.Format(&quot;Градуировочные коэффициенты: &lt;u&gt;{0}&lt;/u&gt; от &lt;u&gt;{1}&quot;, gh, DataIVK.TablePoverka2816.AdditionalInfo.PP1_AdditionalInfo.Koefs_CheckDate);
          
          StaffData.Text =string.Format(&quot;Должность, подпись, И.О. Фамилия лица, проводившего поверку: &lt;u&gt;                                                                                 &lt;/u&gt; &lt;u&gt;                           &lt;/u&gt; &lt;u&gt;{0}&quot;,
          DataIVK.TablePoverka2816.AdditionalInfo.PP1_AdditionalInfo.StaffData);
          DateTimeLong.Text = string.Format(&quot;Дата проведения поверки: &lt;u&gt;{0:dd.MM.yyyy} г.&quot;, tools.UnixTimestampToDatetime(DataIVK.TablePoverka2816.DateTimeLong));          
          break;      
      }  
    }

    private void PageFooter_BeforeLayout(object sender, EventArgs e)
    {
      if((Int32)Report.GetVariableValue(&quot;TotalPages&quot;) &lt; 2) 
      { 
        PageFooter.Visible = false; 
      }
      else
      {
        PageNumeration.Width = (Page.PaperWidth-Page.LeftMargin-Page.RightMargin)*Units.Millimeters;
      }
    }
    
    private string GH (TN.Doc.PP_AdditionalInfo additionalInfo)
    {
      //GH коэффициенты

      string GH1_1 = &quot;&quot;, GH1_2 = &quot;&quot;;
      if (additionalInfo.KoefsSolartron.IsUsed == 1)
      {
        string[] GH = { &quot;K0 = &quot;, &quot; K1 = &quot;, &quot; K2 = &quot;, &quot; K18 = &quot;, &quot; K19 = &quot;, &quot; K20A = &quot;, &quot; K20B = &quot;, &quot; K21A = &quot;, &quot; K21B = &quot; };

        GH[0] += additionalInfo.KoefsSolartron.K0 + &quot;,&quot;;
        GH[1] += additionalInfo.KoefsSolartron.K1 + &quot;,&quot;;
        GH[2] += additionalInfo.KoefsSolartron.K2 + &quot;,&quot;;
        GH[3] += additionalInfo.KoefsSolartron.K18 + &quot;,&quot;;
        GH[4] += additionalInfo.KoefsSolartron.K19 + &quot;,&quot;;
        GH[5] += additionalInfo.KoefsSolartron.K20A + &quot;,&quot;;
        GH[6] += additionalInfo.KoefsSolartron.K20B + &quot;,&quot;;
        GH[7] += additionalInfo.KoefsSolartron.K21A + &quot;,&quot;;
        GH[8] += additionalInfo.KoefsSolartron.K21B + &quot;.&quot;;       
        
        int i = 0;
        do
        {
          GH1_1 += GH[i];
          i++;
        } while (GH1_1.Length &lt; 125 &amp;&amp; i &lt; 9);

        while (i &lt; 9)
        {
          GH1_2 += GH[i];
          i++;
        }
      }
      else if (additionalInfo.KoefsSarasota.IsUsed == 1)
      {
        string[] GH = { &quot;D0 = &quot;, &quot; T0 = &quot;, &quot; TEMPCO = &quot;, &quot; Tcal = &quot;, &quot; PRESCO = &quot;, &quot; Pcal = &quot;, &quot; K = &quot;, &quot; Patm = &quot; };

        GH[0] += additionalInfo.KoefsSarasota.D0 + &quot;,&quot;;
        GH[1] += additionalInfo.KoefsSarasota.T0 + &quot;,&quot;;
        GH[2] += additionalInfo.KoefsSarasota.TEMPCO + &quot;,&quot;;
        GH[3] += additionalInfo.KoefsSarasota.Tcal + &quot;,&quot;;
        GH[4] += additionalInfo.KoefsSarasota.PRESCO + &quot;,&quot;;
        GH[5] += additionalInfo.KoefsSarasota.Pcal + &quot;,&quot;;
        GH[6] += additionalInfo.KoefsSarasota.K + &quot;,&quot;;
        GH[7] += additionalInfo.KoefsSarasota.Patm + &quot;.&quot;;        
        
        int i = 0;
        do
        {
          GH1_1 += GH[i];
          i++;
        } while (GH1_1.Length &lt; 125 &amp;&amp; i &lt; 8);

        while (i &lt; 8)
        {
          GH1_2 += GH[i];
          i++;
        }
      }
      else return string.Empty;
      
      return String.Join(&quot;, &quot;, GH1_1 + GH1_2);
    }
  }    
}

