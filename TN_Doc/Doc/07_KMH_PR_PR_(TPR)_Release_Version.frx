using FastReport.Utils;
using System.Linq;
using Newtonsoft.Json;
using TN.DocData;

namespace FastReport
{
  public class ReportScript
  {
    TN_ToolsFastReport.Tools tools = new TN_ToolsFastReport.Tools();  // классы отчета
    TN.Doc.Doc doc; // данные из входного параметра
    TN.DocData.General General;
    TN.Doc.HeaderDoc Header;
    TN.Doc.DataDoc SettingsData;
    TN.Doc.FooterDoc Footer;
    TN.Doc.DictionarysDoc Dictionarys;
    TN.Doc.DataIVKDoc DataIVK;
    
    string oilName;
    
    private void Page_StartPage(object sender, EventArgs e)
    {
      //using (var sr = new StreamReader(&quot;D:/!_Work/!_Транснефть/SVN/Work/Sources/Reports/FRX/Входящие данные от Алексея (классы и json)/07_TableKMH_PR_PR/DocKMH_PR_PR.json&quot;))
      //{
      // Read the stream as a string
      //   Report.SetParameterValue(&quot;Protocol&quot;, sr.ReadToEnd());
      //}
         
      //// Десериализация данных (формат json) из входного параметра - Json                         
      string json = (string)Report.GetParameterValue(&quot;JsonDoc&quot;);
      Newtonsoft.Json.JsonSerializerSettings settings = new Newtonsoft.Json.JsonSerializerSettings();
      settings.TypeNameHandling = TypeNameHandling.All;
         
      doc = JsonConvert.DeserializeObject&lt;TN.Doc.Doc&gt;(json, settings);
      General = (TN.DocData.General) doc.Doc.Settings.General;
      Header = (TN.Doc.HeaderDoc) doc.Doc.Settings.Header;
      SettingsData = (TN.Doc.DataDoc) doc.Doc.Settings.Data;
      Footer = (TN.Doc.FooterDoc) doc.Doc.Settings.Footer;
      Dictionarys = (TN.Doc.DictionarysDoc) doc.Doc.Settings.Dictionarys;  
      DataIVK = (TN.Doc.DataIVKDoc) doc.Doc.DataIVK;
         
      //// === Настройки страницы 
      // Ширина и высота (в мм)
         
      Page.PaperHeight = General.PageSettings.PaperHeight;
      Page.PaperWidth= General.PageSettings.PaperWidth;
      //Page.Border.Lines = BorderLines.All;
         
      // Поля/отступы от краёв (в мм)
      Page.TopMargin=General.PageSettings.TopMargin;
      Page.BottomMargin=General.PageSettings.BottomMargin;
      Page.LeftMargin=General.PageSettings.LeftMargin;
      Page.RightMargin=General.PageSettings.RightMargin;
         
      // Запуск отрисовки таблиц на странице отчета
      DrawTableHeader();
      DrawTableSourceData();
      DrawTableConclusion();
         
    }
      
    public void DrawTableHeader()
    {          
      oilName = General.NefType == 1 ? &quot;Вязкость нефти при КМХ, мм &lt;sup&gt;2&lt;/sup&gt;/с (сСт):&quot; : &quot;Вязкость нефтепродукта при КМХ, мм &lt;sup&gt;2&lt;/sup&gt;/с (сСт):&quot;;
      
      // Setup Columns
      float widthDynamicCols=(Page.PaperWidth-Page.LeftMargin-Page.RightMargin)/TableHeader.ColumnCount;         
      for (int i = 0; i &lt; (TableHeader.ColumnCount); i++)                 
      {
        TableHeader.Columns[i].Width = widthDynamicCols*Units.Millimeters;
      }
         
      // Fill table with data   
      PR_Type_Oper.Text = &quot;Тип ПР &quot; + DataIVK.TableKMH_PR_PR.AdditionalInfo.PR_Type_Oper;
      PR_FactoryNumber_Oper.Text = &quot;Заводской № &lt;u&gt;&quot; +  DataIVK.TableKMH_PR_PR.AdditionalInfo.PR_FactoryNumber_Oper;
      Place.Text = string.Format(&quot;Место проведения КМХ: СИКН №{1} &lt;u&gt;{0}&lt;/u&gt; (СИКН, НГДУ, ПСП)&quot;, 
        DataIVK.TableKMH_PR_PR.AdditionalInfo.Place,
	DataIVK.TableKMH_PR_PR.AdditionalInfo.Place_SIKN_Name); 
         
      PR_Type_Ctrl.Text = &quot;Тип контрольного ПР &quot; + DataIVK.TableKMH_PR_PR.AdditionalInfo.PR_Type_Ctrl;
      PR_FactoryNumber_Ctrl.Text = &quot;Заводской № &lt;u&gt;&quot; +  DataIVK.TableKMH_PR_PR.AdditionalInfo.PR_FactoryNumber_Ctrl;
      PR_CheckDate_Ctrl.Text = &quot;Дата поверки &lt;u&gt;&quot; +  DataIVK.TableKMH_PR_PR.AdditionalInfo.PR_CheckDate_Ctrl;
      Visc.Text = $&quot;{oilName} &lt;u&gt;&quot; +
        tools.GetNormalizedValue(DataIVK.TableKMH_PR_PR.Protokol.Visc);         
    }
      
    public void  DrawTableSourceData()
    {
      List &lt;string&gt; listPointsQ = DataIVK.TableKMH_PR_PR.Protokol.Table1.Q.Where(i =&gt; ! i.Contains(&quot;-&quot;) &amp; i.Length  &gt; 0).ToList();
      List &lt;string&gt; listKFactor = DataIVK.TableKMH_PR_PR.Protokol.Table1.K.Where(i =&gt; ! i.Contains(&quot;-&quot;) &amp; i.Length  &gt; 0).ToList();
      
      if (listPointsQ.Count == 0)
        listPointsQ.Add(&quot;&quot;);
      if (listKFactor.Count == 0)
        listKFactor.Add(&quot;&quot;);        
         
      if (Engine.FinalPass == true)
      {
        ////=== Insert Columns for K factor &amp; fill  them headers with text
        int tempCounter =listKFactor.Count + listPointsQ.Count;
        for (int i=listKFactor.Count; i &gt;0 ; i--)
        {
          TableColumn column = new TableColumn();  
          TableSourceData.Columns.Insert(0,column);
            
          for (int j=0; j&lt;TableSourceData.RowCount; j++)
          {
            TableSourceData[0,j].Assign(TableSourceData[1,j]);
          } 
               
          TableSourceData[0,2].Text=&quot;&lt;i&gt;K&lt;sub&gt; Q&lt;/i&gt;&quot;+ i.ToString()+&quot;&lt;/sub&gt;, имп/м&lt;sup&gt;3&quot;;
          TableSourceData[0,4].Text=tools.GetNormalizedValue(listKFactor[i-1]);
          tempCounter--;
        }                       
        TableSourceData[0,1].Text=&quot;Значения &lt;i&gt;K &lt;sub&gt;Qi&lt;/sub&gt;&lt;/i&gt;, контрольного П&lt;sub&gt;&lt;/sub&gt;Р в точках расхода&quot;;
        TableSourceData[listKFactor.Count,1].ColSpan=3;
        
        ////=== Insert Columns for points Q &amp; fill  them headers with text
        tempCounter =listPointsQ.Count;
        for (int i=listPointsQ.Count; i &gt;0 ; i--)
        {
          TableColumn column = new TableColumn();  
          TableSourceData.Columns.Insert(0,column);
          for (int j=0; j&lt;TableSourceData.RowCount; j++)
          {
            TableSourceData[0,j].AssignAll(TableSourceData[1,j]);
          }
            
          TableSourceData[0,2].Text=&quot;&lt;i&gt;Q&lt;sub&gt; &quot;+ i.ToString() +&quot;&lt;/i&gt;&lt;/sub&gt;, &lt;sup&gt;(&lt;i&gt; f/v&lt;/i&gt; )&lt;/sup&gt;&lt;sub&gt;&quot;+  i.ToString();
          TableSourceData[0,4].Text=tools.GetNormalizedValue(listPointsQ[i-1]);
          tempCounter--;
        }  
        TableSourceData[0,1].Text=&quot;Точки расходов (м&lt;sup&gt;3&lt;/sup&gt;/ч) или &lt;i&gt;f/v&lt;/i&gt; (Гц/сСт) для П&lt;sub&gt;&lt;/sub&gt;Р&quot;;
        TableSourceData[listPointsQ.Count,1].ColSpan=listKFactor.Count;
        TableSourceData[0,1].ColSpan=listPointsQ.Count;
        TableSourceData[0,0].Text=&quot;&lt;b&gt;1 Исходные данные&quot;;
        TableSourceData[0,0].ColSpan=TableSourceData.ColumnCount;

        // Setup Columns         
        int sumDynamicCols=TableSourceData.ColumnCount;
        float widthDynamicCol=(Page.PaperWidth-Page.LeftMargin-Page.RightMargin)/sumDynamicCols;                  
         
        for (int w = 0; w &lt; (TableSourceData.ColumnCount); w++)                 
        {
          TableSourceData.Columns[w].Width = widthDynamicCol * Units.Millimeters;
          TableSourceData[w, 3].Text = (w+1).ToString(); //Fill Columns headers numeration
        }
      }
    }
      
    private void TableResults_ManualBuild(object sender, EventArgs e)
    {
      // Set width for Columns with Fixed width
      float widthDynamicCol=(Page.PaperWidth-Page.LeftMargin-Page.RightMargin)/TableResults.ColumnCount;                  
      for (int w = 0; w &lt; (TableResults.ColumnCount); w++)                 
      {                                                           
        TableResults.Columns[w].Width = widthDynamicCol  * Units.Millimeters;
      }
            
      // Draw fixed Rows
      for (int n = 0; n &lt; TableResults.FixedRows; n++)
      {
        TableResults.PrintRow(n);
        TableResults.PrintColumns();                                             
      } 
            
      // Fill TableResults with data from IVK 
      var listTab2Measures = DataIVK.TableKMH_PR_PR.Protokol.Table2
      .Where(i =&gt;  i.Ser != &quot;-&quot; &amp; !String.IsNullOrEmpty(i.Ser))
      .ToList();
      var listTab2_1Points = DataIVK.TableKMH_PR_PR.Protokol.Table2_1
      .Where(i =&gt;  i.Point != &quot;-&quot; &amp; !String.IsNullOrEmpty(i.Point))
      .ToList();
            
      // Group Table2 by Ser and create a dictionary of series with their measures
      var groupedMeasures = listTab2Measures
      .GroupBy(m =&gt; m.Ser)
      .Select(g =&gt; new { Ser = g.Key, Measures = g.ToList() })
      .ToList();

      // Ensure both lists have the same number of unique series/points
      int maxIterations = Math.Min(groupedMeasures.Count, listTab2_1Points.Count);
      
      int tempCounter = 0;
      float initialHeight = BaseRow.Height;
         
      for (int z = 0; z &lt; maxIterations; z++)                    
      {
        var measuresForSeries = groupedMeasures[z].Measures;
        var pointData = listTab2_1Points[z];
               
        int sumPointMeasures = measuresForSeries.Count;
        
        // Set RowSpan for the last three columns based on the number of measures in the series
        Ser.RowSpan = sumPointMeasures;
        K_j.RowSpan = sumPointMeasures;
        K_rasch_j.RowSpan = sumPointMeasures;
        Delta_j.RowSpan = sumPointMeasures;
        
        for (int j = 0; j &lt; sumPointMeasures; j++)
        {
          var measure = measuresForSeries[j];

          Ser.Text = measure.Ser;
          Row.Text = measure.Row;
          Q_ji.Text = tools.GetNormalizedValue(measure.Q_ji);
          f_ji.Text = tools.GetNormalizedValue(measure.f_ji);
          t_EPR_ji.Text = tools.GetNormalizedValue(measure.t_EPR_ji);
          P_EPR_ji.Text = tools.GetNormalizedValue(measure.P_EPR_ji);
          t_PR_ji.Text = tools.GetNormalizedValue(measure.t_PR_ji);
          P_PR_ji.Text = tools.GetNormalizedValue(measure.P_PR_ji);
          k_tp_ji.Text = tools.GetNormalizedValue(measure.k_tp_ji);
          N_EPR_ji.Text = tools.GetNormalizedValue(measure.N_EPR_ji);
          N_PR_ji.Text = tools.GetNormalizedValue(measure.N_PR_ji);
          K_ji.Text = tools.GetNormalizedValue(measure.K_ji);

          // Fill the last three cells with data from Table2_1 for the current point
          K_j.Text = tools.GetNormalizedValue(pointData.K_j);
          K_rasch_j.Text = tools.GetNormalizedValue(pointData.K_rasch_j);
          Delta_j.Text = tools.GetNormalizedValue(pointData.Delta_j);

          TableResults.PrintRow(4);
          TableResults.PrintColumns();
        }
        
        tempCounter += sumPointMeasures;

        // Reset RowSpan for the next series
        Ser.RowSpan = 1;
        K_j.RowSpan = 1;
        K_rasch_j.RowSpan = 1;
        Delta_j.RowSpan = 1;
 
        initialHeight = BaseRow.Height;
        BaseRow.Height = 0;
        TableResults.PrintRow(4);
        TableResults.PrintColumns();
        BaseRow.Height= initialHeight;
      }
    }   
      
      
    private void DataBandPrim_BeforeLayout(object sender, EventArgs e)
    {            
      Prim.Width=(Page.PaperWidth-Page.LeftMargin-Page.RightMargin)*Units.Millimeters;
      int colsSum = TableSourceData.ColumnCount;
      Prim.Text = string.Format(&quot;&lt;i&gt;Примечание&lt;i&gt;- при наличии в СОИ алгоритма измерений и вычислений результатов КМХ по контрольному П&lt;sub&gt;&lt;/sub&gt;Р в «Исходных данных» колонки {0}, {1}, {2} не заполняют&quot;, colsSum -2, colsSum-1, colsSum);
    }

    public void  DrawTableConclusion()
    {
      DateTimeLong.Text = string.Format(&quot;Дата проведения КМХ: &lt;u&gt;{0:dd.MM.yyyy} г.&quot;,
        tools.UnixTimestampToDatetime(DataIVK.TableKMH_PR_PR.DateTimeLong));               
      ServiceStaffDescription.Text =&quot;&lt;i&gt;От сервисной организации:&quot;;
      DeliveryStaffDescription.Text =&quot;&lt;i&gt;От сдающей стороны:&quot;;
      RecievingStaffDescription.Text =&quot;&lt;i&gt;От принимающей стороны:&quot;;                                              
      
      string result = DataIVK.TableKMH_PR_PR.AdditionalInfo.ARM_KMH_Result == &quot;годен&quot; ? &quot;П&lt;sub&gt;&lt;/sub&gt;Р годен к дальнейшей эксплуатации&quot; : &quot;П&lt;sub&gt;&lt;/sub&gt;Р не годен и подлежит внеочередной поверке&quot;;
      Conclusion.Text =string.Format(&quot;&lt;b&gt;3. Заключение: δ &lt;sub&gt;mах &lt;/sub&gt; = {0}%. {1}&quot;,                                                     
        tools.GetNormalizedValue(DataIVK.TableKMH_PR_PR.Protokol.Delta_KMH_Max),                                        
        result);                                                 
      
      ServiceStaffData.Text= string.Format(&quot;{0}                              &quot;,DataIVK.TableKMH_PR_PR.AdditionalInfo.ServiceStaffData);     
      DeliveryStaffData.Text= string.Format(&quot;{0}                              &quot;,DataIVK.TableKMH_PR_PR.AdditionalInfo.DeliveryStaffData);                
      RecievingStaffData.Text= string.Format(&quot;{0}                              &quot;,DataIVK.TableKMH_PR_PR.AdditionalInfo.RecievingStaffData);
    }  
                    
    private void PageFooter_BeforeLayout(object sender, EventArgs e)
    {
      if((Int32)Report.GetVariableValue(&quot;TotalPages&quot;) &lt; 2) 
      { 
        //MessageBox.Show(&quot;TotalPages &lt; 2&quot;);
        PageFooter.Visible = false; 
      }
      else
      {
        // MessageBox.Show(&quot;TotalPages &gt; 1&quot;);
        PageNumeration.Width = (Page.PaperWidth-Page.LeftMargin-Page.RightMargin)*Units.Millimeters;
      }
    }
  }    
}

