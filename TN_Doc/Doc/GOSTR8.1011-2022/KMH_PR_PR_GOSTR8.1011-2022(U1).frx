    <Parameter Name="Delta_KMH_Max" DataType="System.String" AsString=""/>
    <Parameter Name="DateKMH" DataType="System.String" AsString=""/>
  </Dictionary>
  <ReportPage Name="Page" PaperWidth="297" PaperHeight="210" RawPaperSize="9" Guides="-18.9" Watermark.Font="Arial, 60pt" StartPageEvent="Page_StartPage">
    <ReportTitleBand Name="ReportTitle" Width="1047.06" Height="183.33" CanGrow="true" CanShrink="true" CanBreak="true">
      <TableObject Name="TableHeader" Width="1047.06" Height="183.33" CanBreak="false">
        <TableColumn Name="Column1" Width="523.49"/>
        <TableColumn Name="Column2" Width="523.57"/>
        <TableRow Name="Row1" Height="88.83" AutoSize="true">
          <TableCell Name="ProtocolType" Text="ПРОТОКОЛ&#13;&#10;&#13;&#10;контроля метрологических характеристик посредством сравнения коэффициентов преобразования при измерениях расхода рабочими,&#13;&#10;резервными средствами измерений объемного расхода и контрольно-резервными средствами измерений, эталонами единицы&#13;&#10;объемного расхода" Padding="2, 1, 2, 6" HorzAlign="Center" VertAlign="Center" Font="Arial, 10pt, style=Bold" FontWidthRatio="0.85" ColSpan="2"/>
          <TableCell Name="Cell2" VertAlign="Center" Font="Arial, 9pt" FontWidthRatio="0.85" TextRenderType="HtmlTags"/>
        </TableRow>
        <TableRow Name="Row131">
          <TableCell Name="PR_Type_Oper" Border.Lines="Left, Right, Top" Text="Тип СИ объемного расхода __________" VertAlign="Center" Font="Arial, 10pt" TextRenderType="HtmlTags"/>
          <TableCell Name="PR_Type_Ctrl" Border.Lines="Right, Top" Text="Тип контрольного СИ объемного расхода __________" VertAlign="Center" Font="Arial, 10pt" TextRenderType="HtmlTags"/>
        </TableRow>
        <TableRow Name="Row132">
          <TableCell Name="PR_FactoryNumber_Oper" Border.Lines="Left, Right" Text="Заводской номер __________" VertAlign="Center" Font="Arial, 10pt" TextRenderType="HtmlTags"/>
          <TableCell Name="PR_FactoryNumber_Ctrl" Border.Lines="Right" Text="Заводской номер __________" VertAlign="Center" Font="Arial, 10pt" TextRenderType="HtmlTags"/>
        </TableRow>
        <TableRow Name="Row133">
          <TableCell Name="DeltaPr" Border.Lines="Left, Right" Text="Пределы допускаемой относительной погрешности, % __________" VertAlign="Center" Font="Arial, 10pt" TextRenderType="HtmlTags"/>
          <TableCell Name="DeltaEpr" Border.Lines="Right" Text="Пределы допускаемой относительной погрешности, % __________" VertAlign="Center" Font="Arial, 10pt" TextRenderType="HtmlTags"/>
        </TableRow>
        <TableRow Name="Row134">
          <TableCell Name="Place_SIKN_Name" Border.Lines="Left, Right" Text="СИКН/СИКНП __________" VertAlign="Center" Font="Arial, 10pt" TextRenderType="HtmlTags"/>
          <TableCell Name="PR_CheckDate_Ctrl" Border.Lines="Right" Text="Дата поверки __________" VertAlign="Center" Font="Arial, 10pt" TextRenderType="HtmlTags"/>
        </TableRow>
