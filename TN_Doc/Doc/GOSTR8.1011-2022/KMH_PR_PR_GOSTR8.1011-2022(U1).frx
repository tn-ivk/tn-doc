<Report ScriptLanguage="CSharp" ReferencedAssemblies="System.dll&#13;&#10;System.Drawing.dll&#13;&#10;System.Windows.Forms.dll&#13;&#10;System.Data.dll&#13;&#10;System.Xml.dll&#13;&#10;Newtonsoft.Json.dll&#13;&#10;System.Collections.dll&#13;&#10;System.Core.dll" DoublePass="true" ReportInfo.Created="03/25/2020 12:46:46" ReportInfo.Modified="08/30/2024 08:56:57" ReportInfo.CreatorVersion="2024.2.0.0">
  <ScriptText>using System;
using System.Reflection;
using System.Collections;
using System.Collections.Generic;
using System.ComponentModel;         
using System.Drawing;
using System.Data;
using System.IO;
using FastReport;
using FastReport.Data;
using FastReport.Dialog;
using FastReport.Barcode;
using FastReport.Table;
using FastReport.Utils;
using System.Linq;
using Newtonsoft.Json.Linq;

namespace FastReport
{
  public class ReportScript
  {
    JToken JDoc;
    JToken JSettings;
    JToken JTableKMH_PR_PR;
    JToken JProtokol;
    JToken JAdditionalInfo;  
    
    private void Page_StartPage(object sender, EventArgs e)
    {
      JDoc = JToken.Parse(Report.GetParameterValue(&quot;JsonDoc&quot;).ToString());
      JSettings = JDoc[&quot;Doc&quot;][&quot;Settings&quot;];
      JTableKMH_PR_PR = JDoc[&quot;Doc&quot;][&quot;DataIVK&quot;][&quot;TableKMH_PR_PR&quot;];
      JProtokol = JDoc[&quot;Doc&quot;][&quot;DataIVK&quot;][&quot;TableKMH_PR_PR&quot;][&quot;Protokol&quot;];
      JAdditionalInfo = JDoc[&quot;Doc&quot;][&quot;DataIVK&quot;][&quot;TableKMH_PR_PR&quot;][&quot;AdditionalInfo&quot;];
      
      Page.PaperHeight = 210; //(int)JSettings[&quot;General&quot;][&quot;PageSettings&quot;][&quot;PaperHeight&quot;];
      Page.PaperWidth = 297; //(int)JSettings[&quot;General&quot;][&quot;PageSettings&quot;][&quot;PaperWidth&quot;];
         
      Page.TopMargin = (int)JSettings[&quot;General&quot;][&quot;PageSettings&quot;][&quot;TopMargin&quot;];
      Page.BottomMargin = (int)JSettings[&quot;General&quot;][&quot;PageSettings&quot;][&quot;BottomMargin&quot;];
      Page.LeftMargin = (int)JSettings[&quot;General&quot;][&quot;PageSettings&quot;][&quot;LeftMargin&quot;];
      Page.RightMargin = (int)JSettings[&quot;General&quot;][&quot;PageSettings&quot;][&quot;RightMargin&quot;];
      
      FillReportTitle();
      FillReportSummary();
    }
     
    private void FillReportTitle()
    {
      PR_Type_Oper.Text = $&quot;Тип СИ объемного расхода &lt;u&gt;{JAdditionalInfo[&quot;PR_Type_Oper&quot;].ToString()}&lt;/u&gt;&quot;;
      PR_FactoryNumber_Oper.Text = $&quot;Заводской номер &lt;u&gt;{JAdditionalInfo[&quot;PR_FactoryNumber_Oper&quot;].ToString()}&lt;/u&gt;&quot;;      
      DeltaPr.Text = $&quot;Пределы допускаемой относительной погрешности, % &lt;u&gt;{JProtokol[&quot;DeltaPr&quot;].ToString().Replace('.',',')}&lt;/u&gt;&quot;;      
      
      string placeSiknName = String.IsNullOrEmpty(JSettings[&quot;Header&quot;][&quot;FieldSIKN&quot;].ToString()) ?
      $&quot;СИКН/СИКНП &lt;u&gt;{JAdditionalInfo[&quot;Place_SIKN_Name&quot;].ToString()}&lt;/u&gt;&quot; :
      $&quot;{JSettings[&quot;Header&quot;][&quot;FieldSIKN&quot;].ToString()} &lt;u&gt;{JAdditionalInfo[&quot;Place_SIKN_Name&quot;].ToString()}&lt;/u&gt;&quot;;                    
      Place_SIKN_Name.Text = placeSiknName;
      
      string placePspName = String.IsNullOrEmpty(JSettings[&quot;Header&quot;][&quot;FieldPSP&quot;].ToString()) ?
      $&quot;ПСП &lt;u&gt;{JAdditionalInfo[&quot;Place&quot;].ToString()}&lt;/u&gt;&quot; :
      $&quot;{JSettings[&quot;Header&quot;][&quot;FieldPSP&quot;].ToString()} &lt;u&gt;{JAdditionalInfo[&quot;Place&quot;].ToString()}&lt;/u&gt;&quot;;      
      Place.Text = placePspName;     
      
      //Place_SIKN_Name.Text = $&quot;СИКН/СИКНП &lt;u&gt;{JAdditionalInfo[&quot;Place_SIKN_Name&quot;].ToString()}&lt;/u&gt;&quot;;
      //Place.Text = $&quot;ПСП &lt;u&gt;{JAdditionalInfo[&quot;Place&quot;].ToString()}&lt;/u&gt;&quot;;
      
      PR_Type_Ctrl.Text = $&quot;Тип контрольного СИ объемного расхода &lt;u&gt;{JAdditionalInfo[&quot;PR_Type_Ctrl&quot;].ToString()}&lt;/u&gt;&quot;;
      PR_FactoryNumber_Ctrl.Text = $&quot;Заводской номер &lt;u&gt;{JAdditionalInfo[&quot;PR_FactoryNumber_Ctrl&quot;].ToString()}&lt;/u&gt;&quot;;      
      DeltaEpr.Text = $&quot;Пределы допускаемой относительной погрешности, % &lt;u&gt;{JProtokol[&quot;DeltaEpr&quot;].ToString().Replace('.',',')}&lt;/u&gt;&quot;;       
      PR_CheckDate_Ctrl.Text = $&quot;Дата поверки &lt;u&gt;{JAdditionalInfo[&quot;PR_CheckDate_Ctrl&quot;].ToString()}&lt;/u&gt;&quot;;
      Visc.Text = $&quot;Вязкость нефти/нефтепродуктов при КМХ, мм&lt;sup&gt;2&lt;/sup&gt;/с (сСт) &lt;u&gt;{JProtokol[&quot;Visc&quot;].ToString().Replace('.',',')}&lt;/u&gt;&quot;;
    }
    
    private void Table1_ManualBuild(object sender, EventArgs e)
    {
      if (Engine.FinalPass == true)
      {
        JToken jsonTable1 = JTableKMH_PR_PR[&quot;Protokol&quot;][&quot;Table1&quot;];       
        
        List&lt;string&gt; listQ = jsonTable1[&quot;Q&quot;].Where(x=&gt;x.ToString()!=&quot;-&quot;).Select(x=&gt;x.ToString()).ToList();
        List&lt;string&gt; listK = jsonTable1[&quot;K&quot;].Where(x=&gt;x.ToString()!=&quot;-&quot;).Select(x=&gt;x.ToString()).ToList();
        
        for (int i=1; i&lt;listQ.Count; i++)
        {
          Table1.Columns.Insert(TColumn_Table1_Q0.Index+1, new TableColumn());
          
          foreach(TableRow row in Table1.Rows)
            row[TColumn_Table1_Q0.Index+1].AssignAll(row[TColumn_Table1_Q0.Index]);
          
          //Table1_RowData[TColumn_Table1_Q0.Index+1].Name = $&quot;Q{i}&quot;;
          //Table1_RowData[TColumn_Table1_Q0.Index+1].Text = $&quot;Q{i}&quot;;
          }
        Table1_Q_Header.ColSpan = listQ.Count;
        
        for (int i = 1; i &lt; listK.Count; i++)
        {
          Table1.Columns.Insert(TColumn_Table1_K0.Index+1, new TableColumn());
          
          foreach(TableRow row in Table1.Rows)
            row[TColumn_Table1_K0.Index+1].AssignAll(row[TColumn_Table1_K0.Index]);
        
          //Table1_RowData[TColumn_Table1_K0.Index+1].Name = $&quot;K{i}&quot;;
          //Table1_RowData[TColumn_Table1_K0.Index+1].Text = $&quot;K{i}&quot;;
        }         
        Table1_K_Header.ColSpan = listK.Count;
         
        float widthColumn=(Page.PaperWidth * Units.Millimeters-
          Page.LeftMargin * Units.Millimeters-
          Page.RightMargin * Units.Millimeters-
          Table1_StaticColumn1.Width-
          Table1_StaticColumn2.Width-
          Table1_StaticColumn3.Width)/(listQ.Count+listK.Count);  
     
        for (int i = 0; i &lt; Table1.ColumnCount; i++)
          if (!Table1.Columns[i].Name.Contains(&quot;StaticColumn&quot;) &amp;&amp; !float.IsInfinity(widthColumn))
            Table1.Columns[i].Width = widthColumn;
       
        for (int i = 0; i &lt; listQ.Count; i++)
        {
          Table1_RowHeader[i].Text = $&quot;Q&lt;sub&gt;{i+1}&lt;/sub&gt;/ f / ν&lt;sub&gt;{i+1}&lt;/sub&gt;&quot;;
          Table1_RowData[i].Text = listQ[i].Replace('.',',');
        }
        
        for (int i = 0; i &lt; listK.Count; i++)
        {
          Table1_RowHeader[TColumn_Table1_K0.Index+i].Text = $&quot;K&lt;sub&gt;Q{i+1}&lt;/sub&gt;&quot;;
          Table1_RowData[TColumn_Table1_K0.Index+i].Text = listK[i].Replace('.',',');
        }
      }                                  
      
      PrintTable(Table1);
    }        
    
    private void Table2_ManualBuild(object sender, EventArgs e)
    {
      if (Engine.FinalPass == true)
      { 
        JToken jsonTable2 = JTableKMH_PR_PR[&quot;Protokol&quot;][&quot;Table2&quot;];
        JToken jsonTable2_1 = JTableKMH_PR_PR[&quot;Protokol&quot;][&quot;Table2_1&quot;];
        
        List&lt;JToken&gt; listTable2 = jsonTable2.Where(x=&gt;x[&quot;Ser&quot;].ToString()!=&quot;-&quot; &amp;&amp; x[&quot;Ser&quot;].ToString()!=&quot;&quot;).ToList();
        List&lt;JToken&gt; listTable2_1 = jsonTable2_1.Where(x=&gt;x[&quot;Point&quot;].ToString()!=&quot;-&quot; &amp;&amp; x[&quot;Point&quot;].ToString()!=&quot;&quot;).ToList();         
        List&lt;string&gt; listSerTable2 = listTable2.Select(x=&gt;x[&quot;Ser&quot;].ToString()).Distinct().ToList();
        
        for(int i = 0; i &lt; listTable2_1.Count; i++)
        {
          List&lt;JToken&gt; SerTable2 = jsonTable2.Where(x=&gt;x[&quot;Ser&quot;].ToString()==listSerTable2[i]).ToList();          
          List&lt;TableRow&gt; rows = new List&lt;TableRow&gt;();
          
          for (int j = 0; j &lt; SerTable2.Count; j++)
          { 
            if (j==0)
            {
              Ser.RowSpan = SerTable2.Count;
              K_j.RowSpan = SerTable2.Count;
              K_rasch_j.RowSpan = SerTable2.Count;
              Delta_j.RowSpan = SerTable2.Count;
            }
            else 
            {
              Ser.RowSpan = 1;
              K_j.RowSpan = 1;
              K_rasch_j.RowSpan = 1;
              Delta_j.RowSpan = 1;
            }
            
            Ser.Text = SerTable2[j][&quot;Ser&quot;].ToString().Replace('.',',');
            Row.Text = SerTable2[j][&quot;Row&quot;].ToString().Replace('.',',');
            Q_ji.Text = SerTable2[j][&quot;Q_ji&quot;].ToString().Replace('.',',');
            f_ji.Text = SerTable2[j][&quot;f_ji&quot;].ToString().Replace('.',',');
            t_EPR_ji.Text = SerTable2[j][&quot;t_EPR_ji&quot;].ToString().Replace('.',',');
            P_EPR_ji.Text = SerTable2[j][&quot;P_EPR_ji&quot;].ToString().Replace('.',',');
            t_PR_ji.Text = SerTable2[j][&quot;t_PR_ji&quot;].ToString().Replace('.',',');
            P_PR_ji.Text = SerTable2[j][&quot;P_PR_ji&quot;].ToString().Replace('.',',');
            k_tp_ji.Text = SerTable2[j][&quot;k_tp_ji&quot;].ToString().Replace('.',',');            
            N_EPR_ji.Text = SerTable2[j][&quot;N_EPR_ji&quot;].ToString().Replace('.',',');
            N_PR_ji.Text = SerTable2[j][&quot;N_PR_ji&quot;].ToString().Replace('.',',');
            K_ji.Text = SerTable2[j][&quot;K_ji&quot;].ToString().Replace('.',',');
            
            K_j.Text = listTable2_1[i][&quot;K_j&quot;].ToString().Replace('.',',');
            K_rasch_j.Text = listTable2_1[i][&quot;K_rasch_j&quot;].ToString().Replace('.',',');
            Delta_j.Text = listTable2_1[i][&quot;Delta_j&quot;].ToString().Replace('.',',');            
           
            TableRow row = new TableRow();
            row.AssignAll(Table2_RowData);
            row.Visible=true;
            //row.Name = $&quot;row{j}&quot;;
            rows.Add(row);         
          }
          Table2.Rows.AddRange(rows.ToArray());
        }
      }
      
      MI.Text = JAdditionalInfo[&quot;GostBinary&quot;][&quot;MI&quot;].ToString();
      
      PrintTable(Table2);
    }     
    
    private void FillReportSummary()
    {
      var  kmhDeltaMax = JProtokol[&quot;Delta_KMH_Max&quot;].ToString().Replace('.',',');
      if(kmhDeltaMax.StartsWith(&quot;-&quot;)&amp;&amp; kmhDeltaMax.Length ==1){
        kmhDeltaMax = &quot; —  &quot;;
      }
      
      if(kmhDeltaMax.Length ==0){
        kmhDeltaMax = &quot; —  &quot;;
      }
      
      if(kmhDeltaMax.StartsWith(&quot;-&quot;)&amp;&amp; kmhDeltaMax.Length &gt;1){
        kmhDeltaMax = $&quot;  {kmhDeltaMax.Substring(1)}  &quot;;
      }
      
            
      if(kmhDeltaMax.StartsWith(&quot;+&quot;)&amp;&amp; kmhDeltaMax.Length &gt;1){
        kmhDeltaMax = $&quot;  {kmhDeltaMax.Substring(1)}  &quot;;
      }
      
      
      Report.SetParameterValue(&quot;Delta_KMH_Max&quot;, kmhDeltaMax);
      Report.SetParameterValue(&quot;ARM_KMH_Result&quot;, JAdditionalInfo[&quot;ARM_KMH_Result&quot;].ToString() == &quot;годен&quot; ? &quot;годно&quot; : &quot;не годно&quot;);
      
      DateTime date = new DateTime(1970, 1, 1, 0, 0, 0, DateTimeKind.Utc).AddSeconds((long)JTableKMH_PR_PR[&quot;DateTimeLong&quot;]);
      Report.SetParameterValue(&quot;DateKMH&quot;, date.ToString(&quot;dd.MM.yyyy&quot;));
        
      bool hasCustomSIKNName = !String.IsNullOrEmpty(JSettings[&quot;Footer&quot;][&quot;FieldSIKN&quot;].ToString());      
      
      ServiceStaffData_Company.Text = JAdditionalInfo[&quot;GostBinary&quot;][&quot;ServiceStaffData&quot;][&quot;Company&quot;].ToString();
      ServiceStaffData_Post.Text = JAdditionalInfo[&quot;GostBinary&quot;][&quot;ServiceStaffData&quot;][&quot;Post&quot;].ToString();
      ServiceStaffData_FIO.Text = JAdditionalInfo[&quot;GostBinary&quot;][&quot;ServiceStaffData&quot;][&quot;FIO&quot;].ToString();
      if(hasCustomSIKNName){
        ServiceStaffData_Company_Desc.Text=$&quot;организация, проводящая техническое обслуживание {JSettings[&quot;Footer&quot;][&quot;FieldSIKN&quot;]}&quot;;
      }
      
      OperatingStaffData_Company.Text = JAdditionalInfo[&quot;GostBinary&quot;][&quot;OperatingStaffData&quot;][&quot;Company&quot;].ToString();
      OperatingStaffData_Post.Text = JAdditionalInfo[&quot;GostBinary&quot;][&quot;OperatingStaffData&quot;][&quot;Post&quot;].ToString();
      OperatingStaffData_FIO.Text = JAdditionalInfo[&quot;GostBinary&quot;][&quot;OperatingStaffData&quot;][&quot;FIO&quot;].ToString();
      if(hasCustomSIKNName){
        OperatingStaffData_Company_Desc.Text=$&quot;организация, эксплуатирующая {JSettings[&quot;Footer&quot;][&quot;FieldSIKN&quot;]}&quot;;
      }
      
      DeliveryOrRecievingStaffData_Company.Text = JAdditionalInfo[&quot;GostBinary&quot;][&quot;DeliveryOrRecievingStaffData&quot;][&quot;Company&quot;].ToString();
      DeliveryOrRecievingStaffData_Post.Text = JAdditionalInfo[&quot;GostBinary&quot;][&quot;DeliveryOrRecievingStaffData&quot;][&quot;Post&quot;].ToString();
      DeliveryOrRecievingStaffData_FIO.Text = JAdditionalInfo[&quot;GostBinary&quot;][&quot;DeliveryOrRecievingStaffData&quot;][&quot;FIO&quot;].ToString();
    }
    
    private void PrintTable(TableObject table)
    {
      for (int i=0;i&lt;table.RowCount;i++)
      {       
        table.PrintRow(i);
        table.PrintColumns();
      }    
    }
  }    
}

</ScriptText>
