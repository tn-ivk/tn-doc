          <TableCell Name="Visc" Border.Lines="Right, Bottom" Text="Вязкость нефти/нефтепродуктов при КМХ, мм&lt;sup&gt;2&lt;/sup&gt;/с (сСт) __________" VertAlign="Center" Font="Arial, 10pt" TextRenderType="HtmlTags"/>
        </TableRow>
      </TableObject>
    </ReportTitleBand>
    <DataBand Name="DataBandTable1" Top="187.33" Width="1047.06" Height="160.65" CanGrow="true" CanShrink="true" CanBreak="true">
      <TableObject Name="Table1" Top="9.45" Width="1047.05" Height="151.2" ManualBuildEvent="Table1_ManualBuild">
        <TableColumn Name="TColumn_Table1_Q0" Width="296.35"/>
        <TableColumn Name="TColumn_Table1_K0" Width="362.5"/>
        <TableColumn Name="Table1_StaticColumn1" MinWidth="88.45" Width="88.45"/>
        <TableColumn Name="Table1_StaticColumn2" MinWidth="126.25" Width="126.25"/>
        <TableColumn Name="Table1_StaticColumn3" MinWidth="173.5" Width="173.5"/>
        <TableRow Name="Row158">
          <TableCell Name="Cell1129" Text="     1 Исходные данные" VertAlign="Center" Font="Arial, 10pt, style=Bold" ColSpan="5"/>
          <TableCell Name="Cell1154" Font="Arial, 10pt"/>
          <TableCell Name="Cell1179" Font="Arial, 10pt"/>
          <TableCell Name="Cell1184" Font="Arial, 10pt"/>
          <TableCell Name="Cell1189" Font="Arial, 10pt"/>
        </TableRow>
        <TableRow Name="Row159" Height="56.7">
          <TableCell Name="Table1_Q_Header" Border.Lines="All" Text="Расход Q, м&lt;sup&gt;3&lt;/sup&gt;/ч или f/ν, Гц/мм&lt;sup&gt;2&lt;/sup&gt;/с для СИ рас-&lt;br&gt;хода" HorzAlign="Center" VertAlign="Center" Font="Arial, 8pt" TextRenderType="HtmlTags"/>
          <TableCell Name="Table1_K_Header" Border.Lines="All" Text="Коэффициент преобразования контрольно-резервно-&lt;br&gt;го СИ объемного расхода/эталона единицы объемно-&lt;br&gt;го расхода в точках расходов K&lt;sub&gt;Qi&lt;/sub&gt;, имп./м&lt;sup&gt;3&lt;/sup&gt;" HorzAlign="Center" VertAlign="Center" Font="Arial, 8pt" TextRenderType="HtmlTags"/>
          <TableCell Name="Cell1180" Border.Lines="All" Text="Для рабочей жидкости&lt;sup&gt;1)&lt;/sup&gt;" HorzAlign="Center" VertAlign="Center" Font="Arial, 8pt" TextRenderType="HtmlTags" ColSpan="3"/>
          <TableCell Name="Cell1185" Border.Lines="All" Font="Arial, 10pt"/>
          <TableCell Name="Cell1190" Border.Lines="All" Font="Arial, 10pt"/>
        </TableRow>
        <TableRow Name="Table1_RowHeader" Height="56.7">
          <TableCell Name="Cell1139" Border.Lines="All" Border.BottomLine.Style="Double" Text="Q&lt;sub&gt;i&lt;/sub&gt;/ f / ν&lt;sub&gt;i&lt;/sub&gt;" HorzAlign="Center" VertAlign="Center" Font="Arial, 8pt" TextRenderType="HtmlTags"/>
          <TableCell Name="Cell1156" Border.Lines="All" Border.BottomLine.Style="Double" Text=" K&lt;sub&gt;Qi&lt;/sub&gt;" HorzAlign="Center" VertAlign="Center" Font="Arial, 8pt" TextRenderType="HtmlTags"/>
          <TableCell Name="Cell1181" Border.Lines="All" Border.BottomLine.Style="Double" Text="Плотность ρ&lt;sub&gt;t&lt;/sub&gt;,&lt;br&gt;кг/м&lt;sup&gt;3&lt;/sup&gt; " HorzAlign="Center" VertAlign="Center" Font="Arial, 8pt" TextRenderType="HtmlTags"/>
          <TableCell Name="Cell1186" Border.Lines="All" Border.BottomLine.Style="Double" Text="Коэффициент объ-&lt;br&gt;емного расширения&lt;br&gt;β&lt;sub&gt;15&lt;/sub&gt;/β&lt;sub&gt;20&lt;/sub&gt;, °С&lt;sup&gt;–1&lt;/sup&gt;" HorzAlign="Center" VertAlign="Center" Font="Arial, 8pt" TextRenderType="HtmlTags"/>
          <TableCell Name="Cell1191" Border.Lines="All" Border.BottomLine.Style="Double" Text="Коэффициент сжимаемости&#13;&#10;γ&lt;sub&gt;15&lt;/sub&gt;/γ&lt;sub&gt;20&lt;/sub&gt;, МПа&lt;sup&gt;–1&lt;/sup&gt;" HorzAlign="Center" VertAlign="Center" Font="Arial, 8pt" TextRenderType="HtmlTags"/>
        </TableRow>
