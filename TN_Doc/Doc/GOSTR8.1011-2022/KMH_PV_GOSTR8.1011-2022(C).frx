  <ScriptText>using System;
using System.Reflection;
using System.Collections;
using System.Collections.Generic;
using System.ComponentModel;         
using System.Drawing;
using System.Data;
using System.IO;
using FastReport;
using FastReport.Data;
using FastReport.Dialog;
using FastReport.Barcode;
using FastReport.Table;
using FastReport.Utils;
using System.Linq;
using Newtonsoft.Json.Linq; 

namespace FastReport
{
  public class ReportScript
  {
    JToken JDoc;
    JToken JSettings;
    JToken JTableKMH_PV;
    JToken JProtokol;
    JToken JAdditionalInfo;    
   
    int ProtocolNumber;
    int KMH_TYPE; 
    int NefType;    

    List&lt;string&gt; ListOilName;
    List&lt;string&gt; ListKMHType;
    
    private void Page_StartPage(object sender, EventArgs e)
    {
      JDoc = JToken.Parse(Report.GetParameterValue(&quot;JsonDoc&quot;).ToString());
      JSettings = JDoc[&quot;Doc&quot;][&quot;Settings&quot;];
      JTableKMH_PV = JDoc[&quot;Doc&quot;][&quot;DataIVK&quot;][&quot;TableKMH_PV&quot;];
      JProtokol = JDoc[&quot;Doc&quot;][&quot;DataIVK&quot;][&quot;TableKMH_PV&quot;][&quot;Protokol&quot;];
      JAdditionalInfo = JDoc[&quot;Doc&quot;][&quot;DataIVK&quot;][&quot;TableKMH_PV&quot;][&quot;AdditionalInfo&quot;];
        
      Page.PaperHeight = (int)JSettings[&quot;General&quot;][&quot;PageSettings&quot;][&quot;PaperHeight&quot;];
      Page.PaperWidth = (int)JSettings[&quot;General&quot;][&quot;PageSettings&quot;][&quot;PaperWidth&quot;];
                    
      Page.TopMargin = (int)JSettings[&quot;General&quot;][&quot;PageSettings&quot;][&quot;TopMargin&quot;];
      Page.BottomMargin = (int)JSettings[&quot;General&quot;][&quot;PageSettings&quot;][&quot;BottomMargin&quot;];
      Page.LeftMargin = (int)JSettings[&quot;General&quot;][&quot;PageSettings&quot;][&quot;LeftMargin&quot;];
      Page.RightMargin = (int)JSettings[&quot;General&quot;][&quot;PageSettings&quot;][&quot;RightMargin&quot;];
                  
      ListOilName = new List&lt;string&gt;() {&quot;нефти&quot;, &quot;нефтепродукте&quot;};
      ListKMHType = new List&lt;string&gt;() {&quot;динамической&quot;, &quot;кинематической&quot;};
  
      ProtocolNumber = (int)JSettings[&quot;General&quot;][&quot;ProtocolNumber&quot;];
      KMH_TYPE = (int)JTableKMH_PV[&quot;KMH_TYPE&quot;]; 
      NefType = (int)JSettings[&quot;General&quot;][&quot;NefType&quot;];
                  
      FillReportTitle();
      FillTable1(ProtocolNumber);
      FillTable2(ProtocolNumber);
      FillReportSummary(ProtocolNumber);
      }
        
    private void FillReportTitle()
    {
      Report.SetParameterValue(&quot;OilName&quot;, ListOilName[NefType-1]);
      Report.SetParameterValue(&quot;KMHType&quot;, ListKMHType[KMH_TYPE]);
                
      string placeSiknName = String.IsNullOrEmpty(JSettings[&quot;Header&quot;][&quot;FieldSIKN&quot;].ToString()) ?
      $&quot;СИКН/СИКНП &lt;u&gt;{JAdditionalInfo[&quot;Place_SIKN_Name&quot;].ToString()}&lt;/u&gt;&quot; :
      $&quot;{JSettings[&quot;Header&quot;][&quot;FieldSIKN&quot;].ToString()} &lt;u&gt;{JAdditionalInfo[&quot;Place_SIKN_Name&quot;].ToString()}&lt;/u&gt;&quot;;                    
      Place_SIKN_Name.Text = placeSiknName;
      
      string placePspName = String.IsNullOrEmpty(JSettings[&quot;Header&quot;][&quot;FieldPSP&quot;].ToString()) ?
      $&quot;ПСП &lt;u&gt;{JAdditionalInfo[&quot;Place_PSP&quot;].ToString()}&lt;/u&gt;&quot; :
      $&quot;{JSettings[&quot;Header&quot;][&quot;FieldPSP&quot;].ToString()} &lt;u&gt;{JAdditionalInfo[&quot;Place_PSP&quot;].ToString()}&lt;/u&gt;&quot;;      
      Place_PSP.Text = placePspName;  
    }
        
    private void FillTable1(int protocolNumber)
    {
      JToken jsonTable1 = JTableKMH_PV[&quot;Protocol&quot;][&quot;Protokol&quot;][protocolNumber-1][&quot;Table1&quot;];
      JToken jsonPV_AddInfo = JAdditionalInfo[&quot;PV_AddInfo&quot;][protocolNumber-1];
          
      PV_Type.Text = jsonPV_AddInfo[&quot;PV_Type&quot;].ToString();
      PV_ManufNum.Text = jsonPV_AddInfo[&quot;PV_ManufNum&quot;].ToString();
      PV_CheckDate.Text = jsonPV_AddInfo[&quot;PV_CheckDate&quot;].ToString();
      Delta_PV.Text = jsonTable1[&quot;Delta_PV&quot;].ToString().Replace('.',',');
                    
      LAB_Type.Text = JAdditionalInfo[&quot;LAB_Type&quot;].ToString();
      LAB_ManufNum.Text = JAdditionalInfo[&quot;LAB_ManufNum&quot;].ToString();
      LAB_CheckDate.Text = JAdditionalInfo[&quot;LAB_CheckDate&quot;].ToString();
      Delta_LAB.Text = jsonTable1[&quot;Delta_LAB&quot;].ToString().Replace('.',','); 
                
      DeltaHeader.Text = KMH_TYPE == 0 ? &quot;|η&lt;sub&gt;п.вз&lt;/sub&gt; – η&lt;sub&gt;лаб&lt;/sub&gt;|&quot; : &quot;|ν&lt;sub&gt;п.вз&lt;/sub&gt; – ν&lt;sub&gt;лаб&lt;/sub&gt;|&quot;;
    }
        
    private void FillTable2(int protocolNumber)
    {
      JToken jsonTable1 = JTableKMH_PV[&quot;Protocol&quot;][&quot;Protokol&quot;][protocolNumber-1][&quot;Table2&quot;];
                    
      Visc.Text = jsonTable1[&quot;Visc&quot;].ToString().Replace('.',',');
      Visc_LAB.Text = jsonTable1[&quot;Visc_LAB&quot;].ToString().Replace('.',',');
      Q.Text = jsonTable1[&quot;Q&quot;].ToString().Replace('.',',');
      t.Text = jsonTable1[&quot;t&quot;].ToString().Replace('.',',');
      P.Text = jsonTable1[&quot;P&quot;].ToString().Replace('.',',');
      Delta.Text = jsonTable1[&quot;Delta&quot;].ToString().Replace('.',',');
                    
      CharacteristicsBIKHeader.Text = protocolNumber == 1 ? &quot;Показатели нефти в БИК&quot; : &quot;Показатели нефтепродуктов в БИК&quot;;
                
      ConditionKMH.Text = KMH_TYPE == 0 ?
        &quot;|η&lt;sub&gt;п.вз&lt;/sub&gt; – η&lt;sub&gt;лаб&lt;/sub&gt;| ≤ |Δ&lt;sub&gt;п.вз&lt;/sub&gt;| + |Δ&lt;sub&gt;лаб&lt;/sub&gt;|&quot; :
        &quot;|ν&lt;sub&gt;п.вз&lt;/sub&gt; – ν&lt;sub&gt;лаб&lt;/sub&gt;| ≤ |Δ&lt;sub&gt;п.вз&lt;/sub&gt;| + |Δ&lt;sub&gt;лаб&lt;/sub&gt;|&quot;;  
      
      MI.Text = JAdditionalInfo[&quot;GostBinary&quot;][&quot;MI&quot;].ToString();
    }

    private void FillReportSummary(int protocolNumber)
    {
      JToken jsonPV_AddInfo = JAdditionalInfo[&quot;PV_AddInfo&quot;][protocolNumber-1];
                    
      Report.SetParameterValue(&quot;ARM_KMH_Result&quot;, jsonPV_AddInfo[&quot;ARM_KMH_Result&quot;].ToString() == &quot;годен&quot; ? &quot;годно&quot; : &quot;не годно&quot;);
                    
      DateTime date = new DateTime(1970, 1, 1, 0, 0, 0, DateTimeKind.Utc).AddSeconds((long)JTableKMH_PV[&quot;DateTimeLong&quot;]);
      Report.SetParameterValue(&quot;DateKMH&quot;, date.ToString(&quot;dd.MM.yyyy&quot;));
            
      
      //if ((bool)JARMData[&quot;GostBinary&quot;][&quot;OperatingStaffDataIsDelivery&quot;])
      //{
      //}       
      
      ServiceStaffData_Company.Text = JAdditionalInfo[&quot;GostBinary&quot;][&quot;ServiceStaffData&quot;][&quot;Company&quot;].ToString();
      ServiceStaffData_Post.Text = JAdditionalInfo[&quot;GostBinary&quot;][&quot;ServiceStaffData&quot;][&quot;Post&quot;].ToString();
      ServiceStaffData_FIO.Text = JAdditionalInfo[&quot;GostBinary&quot;][&quot;ServiceStaffData&quot;][&quot;FIO&quot;].ToString();
      
      OperatingStaffData_Company.Text = JAdditionalInfo[&quot;GostBinary&quot;][&quot;OperatingStaffData&quot;][&quot;Company&quot;].ToString();
      OperatingStaffData_Post.Text = JAdditionalInfo[&quot;GostBinary&quot;][&quot;OperatingStaffData&quot;][&quot;Post&quot;].ToString();
      OperatingStaffData_FIO.Text = JAdditionalInfo[&quot;GostBinary&quot;][&quot;OperatingStaffData&quot;][&quot;FIO&quot;].ToString();
      
      DeliveryOrRecievingStaffData_Company.Text = JAdditionalInfo[&quot;GostBinary&quot;][&quot;DeliveryOrRecievingStaffData&quot;][&quot;Company&quot;].ToString();
      DeliveryOrRecievingStaffData_Post.Text = JAdditionalInfo[&quot;GostBinary&quot;][&quot;DeliveryOrRecievingStaffData&quot;][&quot;Post&quot;].ToString();
      DeliveryOrRecievingStaffData_FIO.Text = JAdditionalInfo[&quot;GostBinary&quot;][&quot;DeliveryOrRecievingStaffData&quot;][&quot;FIO&quot;].ToString();
    }
  }
}


