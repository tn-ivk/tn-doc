    public void Table1_ManualBuild(object sender, EventArgs e)
    {       
      if (Engine.FinalPass == true)
      {
        JToken Table1 = JTableKMH_PR_PU[&quot;Protokol&quot;][&quot;Table1&quot;]; 
      
        List&lt;string&gt; DetName = Table1[&quot;DetName&quot;].Where(x=&gt;x.ToString()!=&quot;-&quot;).Select(x=&gt;x.ToString()).ToList();
        List&lt;string&gt; V0 = Table1[&quot;V0&quot;].Where(x=&gt;x.ToString()!=&quot;-&quot;).Select(x=&gt;x.ToString()).ToList();
        
        
        /////
        for (int i=0; i &lt;V0.Count; i++)
        {
          TableColumn column = new TableColumn();  
          TableSourceData.Columns.Insert(0,column);
                      
          for (int j=0;j&lt;TableSourceData.RowCount;j++)
          {
            TableSourceData[0,j].AssignAll(TableSourceData[1,j]);       
          }
                        
          TableSourceData[0,2].Text=string.Format(&quot;&lt;i&gt;V&lt;sub&gt;0 &lt;/i&gt; ({0})&lt;/sub&gt;,&lt;br&gt;м&lt;sup&gt;3&lt;/sup&gt;&quot;,listDetectors[tempCounter-1]);
          TableSourceData[0,3].Text=tempCounter.ToString();
          tempCounter--;
        }
        
        
        /////
        int indexColTemplate = ColumnTemplate.Index;
        
        
        for (int i=1; i&lt;V0.Count; i++)
        {
          Table1.Columns.Insert(TColumn_Table1_V0.Index+1, new TableColumn());
          
          foreach(TableRow row in Table1.Rows)
            row[TColumn_Table1_V0.Index+1].AssignAll(row[TColumn_Table1_V0.Index]);
        }
        
        
        
        
        
      }
      
      //DataIVK.TableKMH_PR_PU.Protokol.Table1;
      //DataIVK.TableKMH_PR_PU.Protokol.Table1.DetName;
      //DataIVK.TableKMH_PR_PU.Protokol.Table1.V0;
      //DataIVK.TableKMH_PR_PU.Protokol.Table1.Q;
      
      }
    
