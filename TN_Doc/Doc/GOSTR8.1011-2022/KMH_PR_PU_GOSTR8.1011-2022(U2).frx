<Report ScriptLanguage="CSharp" ReferencedAssemblies="System.dll&#13;&#10;System.Drawing.dll&#13;&#10;System.Windows.Forms.dll&#13;&#10;System.Data.dll&#13;&#10;System.Xml.dll&#13;&#10;Newtonsoft.Json.dll&#13;&#10;System.Collections.dll&#13;&#10;System.Core.dll&#13;&#10;TN_ToolsFastReport.dll&#13;&#10;TN_DocGeneral.dll&#13;&#10;KMH_PR_PU.dll" DoublePass="true" ReportInfo.Created="03/25/2020 12:46:46" ReportInfo.Modified="07/12/2024 08:26:11" ReportInfo.CreatorVersion="2023.2.0.0">
  <ScriptText>using System;
using System.Reflection;
using System.Collections;
using System.Collections.Generic;
using System.ComponentModel;         
using System.Drawing;
using System.Data;
using System.IO;
using FastReport;
using FastReport.Data;
using FastReport.Dialog;
using FastReport.Barcode;
using FastReport.Table;
using FastReport.Utils;
using System.Linq;
using Newtonsoft.Json.Linq;

namespace FastReport
{
  public class ReportScript
  {
    JToken JDoc;
    JToken JSettings;
    JToken JTableKMH_PR_PU;
    JToken JProtokol;
    JToken JAdditionalInfo;    
    
    int TypeTPU = 2;
    
    string ErrorValue = &quot;Ошибка&quot;; //&quot;Нет ошибки&quot;
    Color  ErrorColor = Color.LightCoral;
    
    private void Page_StartPage(object sender, EventArgs e)
    {
      JDoc = JToken.Parse(Report.GetParameterValue(&quot;JsonDoc&quot;).ToString());
      JSettings = JDoc[&quot;Doc&quot;][&quot;Settings&quot;];
      JTableKMH_PR_PU = JDoc[&quot;Doc&quot;][&quot;DataIVK&quot;][&quot;TableKMH_PR_PU&quot;];
      JProtokol = JDoc[&quot;Doc&quot;][&quot;DataIVK&quot;][&quot;TableKMH_PR_PU&quot;][&quot;Protokol&quot;];
      JAdditionalInfo = JDoc[&quot;Doc&quot;][&quot;DataIVK&quot;][&quot;TableKMH_PR_PU&quot;][&quot;AdditionalInfo&quot;];
      
      Page.PaperHeight = (int)JSettings[&quot;General&quot;][&quot;PageSettings&quot;][&quot;PaperHeight&quot;];
      Page.PaperWidth = (int)JSettings[&quot;General&quot;][&quot;PageSettings&quot;][&quot;PaperWidth&quot;];
         
      Page.TopMargin = (int)JSettings[&quot;General&quot;][&quot;PageSettings&quot;][&quot;TopMargin&quot;];
      Page.BottomMargin = (int)JSettings[&quot;General&quot;][&quot;PageSettings&quot;][&quot;BottomMargin&quot;];
      Page.LeftMargin = (int)JSettings[&quot;General&quot;][&quot;PageSettings&quot;][&quot;LeftMargin&quot;];
      Page.RightMargin = (int)JSettings[&quot;General&quot;][&quot;PageSettings&quot;][&quot;RightMargin&quot;];
      
      TypeTPU = (int)JSettings[&quot;Data&quot;][&quot;TypeTPU&quot;];
      
      FillReportTitle();
      FillReportSummary();
    }
     
    private void FillReportTitle()
    {
      PR_Type.Text = $&quot;Тип СИ объемного расхода &lt;u&gt;{JAdditionalInfo[&quot;PR_Type&quot;].ToString()}&lt;/u&gt;&quot;;
      PR_FactoryNumber.Text = $&quot;Заводской номер &lt;u&gt;{JAdditionalInfo[&quot;PR_FactoryNumber&quot;].ToString()}&lt;/u&gt;&quot;;      
      DeltaPr.Text = $&quot;Пределы допускаемой относительной погрешности, % &lt;u&gt;{JProtokol[&quot;DeltaPr&quot;].ToString().Replace('.',',')}&lt;/u&gt;&quot;;      
      
      string placeSiknName = String.IsNullOrEmpty(JSettings[&quot;Header&quot;][&quot;FieldSIKN&quot;].ToString()) ?
      $&quot;СИКН/СИКНП &lt;u&gt;{JAdditionalInfo[&quot;Place_SIKN&quot;].ToString()}&lt;/u&gt;&quot; :
      $&quot;{JSettings[&quot;Header&quot;][&quot;FieldSIKN&quot;].ToString()} &lt;u&gt;{JAdditionalInfo[&quot;Place_SIKN&quot;].ToString()}&lt;/u&gt;&quot;;                    
      Place_SIKN.Text = placeSiknName;
      
      string placePspName = String.IsNullOrEmpty(JSettings[&quot;Header&quot;][&quot;FieldPSP&quot;].ToString()) ?
      $&quot;ПСП &lt;u&gt;{JAdditionalInfo[&quot;Place&quot;].ToString()}&lt;/u&gt;&quot; :
      $&quot;{JSettings[&quot;Header&quot;][&quot;FieldPSP&quot;].ToString()} &lt;u&gt;{JAdditionalInfo[&quot;Place&quot;].ToString()}&lt;/u&gt;&quot;;      
      Place.Text = placePspName;      
      
      //Place_SIKN.Text = $&quot;СИКН/СИКНП &lt;u&gt;{JAdditionalInfo[&quot;Place_SIKN&quot;].ToString()}&lt;/u&gt;&quot;;
      //Place.Text = $&quot;ПСП &lt;u&gt;{JAdditionalInfo[&quot;Place&quot;].ToString()}&lt;/u&gt;&quot;;
      
      PU_Type.Text = $&quot;Тип ПУ &lt;u&gt;{JAdditionalInfo[&quot;PU_Type&quot;].ToString()}&lt;/u&gt;&quot;;
      PU_FactoryNumber.Text = $&quot;Заводской номер &lt;u&gt;{JAdditionalInfo[&quot;PU_FactoryNumber&quot;].ToString()}&lt;/u&gt;&quot;;      
      DeltaPu.Text = $&quot;Пределы допускаемой относительной погрешности, % &lt;u&gt;{JProtokol[&quot;DeltaPu&quot;].ToString().Replace('.',',')}&lt;/u&gt;&quot;;      
      PU_CheckDate.Text = $&quot;Дата поверки &lt;u&gt;{JAdditionalInfo[&quot;PU_CheckDate&quot;].ToString()}&lt;/u&gt;&quot;;
      Visc.Text = $&quot;Вязкость нефти/нефтепродуктов при КМХ, мм&lt;sup&gt;2&lt;/sup&gt;/с (сСт) &lt;u&gt;{JProtokol[&quot;Visc&quot;].ToString().Replace('.',',')}&lt;/u&gt;&quot;;
    }
    
    private void Table1_ManualBuild(object sender, EventArgs e)
    {     
      if (Engine.FinalPass == true)
      {
        JToken jsonTable1 = JTableKMH_PR_PU[&quot;Protokol&quot;][&quot;Table1&quot;]; 
      
        List&lt;string&gt; DetName = jsonTable1[&quot;DetName&quot;].Where(x=&gt;x.ToString()!=&quot;-&quot;).Select(x=&gt;x.ToString()).ToList();
        List&lt;string&gt; listV0 = jsonTable1[&quot;V0&quot;].Where(x=&gt;x.ToString()!=&quot;-&quot;).Select(x=&gt;x.ToString()).ToList();
        List&lt;string&gt; Q0 = jsonTable1[&quot;Q&quot;].Where(x=&gt;x.ToString()!=&quot;-&quot; &amp;&amp; x.ToString()!=&quot;&quot;).Select(x=&gt;x.ToString()).ToList();
        
        Table1_V0_Header.ColSpan = 1;
        int indexColTemplate = TColumn_Table1_V0.Index;           
        for (int i = 1; i &lt; listV0.Count; i++)
        {
          Table1.Columns.Insert(TColumn_Table1_V0.Index+1, new TableColumn());
          
          foreach(TableRow row in Table1.Rows)
            row[TColumn_Table1_V0.Index+1].AssignAll(row[TColumn_Table1_V0.Index]);
        }  
        Table1_V0_Header.ColSpan = Table1_Alpha_t.Index + 1;
        
        for (int i = 1; i &lt; Q0.Count; i++)
        {
          Table1.Columns.Insert(TColumn_Table1_Q.Index+1, new TableColumn());
          
          foreach(TableRow row in Table1.Rows)
            row[TColumn_Table1_Q.Index+1].AssignAll(row[TColumn_Table1_Q.Index]);
        }         
        Table1_Q_Header.ColSpan = Q0.Count;
        
      
        float widthColumn=(Page.PaperWidth-Page.LeftMargin-Page.RightMargin)/Table1.Columns.Count;                  
        for (int i = 0; i &lt; Table1.ColumnCount; i++)                 
          Table1.Columns[i].Width = widthColumn * Units.Millimeters;

        for (int i = 0; i &lt; listV0.Count; i++)
        {           
          if (TypeTPU == 1) //При прямом ходе поршня
            Table1_RowHeader[i].Text = $&quot;Объем калиброванного участка&lt;br&gt;при прямом ходе поршня, при-&lt;br&gt;веденный к рабочим условиям,&lt;br&gt;V&lt;sub&gt;0({DetName[i]})&lt;/sub&gt;, м&lt;sup&gt;3&lt;/sup&gt;&quot;;
          else if (TypeTPU == 2)//При прямом и обратном ходе поршня
            Table1_RowHeader[i].Text = $&quot;Объем калиброванного участка&lt;br&gt;при прямом и обратном ходе&lt;br&gt;поршня, приведенный к рабо-&lt;br&gt;чим условиям, V&lt;sub&gt;ij({DetName[i]})&lt;/sub&gt;, м&lt;sup&gt;3&lt;/sup&gt;&quot;;
          else
            Table1_RowHeader[i].Text = $&quot;Объем калиброванного участка&lt;br&gt;при прямом и обратном ходе&lt;br&gt;поршня, приведенный к рабо-&lt;br&gt;чим условиям, V&lt;sub&gt;ij({DetName[i]})&lt;/sub&gt;, м&lt;sup&gt;3&lt;/sup&gt;&quot;;
          
          Table1_RowData[i].Text = listV0[i].Replace('.',',');
        }

        m_D.Text = jsonTable1[&quot;m_D&quot;].ToString().Replace('.',',');
        m_S.Text = jsonTable1[&quot;m_S&quot;].ToString().Replace('.',',');
        m_E.Text = jsonTable1[&quot;m_E&quot;].ToString().Replace('.',',');
        Alpha_t.Text = jsonTable1[&quot;Alpha_t&quot;].ToString().Replace('.',',');

        for (int i = 0; i &lt; Q0.Count; i++)
        {
          Table1_RowHeader[TColumn_Table1_Q.Index+i].Text = $&quot;Q&lt;sub&gt;{i+1}&lt;/sub&gt;/f/ν&lt;sub&gt;{i+1}&lt;/sub&gt;&quot;;
          Table1_RowData[TColumn_Table1_Q.Index+i].Text = Q0[i].Replace('.',',');
        }

        Alpha_D.Text = jsonTable1[&quot;Alpha_D&quot;].ToString().Replace('.',',');  
      }
      
      Cell938.Text = $&quot;Характеристики&lt;br&gt;рабочей жидкости &lt;sup&gt;1)&lt;/sup&gt;&quot;;
      
      PrintTable(Table1);                  
    }        
    
    private void Table2_ManualBuild(object sender, EventArgs e)
    {
      if (Engine.FinalPass == true)
      { 
        JToken jsonTable1 = JTableKMH_PR_PU[&quot;Protokol&quot;][&quot;Table1&quot;]; 
        JToken jsonTable2 = JTableKMH_PR_PU[&quot;Protokol&quot;][&quot;Table2&quot;][&quot;Obj&quot;];
        JToken jsonTable2_1 = JTableKMH_PR_PU[&quot;Protokol&quot;][&quot;Table2_1&quot;][&quot;Obj&quot;];
        
        List&lt;JToken&gt; listTable2 = jsonTable2.Where(x=&gt;x[&quot;Ser&quot;].ToString()!=&quot;-&quot; &amp;&amp; x[&quot;Ser&quot;].ToString()!=&quot;&quot;).ToList();
        List&lt;JToken&gt; listTable2_1 = jsonTable2_1.Where(x=&gt;x[&quot;Point&quot;].ToString()!=&quot;-&quot; &amp;&amp; x[&quot;Point&quot;].ToString()!=&quot;&quot;).ToList();         
        List&lt;string&gt; listSerTable2 = listTable2.Select(x =&gt; x[&quot;Ser&quot;].ToString()).Distinct().ToList();
        
        List&lt;string&gt; DetName = jsonTable1[&quot;DetName&quot;].Where(x=&gt;x.ToString()!=&quot;-&quot;).Select(x=&gt;x.ToString()).ToList();
        List&lt;string&gt; listV0 = jsonTable1[&quot;V0&quot;].Where(x=&gt;x.ToString()!=&quot;-&quot;).Select(x=&gt;x.ToString()).ToList();
      
        for (int i=1; i&lt;listV0.Count; i++)
        {
          Table2.Columns.Insert(TColumn_Table2_V0.Index+1, new TableColumn());
         
          foreach(TableRow row in Table2.Rows)
            row[TColumn_Table2_V0.Index+1].AssignAll(row[TColumn_Table2_V0.Index]);
          
          //Table2_RowData[TColumn_Table2_V0.Index+1].Name = $&quot;V{i.ToString()}&quot;;
          //Table2_RowData[TColumn_Table2_V0.Index+1].Text = $&quot;V{i.ToString()}&quot;;
        }
         
        float widthColumn=(Page.PaperWidth-Page.LeftMargin-Page.RightMargin)/Table2.Columns.Count;                  
        for (int i = 0; i &lt; Table2.ColumnCount; i++)                 
          Table2.Columns[i].Width = widthColumn * Units.Millimeters;
       
        for (int i = 0; i &lt; listV0.Count; i++)
        {
          if (TypeTPU == 1) //При прямом ходе поршня
            Table2_RowHeader[TColumn_Table2_V0.Index+i].Text = $&quot;Объем калибро-&lt;br&gt;ванного участка&lt;br&gt;при прямом ходе&lt;br&gt;поршня V&lt;sub&gt;конij({DetName[i]})&lt;/sub&gt;,&lt;br&gt;м&lt;sup&gt;3&lt;/sup&gt;&quot;;
          else if (TypeTPU == 2)//При прямом и обратном ходе поршня
            Table2_RowHeader[TColumn_Table2_V0.Index+i].Text = $&quot;Объем калибро-&lt;br&gt;ванного участка&lt;br&gt;при прямом и об-&lt;br&gt;ратном ходе порш-&lt;br&gt;ня V&lt;sub&gt;конij({DetName[i]})&lt;/sub&gt;, м&lt;sup&gt;3&lt;/sup&gt;&quot;;
          else
            Table2_RowHeader[TColumn_Table2_V0.Index+i].Text = $&quot;Объем калибро-&lt;br&gt;ванного участка&lt;br&gt;при прямом и об-&lt;br&gt;ратном ходе порш-&lt;br&gt;ня V&lt;sub&gt;конij({DetName[i]})&lt;/sub&gt;, м&lt;sup&gt;3&lt;/sup&gt;&quot;;
        }
        
        for(int i = 0; i &lt; listTable2_1.Count; i++)
        {
          List&lt;JToken&gt; SerTable2 = jsonTable2.Where(x=&gt;x[&quot;Ser&quot;].ToString()==listSerTable2[i]).ToList();          
          List&lt;TableRow&gt; rows = new List&lt;TableRow&gt;();

          for (int j = 0; j &lt; SerTable2.Count; j++)
          { 
            if (j==0)
            {
              Ser.RowSpan = SerTable2.Count;
              K_j.RowSpan = SerTable2.Count;
              K_rasch_j.RowSpan = SerTable2.Count;
              Delta_j.RowSpan = SerTable2.Count;
            }
            else 
            {
              Ser.RowSpan = 1;
              K_j.RowSpan = 1;
              K_rasch_j.RowSpan = 1;
              Delta_j.RowSpan = 1;
            }
            
            Ser.Text = SerTable2[j][&quot;Ser&quot;].ToString().Replace('.',',');
            Row.Text = SerTable2[j][&quot;Row&quot;].ToString().Replace('.',',');
            Q_ji.Text = SerTable2[j][&quot;Q_ji&quot;].ToString().Replace('.',',');
            f_ji.Text = SerTable2[j][&quot;f_ji&quot;].ToString().Replace('.',',');
            t_PU_ji.Text = SerTable2[j][&quot;t_PU_ji&quot;].ToString().Replace('.',',');
            P_PU_ji.Text = SerTable2[j][&quot;P_PU_ji&quot;].ToString().Replace('.',',');
            t_PR_ji.Text = SerTable2[j][&quot;t_PR_ji&quot;].ToString().Replace('.',',');
            P_PR_ji.Text = SerTable2[j][&quot;P_PR_ji&quot;].ToString().Replace('.',',');
            //t_cm_ji.Text = SerTable2[j][&quot;t_cm_ji&quot;].ToString().Replace('.',',');
            k_tp_ji.Text = SerTable2[j][&quot;k_tp_ji&quot;].ToString().Replace('.',',');
            
            for (int z = 0; z &lt; DetName.Count; z++)
            {
              if (DetName[z] == SerTable2[j][&quot;Det&quot;].ToString())
                Table2[TColumn_Table2_V0.Index + z, Table2_RowData.Index].Text = SerTable2[j][&quot;V_ji&quot;].ToString().Replace('.',',');
              else
                Table2[TColumn_Table2_V0.Index + z, Table2_RowData.Index].Text = &quot;-&quot;;
            }
            
            //int indexOffset = DetName.IndexOf(SerTable2[j][&quot;Det&quot;].ToString()); 
            //Table2[TColumn_Table2_V0.Index + indexOffset, Table2_RowData.Index].Text = SerTable2[j][&quot;V_ji&quot;].ToString().Replace('.',',');
            //V_ji.Text = SerTable2[j][&quot;V_ji&quot;].ToString().Replace('.',',');
            
            N_ji.Text = SerTable2[j][&quot;N_ji&quot;].ToString().Replace('.',',');
            K_ji.Text = SerTable2[j][&quot;K_ji&quot;].ToString().Replace('.',',');    
          
            K_j.Text = listTable2_1[i][&quot;K_j&quot;].ToString().Replace('.',',');
            K_rasch_j.Text = listTable2_1[i][&quot;K_rasch_j&quot;].ToString().Replace('.',',');
            Delta_j.Text = listTable2_1[i][&quot;Delta_j&quot;].ToString().Replace('.',',');            
           
            TableRow row = new TableRow();
            row.AssignAll(Table2_RowData);
            row.Visible=true;
            //row.Name = $&quot;row{j}&quot;;
            rows.Add(row);         
            
            //Table2.PrintRow(Table2_RowData.Index);
            //Table2.PrintColumns();         
          }
          
          Table2.Rows.AddRange(rows.ToArray());
        }
      }
      
      MI.Text = JAdditionalInfo[&quot;GostBinary&quot;][&quot;MI&quot;].ToString();
      
      PrintTable(Table2);
    }     
    
    private void FillReportSummary()
    {
      Report.SetParameterValue(&quot;Delta_KMH_Max&quot;, JProtokol[&quot;Delta_KMH_Max&quot;].ToString().Replace('.',','));
      Report.SetParameterValue(&quot;ARM_KMH_Result&quot;, JAdditionalInfo[&quot;ARM_KMH_Result&quot;].ToString() == &quot;годен&quot; ? &quot;годно&quot; : &quot;не годно&quot;);
      
      DateTime date = new DateTime(1970, 1, 1, 0, 0, 0, DateTimeKind.Utc).AddSeconds((long)JTableKMH_PR_PU[&quot;DateTimeLong&quot;]);
      Report.SetParameterValue(&quot;DateKMH&quot;, date.ToString(&quot;dd.MM.yyyy&quot;));
      
      
      //if ((bool)JARMData[&quot;GostBinary&quot;][&quot;OperatingStaffDataIsDelivery&quot;])
      //{
      //}       
      
      ServiceStaffData_Company.Text = JAdditionalInfo[&quot;GostBinary&quot;][&quot;ServiceStaffData&quot;][&quot;Company&quot;].ToString();
      ServiceStaffData_Post.Text = JAdditionalInfo[&quot;GostBinary&quot;][&quot;ServiceStaffData&quot;][&quot;Post&quot;].ToString();
      ServiceStaffData_FIO.Text = JAdditionalInfo[&quot;GostBinary&quot;][&quot;ServiceStaffData&quot;][&quot;FIO&quot;].ToString();
      
      OperatingStaffData_Company.Text = JAdditionalInfo[&quot;GostBinary&quot;][&quot;OperatingStaffData&quot;][&quot;Company&quot;].ToString();
      OperatingStaffData_Post.Text = JAdditionalInfo[&quot;GostBinary&quot;][&quot;OperatingStaffData&quot;][&quot;Post&quot;].ToString();
      OperatingStaffData_FIO.Text = JAdditionalInfo[&quot;GostBinary&quot;][&quot;OperatingStaffData&quot;][&quot;FIO&quot;].ToString();
      
      DeliveryOrRecievingStaffData_Company.Text = JAdditionalInfo[&quot;GostBinary&quot;][&quot;DeliveryOrRecievingStaffData&quot;][&quot;Company&quot;].ToString();
      DeliveryOrRecievingStaffData_Post.Text = JAdditionalInfo[&quot;GostBinary&quot;][&quot;DeliveryOrRecievingStaffData&quot;][&quot;Post&quot;].ToString();
      DeliveryOrRecievingStaffData_FIO.Text = JAdditionalInfo[&quot;GostBinary&quot;][&quot;DeliveryOrRecievingStaffData&quot;][&quot;FIO&quot;].ToString();
    }
    
    private void PrintTable(TableObject table)
    {
      for (int i=0;i&lt;table.RowCount;i++)
      {       
        table.PrintRow(i);
        table.PrintColumns();
      }    
    }
    
    private void ControlTableSKO_ManualBuild(object sender, EventArgs e)
    {
      if (Engine.FinalPass == true)
      { 
        JToken jsonTable1 = JTableKMH_PR_PU[&quot;Protokol&quot;][&quot;Table1&quot;]; 
        JToken jsonTable2 = JTableKMH_PR_PU[&quot;Protokol&quot;][&quot;Table2&quot;][&quot;Obj&quot;];
        JToken jsonTable2_1 = JTableKMH_PR_PU[&quot;Protokol&quot;][&quot;Table2_1&quot;][&quot;Obj&quot;];
        
        List&lt;JToken&gt; listTable2 = jsonTable2.Where(x=&gt;x[&quot;Ser&quot;].ToString()!=&quot;-&quot; &amp;&amp; x[&quot;Ser&quot;].ToString()!=&quot;&quot;).ToList();
        List&lt;JToken&gt; listTable2_1 = jsonTable2_1.Where(x=&gt;x[&quot;Point&quot;].ToString()!=&quot;-&quot; &amp;&amp; x[&quot;Point&quot;].ToString()!=&quot;&quot;).ToList();         
        List&lt;string&gt; listSerTable2 = listTable2.Select(x =&gt; x[&quot;Ser&quot;].ToString()).Distinct().ToList();
        
        List&lt;string&gt; DetName = jsonTable1[&quot;DetName&quot;].Where(x=&gt;x.ToString()!=&quot;-&quot;).Select(x=&gt;x.ToString()).ToList();
        List&lt;string&gt; listV0 = jsonTable1[&quot;V0&quot;].Where(x=&gt;x.ToString()!=&quot;-&quot;).Select(x=&gt;x.ToString()).ToList();
      
        for(int i = 0; i &lt; listTable2_1.Count; i++)
        {
          List&lt;JToken&gt; SerTable2 = jsonTable2.Where(x=&gt;x[&quot;Ser&quot;].ToString()==listSerTable2[i]).ToList();          
          List&lt;TableRow&gt; rows = new List&lt;TableRow&gt;();

          for (int j = 0; j &lt; SerTable2.Count; j++)
          { 
            if (j == 0)
            {
              ControlTableSKO_Ser.RowSpan = SerTable2.Count;
              ControlTableSKO_K_j.RowSpan = SerTable2.Count;
              ControlTableSKO_K_rasch_j.RowSpan = SerTable2.Count;
              ControlTableSKO_SKO_j.RowSpan = SerTable2.Count;
            }
            else 
            {
              ControlTableSKO_Ser.RowSpan = 1;
              ControlTableSKO_K_j.RowSpan = 1;
              ControlTableSKO_K_rasch_j.RowSpan = 1;
              ControlTableSKO_SKO_j.RowSpan = 1;
            }
            
            ControlTableSKO_Ser.Text = SerTable2[j][&quot;Ser&quot;].ToString().Replace('.',',');
            ControlTableSKO_Row.Text = SerTable2[j][&quot;Row&quot;].ToString().Replace('.',',');
            ControlTableSKO_Q_ji.Text = SerTable2[j][&quot;Q_ji&quot;].ToString().Replace('.',',');
            
            ControlTableSKO_K_j.Text = listTable2_1[i][&quot;K_j&quot;].ToString().Replace('.',','); 
            ControlTableSKO_K_rasch_j.Text = listTable2_1[i][&quot;K_rasch_j&quot;].ToString().Replace('.',',');            
            ControlTableSKO_SKO_j.Text = listTable2_1[i][&quot;SKO_j&quot;].ToString().Replace('.',',');

            if ((string)listTable2_1[i][&quot;SKO_j_ERROR&quot;] == ErrorValue)
              ControlTableSKO_SKO_j.FillColor = ErrorColor;

            TableRow row = new TableRow();
            row.AssignAll(ControlTableSKO_RowData);
            row.Visible = true;
            rows.Add(row);         
          }
          ControlTableSKO.Rows.AddRange(rows.ToArray());
        }
      }
      PrintTable(ControlTableSKO);
    }     
  }    
}

</ScriptText>
