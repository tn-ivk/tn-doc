  <ScriptText>using System;
using System.Reflection;
using System.Collections;
using System.Collections.Generic;
using System.ComponentModel;         
using System.Drawing;
using System.Data;
using System.IO;
using FastReport;
using FastReport.Data;
using FastReport.Dialog;
using FastReport.Barcode;
using FastReport.Table;
using FastReport.Utils;
using System.Linq;
using Newtonsoft.Json.Linq; 

namespace FastReport
{
  public class ReportScript
  {
    JToken JDoc;
    JToken JSettings;
    JToken JTableKMH_PP_Areom;
    JToken JProtokol;
    JToken JAdditionalInfo;    
   
    int ProtocolNumber;
    int KMH_TYPE; 
    int NefType;    

    List&lt;string&gt; ListOilName;
    List&lt;string&gt; ListKMHType;
    
    private void Page_StartPage(object sender, EventArgs e)
    {
      JDoc = JToken.Parse(Report.GetParameterValue(&quot;JsonDoc&quot;).ToString());
      JSettings = JDoc[&quot;Doc&quot;][&quot;Settings&quot;];
      JTableKMH_PP_Areom = JDoc[&quot;Doc&quot;][&quot;DataArm&quot;][&quot;TableKMH_PP_Areom&quot;];
      JProtokol = JDoc[&quot;Doc&quot;][&quot;DataIVK&quot;][&quot;TableKMH_PP_Areom&quot;][&quot;Protokol&quot;];
      JAdditionalInfo = JDoc[&quot;Doc&quot;][&quot;DataIVK&quot;][&quot;TableKMH_PP_Areom&quot;][&quot;AdditionalInfo&quot;];
        
      Page.PaperHeight = (int)JSettings[&quot;General&quot;][&quot;PageSettings&quot;][&quot;PaperHeight&quot;];
      Page.PaperWidth = (int)JSettings[&quot;General&quot;][&quot;PageSettings&quot;][&quot;PaperWidth&quot;];
                    
      Page.TopMargin = (int)JSettings[&quot;General&quot;][&quot;PageSettings&quot;][&quot;TopMargin&quot;];
      Page.BottomMargin = (int)JSettings[&quot;General&quot;][&quot;PageSettings&quot;][&quot;BottomMargin&quot;];
      Page.LeftMargin = (int)JSettings[&quot;General&quot;][&quot;PageSettings&quot;][&quot;LeftMargin&quot;];
      Page.RightMargin = (int)JSettings[&quot;General&quot;][&quot;PageSettings&quot;][&quot;RightMargin&quot;];
                  
      ListOilName = new List&lt;string&gt;() {&quot;нефти&quot;, &quot;нефтепродуктов&quot;};
      
      ProtocolNumber = (int)JSettings[&quot;General&quot;][&quot;ProtocolNumber&quot;];
      KMH_TYPE = (int)JTableKMH_PP_Areom[&quot;KMH_TYPE&quot;]; 
      NefType = (int)JSettings[&quot;General&quot;][&quot;NefType&quot;];
      
      FillReportTitle(ProtocolNumber);
      FillTable1(ProtocolNumber);
      FillReportSummary(ProtocolNumber);        
    }
        
    private void FillReportTitle(int protocolNumber)
    {
      Report.SetParameterValue(&quot;OilName&quot;, ListOilName[NefType-1]);
      JToken jsonPP_AddInfo;
      
      if (protocolNumber == 1)
        jsonPP_AddInfo = JAdditionalInfo[&quot;PP1_AddInfo&quot;];
      else
        jsonPP_AddInfo = JAdditionalInfo[&quot;PP2_AddInfo&quot;];
      
      string placeSiknName = String.IsNullOrEmpty(JSettings[&quot;Header&quot;][&quot;FieldSIKN&quot;].ToString()) ?
      $&quot;СИКН/СИКНП &lt;u&gt;{jsonPP_AddInfo[&quot;SIKN_Num&quot;].ToString()}&lt;/u&gt;&quot; :
      $&quot;{JSettings[&quot;Header&quot;][&quot;FieldSIKN&quot;].ToString()} &lt;u&gt;{jsonPP_AddInfo[&quot;SIKN_Num&quot;].ToString()}&lt;/u&gt;&quot;;                    
      SIKN_Num.Text = placeSiknName;
      
      string placePspName = String.IsNullOrEmpty(JSettings[&quot;Header&quot;][&quot;FieldPSP&quot;].ToString()) ?
      $&quot;ПСП &lt;u&gt;{jsonPP_AddInfo[&quot;PSP_Name&quot;].ToString()}&lt;/u&gt;&quot; :
      $&quot;{JSettings[&quot;Header&quot;][&quot;FieldPSP&quot;].ToString()} &lt;u&gt;{jsonPP_AddInfo[&quot;PSP_Name&quot;].ToString()}&lt;/u&gt;&quot;;      
      PSP_Name.Text = placePspName;      
    }
        
    private void FillTable1(int protocolNumber)
    {
      JToken jsonTable1;
      JToken jsonPP_AddInfo;
      
      if (protocolNumber == 1)
      {
        jsonTable1 = JProtokol[&quot;Table1_1&quot;];
        jsonPP_AddInfo = JAdditionalInfo[&quot;PP1_AddInfo&quot;];
        }
      else
      {
        jsonTable1 = JProtokol[&quot;Table1_2&quot;];
        jsonPP_AddInfo = JAdditionalInfo[&quot;PP2_AddInfo&quot;];
      }
      
      SensName_Oper.Text = jsonPP_AddInfo[&quot;SensName_Oper&quot;].ToString();
      ManufNum_Oper.Text = jsonPP_AddInfo[&quot;ManufNum_Oper&quot;].ToString();
      CheckDate_Oper.Text = jsonPP_AddInfo[&quot;CheckDate_Oper&quot;].ToString();
      Delta_PP.Text = jsonTable1[&quot;Delta_PP&quot;].ToString().Replace('.',',');
                    
      SensName_Areom.Text = jsonPP_AddInfo[&quot;SensName_Areom&quot;].ToString();
      ManufNum_Areom.Text = jsonPP_AddInfo[&quot;ManufNum_Areom&quot;].ToString();
      CheckDate_Areom.Text = jsonPP_AddInfo[&quot;CheckDate_Areom&quot;].ToString();
      AbsError_Areom.Text = jsonPP_AddInfo[&quot;AbsError_Areom&quot;].ToString().Replace('.',','); 
      
      Delta_Syst.Text = jsonTable1[&quot;Delta_Syst&quot;].ToString().Replace('.',',');
      Delta_Meth.Text = jsonTable1[&quot;Delta_Meth&quot;].ToString().Replace('.',',');
    }
        
    private void Table2_ManualBuild(object sender, EventArgs e)
    {
      if (Engine.FinalPass == true)
      { 
        JToken jsonTable2;
      
        if (ProtocolNumber == 1)
          jsonTable2 = JProtokol[&quot;Table2_1&quot;];
        else
          jsonTable2 = JProtokol[&quot;Table2_2&quot;];     
      
        List&lt;JToken&gt; listTable2 = jsonTable2.Where(x=&gt;(int)x[&quot;Activated&quot;]!=0).ToList();
        List&lt;TableRow&gt; rows = new List&lt;TableRow&gt;();
        
        for (int i = 0; i &lt; listTable2.Count; i++)
        {
          Number.Text = (i + 1).ToString();
          Q.Text = listTable2[i][&quot;Q&quot;].ToString().Replace('.',',');
          t.Text = listTable2[i][&quot;t&quot;].ToString().Replace('.',',');
          P.Text = listTable2[i][&quot;P&quot;].ToString().Replace('.',',');
          Dens_PP.Text = listTable2[i][&quot;Dens_PP&quot;].ToString().Replace('.',',');
      
          DensLab_1.Text = listTable2[i][&quot;DensLab&quot;][0].ToString().Replace('.',',');
          tempLab_1.Text = listTable2[i][&quot;TempLab&quot;][0].ToString().Replace('.',',');
          BetaLab_1.Text = listTable2[i][&quot;BetaLab&quot;][0].ToString().Replace('.',',');
          GamaLab_1.Text = listTable2[i][&quot;GamaLab&quot;][0].ToString().Replace('.',',');
          DensLab_2.Text = listTable2[i][&quot;DensLab&quot;][1].ToString().Replace('.',',');
          tempLab_2.Text = listTable2[i][&quot;TempLab&quot;][1].ToString().Replace('.',',');
          BetaLab_2.Text = listTable2[i][&quot;BetaLab&quot;][1].ToString().Replace('.',',');
          GamaLab_2.Text = listTable2[i][&quot;GamaLab&quot;][1].ToString().Replace('.',',');

          Dens_Priv.Text = listTable2[i][&quot;Dens_Priv&quot;].ToString().Replace('.',',');
          Delta.Text = listTable2[i][&quot;Delta&quot;].ToString().Replace('.',',');
           
          TableRow row1 = new TableRow();
          row1.AssignAll(Table2_RowData1);
          row1.Visible=true;
          rows.Add(row1);         
          
          if((bool)listTable2[i][&quot;DisplayTwoRow&quot;])
          {
            TableRow row2 = new TableRow();
            row2.AssignAll(Table2_RowData2);
            row2.Visible=true;
          
            rows.Add(row2);
          }
        }    
          
        Table2.Rows.AddRange(rows.ToArray());
        
        MI.Text = JAdditionalInfo[&quot;GostBinary&quot;][&quot;MI&quot;].ToString();
        
        PrintTable(Table2);      
      }
 
    }

    private void FillReportSummary(int protocolNumber)
    {
      JToken jsonPP_AddInfo;
      
      if (protocolNumber == 1)
        jsonPP_AddInfo = JAdditionalInfo[&quot;PP1_AddInfo&quot;];
      else
        jsonPP_AddInfo = JAdditionalInfo[&quot;PP2_AddInfo&quot;];      
      
      Report.SetParameterValue(&quot;ARM_KMH_Result&quot;, jsonPP_AddInfo[&quot;ARM_KMH_Result&quot;].ToString() == &quot;годен&quot; ? &quot;годно&quot; : &quot;не годно&quot;);
                    
      DateTime date = new DateTime(1970, 1, 1, 0, 0, 0, DateTimeKind.Utc).AddSeconds((long)JTableKMH_PP_Areom[&quot;DateTimeLong&quot;]);
      Report.SetParameterValue(&quot;DateKMH&quot;, date.ToString(&quot;dd.MM.yyyy&quot;));
      
      bool hasCustomSIKNName = !String.IsNullOrEmpty(JSettings[&quot;Footer&quot;][&quot;FieldSIKN&quot;].ToString());
      
      ServiceStaffData_Company.Text = JAdditionalInfo[&quot;GostBinary&quot;][&quot;ServiceStaffData&quot;][&quot;Company&quot;].ToString();
      ServiceStaffData_Post.Text = JAdditionalInfo[&quot;GostBinary&quot;][&quot;ServiceStaffData&quot;][&quot;Post&quot;].ToString();
      ServiceStaffData_FIO.Text = JAdditionalInfo[&quot;GostBinary&quot;][&quot;ServiceStaffData&quot;][&quot;FIO&quot;].ToString();
      
      if(hasCustomSIKNName){
         ServiceStaffData_Company_Desc.Text=$&quot;организация, проводящая техническое обслуживание {JSettings[&quot;Footer&quot;][&quot;FieldSIKN&quot;]}&quot;;
      }
        
      OperatingStaffData_Company.Text = JAdditionalInfo[&quot;GostBinary&quot;][&quot;OperatingStaffData&quot;][&quot;Company&quot;].ToString();
      OperatingStaffData_Post.Text = JAdditionalInfo[&quot;GostBinary&quot;][&quot;OperatingStaffData&quot;][&quot;Post&quot;].ToString();
      OperatingStaffData_FIO.Text = JAdditionalInfo[&quot;GostBinary&quot;][&quot;OperatingStaffData&quot;][&quot;FIO&quot;].ToString();
      
      if(hasCustomSIKNName){
       OperatingStaffData_Company_Desc.Text=$&quot;организация, эксплуатирующая {JSettings[&quot;Footer&quot;][&quot;FieldSIKN&quot;]}&quot;;
      }
      
      DeliveryOrRecievingStaffData_Company.Text = JAdditionalInfo[&quot;GostBinary&quot;][&quot;DeliveryOrRecievingStaffData&quot;][&quot;Company&quot;].ToString();
      DeliveryOrRecievingStaffData_Post.Text = JAdditionalInfo[&quot;GostBinary&quot;][&quot;DeliveryOrRecievingStaffData&quot;][&quot;Post&quot;].ToString();
      DeliveryOrRecievingStaffData_FIO.Text = JAdditionalInfo[&quot;GostBinary&quot;][&quot;DeliveryOrRecievingStaffData&quot;][&quot;FIO&quot;].ToString(); 
    }
    
    private void PrintTable(TableObject table)
    {
      for (int i=0;i&lt;table.RowCount;i++)
      {       
        table.PrintRow(i);
        table.PrintColumns();
      }    
    }
  }
}


</ScriptText>
