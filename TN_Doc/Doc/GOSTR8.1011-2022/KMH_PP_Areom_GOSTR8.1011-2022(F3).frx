        <TableRow Name="Row218" Height="132.3">
          <TableCell Name="Cell1152" Border.Lines="All" Border.BottomLine.Style="Double" Font="Arial, 10pt"/>
          <TableCell Name="Cell1153" Border.Lines="All" Border.BottomLine.Style="Double" Text="Расход Q, м&lt;sup&gt;3&lt;/sup&gt;/ч" HorzAlign="Center" VertAlign="Center" Angle="270" Font="Arial, 8pt" TextRenderType="HtmlTags"/>
          <TableCell Name="Cell1154" Border.Lines="All" Border.BottomLine.Style="Double" Text="Температура t&lt;sub&gt;плi&lt;/sub&gt;, °С" HorzAlign="Center" VertAlign="Center" Angle="270" Font="Arial, 8pt" TextRenderType="HtmlTags"/>
          <TableCell Name="Cell1155" Border.Lines="All" Border.BottomLine.Style="Double" Text="Давление Р&lt;sub&gt;пл&lt;/sub&gt;, МПа" HorzAlign="Center" VertAlign="Center" Angle="270" Font="Arial, 8pt" TextRenderType="HtmlTags"/>
