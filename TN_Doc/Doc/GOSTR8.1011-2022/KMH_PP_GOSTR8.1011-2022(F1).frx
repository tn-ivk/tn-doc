  <ScriptText>using System;
using System.Reflection;
using System.Collections;
using System.Collections.Generic;
using System.ComponentModel;         
using System.Drawing;
using System.Data;
using System.IO;
using FastReport;
using FastReport.Data;
using FastReport.Dialog;
using FastReport.Barcode;
using FastReport.Table;
using FastReport.Utils;
using System.Linq;
using Newtonsoft.Json.Linq; 

namespace FastReport
{
  public class ReportScript
  {
    JToken JDoc;
    JToken JSettings;
    JToken JTableKMH_PP;
    JToken JProtokol;
    JToken JAdditionalInfo;    
   
    int ProtocolNumber;
    int KMH_TYPE; 
    int NefType;    

    List&lt;string&gt; ListOilName;
    List&lt;string&gt; ListKMHType;
    
    private void Page_StartPage(object sender, EventArgs e)
    {
      JDoc = JToken.Parse(Report.GetParameterValue(&quot;JsonDoc&quot;).ToString());
      JSettings = JDoc[&quot;Doc&quot;][&quot;Settings&quot;];
      JTableKMH_PP = JDoc[&quot;Doc&quot;][&quot;DataIVK&quot;][&quot;TableKMH_PP&quot;];
      JProtokol = JDoc[&quot;Doc&quot;][&quot;DataIVK&quot;][&quot;TableKMH_PP&quot;][&quot;Protokol&quot;];
      JAdditionalInfo = JDoc[&quot;Doc&quot;][&quot;DataIVK&quot;][&quot;TableKMH_PP&quot;][&quot;AdditionalInfo&quot;];
        
      Page.PaperHeight = (int)JSettings[&quot;General&quot;][&quot;PageSettings&quot;][&quot;PaperHeight&quot;];
      Page.PaperWidth = (int)JSettings[&quot;General&quot;][&quot;PageSettings&quot;][&quot;PaperWidth&quot;];
                    
      Page.TopMargin = (int)JSettings[&quot;General&quot;][&quot;PageSettings&quot;][&quot;TopMargin&quot;];
      Page.BottomMargin = (int)JSettings[&quot;General&quot;][&quot;PageSettings&quot;][&quot;BottomMargin&quot;];
      Page.LeftMargin = (int)JSettings[&quot;General&quot;][&quot;PageSettings&quot;][&quot;LeftMargin&quot;];
      Page.RightMargin = (int)JSettings[&quot;General&quot;][&quot;PageSettings&quot;][&quot;RightMargin&quot;];
                  
      ListOilName = new List&lt;string&gt;() {&quot;нефти&quot;, &quot;нефтепродукте&quot;};
      //ListKMHType = new List&lt;string&gt;() {&quot;объемной&quot;, &quot;массовой&quot;};
  
      ProtocolNumber = (int)JSettings[&quot;General&quot;][&quot;ProtocolNumber&quot;];
      KMH_TYPE = (int)JTableKMH_PP[&quot;KMH_TYPE&quot;]; 
      NefType = (int)JSettings[&quot;General&quot;][&quot;NefType&quot;];
                  
      FillReportTitle();
      FillTable1();
      FillReportSummary();
    }
        
    private void FillReportTitle()
    {
      Report.SetParameterValue(&quot;OilName&quot;, ListOilName[NefType-1]);
      //Report.SetParameterValue(&quot;KMHType&quot;, ListKMHType[KMH_TYPE]);
                
      string placeSiknName = String.IsNullOrEmpty(JSettings[&quot;Header&quot;][&quot;FieldSIKN&quot;].ToString()) ?
      $&quot;СИКН/СИКНП &lt;u&gt;{JAdditionalInfo[&quot;SIKN_Num&quot;].ToString()}&lt;/u&gt;&quot; :
      $&quot;{JSettings[&quot;Header&quot;][&quot;FieldSIKN&quot;].ToString()} &lt;u&gt;{JAdditionalInfo[&quot;SIKN_Num&quot;].ToString()}&lt;/u&gt;&quot;;                     
      SIKN_Num.Text = placeSiknName;
      
      string placePspName = String.IsNullOrEmpty(JSettings[&quot;Header&quot;][&quot;FieldPSP&quot;].ToString()) ?
      $&quot;ПСП &lt;u&gt;{JAdditionalInfo[&quot;PSP_Name&quot;].ToString()}&lt;/u&gt;&quot; :
      $&quot;{JSettings[&quot;Header&quot;][&quot;FieldPSP&quot;].ToString()} &lt;u&gt;{JAdditionalInfo[&quot;PSP_Name&quot;].ToString()}&lt;/u&gt;&quot;;      
      PSP_Name.Text = placePspName; 
    }
        
    private void FillTable1()
    {
      SensName_Oper.Text = JAdditionalInfo[&quot;SensName_Oper&quot;].ToString();
      ManufNum_Oper.Text = JAdditionalInfo[&quot;ManufNum_Oper&quot;].ToString();
      CheckDate_Oper.Text = JAdditionalInfo[&quot;CheckDate_Oper&quot;].ToString();
      Delta_Rab.Text = JProtokol[&quot;Delta_Rab&quot;].ToString().Replace('.',',');
      
      SensName_Ethal.Text = JAdditionalInfo[&quot;SensName_Ethal&quot;].ToString();
      ManufNum_Ethal.Text = JAdditionalInfo[&quot;ManufNum_Ethal&quot;].ToString();
      CheckDate_Ethal.Text = JAdditionalInfo[&quot;CheckDate_Ethal&quot;].ToString();
      LastCleanDate_Ethal.Text = JAdditionalInfo[&quot;LastCleanDate_Ethal&quot;].ToString();
      Delta_Etal.Text = JProtokol[&quot;Delta_Etal&quot;].ToString().Replace('.',',');
    }
        
    private void Table2_ManualBuild(object sender, EventArgs e)
    {
      if (Engine.FinalPass == true)
      {
        JToken jsonTable1 = JProtokol[&quot;Table1&quot;];
        
        List&lt;JToken&gt; listTable1 = jsonTable1.Where(x=&gt;x[&quot;Q&quot;].ToString()!=&quot;-&quot; ||
          x[&quot;t&quot;].ToString()!=&quot;-&quot; ||
          x[&quot;P&quot;].ToString()!=&quot;-&quot; ||
          x[&quot;Dens_Rab&quot;].ToString()!=&quot;-&quot; ||
          x[&quot;Dens_Etal&quot;].ToString()!=&quot;-&quot; ||
          x[&quot;Delta&quot;].ToString()!=&quot;-&quot;).ToList();
        
        List&lt;TableRow&gt; rows = new List&lt;TableRow&gt;();
        
        for (int i=0; i&lt;listTable1.Count; i++)
        {
          Number.Text = (i+1).ToString();
          Q.Text = listTable1[i][&quot;Q&quot;].ToString().Replace('.',',');
          t.Text = listTable1[i][&quot;t&quot;].ToString().Replace('.',',');
          P.Text = listTable1[i][&quot;P&quot;].ToString().Replace('.',',');
          Dens_Rab.Text = listTable1[i][&quot;Dens_Rab&quot;].ToString().Replace('.',',');
          Dens_Etal.Text = listTable1[i][&quot;Dens_Etal&quot;].ToString().Replace('.',',');
          Delta.Text = listTable1[i][&quot;Delta&quot;].ToString().Replace('.',',');
          
          TableRow row = new TableRow();
          row.AssignAll(Table2_RowData);
          row.Visible=true;
          //row.Name = $&quot;row{j}&quot;;
          rows.Add(row);  
        }
        
        Table2.Rows.AddRange(rows.ToArray());
        
        MI.Text = JAdditionalInfo[&quot;GostBinary&quot;][&quot;MI&quot;].ToString();
        
        PrintTable(Table2);       
      } 
    }

    private void FillReportSummary()
    {
      Report.SetParameterValue(&quot;ARM_KMH_Result&quot;, JAdditionalInfo[&quot;ARM_KMH_Result&quot;].ToString() == &quot;годен&quot; ? &quot;годно&quot; : &quot;не годно&quot;);
                    
      DateTime date = new DateTime(1970, 1, 1, 0, 0, 0, DateTimeKind.Utc).AddSeconds((long)JTableKMH_PP[&quot;DateTimeLong&quot;]);
      Report.SetParameterValue(&quot;DateKMH&quot;, date.ToString(&quot;dd.MM.yyyy&quot;));
            
      
      //if ((bool)JARMData[&quot;GostBinary&quot;][&quot;OperatingStaffDataIsDelivery&quot;])
      //{
      //}       
      
      ServiceStaffData_Company.Text = JAdditionalInfo[&quot;GostBinary&quot;][&quot;ServiceStaffData&quot;][&quot;Company&quot;].ToString();
      ServiceStaffData_Post.Text = JAdditionalInfo[&quot;GostBinary&quot;][&quot;ServiceStaffData&quot;][&quot;Post&quot;].ToString();
      ServiceStaffData_FIO.Text = JAdditionalInfo[&quot;GostBinary&quot;][&quot;ServiceStaffData&quot;][&quot;FIO&quot;].ToString();
      
      OperatingStaffData_Company.Text = JAdditionalInfo[&quot;GostBinary&quot;][&quot;OperatingStaffData&quot;][&quot;Company&quot;].ToString();
      OperatingStaffData_Post.Text = JAdditionalInfo[&quot;GostBinary&quot;][&quot;OperatingStaffData&quot;][&quot;Post&quot;].ToString();
      OperatingStaffData_FIO.Text = JAdditionalInfo[&quot;GostBinary&quot;][&quot;OperatingStaffData&quot;][&quot;FIO&quot;].ToString();
      
      DeliveryOrRecievingStaffData_Company.Text = JAdditionalInfo[&quot;GostBinary&quot;][&quot;DeliveryOrRecievingStaffData&quot;][&quot;Company&quot;].ToString();
      DeliveryOrRecievingStaffData_Post.Text = JAdditionalInfo[&quot;GostBinary&quot;][&quot;DeliveryOrRecievingStaffData&quot;][&quot;Post&quot;].ToString();
      DeliveryOrRecievingStaffData_FIO.Text = JAdditionalInfo[&quot;GostBinary&quot;][&quot;DeliveryOrRecievingStaffData&quot;][&quot;FIO&quot;].ToString();
    }
    
    private void PrintTable(TableObject table)
    {
      for (int i=0;i&lt;table.RowCount;i++)
      {       
        table.PrintRow(i);
        table.PrintColumns();
      }    
    }

  }
}


