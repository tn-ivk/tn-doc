using FastReport.Utils;
using System.Linq;
using Newtonsoft.Json.Linq;

namespace FastReport
{
  public class ReportScript
  {
    JToken JDoc;
    JToken JSettings;
    JToken JTableKMH_MPR_PU;
    JToken JProtokol;
    JToken JAdditionalInfo;    

    private void Page_StartPage(object sender, EventArgs e)
    {
      JDoc = JToken.Parse(Report.GetParameterValue(&quot;JsonDoc&quot;).ToString());
      JSettings = JDoc[&quot;Doc&quot;][&quot;Settings&quot;];
      JTableKMH_MPR_PU = JDoc[&quot;Doc&quot;][&quot;DataIVK&quot;][&quot;TableKMH_MPR_PU&quot;];
      JProtokol = JDoc[&quot;Doc&quot;][&quot;DataIVK&quot;][&quot;TableKMH_MPR_PU&quot;][&quot;Protokol&quot;];
      JAdditionalInfo = JDoc[&quot;Doc&quot;][&quot;DataIVK&quot;][&quot;TableKMH_MPR_PU&quot;][&quot;AdditionalInfo&quot;];
      
      Page.PaperHeight = 210; //(int)JSettings[&quot;General&quot;][&quot;PageSettings&quot;][&quot;PaperHeight&quot;];
      Page.PaperWidth = 297; //(int)JSettings[&quot;General&quot;][&quot;PageSettings&quot;][&quot;PaperWidth&quot;];
         
      Page.TopMargin = (int)JSettings[&quot;General&quot;][&quot;PageSettings&quot;][&quot;TopMargin&quot;];
      Page.BottomMargin = (int)JSettings[&quot;General&quot;][&quot;PageSettings&quot;][&quot;BottomMargin&quot;];
      Page.LeftMargin = (int)JSettings[&quot;General&quot;][&quot;PageSettings&quot;][&quot;LeftMargin&quot;];
      Page.RightMargin = (int)JSettings[&quot;General&quot;][&quot;PageSettings&quot;][&quot;RightMargin&quot;];
      
      FillReportTitle();
      FillReportSummary();
    }
      
    public void FillReportTitle()
    {
      PR_Type.Text = $&quot;Тип СИ массового расхода &lt;u&gt;{JAdditionalInfo[&quot;PR_Type&quot;].ToString()}&lt;/u&gt;&quot;;
      PR_FactoryNumber.Text = $&quot;Заводской номер &lt;u&gt;{JAdditionalInfo[&quot;PR_FactoryNumber&quot;].ToString()}&lt;/u&gt;&quot;;
      DeltaPr.Text = $&quot;Пределы допускаемой относительной погрешности, % &lt;u&gt;{JProtokol[&quot;DeltaPr&quot;].ToString().Replace('.',',')}&lt;/u&gt;&quot;;    
      
      string placeSiknName = String.IsNullOrEmpty(JSettings[&quot;Header&quot;][&quot;FieldSIKN&quot;].ToString()) ?
      $&quot;СИКН/СИКНП &lt;u&gt;{JAdditionalInfo[&quot;SIKN&quot;].ToString()}&lt;/u&gt;&quot; :
      $&quot;{JSettings[&quot;Header&quot;][&quot;FieldSIKN&quot;].ToString()} &lt;u&gt;{JAdditionalInfo[&quot;SIKN&quot;].ToString()}&lt;/u&gt;&quot;;                    
      SIKN.Text = placeSiknName;
      
      string placePspName = String.IsNullOrEmpty(JSettings[&quot;Header&quot;][&quot;FieldPSP&quot;].ToString()) ?
      $&quot;ПСП &lt;u&gt;{JAdditionalInfo[&quot;Place_PSP&quot;].ToString()}&lt;/u&gt;&quot; :
      $&quot;{JSettings[&quot;Header&quot;][&quot;FieldPSP&quot;].ToString()} &lt;u&gt;{JAdditionalInfo[&quot;Place_PSP&quot;].ToString()}&lt;/u&gt;&quot;;      
      Place_PSP.Text = placePspName;      
      
      //SIKN.Text = $&quot;СИКН/СИКНП &lt;u&gt;{JAdditionalInfo[&quot;SIKN&quot;].ToString()}&lt;/u&gt;&quot;;
      //Place_PSP.Text = $&quot;ПСП &lt;u&gt;{JAdditionalInfo[&quot;Place_PSP&quot;].ToString()}&lt;/u&gt;&quot;;
      
      PU_Type.Text = $&quot;Тип ПУ &lt;u&gt;{JAdditionalInfo[&quot;PU_Type&quot;].ToString()}&lt;/u&gt;&quot;;
      PU_FactoryNumber.Text = $&quot;Заводской номер &lt;u&gt;{JAdditionalInfo[&quot;PU_FactoryNumber&quot;].ToString()}&lt;/u&gt;&quot;;
      Title_Delta_PU.Text = $&quot;Пределы допускаемой относительной погрешности, % &lt;u&gt;{JProtokol[&quot;Table1&quot;][&quot;Delta_PU&quot;].ToString().Replace('.',',')}&lt;/u&gt;&quot;;
      PU_CheckDate.Text = $&quot;Дата поверки &lt;u&gt;{JAdditionalInfo[&quot;PU_CheckDate&quot;].ToString()}&lt;/u&gt;&quot;;
    }

    private void Table1_ManualBuild(object sender, EventArgs e)
    {
      if (Engine.FinalPass == true)
      {
        JToken jsonTable1 = JTableKMH_MPR_PU[&quot;Protokol&quot;][&quot;Table1&quot;]; 

        List&lt;string&gt; listDetName = jsonTable1[&quot;DetName&quot;].Where(x=&gt;x.ToString()!=&quot;-&quot;).Select(x=&gt;x.ToString()).ToList();
        List&lt;string&gt; listV0 = jsonTable1[&quot;V0&quot;].Where(x=&gt;x.ToString()!=&quot;-&quot;).Select(x=&gt;x.ToString()).ToList();

        List&lt;TableRow&gt; rows = new List&lt;TableRow&gt;();
        
        for (int i=0; i&lt;listDetName.Count; i++)
        {
          if (i==0)
          {
            Delta_PU.RowSpan = listDetName.Count;
            m_D.RowSpan = listDetName.Count;
            m_S.RowSpan = listDetName.Count;
            m_E.RowSpan = listDetName.Count;
            Alpha_t_PU.RowSpan = listDetName.Count;
            Delta_t_PU.RowSpan = listDetName.Count;
            Delta_PP.RowSpan = listDetName.Count;
            Delta_t_PP.RowSpan = listDetName.Count;
            Delta_k_UOI.RowSpan = listDetName.Count;
            KF_konf.RowSpan = listDetName.Count;
            ZS.RowSpan = listDetName.Count;
            Alpha_k1_PU.RowSpan = listDetName.Count;
            Alpha_t_cm.RowSpan = listDetName.Count;
          }
          else 
          {
            Delta_PU.RowSpan = 1;
            m_D.RowSpan = 1;
            m_S.RowSpan = 1;
            m_E.RowSpan = 1;
            Alpha_t_PU.RowSpan = 1;
            Delta_t_PU.RowSpan = 1;
            Delta_PP.RowSpan = 1;
            Delta_t_PP.RowSpan = 1;
            Delta_k_UOI.RowSpan = 1;
            KF_konf.RowSpan = 1;
            ZS.RowSpan = 1;
            Alpha_k1_PU.RowSpan = 1;
            Alpha_t_cm.RowSpan = 1;
          }

          DetName.Text = listDetName[i].ToString();
          V0.Text = listV0[i].ToString();

          Delta_PU.Text = jsonTable1[&quot;Delta_PU&quot;].ToString().Replace('.',',');
          m_D.Text = jsonTable1[&quot;m_D&quot;].ToString().Replace('.',',');
          m_S.Text = jsonTable1[&quot;m_S&quot;].ToString().Replace('.',',');
          m_E.Text = jsonTable1[&quot;m_E&quot;].ToString().Replace('.',',');
          Alpha_t_PU.Text = jsonTable1[&quot;Alpha_t_PU&quot;].ToString().Replace('.',',');
          Delta_t_PU.Text = jsonTable1[&quot;Delta_t_PU&quot;].ToString().Replace('.',',');
          Delta_PP.Text = jsonTable1[&quot;Delta_PP&quot;].ToString().Replace('.',',');
          Delta_t_PP.Text = jsonTable1[&quot;Delta_t_PP&quot;].ToString().Replace('.',',');
          Delta_k_UOI.Text = jsonTable1[&quot;Delta_k_UOI&quot;].ToString().Replace('.',',');
          KF_konf.Text = jsonTable1[&quot;KF_konf&quot;].ToString().Replace('.',',');
          ZS.Text = jsonTable1[&quot;ZS&quot;].ToString().Replace('.',',');
          Alpha_k1_PU.Text = jsonTable1[&quot;Alpha_k1_PU&quot;].ToString().Replace('.',',');
          Alpha_t_cm.Text = jsonTable1[&quot;Alpha_t_cm&quot;].ToString().Replace('.',',');
          
          TableRow row = new TableRow();
          row.AssignAll(Table1_RowData);
          row.Visible=true;
          //row.Name = $&quot;row{j}&quot;;
          rows.Add(row);        
        }
        
        Table1.Rows.AddRange(rows.ToArray());
        
        MI.Text = JAdditionalInfo[&quot;GostBinary&quot;][&quot;MI&quot;].ToString();
      
        PrintTable(Table1);
      }      
    }

    private void Table2_ManualBuild(object sender, EventArgs e)
    {
      if (Engine.FinalPass == true)
      {
        JToken jsonTable2 = JTableKMH_MPR_PU[&quot;Protokol&quot;][&quot;Table2&quot;];

        List&lt;JToken&gt; listTable2 = jsonTable2.Where(x=&gt;x[&quot;Ser&quot;].ToString()!=&quot;-&quot; &amp;&amp; x[&quot;Ser&quot;].ToString()!=&quot;&quot;).ToList();
        List&lt;string&gt; listSerTable2 = listTable2.Select(x =&gt; x[&quot;Ser&quot;].ToString()).Distinct().ToList();

        List&lt;TableRow&gt; rows = new List&lt;TableRow&gt;();
        
        for (int i=0; i&lt;listSerTable2.Count; i++)
        {
          List&lt;JToken&gt; SerTable2 = jsonTable2.Where(x=&gt;x[&quot;Ser&quot;].ToString()==listSerTable2[i]).ToList();          
         
          for (int j = 0; j &lt; SerTable2.Count; j++)
          {
            if (j==0)
              Ser.RowSpan = SerTable2.Count;
            else 
              Ser.RowSpan = 1;
         
            Ser.Text = SerTable2[j][&quot;Ser&quot;].ToString();
            Row.Text = SerTable2[j][&quot;Row&quot;].ToString();
            Q_ji.Text = SerTable2[j][&quot;Q_ji&quot;].ToString().Replace('.',',');
            T_ji.Text = SerTable2[j][&quot;T_ji&quot;].ToString().Replace('.',',');
            t_PU_ji.Text = SerTable2[j][&quot;t_PU_ji&quot;].ToString().Replace('.',',');
            P_PU_ji.Text = SerTable2[j][&quot;P_PU_ji&quot;].ToString().Replace('.',',');
            Dens_ji.Text = SerTable2[j][&quot;Dens_ji&quot;].ToString().Replace('.',',');
            DensTemp_ji.Text = SerTable2[j][&quot;DensTemp_ji&quot;].ToString().Replace('.',',');
            DensPress_ji.Text = SerTable2[j][&quot;DensPress_ji&quot;].ToString().Replace('.',',');
            N_ji.Text = SerTable2[j][&quot;N_ji&quot;].ToString().Replace('.',',');
            V_PU_PR_ji.Text = SerTable2[j][&quot;V_PU_PR_ji&quot;].ToString().Replace('.',',');
            Dens_PP_PR_ji.Text = SerTable2[j][&quot;Dens_PP_PR_ji&quot;].ToString().Replace('.',',');
            M_RA_ji.Text = SerTable2[j][&quot;M_RA_ji&quot;].ToString().Replace('.',',');
            M_from_GH_ji.Text = SerTable2[j][&quot;M_from_GH_ji&quot;].ToString().Replace('.',',');
            Delta_KMH_ji.Text = SerTable2[j][&quot;Delta_KMH_ji&quot;].ToString().Replace('.',',');
          
            TableRow row = new TableRow();
            row.AssignAll(Table2_RowData);
            row.Visible=true;
            //row.Name = $&quot;row{j}&quot;;
            rows.Add(row);        
          }
          
          Table2.Rows.AddRange(rows.ToArray());
        }
        
        MI.Text = JAdditionalInfo[&quot;GostBinary&quot;][&quot;MI&quot;].ToString();
      
        PrintTable(Table2);
      }    
    }

    public void FillReportSummary()
    {
      Report.SetParameterValue(&quot;Delta_KMH_Max&quot;, JProtokol[&quot;Delta_max&quot;].ToString().Replace('.',','));
      Report.SetParameterValue(&quot;ARM_KMH_Result&quot;, JAdditionalInfo[&quot;ARM_KMH_Result&quot;].ToString() == &quot;годен&quot; ? &quot;годно&quot; : &quot;не годно&quot;);
      
      DateTime date = new DateTime(1970, 1, 1, 0, 0, 0, DateTimeKind.Utc).AddSeconds((long)JTableKMH_MPR_PU[&quot;DateTimeLong&quot;]);
      Report.SetParameterValue(&quot;DateKMH&quot;, date.ToString(&quot;dd.MM.yyyy&quot;));
      
      
      //if ((bool)JARMData[&quot;GostBinary&quot;][&quot;OperatingStaffDataIsDelivery&quot;])
      //{
      //}       
      
      ServiceStaffData_Company.Text = JAdditionalInfo[&quot;GostBinary&quot;][&quot;ServiceStaffData&quot;][&quot;Company&quot;].ToString();
      ServiceStaffData_Post.Text = JAdditionalInfo[&quot;GostBinary&quot;][&quot;ServiceStaffData&quot;][&quot;Post&quot;].ToString();
      ServiceStaffData_FIO.Text = JAdditionalInfo[&quot;GostBinary&quot;][&quot;ServiceStaffData&quot;][&quot;FIO&quot;].ToString();
      
      OperatingStaffData_Company.Text = JAdditionalInfo[&quot;GostBinary&quot;][&quot;OperatingStaffData&quot;][&quot;Company&quot;].ToString();
      OperatingStaffData_Post.Text = JAdditionalInfo[&quot;GostBinary&quot;][&quot;OperatingStaffData&quot;][&quot;Post&quot;].ToString();
      OperatingStaffData_FIO.Text = JAdditionalInfo[&quot;GostBinary&quot;][&quot;OperatingStaffData&quot;][&quot;FIO&quot;].ToString();
      
      DeliveryOrRecievingStaffData_Company.Text = JAdditionalInfo[&quot;GostBinary&quot;][&quot;DeliveryOrRecievingStaffData&quot;][&quot;Company&quot;].ToString();
      DeliveryOrRecievingStaffData_Post.Text = JAdditionalInfo[&quot;GostBinary&quot;][&quot;DeliveryOrRecievingStaffData&quot;][&quot;Post&quot;].ToString();
      DeliveryOrRecievingStaffData_FIO.Text = JAdditionalInfo[&quot;GostBinary&quot;][&quot;DeliveryOrRecievingStaffData&quot;][&quot;FIO&quot;].ToString();
    }  
      
    private void PrintTable(TableObject table)
    {
      for (int i=0;i&lt;table.RowCount;i++)
      {       
        table.PrintRow(i);
        table.PrintColumns();
      }    
    }

  }    
}

