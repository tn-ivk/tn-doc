  <ScriptText>using System;
using System.Reflection;
using System.Collections;
using System.Collections.Generic;
using System.ComponentModel;         
using System.Drawing;
using System.Data;
using System.IO;
using FastReport;
using FastReport.Data;
using FastReport.Dialog;
using FastReport.Barcode;
using FastReport.Table;
using FastReport.Utils;
using System.Linq;
using Newtonsoft.Json.Linq; 

namespace FastReport
{
  public class ReportScript
  {
    JToken JDoc;
    JToken JSettings;
    JToken JTableKMH_MI2816;
    JToken JProtokol;
    JToken JAdditionalInfo;
    JToken JARMData;
   
    int ProtocolNumber;
    int NefType;    

    List&lt;string&gt; ListOilName;
    
    private void Page_StartPage(object sender, EventArgs e)
    {
      JDoc = JToken.Parse(Report.GetParameterValue(&quot;JsonDoc&quot;).ToString());
      JSettings = JDoc[&quot;Doc&quot;][&quot;Settings&quot;];
      JTableKMH_MI2816 = JDoc[&quot;Doc&quot;][&quot;DataIVK&quot;][&quot;TableKMH_MI2816&quot;];
      JProtokol = JDoc[&quot;Doc&quot;][&quot;DataIVK&quot;][&quot;TableKMH_MI2816&quot;][&quot;Protokol&quot;];
      JAdditionalInfo = JDoc[&quot;Doc&quot;][&quot;DataIVK&quot;][&quot;TableKMH_MI2816&quot;][&quot;AdditionalInfo&quot;];
      JARMData = JDoc[&quot;Doc&quot;][&quot;DataIVK&quot;][&quot;TableKMH_MI2816&quot;][&quot;ARMData&quot;];
        
      Page.PaperHeight = (int)JSettings[&quot;General&quot;][&quot;PageSettings&quot;][&quot;PaperHeight&quot;];
      Page.PaperWidth = (int)JSettings[&quot;General&quot;][&quot;PageSettings&quot;][&quot;PaperWidth&quot;];
                    
      Page.TopMargin = (int)JSettings[&quot;General&quot;][&quot;PageSettings&quot;][&quot;TopMargin&quot;];
      Page.BottomMargin = (int)JSettings[&quot;General&quot;][&quot;PageSettings&quot;][&quot;BottomMargin&quot;];
      Page.LeftMargin = (int)JSettings[&quot;General&quot;][&quot;PageSettings&quot;][&quot;LeftMargin&quot;];
      Page.RightMargin = (int)JSettings[&quot;General&quot;][&quot;PageSettings&quot;][&quot;RightMargin&quot;];
                  
      ListOilName = new List&lt;string&gt;() {&quot;нефти&quot;, &quot;нефтепродуктов&quot;};
  
      ProtocolNumber = (int)JSettings[&quot;General&quot;][&quot;ProtocolNumber&quot;];
      NefType = (int)JSettings[&quot;General&quot;][&quot;NefType&quot;];
                  
      FillReportTitle(ProtocolNumber);
      FillTable1(ProtocolNumber);
      FillTable2(ProtocolNumber);
      FillEnviromentTable(ProtocolNumber);
      FillReportSummary(ProtocolNumber);
    }
        
    private void FillReportTitle(int protocolNumber)
    {
      JToken jsonPP_AdditionalInfo;
      
      Report.SetParameterValue(&quot;OilName&quot;, ListOilName[NefType-1]);
                
      if(protocolNumber == 1)
        jsonPP_AdditionalInfo =  JAdditionalInfo[&quot;PP1_AdditionalInfo&quot;];
      else
        jsonPP_AdditionalInfo =  JAdditionalInfo[&quot;PP2_AdditionalInfo&quot;];
      
      string placeSiknName = String.IsNullOrEmpty(JSettings[&quot;Header&quot;][&quot;FieldSIKN&quot;].ToString()) ?
      $&quot;СИКН/СИКНП &lt;u&gt;{jsonPP_AdditionalInfo[&quot;SIKN_Name&quot;].ToString()}&lt;/u&gt;&quot; :
      $&quot;{JSettings[&quot;Header&quot;][&quot;FieldSIKN&quot;].ToString()} &lt;u&gt;{jsonPP_AdditionalInfo[&quot;SIKN_Name&quot;].ToString()}&lt;/u&gt;&quot;;                    
      SIKN_Name.Text = placeSiknName;
      
      string placePspName = String.IsNullOrEmpty(JSettings[&quot;Header&quot;][&quot;FieldPSP&quot;].ToString()) ?
      $&quot;ПСП &lt;u&gt;{jsonPP_AdditionalInfo[&quot;PSP_Name&quot;].ToString()}&lt;/u&gt;&quot; :
      $&quot;{JSettings[&quot;Header&quot;][&quot;FieldPSP&quot;].ToString()} &lt;u&gt;{jsonPP_AdditionalInfo[&quot;PSP_Name&quot;].ToString()}&lt;/u&gt;&quot;;      
      PSP_Name.Text = placePspName;      
    }
        
    private void FillTable1(int protocolNumber)
    {
      JToken jsonPP_AdditionalInfo;
      
      if(protocolNumber == 1)
        jsonPP_AdditionalInfo = JAdditionalInfo[&quot;PP1_AdditionalInfo&quot;];
      else
        jsonPP_AdditionalInfo = JAdditionalInfo[&quot;PP2_AdditionalInfo&quot;];
      
      Picn1_P11.Text = JARMData[&quot;Picn1&quot;][&quot;P11&quot;].ToString().Replace('.',',');
      Picn1_P12.Text = JARMData[&quot;Picn1&quot;][&quot;P12&quot;].ToString().Replace('.',',');
      Picn1_P13.Text = JARMData[&quot;Picn1&quot;][&quot;P13&quot;].ToString();
      Picn1_P14.Text = JARMData[&quot;Picn1&quot;][&quot;P14&quot;].ToString().Replace('.',',');
      Picn1_P15.Text = JARMData[&quot;Picn1&quot;][&quot;P15&quot;].ToString().Replace('.',',');
      Picn1_P16.Text = JARMData[&quot;Picn1&quot;][&quot;P16&quot;].ToString().Replace('.',',');
      Picn1_P17.Text = JARMData[&quot;Picn1&quot;][&quot;P17&quot;].ToString().Replace('.',',');
      Picn1_P18.Text = JARMData[&quot;Picn1&quot;][&quot;P18&quot;].ToString().Replace('.',',');
      Picn1_P19.Text = JARMData[&quot;Picn1&quot;][&quot;P19&quot;].ToString().Replace('.',',');
      Picn1_P110.Text = JARMData[&quot;Picn1&quot;][&quot;P110&quot;].ToString().Replace('.',',');
      Picn1_P111.Text = JARMData[&quot;Picn1&quot;][&quot;P111&quot;].ToString().Replace('.',',');

      Picn2_P11.Text = JARMData[&quot;Picn2&quot;][&quot;P11&quot;].ToString().Replace('.',',');
      Picn2_P12.Text = JARMData[&quot;Picn2&quot;][&quot;P12&quot;].ToString().Replace('.',',');
      Picn2_P13.Text = JARMData[&quot;Picn2&quot;][&quot;P13&quot;].ToString();
      Picn2_P14.Text = JARMData[&quot;Picn2&quot;][&quot;P14&quot;].ToString().Replace('.',',');
      Picn2_P15.Text = JARMData[&quot;Picn2&quot;][&quot;P15&quot;].ToString().Replace('.',',');
      Picn2_P16.Text = JARMData[&quot;Picn2&quot;][&quot;P16&quot;].ToString().Replace('.',',');
      Picn2_P17.Text = JARMData[&quot;Picn2&quot;][&quot;P17&quot;].ToString().Replace('.',',');
      Picn2_P18.Text = JARMData[&quot;Picn2&quot;][&quot;P18&quot;].ToString().Replace('.',',');
      Picn2_P19.Text = JARMData[&quot;Picn2&quot;][&quot;P19&quot;].ToString().Replace('.',',');
      Picn2_P110.Text = JARMData[&quot;Picn2&quot;][&quot;P110&quot;].ToString().Replace('.',',');
      Picn2_P111.Text = JARMData[&quot;Picn2&quot;][&quot;P111&quot;].ToString().Replace('.',',');

      Weigher_P21.Text = JARMData[&quot;Weigher&quot;][&quot;P21&quot;].ToString().Replace('.',',');
      Weigher_P22.Text = JARMData[&quot;Weigher&quot;][&quot;P22&quot;].ToString().Replace('.',',');
      Weigher_P23.Text = JARMData[&quot;Weigher&quot;][&quot;P23&quot;].ToString();
      Weigher_P24.Text = JARMData[&quot;Weigher&quot;][&quot;P24&quot;].ToString().Replace('.',',');
      Weigher_P25.Text = JARMData[&quot;Weigher&quot;][&quot;P25&quot;].ToString().Replace('.',',');

      Temp_P31.Text = JARMData[&quot;Temp&quot;][&quot;P31&quot;].ToString().Replace('.',',');
      Temp_P32.Text = JARMData[&quot;Temp&quot;][&quot;P32&quot;].ToString().Replace('.',',');
      Temp_P33.Text = JARMData[&quot;Temp&quot;][&quot;P33&quot;].ToString();
      Temp_P34.Text = JARMData[&quot;Temp&quot;][&quot;P34&quot;].ToString().Replace('.',',');
      Temp_P35.Text = JARMData[&quot;Temp&quot;][&quot;P35&quot;].ToString().Replace('.',',');

      Press_P41.Text = JARMData[&quot;Press&quot;][&quot;P41&quot;].ToString().Replace('.',',');
      Press_P42.Text = JARMData[&quot;Press&quot;][&quot;P42&quot;].ToString().Replace('.',',');
      Press_P43.Text = JARMData[&quot;Press&quot;][&quot;P43&quot;].ToString();
      Press_P44.Text = JARMData[&quot;Press&quot;][&quot;P44&quot;].ToString().Replace('.',',');
      Press_P45.Text = JARMData[&quot;Press&quot;][&quot;P45&quot;].ToString().Replace('.',',');
      
      Delta_Picn.Text = jsonPP_AdditionalInfo[&quot;Delta_Picn&quot;].ToString().Replace('.',',');
      
      DensSensor_Name.Text = jsonPP_AdditionalInfo[&quot;DensSensor_Name&quot;].ToString();
      DensSensor_FactoryNumber.Text = jsonPP_AdditionalInfo[&quot;DensSensor_FactoryNumber&quot;].ToString();
      DensSensor_CheckDate.Text = jsonPP_AdditionalInfo[&quot;DensSensor_CheckDate&quot;].ToString();
      Delta_PP.Text = jsonPP_AdditionalInfo[&quot;Delta_PP&quot;].ToString().Replace('.',',');
    }
        
    private void FillTable2(int protocolNumber)
    {
      JToken jsonTable1 = JProtokol[&quot;Table1&quot;][protocolNumber-1];
      JToken jsonTable1_1 = JProtokol[&quot;Table1_1&quot;];
                    
      Q.Text = jsonTable1[&quot;Q&quot;].ToString().Replace('.',',');
      PP_t.Text = jsonTable1[&quot;PP_t&quot;].ToString().Replace('.',',');
      PP_P.Text = jsonTable1[&quot;PP_P&quot;].ToString().Replace('.',',');
      PP_Dens.Text = jsonTable1[&quot;PP_Dens&quot;].ToString().Replace('.',',');
      Picn_Avg.Text = jsonTable1[&quot;Picn_Avg&quot;].ToString().Replace('.',',');
      Picn_Normolized.Text = jsonTable1[&quot;Picn_Normolized&quot;].ToString().Replace('.',',');
      Delta.Text = jsonTable1[&quot;Delta&quot;].ToString().Replace('.',',');

      Index_1.Text = jsonTable1_1[0][&quot;Index&quot;].ToString();
      W_p_1.Text = jsonTable1_1[0][&quot;W_p&quot;].ToString().Replace('.',',');
      W_z_1.Text = jsonTable1_1[0][&quot;W_z&quot;].ToString().Replace('.',',');
      t_1.Text = jsonTable1_1[0][&quot;t&quot;].ToString().Replace('.',',');
      P_1.Text = jsonTable1_1[0][&quot;P&quot;].ToString().Replace('.',',');         
      
      Index_2.Text = jsonTable1_1[1][&quot;Index&quot;].ToString();
      W_p_2.Text = jsonTable1_1[1][&quot;W_p&quot;].ToString().Replace('.',',');
      W_z_2.Text = jsonTable1_1[1][&quot;W_z&quot;].ToString().Replace('.',',');
      t_2.Text = jsonTable1_1[1][&quot;t&quot;].ToString().Replace('.',',');
      P_2.Text = jsonTable1_1[1][&quot;P&quot;].ToString().Replace('.',',');  
      
      MI.Text = JARMData[&quot;GostBinary&quot;][&quot;MI&quot;].ToString();
    }

    private void FillEnviromentTable(int protocolNumber){ 
      Env_Temperature.Text = JARMData[&quot;GostBinary&quot;][&quot;Env&quot;][&quot;Temperature&quot;].ToString();
      Env_Humidity.Text = JARMData[&quot;GostBinary&quot;][&quot;Env&quot;][&quot;RelativeHumidity&quot;].ToString();
      string pressureKpa =  JARMData[&quot;GostBinary&quot;][&quot;Env&quot;][&quot;PressureKp&quot;].ToString();
      string pressureMM =   JARMData[&quot;GostBinary&quot;][&quot;Env&quot;][&quot;PressureMmMercury&quot;].ToString();
      Env_Pressure.Text = pressureKpa + &quot; (&quot;+pressureMM+&quot;)&quot;;
    }

    private void FillReportSummary(int protocolNumber)
    {
      string armKMHResult;
      
      if(protocolNumber == 1)
        armKMHResult =  JARMData[&quot;ARM_KMH_Result1&quot;].ToString() == &quot;годен&quot; ? &quot;годно&quot; : &quot;не годно&quot;;
      else
        armKMHResult =  JARMData[&quot;ARM_KMH_Result2&quot;].ToString() == &quot;годен&quot; ? &quot;годно&quot; : &quot;не годно&quot;;

      Report.SetParameterValue(&quot;ARM_KMH_Result&quot;, armKMHResult);
                    
      DateTime date = new DateTime(1970, 1, 1, 0, 0, 0, DateTimeKind.Utc).AddSeconds((long)JTableKMH_MI2816[&quot;DateTimeLong&quot;]);
      Report.SetParameterValue(&quot;DateKMH&quot;, date.ToString(&quot;dd.MM.yyyy&quot;)); 
      
      
      bool hasCustomSIKNName = !String.IsNullOrEmpty(JSettings[&quot;Footer&quot;][&quot;FieldSIKN&quot;].ToString());
      ServiceStaffData_Company.Text = JARMData[&quot;GostBinary&quot;][&quot;ServiceStaffData&quot;][&quot;Company&quot;].ToString();
      ServiceStaffData_Post.Text = JARMData[&quot;GostBinary&quot;][&quot;ServiceStaffData&quot;][&quot;Post&quot;].ToString();
      ServiceStaffData_FIO.Text = JARMData[&quot;GostBinary&quot;][&quot;ServiceStaffData&quot;][&quot;FIO&quot;].ToString();
      if(hasCustomSIKNName){
        ServiceStaffData_Company_Desc.Text=$&quot;организация, проводящая техническое обслуживание {JSettings[&quot;Footer&quot;][&quot;FieldSIKN&quot;]}&quot;;
      }
      
      OperatingStaffData_Company.Text = JARMData[&quot;GostBinary&quot;][&quot;OperatingStaffData&quot;][&quot;Company&quot;].ToString();
      OperatingStaffData_Post.Text = JARMData[&quot;GostBinary&quot;][&quot;OperatingStaffData&quot;][&quot;Post&quot;].ToString();
      OperatingStaffData_FIO.Text = JARMData[&quot;GostBinary&quot;][&quot;OperatingStaffData&quot;][&quot;FIO&quot;].ToString();
      if(hasCustomSIKNName){
        OperatingStaffData_Company_Desc.Text=$&quot;организация, эксплуатирующая {JSettings[&quot;Footer&quot;][&quot;FieldSIKN&quot;]}&quot;;
      }
      
      DeliveryOrRecievingStaffData_Company.Text = JARMData[&quot;GostBinary&quot;][&quot;DeliveryOrRecievingStaffData&quot;][&quot;Company&quot;].ToString();
      DeliveryOrRecievingStaffData_Post.Text = JARMData[&quot;GostBinary&quot;][&quot;DeliveryOrRecievingStaffData&quot;][&quot;Post&quot;].ToString();
      DeliveryOrRecievingStaffData_FIO.Text = JARMData[&quot;GostBinary&quot;][&quot;DeliveryOrRecievingStaffData&quot;][&quot;FIO&quot;].ToString();
    }
  }
}


