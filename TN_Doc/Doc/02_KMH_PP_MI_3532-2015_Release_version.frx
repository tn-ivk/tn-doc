<Report ScriptLanguage="CSharp" ReferencedAssemblies="System.dll&#13;&#10;System.Drawing.dll&#13;&#10;System.Windows.Forms.dll&#13;&#10;System.Data.dll&#13;&#10;System.Xml.dll&#13;&#10;Newtonsoft.Json.dll&#13;&#10;System.Collections.dll&#13;&#10;System.Core.dll&#13;&#10;TN_DocGeneral.dll&#13;&#10;KMH_PP.dll" DoublePass="true" ReportInfo.Created="03/25/2020 12:46:46" ReportInfo.Modified="07/29/2024 13:02:37" ReportInfo.CreatorVersion="2023.3.5.0">
  <ScriptText>using System;
using System.Reflection;
using System.Collections;
using System.Collections.Generic;
using System.ComponentModel;         
using System.Drawing;
using System.Data;
using System.IO;
using FastReport;
using FastReport.Data;
using FastReport.Dialog;
using FastReport.Barcode;
using FastReport.Table;
using FastReport.Utils;
using System.Linq;
using Newtonsoft.Json;
using TN.DocData;

namespace FastReport
{
  public class ReportScript
  {
    TN_ToolsFastReport.Tools tools = new TN_ToolsFastReport.Tools();  // классы отчета
    TN.Doc.Doc doc; // данные из входного параметра
    TN.DocData.General General;
    TN.Doc.HeaderDoc Header;
    TN.Doc.DataDoc SettingsData;
    TN.Doc.FooterDoc Footer;
    TN.Doc.DictionarysDoc Dictionarys;
    TN.Doc.DataIVKDoc DataIVK;
      
    List &lt;TN.Doc.Table1&gt; tableResultsParams;

    private void Page_StartPage(object sender, EventArgs e)
    {
      //using (var sr = new StreamReader(&quot;D:/!_Work/!_Транснефть/SVN/Work/Sources/Reports/FRX/Входящие данные от Алексея (классы и json)/02_TableKMH_PP/DocKMH_PP.json&quot;))
      //{
      // Read the stream as a string
      //Report.SetParameterValue(&quot;Protocol&quot;, sr.ReadToEnd());
      //}
      //// Десериализация данных (формат json) из входного параметра - Json                         
      string json = (string)Report.GetParameterValue(&quot;JsonDoc&quot;);
      Newtonsoft.Json.JsonSerializerSettings settings = new Newtonsoft.Json.JsonSerializerSettings();
      settings.TypeNameHandling = TypeNameHandling.All;

      doc = JsonConvert.DeserializeObject&lt;TN.Doc.Doc&gt;(json, settings);
      General = (TN.DocData.General) doc.Doc.Settings.General;
      Header = (TN.Doc.HeaderDoc) doc.Doc.Settings.Header;
      SettingsData = (TN.Doc.DataDoc) doc.Doc.Settings.Data;
      Footer = (TN.Doc.FooterDoc) doc.Doc.Settings.Footer;
      Dictionarys = (TN.Doc.DictionarysDoc) doc.Doc.Settings.Dictionarys;  
      DataIVK = (TN.Doc.DataIVKDoc) doc.Doc.DataIVK;

      //// === Настройки страницы 
      // Ширина и высота (в мм)
         
      Page.PaperHeight = General.PageSettings.PaperHeight;
      Page.PaperWidth = General.PageSettings.PaperWidth;
         
      // Поля/отступы от краёв (в мм)
      Page.TopMargin = General.PageSettings.TopMargin;
      Page.BottomMargin = General.PageSettings.BottomMargin;
      Page.LeftMargin = General.PageSettings.LeftMargin;
      Page.RightMargin = General.PageSettings.RightMargin;
          
      // Запуск отрисовки таблиц на странице отчета
      DrawTableHeader();
      DrawTableSourceData();  
      DrawTableConclusion();
    }
      
    public void DrawTableHeader()
    {
      // Setup Columns
      float widthDynamicCols=(Page.PaperWidth-Page.LeftMargin-Page.RightMargin)/TableHeader.ColumnCount;         

      for (int i = 0; i &lt; (TableHeader.ColumnCount); i++)                 
      {
        TableHeader.Columns[i].Width = widthDynamicCols*Units.Millimeters;
      }
         
      // Fill table with data         
      ProtocolType.Text = Dictionarys.ProtocolType[DataIVK.TableKMH_PP.KMH_TYPE];
      SIKN_Num.Text = Header.FieldSIKN + DataIVK.TableKMH_PP.AdditionalInfo.SIKN_Num;
      PSP_Name.Text = Header.FieldPSP + DataIVK.TableKMH_PP.AdditionalInfo.PSP_Name;         
      ControlConditions.Text = Dictionarys.ControlConditions[DataIVK.TableKMH_PP.KMH_TYPE];
    }
               
    public void  DrawTableSourceData()
    {
      // Setup Columns         
      float widthCol1=70f;
      int sumDynamicCols=2;

      float widthDynamicCol=(Page.PaperWidth-Page.LeftMargin-Page.RightMargin-(float)widthCol1)/sumDynamicCols;                  
         
      for (int w = 0; w &lt; (TableSourceData.ColumnCount); w++)                 
      {
        switch (w)
        {
          case 0:
            TableSourceData.Columns[w].Width = (float)widthCol1 * Units.Millimeters;
            break;
          default:
            TableSourceData.Columns[w].Width = widthDynamicCol * Units.Millimeters;
            break;
        }
      }
         
      //// ===  Fill table with data

      // Column 2
      SensName_Oper.Text = DataIVK.TableKMH_PP.AdditionalInfo.SensName_Oper;
      ManufNum_Oper.Text = DataIVK.TableKMH_PP.AdditionalInfo.ManufNum_Oper;
      CheckDate_Oper.Text = DataIVK.TableKMH_PP.AdditionalInfo.CheckDate_Oper;
      Delta_Rab.Text = tools.GetNormalizedValue(DataIVK.TableKMH_PP.Protokol.Delta_Rab);
         
      // Column 3
      DensityMeterType.Text = Dictionarys.DensityMeterType[DataIVK.TableKMH_PP.KMH_TYPE];
      SensName_Ethal.Text = DataIVK.TableKMH_PP.AdditionalInfo.SensName_Ethal;
      ManufNum_Ethal.Text = DataIVK.TableKMH_PP.AdditionalInfo.ManufNum_Ethal;
      CheckDate_Ethal.Text = DataIVK.TableKMH_PP.AdditionalInfo.CheckDate_Ethal;
      LastCleanDate_Ethal.Text = DataIVK.TableKMH_PP.AdditionalInfo.LastCleanDate_Ethal;
      Delta_Etal.Text = tools.GetNormalizedValue(DataIVK.TableKMH_PP.Protokol.Delta_Etal);
         
      Footnote.Text = Dictionarys.Footnote[DataIVK.TableKMH_PP.KMH_TYPE];
    }

    private void TableResults_ManualBuild(object sender, EventArgs e)
    {
      //// Get data from json
      tableResultsParams = DataIVK.TableKMH_PP.Protokol.Table1.Where(y =&gt;  y.Q != &quot;-&quot; || 
        y.t != &quot;-&quot; || 
        y.P != &quot;-&quot; || 
        y.Dens_Rab != &quot;-&quot; || 
        y.Dens_Etal != &quot;-&quot; || 
        y.Delta != &quot;-&quot; || 
      y.Error != &quot;-&quot;).ToList();
      NefType.Text = Dictionarys.OilTechParams[General.NefType];
         
      //Setup Columns width
      int sumDynamicCols=TableResults.ColumnCount-1;
      float widthDynamicCol=(Page.PaperWidth-Page.LeftMargin-Page.RightMargin - (MeasNum.Width/Units.Millimeters))/sumDynamicCols;                  
 
      for (int w = 1; w &lt; (TableResults.ColumnCount); w++)                 
      {
        TableResults.Columns[w].Width = widthDynamicCol * Units.Millimeters;
      }      
                           
      // Fill table header with the text
      Dens.Text = Dictionarys.Dens[DataIVK.TableKMH_PP.KMH_TYPE];
      DensDiff.Text = Dictionarys.DensDiff[DataIVK.TableKMH_PP.KMH_TYPE];

      //Draw Fixed rows
      for (int n = 0; n &lt; TableResults.FixedRows; n++)
      {
        TableResults.PrintRow(n);
        TableResults.PrintColumns();                                             
      }
         
      //Fill table with data
      for (int i = 0; i &lt; (tableResultsParams.Count); i++)                 
      {  
        CounterMeasure.Text=(i+1).ToString();
        Q.Text=tools.GetNormalizedValue(tableResultsParams[i].Q);
        t.Text=tools.GetNormalizedValue(tableResultsParams[i].t);
        P.Text=tools.GetNormalizedValue(tableResultsParams[i].P);
        Dens_Rab.Text=tools.GetNormalizedValue(tableResultsParams[i].Dens_Rab);
        Dens_Etal.Text=tools.GetNormalizedValue(tableResultsParams[i].Dens_Etal);
        Delta.Text=tools.GetNormalizedValue(tableResultsParams[i].Delta);
            
        TableResults.PrintRow(3);     
        TableResults.PrintColumns();  
      }
    }
    
    public void  DrawTableConclusion()
    {
      // Setup width for last Column
      TableConclusion.Columns[4].Width=(Page.PaperWidth-Page.LeftMargin-Page.RightMargin - 
        ((TableConclusion.Columns[0].Width + TableConclusion.Columns[1].Width + TableConclusion.Columns[2].Width + TableConclusion.Columns[3].Width)/Units.Millimeters))*Units.Millimeters;
                                       
      //// ===  Fill table with data
      ARM_KMH_Result.Text =string.Format(&quot;Поточный ПП зав. № &lt;u&gt; {0}&lt;/u&gt; {1}&quot;, 
        DataIVK.TableKMH_PP.AdditionalInfo.ManufNum_Oper,
        DataIVK.TableKMH_PP.AdditionalInfo.ARM_KMH_Result + &quot; к дальнейшей эксплуатации&quot;);
      DateTimeLong.Text = string.Format(&quot;Дата проведения КМХ: &lt;u&gt;{0:dd.MM.yyyy} г.&quot;,(tools.UnixTimestampToDatetime(DataIVK.TableKMH_PP.DateTimeLong)));               
      ServiceStaffData.Text = DataIVK.TableKMH_PP.AdditionalInfo.ServiceStaffData;
      DeliveryStaffData.Text = DataIVK.TableKMH_PP.AdditionalInfo.DeliveryStaffData;
      RecievingStaffData.Text = DataIVK.TableKMH_PP.AdditionalInfo.RecievingStaffData;
    }  

    private void PageFooter_BeforeLayout(object sender, EventArgs e)
    {
      if((Int32)Report.GetVariableValue(&quot;TotalPages&quot;) &lt; 2) 
      { 
        PageFooter.Visible = false; 
      }
      else
      {
        PageNumeration.Width = (Page.PaperWidth-Page.LeftMargin-Page.RightMargin)*Units.Millimeters;
      }
    }
  }    
}

</ScriptText>
