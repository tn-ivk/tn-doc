<Report ScriptLanguage="CSharp" ReferencedAssemblies="System.dll&#13;&#10;System.Drawing.dll&#13;&#10;System.Windows.Forms.dll&#13;&#10;System.Data.dll&#13;&#10;System.Xml.dll&#13;&#10;Newtonsoft.Json.dll&#13;&#10;System.Collections.dll&#13;&#10;System.Core.dll&#13;&#10;TN_ToolsFastReport.dll&#13;&#10;TN_DocGeneral.dll&#13;&#10;KMH_PV.dll" ReportInfo.Created="03/25/2020 12:46:46" ReportInfo.Modified="12/22/2023 11:06:31" ReportInfo.CreatorVersion="2023.2.0.0">
  <ScriptText>using System;
using System.Reflection;
using System.Collections;
using System.Collections.Generic;
using System.ComponentModel;         
using System.Drawing;
using System.Data;
using System.IO;
using FastReport;
using FastReport.Data;
using FastReport.Dialog;
using FastReport.Barcode;
using FastReport.Table;
using FastReport.Utils;
using System.Linq;
using Newtonsoft.Json;
using TN.DocData;
    
namespace FastReport
{
  public class ReportScript
  {
    TN_ToolsFastReport.Tools tools = new TN_ToolsFastReport.Tools();  // классы отчета
    TN.Doc.Doc doc; // данные из входного параметра
    TN.DocData.General General;
    TN.Doc.HeaderDoc Header;
    TN.Doc.DataDoc SettingsData;
    TN.Doc.FooterDoc Footer;
    TN.Doc.DictionarysDoc Dictionarys;
    TN.Doc.DataIVKDoc DataIVK;
      
    int protocolNumber;
    int KMH_TYPE; 
    int NefType;

    private void Page_StartPage(object sender, EventArgs e)
    {
      //// Десериализация данных (формат json) из входного параметра - Json                         
      string json = (string)Report.GetParameterValue(&quot;JsonDoc&quot;);
      Newtonsoft.Json.JsonSerializerSettings settings = new Newtonsoft.Json.JsonSerializerSettings();
      settings.TypeNameHandling = TypeNameHandling.All;
      
      doc = JsonConvert.DeserializeObject&lt;TN.Doc.Doc&gt;(json, settings);
      General = (TN.DocData.General) doc.Doc.Settings.General;
      Header = (TN.Doc.HeaderDoc) doc.Doc.Settings.Header;
      SettingsData = (TN.Doc.DataDoc) doc.Doc.Settings.Data;
      Footer = (TN.Doc.FooterDoc) doc.Doc.Settings.Footer;
      Dictionarys = (TN.Doc.DictionarysDoc) doc.Doc.Settings.Dictionarys;  
      DataIVK = (TN.Doc.DataIVKDoc) doc.Doc.DataIVK;
          
      KMH_TYPE = DataIVK.TableKMH_PV.KMH_TYPE; 
      NefType = General.NefType;
                                       
      //// === Настройки страницы 
      // Ширина и высота (в мм)
         
      Page.PaperHeight = General.PageSettings.PaperHeight;
      Page.PaperWidth = General.PageSettings.PaperWidth;
         
      // Поля/отступы от краёв (в мм)
      Page.TopMargin = General.PageSettings.TopMargin;
      Page.BottomMargin = General.PageSettings.BottomMargin;
      Page.LeftMargin = General.PageSettings.LeftMargin;
      Page.RightMargin = General.PageSettings.RightMargin;
         
      //Definition for which device create the protocol
      protocolNumber = General.ProtocolNumber;
         
      // Запуск отрисовки таблиц на странице отчета
      DrawTableHeader();
      DrawTableSourceData();
      DrawTableResults(); 
      DrawTableConclusion();
    }
      
    public void DrawTableHeader()
    {
      // Setup Columns
      TableHeader01.Columns[0].Width= (Page.PaperWidth-Page.LeftMargin-Page.RightMargin)*Units.Millimeters;

      // Fill table with data   
      ProtokolNum.Text = &quot;&lt;b&gt;Протокол № &quot;+ DataIVK.TableKMH_PV.AdditionalInfo.PV_AddInfo[protocolNumber-1].ProtokolNum;  
      Laboratory_Name.Text = &quot;по результатам испытаний точечной пробы в &lt;u&gt;&quot; + DataIVK.TableKMH_PV.AdditionalInfo.Laboratory_Name;
      Place_Factory.Text = $&quot;{Header.FieldSIKN}{DataIVK.TableKMH_PV.AdditionalInfo.Place_SIKN_Name} {DataIVK.TableKMH_PV.AdditionalInfo.Place_PSP}&quot;;//  string.Format(&quot;{0} {1}&quot;, DataIVK.TableKMH_PV.AdditionalInfo.Place_SIKN_Name,DataIVK.TableKMH_PV.AdditionalInfo.Place_PSP);                 
      PV_Type.Text = DataIVK.TableKMH_PV.AdditionalInfo.PV_AddInfo[protocolNumber-1].PV_Type;  
      PV_ManufNum.Text = DataIVK.TableKMH_PV.AdditionalInfo.PV_AddInfo[protocolNumber-1].PV_ManufNum;  
      PV_CheckDate.Text = DataIVK.TableKMH_PV.AdditionalInfo.PV_AddInfo[protocolNumber-1].PV_CheckDate;  
      LAB_Type.Text = DataIVK.TableKMH_PV.AdditionalInfo.LAB_Type ; 
      LAB_ManufNum.Text = DataIVK.TableKMH_PV.AdditionalInfo.LAB_ManufNum;
      LAB_CheckDate.Text = DataIVK.TableKMH_PV.AdditionalInfo.LAB_CheckDate;
      Laboratory_Name2.Text = $&quot;{DataIVK.TableKMH_PV.AdditionalInfo.Laboratory_Name} {DataIVK.TableKMH_PV.AdditionalInfo.Place_PSP} {DataIVK.TableKMH_PV.AdditionalInfo.Place_Factory}&quot;;
    }
               
    public void  DrawTableSourceData()
    {
      // Setup Columns         
      int sumDynamicCols=2;
      float widthDynamicCol=(Page.PaperWidth-Page.LeftMargin-Page.RightMargin-(TableSourceData.Columns[0].Width/Units.Millimeters))/sumDynamicCols;                  
      for (int w = 1; w &lt; (TableSourceData.ColumnCount); w++)                 
      {
        TableSourceData.Columns[w].Width = widthDynamicCol * Units.Millimeters;
      }
            
      // Fill table with text &amp; data
      Parameter01Name.Text = Dictionarys.Parameter01Name[KMH_TYPE];
      Parameter02Name.Text = Dictionarys.Parameter02Name[KMH_TYPE]; 
      Delta_PV.Text = tools.GetNormalizedValue(DataIVK.TableKMH_PV.Protocol.Protokol[protocolNumber-1].Table1.Delta_PV);    
      Delta_LAB.Text = tools.GetNormalizedValue(DataIVK.TableKMH_PV.Protocol.Protokol[protocolNumber-1].Table1.Delta_LAB);  
      UpLimitMeas_PV.Text = tools.GetNormalizedValue(DataIVK.TableKMH_PV.Protocol.Protokol[protocolNumber-1].Table1.UpLimitMeas_PV);    
      UpLimitMeas_LAB.Text = tools.GetNormalizedValue(DataIVK.TableKMH_PV.Protocol.Protokol[protocolNumber-1].Table1.UpLimitMeas_LAB);  
         
      ControlConditions.Text = string.Format(&quot;{0}{1}{2}&quot;,
        Dictionarys.ControlConditions[KMH_TYPE], 
        tools.GetNormalizedValue(DataIVK.TableKMH_PV.Protocol.Protokol[protocolNumber-1].KMX_Condition),
        Dictionarys.UnitsMeasurement[KMH_TYPE]);
    }
    
    //// === Setup table for TableResultsHeader         
    public void  DrawTableResults()
    {
      // Setup Columns
      int sumDynamicCols = TableResults.ColumnCount-1;
      float widthDynamicCol=(Page.PaperWidth-Page.LeftMargin-Page.RightMargin-(TableResults.Columns[7].Width/Units.Millimeters))/sumDynamicCols;                  
      for (int w = 0; w &lt; (TableResults.ColumnCount); w++)                 
      {
        switch(w)
        {
          case 0:
          case 1:
          case 2:
          case 3:
          case 4:
          case 5:
          case 6:
            TableResults.Columns[w].Width = widthDynamicCol*Units.Millimeters;;
            break;
        }
      }

      // Fill table with text      
      NeftType.Text = Dictionarys.OilTechParams[NefType];
      Dens.Text = Dictionarys.Dens[KMH_TYPE];
      Visc_LAB.Text = Dictionarys.Visc_LAB[KMH_TYPE]; 
      Delta.Text  = Dictionarys.Delta[KMH_TYPE];  
      FlowPV.Text = &quot;Поточный&lt;br&gt;ПВз&quot;;
         
      if (KMH_TYPE == 1 )
      {
        FlowPV.Text = &quot;Поточный ПВз&quot;;
      }

      //// === Setup table for TableResults &amp; fill data from IVK
      P.Text = tools.GetNormalizedValue(DataIVK.TableKMH_PV.Protocol.Protokol[protocolNumber-1].Table2.P);
      t.Text = tools.GetNormalizedValue(DataIVK.TableKMH_PV.Protocol.Protokol[protocolNumber-1].Table2.t);
      Dens2.Text = tools.GetNormalizedValue(DataIVK.TableKMH_PV.Protocol.Protokol[protocolNumber-1].Table2.Dens);
      Visc.Text = tools.GetNormalizedValue(DataIVK.TableKMH_PV.Protocol.Protokol[protocolNumber-1].Table2.Visc);                             
      Visc_LAB2.Text = tools.GetNormalizedValue(DataIVK.TableKMH_PV.Protocol.Protokol[protocolNumber-1].Table2.Visc_LAB); 
      t_LAB.Text = tools.GetNormalizedValue(DataIVK.TableKMH_PV.Protocol.Protokol[protocolNumber-1].Table2.t_LAB); 
      Delta2.Text = tools.GetNormalizedValue(DataIVK.TableKMH_PV.Protocol.Protokol[protocolNumber-1].Table2.Delta); 
    }
      
    public void  DrawTableConclusion()
    {  
      PV_Type2.Text = string.Format(&quot;     поточный преобразователь вязкости  &lt;u&gt;{0}&quot;,DataIVK.TableKMH_PV.AdditionalInfo.PV_AddInfo[protocolNumber-1].PV_Type);
      PV_ManufNum2.Text = DataIVK.TableKMH_PV.AdditionalInfo.PV_AddInfo[protocolNumber-1].PV_ManufNum;
      ARM_KMH_Result.Text = DataIVK.TableKMH_PV.AdditionalInfo.PV_AddInfo[protocolNumber-1].ARM_KMH_Result;
      DateTimeLong.Text = string.Format(&quot;Дата проведения КМХ:&lt;u&gt; {0:dd.MM.yyyy} г.&quot;,tools.UnixTimestampToDatetime(DataIVK.TableKMH_PV.DateTimeLong));
      ServiceStaffData.Text= DataIVK.TableKMH_PV.AdditionalInfo.ServiceStaffData;
      DeliveryStaffData.Text= DataIVK.TableKMH_PV.AdditionalInfo.DeliveryStaffData;
      RecievingStaffData.Text= DataIVK.TableKMH_PV.AdditionalInfo.RecievingStaffData;
    }  
  }    
}

