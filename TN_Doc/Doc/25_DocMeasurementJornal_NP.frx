      <DataFooterBand Name="DataFooter1" Top="232.27" Width="1047.06" Height="75.6" Border.Lines="All">
        <TableObject Name="Table1" Width="1043.28" Height="75.6">
          <TableColumn Name="Column277" Width="1043.28"/>
          <TableRow Name="Row185" Height="75.6">
            <TableCell Name="Cell1540" Text="	П р и м е ч а н и я&#13;&#10;	1      Графа 3 заполняется при наливе нефтепродукта в танкер.&#13;&#10;	2      ρ&lt;i&gt;&lt;sub&gt;пл&lt;/sub&gt;  (графа 16) - срендевзвешенное значение плотности, измеренной поточным ПП.&#13;&#10;	3      ρ&lt;i&gt;&lt;sub&gt;v&lt;/sub&gt;  (графа 17) - средневзвешенное значение плотности, измеренной поточным ПП и приведенное к условиям измерений объема.&#13;&#10;	4      Графы 13 и 15 заполняются при наличии БИК.&#13;&#10;	5      Графы 16 - 19 при наличии плотномера в составе СИКН." VertAlign="Center" Font="Arial, 8pt" FontWidthRatio="0.85" TextRenderType="HtmlTags"/>
          </TableRow>
        </TableObject>
      </DataFooterBand>
    </DataBand>
