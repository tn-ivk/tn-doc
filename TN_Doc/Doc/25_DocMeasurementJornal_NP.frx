namespace FastReport
{
  public class ReportScript
  {
      
    TN_ToolsFastReport.Tools tools = new TN_ToolsFastReport.Tools();  // классы отчета
    TN.Doc.Doc doc; 
    TN.Doc.DataIVKDoc DataIVK;
    TN.Doc.HeaderDoc Header;
    TN.Doc.DataDoc SettingsData;
    TN.Doc.FooterDoc Footer;
    TN.Doc.DictionarysDoc Dictionarys;
    
    private void Page_StartPage(object sender, EventArgs e)
    {
      //using (var sr = new StreamReader(&quot;D:/!_Work/!_Транснефть/SVN/Work/Sources/Reports/FRX/Входящие данные от Алексея (классы и json)/25_TableMeasurementJornal/DocMeasurementJornal.json&quot;))
      //{
      // Read the stream as a string
      //   Report.SetParameterValue(&quot;Journal&quot;, sr.ReadToEnd());
      //}
      //// Десериализация данных (формат json) из входного параметра - Json                         
      string json = (string)Report.GetParameterValue(&quot;JsonDoc&quot;);
      Newtonsoft.Json.JsonSerializerSettings settings = new Newtonsoft.Json.JsonSerializerSettings();
      settings.TypeNameHandling = TypeNameHandling.All;
      doc = JsonConvert.DeserializeObject&lt;TN.Doc.Doc&gt;(json, settings);
         
      DataIVK = (TN.Doc.DataIVKDoc)doc.Doc.DataIVK;
      Header = (TN.Doc.HeaderDoc)doc.Doc.Settings.Header;
      SettingsData = (TN.Doc.DataDoc)doc.Doc.Settings.Data;
      Footer = (TN.Doc.FooterDoc)doc.Doc.Settings.Footer;
      Dictionarys = (TN.Doc.DictionarysDoc)doc.Doc.Settings.Dictionarys;

      //// === Настройки страницы 
      // Ширина и высота (в мм)
      Page.PaperHeight = doc.Doc.Settings.General.PageSettings.PaperHeight;
      Page.PaperWidth= doc.Doc.Settings.General.PageSettings.PaperWidth;
      //Page.Border.Lines = BorderLines.All;
         
      // Поля/отступы от краёв (в мм)
      Page.TopMargin=doc.Doc.Settings.General.PageSettings.TopMargin;
      Page.BottomMargin=doc.Doc.Settings.General.PageSettings.BottomMargin;
      Page.LeftMargin=doc.Doc.Settings.General.PageSettings.LeftMargin;
      Page.RightMargin=doc.Doc.Settings.General.PageSettings.RightMargin;
         
      // Запуск отрисовки таблиц на странице отчета
      DrawTableHeader();
      //DrawTableTotal();
      DrawTableSigners();
      
      Table1.Width = TableJournal.Width;
    }      
   
    public void DrawTableHeader()
    {                                             
      SIKN_Name.Text = DataIVK.TableMeasurementJornal.AdditionalInfo.SIKN_Name; 
      Factory.Text = DataIVK.TableMeasurementJornal.AdditionalInfo.Factory; 
    }

    private void TableJournal_ManualBuild(object sender, EventArgs e)
    {
      List &lt;TN.Doc.Rows&gt; listTableJournal2h;
      List &lt;TN.Doc.Rows&gt; listTableJournalShifts;
      List &lt;TN.Doc.Rows&gt; listTableJournalDay;
         
      listTableJournal2h =DataIVK.TableMeasurementJornal.Data.Rows.Where(i =&gt; i.Used == 1).ToList();            
      listTableJournalShifts =DataIVK.TableMeasurementJornal.Data.Rows.Where(i =&gt; i.Used == 2).ToList();            
      listTableJournalDay =DataIVK.TableMeasurementJornal.Data.Rows.Where(i =&gt; i.Used == 3).ToList();            
        
      // Setup Columns width
      float widthDynamicCols=(Page.PaperWidth-Page.LeftMargin-Page.RightMargin-(TableJournal.Columns[0].Width/Units.Millimeters))/(TableJournal.ColumnCount-1);         
      for (int i = 1; i &lt; (TableJournal.ColumnCount); i++)                 
      {
        TableJournal.Columns[i].Width = widthDynamicCols*Units.Millimeters;
      }        
      
      //Draw Fixed rows
      for (int n = 0; n &lt; TableJournal.FixedRows; n++)
      {
        TableJournal.PrintRow(n);
        TableJournal.PrintColumns();                                             
      }       
         
      //Fill the table with data
      //string journalDate = string.Format(&quot;{0}.{1}.{2}г.&quot;,  
      //  DataIVK.TableMeasurementJornal.Day,
      //  DataIVK.TableMeasurementJornal.Month,
      //  DataIVK.TableMeasurementJornal.Year);

      string journalDate = new DateTime(DataIVK.TableMeasurementJornal.Year, DataIVK.TableMeasurementJornal.Month, DataIVK.TableMeasurementJornal.Day).ToString(&quot;dd.MM.yyyy&quot;);
      
      int tempCounter =1; 
      int tempCounterOut=0;
         
      FillTableWithData(tempCounter, journalDate, listTableJournal2h, out tempCounterOut); // fill data for 2hour 
      FillTableWithData(tempCounterOut, journalDate, listTableJournalShifts,  out tempCounterOut); // fill data for shifts 
      FillTableWithData(tempCounterOut, journalDate, listTableJournalDay,  out tempCounterOut); // fill data for 24 hours 
    }
      
    private void TableTotal_ManualBuild(object sender, EventArgs e)
    {
      List&lt;string&gt; listShiftsData;
      listShiftsData = DataIVK.TableMeasurementJornal.Data.Shift.Select(x =&gt; x == &quot;&quot; ? &quot;-&quot; : x).ToList();;
         
      for (int i = 0; i &lt; DataIVK.TableMeasurementJornal.AdditionalInfo.ShiftNum; i++)                 
      {
        switch(DataIVK.TableMeasurementJornal.AdditionalInfo.ShiftNum)
        {
          case 0:
            Total.Text=&quot;&quot;;
            break;
          case 1:
            Total.Text=string.Format(&quot;Итого масса нефтепродукта за смену/на танкер* &lt;u&gt;{0}&lt;/u&gt; тонн.&quot;, tools.GetNormalizedValue(listShiftsData[i]));
            break;
          default:
            Total.Text=string.Format(&quot;Итого масса нефтепродукта за {1} смену/на танкер* &lt;u&gt;{0}&lt;/u&gt; тонн.&quot;, tools.GetNormalizedValue(listShiftsData[i]), i+1);
            break;
        }
        TableTotal.PrintRow(0);                                                                                                                                                                       
        TableTotal.PrintColumns();          
      }
      
      Total.Text=string.Format(&quot;Итого масса нефтепродукта за сутки/на танкер* &lt;u&gt;{0}&lt;/u&gt; тонн.&quot;, DataIVK.TableMeasurementJornal.Data.Day != &quot;&quot; ? tools.GetNormalizedValue(DataIVK.TableMeasurementJornal.Data.Day) : &quot;-&quot;);
      
      TableTotal.PrintRow(0);                                                                                                                                                                       
      TableTotal.PrintColumns();          
    }
      
    public void  DrawTableSigners()
    {
      Dictionary&lt;string,string&gt; dictSignersFIO = new Dictionary&lt;string,string&gt; ();         
         
      if (DataIVK.TableMeasurementJornal.DataARM == null)
      {   
        dictSignersFIO.Add(&quot;DeliveryFIO1&quot;, &quot;&quot;);
        dictSignersFIO.Add(&quot;ReceiveFIO1&quot;, &quot;&quot;);
        dictSignersFIO.Add(&quot;DeliveryFIO2&quot;, &quot;&quot;);
        dictSignersFIO.Add(&quot;ReceiveFIO2&quot;, &quot;&quot;);
      }
      else
      {
        PropertyInfo[] props =  DataIVK.TableMeasurementJornal.DataARM.GetType().GetProperties();
        foreach (var prop in props)
        {
          dictSignersFIO.Add(prop.Name, prop.GetValue(DataIVK.TableMeasurementJornal.DataARM, null).ToString());
        }
      }
      DeliveryFIO1.Text = dictSignersFIO[&quot;DeliveryFIO1&quot;];
      ReceiveFIO1.Text = dictSignersFIO[&quot;ReceiveFIO1&quot;];
      DeliveryFIO2.Text = dictSignersFIO[&quot;DeliveryFIO2&quot;];
      ReceiveFIO2.Text = dictSignersFIO[&quot;ReceiveFIO2&quot;];       
    } 
      
    private void PageFooter_BeforeLayout(object sender, EventArgs e)
    {
      if((Int32)Report.GetVariableValue(&quot;TotalPages&quot;) &lt; 2) 
      { 
        PageFooter.Visible = false; 
      }
      else
      {
        PageNumeration.Width = (Page.PaperWidth-Page.LeftMargin-Page.RightMargin)*Units.Millimeters;
      }
    }
    
    public int FillTableWithData (int tempCounter, string date, List &lt;TN.Doc.Rows&gt; listTableJournal, out int tempCounterOut)
    {
      for (int j=0; j&lt;listTableJournal.Count; j++)                                                                                                                    
      {                                                                            
        Num.Text = tempCounter.ToString();
        Date.Text = date;  
        TankerName.Text = listTableJournal[j].TankerName;
        
        if (listTableJournal[j].strBegin.Length==19 &amp; listTableJournal[j].strEnd.Length==19 )
        {
          strBegin.Text = listTableJournal[j].strBegin.Remove(16).Remove(0,11);                               
          strEnd.Text = listTableJournal[j].strEnd.Remove(16).Remove(0,11);             
        }
        else
        {
          strBegin.Text = &quot;-&quot;;                                             
          strEnd.Text = &quot;-&quot;;                                                                                                                                            
        }
        
        BeginVol20.Text = tools.GetNormalizedValue(listTableJournal[j].SIKN[0].BeginVol20);                                     
        EndVol20.Text = tools.GetNormalizedValue(listTableJournal[j].SIKN[0].EndVol20);                 
        
        BeginMass.Text = tools.GetNormalizedValue(listTableJournal[j].SIKN[0].BeginMass);                
        EndMass.Text = tools.GetNormalizedValue(listTableJournal[j].SIKN[0].EndMass);           
        
        Vol20.Text = tools.GetNormalizedValue(listTableJournal[j].SIKN[0].Vol20);                        
        Mass.Text = tools.GetNormalizedValue(listTableJournal[j].SIKN[0].Mass);                  
        
        Temp.Text = tools.GetNormalizedValue(listTableJournal[j].SIKN[0].Temp);                    
        B_DensTemp.Text = tools.GetNormalizedValue(listTableJournal[j].BIK[0].DensTemp);   
        
        Press.Text = tools.GetNormalizedValue(listTableJournal[j].SIKN[0].Press);                     
        B_DensPress.Text = tools.GetNormalizedValue(listTableJournal[j].BIK[0].DensPress);     
        
        B_Dens.Text = tools.GetNormalizedValue(listTableJournal[j].BIK[0].Dens);           
        S_Dens.Text = tools.GetNormalizedValue(listTableJournal[j].SIKN[0].Dens);
        
        B_Dens20.Text = tools.GetNormalizedValue(listTableJournal[j].BIK[0].Dens20);
        B_Dens15.Text = tools.GetNormalizedValue(listTableJournal[j].BIK[0].Dens15);
        
        TableJournal.PrintRow(5);                                                                                                                                                                       
        TableJournal.PrintColumns();          
        
        tempCounter++;
      }
      
      tempCounterOut=tempCounter;
      
      return tempCounterOut;            
    } 
  }    
}

