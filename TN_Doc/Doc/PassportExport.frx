using TN.DocData;

namespace FastReport
{
  public class ReportScript
  {
    TN_ToolsFastReport.Tools tools = new TN_ToolsFastReport.Tools();    
    TN.Doc.Doc doc;
    TN.DocData.General General;
    TN.Doc.DataIVKDoc DataIVK;
    TN.Doc.HeaderDoc Header;
    TN.Doc.DataDoc SettingsData;
    TN.Doc.FooterDoc Footer;
    TN.Doc.DictionarysDoc Dictionarys;
    
    JObject json;
      
    private void Page_StartPage(object sender, EventArgs e)
    {
      //using (var sr = new StreamReader(&quot;D:/!_Work/!_Транснефть/SVN/Work/Sources/Reports/FRX/Входящие данные от Алексея (классы и json)/12_Passport/DocPassport.json&quot;))
      //{
      // Read the stream as a string
      //   Report.SetParameterValue(&quot;JsonDoc&quot;, sr.ReadToEnd());
      //}
      //// Десериализация данных (формат json) из входного параметра - Json                         
         
      string jsonDoc = (string)Report.GetParameterValue(&quot;JsonDoc&quot;);
      json = JObject.Parse(jsonDoc);      
        
      Newtonsoft.Json.JsonSerializerSettings settingsReport = new Newtonsoft.Json.JsonSerializerSettings();
      settingsReport.TypeNameHandling = TypeNameHandling.All;
         
      doc = JsonConvert.DeserializeObject&lt;TN.Doc.Doc&gt;(jsonDoc, settingsReport);
      General = (TN.DocData.General) doc.Doc.Settings.General;
      DataIVK = (TN.Doc.DataIVKDoc)doc.Doc.DataIVK;
      Header = (TN.Doc.HeaderDoc)doc.Doc.Settings.Header;
      SettingsData = (TN.Doc.DataDoc)doc.Doc.Settings.Data;
      Footer = (TN.Doc.FooterDoc)doc.Doc.Settings.Footer;
      Dictionarys = (TN.Doc.DictionarysDoc)doc.Doc.Settings.Dictionarys;
      
      //// === Настройки страницы 
      // Ширина и высота (в мм)
      Page.PaperHeight = General.PageSettings.PaperHeight;
      Page.PaperWidth = General.PageSettings.PaperWidth;
      //Page.Border.Lines = BorderLines.All;
         
      // Поля/отступы от краёв (в мм)
      Page.TopMargin = General.PageSettings.TopMargin;
      Page.BottomMargin = General.PageSettings.BottomMargin;
      Page.LeftMargin = General.PageSettings.LeftMargin;
      Page.RightMargin = General.PageSettings.RightMargin;
         
      // Запуск отрисовки таблиц на странице отчета
      DrawTableHeader();
      DrawTableMain();
      DrawTableSigners();
    }
      
    public void DrawTableHeader()
    {               
      DateTime Begin =  tools.UnixTimestampToDatetime((long)DataIVK.TablePassport.Begin);
      DateTime End =  tools.UnixTimestampToDatetime((long)DataIVK.TablePassport.End);
      
      NumberAndDatePassport.Text = string.Format(&quot;№ &lt;u&gt;{0}&lt;/u&gt; от &lt;u&gt;{1:dd.MM.yyyy}&lt;/u&gt; г.&quot;,
        DataIVK.TablePassport.PassportResult.PassportId, 
        Begin.ToShortDateString());

      DelivePoint.Text = DataIVK.TablePassport.AdditionalData.DelivePoint;
      Permit.Text = DataIVK.TablePassport.DataARM.ExportPermit;
      Sample.Text = DataIVK.TablePassport.DataARM.Sample;
      DataOfLoaded.Text = string.Format(&quot;{0:dd.MM.yyyy}&quot;, Begin.ToShortDateString());
      TankerName.Text = DataIVK.TablePassport.AdditionalData.TankerName;
      Gross.Text = DataIVK.TablePassport.TableActAndPassport.Act.Mass_Gross_Raw.Value.ToString();
    }

    public void  DrawTableMain()
    {
      //Filling &quot;method&quot; column rows with data
      Dens20Result_Desc.Text = DataIVK.TablePassport.TableActAndPassport.Passport.Dens20Result.Desc;
      Dens15Result_Desc.Text = DataIVK.TablePassport.TableActAndPassport.Passport.Dens15Result.Desc;
      MassWaterFracResult_Desc.Text = DataIVK.TablePassport.TableActAndPassport.Passport.MassWaterFracResult.Desc;
      Chloride_Salts_Concentration_Desc.Text = DataIVK.TablePassport.TableActAndPassport.Passport.Chloride_Salts.Concentration.Desc;
      Impurity_Desc.Text = DataIVK.TablePassport.TableActAndPassport.Passport.Impurity.Desc;
      SulfurResult_Desc.Text = DataIVK.TablePassport.TableActAndPassport.Passport.SulfurResult.Desc;
      DNP_kPa_Desc.Text = DataIVK.TablePassport.TableActAndPassport.Passport.DNP.kPa.Desc;
      Yield_fractions_Desc.Text =string.Format(&quot;&lt;br&gt;&lt;br&gt;{0}&lt;br&gt;{1}&quot;, 
        DataIVK.TablePassport.TableActAndPassport.Passport.Yield_fraction_200.Desc,
        DataIVK.TablePassport.TableActAndPassport.Passport.Yield_fraction_300.Desc,
        DataIVK.TablePassport.TableActAndPassport.Passport.Yield_fraction_350.Desc);
      Mass_fraction_of_paraffin_Desc.Text = DataIVK.TablePassport.TableActAndPassport.Passport.Mass_fraction_of_paraffin.Desc;
      Mass_fraction_of_hydrogen_sulfide_Desc.Text = DataIVK.TablePassport.TableActAndPassport.Passport.Mass_fraction_of_hydrogen_sulfide.Desc;
      Mass_fraction_of_methyl_and_ethyl_mercaptan_Desc.Text = DataIVK.TablePassport.TableActAndPassport.Passport.Mass_fraction_of_methyl_and_ethyl_mercaptan.Desc;
      Mass_fraction_of_organic_chlorides_Desc.Text = DataIVK.TablePassport.TableActAndPassport.Passport.Mass_fraction_of_organic_chlorides.Desc;
         
      //Filling &quot;result&quot; column rows with data
      Dens20Result.Text=tools.GetNormalizedValue(DataIVK.TablePassport.PassportResult.Dens20Result);
      Dens15Result.Text=tools.GetNormalizedValue(DataIVK.TablePassport.PassportResult.Dens15Result);
      MassWaterFracResult.Text =tools.GetNormalizedValue(DataIVK.TablePassport.PassportResult.MassWaterFracResult);
      Chloride_Salts_Concentration.Text =tools.GetNormalizedValue(DataIVK.TablePassport.PassportResult.Chloride_Salts.Concentration);
      Impurity.Text =tools.GetNormalizedValue(DataIVK.TablePassport.PassportResult.Impurity);
      SulfurResult.Text =tools.GetNormalizedValue(DataIVK.TablePassport.PassportResult.SulfurResult);
      DNP_kPa.Text =tools.GetNormalizedValue(DataIVK.TablePassport.PassportResult.DNP.kPa);
         
      Yield_fractions.Text =string.Format(&quot;&lt;br&gt;&lt;br&gt;{0}&lt;br&gt;{1}&quot;, 
        tools.GetNormalizedValue(DataIVK.TablePassport.PassportResult.Yield_fraction_200),
        tools.GetNormalizedValue(DataIVK.TablePassport.PassportResult.Yield_fraction_300),
        tools.GetNormalizedValue(DataIVK.TablePassport.PassportResult.Yield_fraction_350));
         
      Mass_fraction_of_paraffin.Text =tools.GetNormalizedValue(DataIVK.TablePassport.PassportResult.Mass_fraction_of_paraffin);
         
      Mass_fraction_of_hydrogen_sulfide.Text =tools.GetNormalizedValue(DataIVK.TablePassport.PassportResult.Mass_fraction_of_hydrogen_sulfide);
         
      Mass_fraction_of_methyl_and_ethyl_mercaptan.Text =tools.GetNormalizedValue(DataIVK.TablePassport.PassportResult.Mass_fraction_of_methyl_and_ethyl_mercaptan);
         
      Mass_fraction_of_organic_chlorides.Text =tools.GetNormalizedValue(DataIVK.TablePassport.PassportResult.Mass_fraction_of_organic_chlorides);
    }
      
    public void  DrawTableSigners()
    {     
      GOSTIndexResult.Text = string.Format(&quot;Обозначение нефти по ГОСТ Р 51858&lt;br&gt;/Classification according to GOST R 51858/&lt;br&gt;&lt;u&gt;{0}.ГОСТ Р 51858-2002&quot;, DataIVK.TablePassport.PassportResult.GostIndexResult.Replace('X','-'));
      Laboratory_IOF.Text = DataIVK.TablePassport.AdditionalData.Laboratory_IOF;
    }  
      
    private void PageFooter_BeforeLayout(object sender, EventArgs e)
    {
      if((Int32)Report.GetVariableValue(&quot;TotalPages&quot;) &lt; 2) 
      { 
        PageFooter.Visible = false; 
      }
      else
      {
        PageNumeration.Width = (Page.PaperWidth-Page.LeftMargin-Page.RightMargin)*Units.Millimeters;
      }
    }
  }    
}</ScriptText>
