        List &lt;TN.Doc.PointsTable4_2&gt; listPointsTable4_2;      
        listPointsTable4_2 = DataIVK.TablePoverka3151.Protokol.Table4_2.Points.Where(i =&gt; ! i.Point.Contains(&quot;-&quot;)   &amp; String.IsNullOrEmpty(i.Point) == false).ToList();
           
        var dictTable4_2Subrange =  typeof(TN.Doc.SubrangeTable4_2)
