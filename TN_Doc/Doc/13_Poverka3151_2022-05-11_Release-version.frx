          Q_j2.Text = tools.GetNormalizedValue(listPointsTable4_2[n].Q_j);                                                          
          KF_j2.Text =  tools.GetNormalizedValue(listPointsTable4_2[n].KF_j); 
          SKO_KF2.Text =  tools.GetNormalizedValue(dictTable4_2Subrange[&quot;SKO_KF&quot;]); 
          Delta_0_mas2.Text =  tools.GetNormalizedValue(dictTable4_2Subrange[&quot;Delta_0_mas&quot;]); 
          KF2.Text =  tools.GetNormalizedValue(dictTable4_2Subrange[&quot;KF&quot;]); 
          Teta_KF2.Text =  tools.GetNormalizedValue(dictTable4_2Subrange[&quot;Teta_KF&quot;]); 
          E2.Text =  tools.GetNormalizedValue(dictTable4_2Subrange[&quot;e&quot;]); 
          Teta_Sum2.Text =  tools.GetNormalizedValue(dictTable4_2Subrange[&quot;Teta_Sum&quot;]); 
          Delta2.Text =  tools.GetNormalizedValue(dictTable4_2Subrange[&quot;Delta&quot;]); 
                
          //RowsSpans
          for (int i = 0; i &lt; (Table4_2Results.ColumnCount); i++)
          {          
            switch(i)
            {
              case 3:  
              case 4:
              case 5:  
              case 6:     
              case 7:                                                                
