namespace FastReport
{
  public class ReportScript
  {
    TN_ToolsFastReport.Tools tools = new TN_ToolsFastReport.Tools();
    TN.Doc.Doc doc;
    TN.DocData.General General;
    TN.Doc.HeaderDoc Header;
    TN.Doc.DataDoc SettingsData;
    TN.Doc.FooterDoc Footer;
    TN.Doc.DictionarysDoc Dictionarys;
    TN.Doc.DataIVKDoc DataIVK;
      
    List &lt;TN.Doc.Table2&gt; listTable2Results;       

    private void Page_StartPage(object sender, EventArgs e)
    {
      //using (var sr = new StreamReader(&quot;D:/!_Work/!_Транснефть/SVN/Work/Sources/Reports/FRX/Входящие данные от Алексея (классы и json)/13_TablePoverka3151/DocPoverka3151.json&quot;))
      //{
      // Read the stream as a string
      //   Report.SetParameterValue(&quot;JsonDoc&quot;, sr.ReadToEnd());
      //}
         
      //// Десериализация данных (формат json) из входного параметра - Json                         
      string json = (string)Report.GetParameterValue(&quot;JsonDoc&quot;);
      Newtonsoft.Json.JsonSerializerSettings settings = new Newtonsoft.Json.JsonSerializerSettings();
      settings.TypeNameHandling = TypeNameHandling.All;
         
      doc = JsonConvert.DeserializeObject&lt;TN.Doc.Doc&gt;(json, settings);
      General = (TN.DocData.General) doc.Doc.Settings.General;
      Header = (TN.Doc.HeaderDoc) doc.Doc.Settings.Header;
      SettingsData = (TN.Doc.DataDoc) doc.Doc.Settings.Data;
      Footer = (TN.Doc.FooterDoc) doc.Doc.Settings.Footer;
      Dictionarys = (TN.Doc.DictionarysDoc) doc.Doc.Settings.Dictionarys;  
      DataIVK = (TN.Doc.DataIVKDoc) doc.Doc.DataIVK;
      
      //// === Настройки страницы 
      // Ширина и высота (в мм)
         
      Page.PaperHeight = General.PageSettings.PaperHeight;
      Page.PaperWidth = General.PageSettings.PaperWidth;
      //Page.Border.Lines = BorderLines.All;
         
      // Поля/отступы от краёв (в мм)
      Page.TopMargin = General.PageSettings.TopMargin;
      Page.BottomMargin = General.PageSettings.BottomMargin;
      Page.LeftMargin = General.PageSettings.LeftMargin;
      Page.RightMargin = General.PageSettings.RightMargin;
                                                                
      // Load Data from classes
      listTable2Results = DataIVK.TablePoverka3151.Protokol.Table2.Where(i =&gt; i.Activated==1).ToList();
         
      // Запуск отрисовки таблиц на странице отчета
      DrawTableHeader();    
      DrawTableConclusion();
    }
      
    public void DrawTableHeader()
    {
      //Setup Columns width
      TableHeader01.Columns[0].Width =  (Page.PaperWidth-Page.LeftMargin-Page.RightMargin)/Units.Millimeters;

      //Filling table with data   
      ProtokolNum.Text = string.Format( &quot;П Р О Т О К О Л № {0}&quot;, DataIVK.TablePoverka3151.AdditionalInfo.ProtokolNum); 
      PR_Type.Text = string.Format(&quot;поверки преобразователя массового расхода модели &lt;u&gt;{0}&lt;/u&gt; по МИ 3151-2008&quot;,  
        DataIVK.TablePoverka3151.AdditionalInfo.PR_Type); 
             
      Place_PSP.Text = DataIVK.TablePoverka3151.AdditionalInfo.Place_PSP;                                                       
      Place_Factory.Text = DataIVK.TablePoverka3151.AdditionalInfo.Place_Factory;    
      PR_Sensor_Type.Text = DataIVK.TablePoverka3151.AdditionalInfo.PR_Sensor_Type;    
      PR_Sensor_DU.Text = DataIVK.TablePoverka3151.AdditionalInfo.PR_Sensor_DU;
      PR_Sensor_FactoryNumber.Text = DataIVK.TablePoverka3151.AdditionalInfo.PR_Sensor_FactoryNumber;
      PR_PEP.Text = DataIVK.TablePoverka3151.AdditionalInfo.PR_PEP;
      PR_PEP_FactoryNumber.Text = DataIVK.TablePoverka3151.AdditionalInfo.PR_PEP_FactoryNumber;
      FieldSIKN.Text = DataIVK.TablePoverka3151.AdditionalInfo.SIKN;
      IL_Name.Text = DataIVK.TablePoverka3151.IL_Name;
      OilType.Text = DataIVK.TablePoverka3151.Protokol.OilType;
      PU_Name.Text = DataIVK.TablePoverka3151.AdditionalInfo.PU_Name;
      PU_Category.Text = DataIVK.TablePoverka3151.AdditionalInfo.PU_Category;
      PU_FactoryNumber.Text = DataIVK.TablePoverka3151.AdditionalInfo.PU_FactoryNumber;
      PU_CheckDate.Text = DataIVK.TablePoverka3151.AdditionalInfo.PU_CheckDate;
      PP_Name.Text = DataIVK.TablePoverka3151.AdditionalInfo.PP_Name;
      PP_FactoryNumber.Text = DataIVK.TablePoverka3151.AdditionalInfo.PP_FactoryNumber;               
      PP_CheckDate.Text = DataIVK.TablePoverka3151.AdditionalInfo.PP_CheckDate;        
    }
              
    private void Table1SourceData_ManualBuild(object sender, EventArgs e)
    {  
      List &lt;string&gt; listTable1Detectors = DataIVK.TablePoverka3151.Protokol.Table1.DetName.Where(i =&gt; i.Length &gt; 1 | ! i.Contains(&quot;&quot;)).ToList();
      List &lt;string&gt; listTable1V0 = DataIVK.TablePoverka3151.Protokol.Table1.V0.Where(i =&gt; /*! i.Contains(&quot;-&quot;)   &amp;*/ String.IsNullOrEmpty(i) == false).ToList();
         
      Dictionary&lt;string,string&gt; dictTable1SourceData = new Dictionary&lt;string,string&gt; ();
      foreach (var propertyInfo in DataIVK.TablePoverka3151.Protokol.Table1.GetType().GetProperties())
      {
        var propertyValue = propertyInfo.GetValue(DataIVK.TablePoverka3151.Protokol.Table1);
        if (propertyValue is string)
        {
          dictTable1SourceData.Add(propertyInfo.Name, propertyInfo.GetValue(DataIVK.TablePoverka3151.Protokol.Table1 , null).ToString());
        }
      }
         
      //Setup Columns width
  
      //Draw Fixed rows
      for (int n = 0; n &lt; Table1SourceData.FixedRows; n++)
      {
        Table1SourceData.PrintRow(n);
        Table1SourceData.PrintColumns();                                             
      }
         
      //Filling table with data
      for (int n = 0; n &lt; (listTable1Detectors.Count); n++)
      {
        DetName.Text =  listTable1Detectors[n];
        V0.Text =  tools.GetNormalizedValue(listTable1V0[n]);     
        Delta_PU.Text = tools.GetNormalizedValue(dictTable1SourceData[&quot;Delta_PU&quot;]);              
        m_D.Text = tools.GetNormalizedValue(dictTable1SourceData[&quot;m_D&quot;]);  
        m_S.Text = tools.GetNormalizedValue(dictTable1SourceData[&quot;m_S&quot;]);    
        m_E.Text = tools.GetNormalizedValue(dictTable1SourceData[&quot;m_E&quot;]);
        Alpha_t_PU.Text = tools.GetNormalizedValue(dictTable1SourceData[&quot;Alpha_t_PU&quot;]); 
        Delta_t_PU.Text = tools.GetNormalizedValue(dictTable1SourceData[&quot;Delta_t_PU&quot;]); 
        Delta_PP.Text = tools.GetNormalizedValue(dictTable1SourceData[&quot;Delta_PP&quot;]); 
        Delta_t_PP.Text = tools.GetNormalizedValue(dictTable1SourceData[&quot;Delta_t_PP&quot;]); 
        Delta_k_UOI.Text = tools.GetNormalizedValue(dictTable1SourceData[&quot;Delta_k_UOI&quot;]); 
        KF_konf.Text = tools.GetNormalizedValue(dictTable1SourceData[&quot;KF_konf&quot;]); 
        ZS.Text = tools.GetNormalizedValue(dictTable1SourceData[&quot;ZS&quot;]); 

        //RowsSpans
        for (int i = 0; i &lt; (Table1SourceData.ColumnCount); i++)
        {          
          switch(i)
          {
            case 2:
            case 3:  
            case 4:
            case 5:  
            case 6:     
            case 7:                                                                
            case 8:                                                                
            case 9:                                                            
            case 10:                                                          
            case 11:                                                          
            case 12:
              Table1SourceData[i,4].RowSpan =  listTable1Detectors.Count;
              break;  
          }
        }
        Table1SourceData.PrintRow(4);     
        Table1SourceData.PrintColumns();  
      }
    }
      
    private void Table2Results_ManualBuild(object sender, EventArgs e)
    {      
      for (int n = 0; n &lt; Table2Results.FixedRows; n++)
      {
        Table2Results.PrintRow(n);
        Table2Results.PrintColumns();                                             
      }
        
      //Filling table with data
      for (int n = 0; n &lt; (listTable2Results.Count); n++)
      {
        SerRow.Text =  String.Format(&quot;{0}/{1}&quot;, listTable2Results[n].Ser, listTable2Results[n].Row);
        Q_ji.Text = tools.GetNormalizedValue(listTable2Results[n].Q_ji);                   
        Det.Text =  tools.GetNormalizedValue(listTable2Results[n].Det);        
        T_ji.Text = tools.GetNormalizedValue(listTable2Results[n].T_ji);        
        t_PU_ji.Text = tools.GetNormalizedValue(listTable2Results[n].t_PU_ji); 
        P_PU_ji.Text = tools.GetNormalizedValue(listTable2Results[n].P_PU_ji);  
        Dens_ji.Text = tools.GetNormalizedValue(listTable2Results[n].Dens_ji);
        DensTemp_ji.Text =  tools.GetNormalizedValue(listTable2Results[n].DensTemp_ji);          
        DensPress_ji.Text =  tools.GetNormalizedValue(listTable2Results[n].DensPress_ji);          
        N_ji.Text =  tools.GetNormalizedValue(listTable2Results[n].N_ji);          
        V_PU_PR_ji.Text =  tools.GetNormalizedValue(listTable2Results[n].V_PU_PR_ji);          
        Dens_PP_PR_ji.Text =  tools.GetNormalizedValue(listTable2Results[n].Dens_PP_PR_ji);          

        Table2Results.PrintRow(5);     
        Table2Results.PrintColumns();  
      }
    }

    private void Table2ResultsEnding_ManualBuild(object sender, EventArgs e)
    {
      //Draw Fixed rows
      for (int n = 0; n &lt; Table2ResultsEnding.FixedRows; n++)
      {
        Table2ResultsEnding.PrintRow(n);
        Table2ResultsEnding.PrintColumns();                                             
      }
         
      //Filling table with data
      for (int n = 0; n &lt; (listTable2Results.Count); n++)
      {
        SerRow2.Text =  String.Format(&quot;{0}/{1}&quot;, listTable2Results[n].Ser, listTable2Results[n].Row);                      
        M_RA_ji.Text =  tools.GetNormalizedValue(listTable2Results[n].M_RA_ji);
        M_mas_ji.Text = tools.GetNormalizedValue(listTable2Results[n].M_mas_ji);
        MF_ji.Text = tools.GetNormalizedValue(listTable2Results[n].MF_ji);

        Table2ResultsEnding.PrintRow(4);     
        Table2ResultsEnding.PrintColumns();  
      }
    }
      
    private void Table3Results_ManualBuild(object sender, EventArgs e)
    { 
      List &lt;TN.Doc.Table3&gt; listTable3CoeffValue;
      listTable3CoeffValue = DataIVK.TablePoverka3151.Protokol.Table3.Where(i =&gt; ! i.t_P_n.Contains(&quot;-&quot;)   &amp; String.IsNullOrEmpty(i.t_P_n) == false).ToList();

      //Draw Fixed rows 
      for (int n = 0; n &lt; Table3Results.FixedRows; n++)
      {
        Table3Results.PrintRow(n);
        Table3Results.PrintColumns();                                             
      }
         
      //Filling table with data
      for (int n = 0; n &lt; (listTable3CoeffValue.Count); n++)
      {
        t_P_n.Text = tools.GetNormalizedValue(listTable3CoeffValue[n].t_P_n);
        Z_P.Text =  tools.GetNormalizedValue(listTable3CoeffValue[n].Z_P);           

        Table3Results.PrintRow(3);     
        Table3Results.PrintColumns();           
      } 
    }
      
    private void Table4_1Results_ManualBuild(object sender, EventArgs e)
    {
      if (DataIVK.TablePoverka3151.GH_Type == 1)
      {
        List &lt;TN.Doc.PointsTable4_1&gt; listPointsTable4_1;      
        listPointsTable4_1 = DataIVK.TablePoverka3151.Protokol.Table4_1.Points.Where(i =&gt; ! i.Point.Contains(&quot;-&quot;)   &amp; String.IsNullOrEmpty(i.Point) == false).ToList();

        var dictTable4_1Subrange =  typeof(TN.Doc.SubrangeTable4_1)
          .GetProperties()
          .ToDictionary(prop =&gt; prop.Name, prop =&gt; (string)prop.GetValue(DataIVK.TablePoverka3151.Protokol.Table4_1.Subrange , null));
            
        //Drawing Fixed rows
        for (int n = 0; n &lt; Table4_1Results.FixedRows; n++)                                                            
        {                                                                                                                    
          Table4_1Results.PrintRow(n);
          Table4_1Results.PrintColumns();                                             
        }
                  
        //Filling table with data                                                                             
        for (int n = 0; n &lt; (listPointsTable4_1.Count); n++)                                                 
        {                                                                                                                            
          Point.Text = listPointsTable4_1[n].Point;                                                                
          Q_j.Text = tools.GetNormalizedValue(listPointsTable4_1[n].Q_j);                                                          
          MF_j.Text =  tools.GetNormalizedValue(listPointsTable4_1[n].MF_j); 
          SKO_MF.Text =  tools.GetNormalizedValue(dictTable4_1Subrange[&quot;SKO_MF&quot;]); 
          Delta_0_mas.Text =  tools.GetNormalizedValue(dictTable4_1Subrange[&quot;Delta_0_mas&quot;]); 
          MF.Text =  tools.GetNormalizedValue(dictTable4_1Subrange[&quot;MF&quot;]); 
          K_GR.Text =  tools.GetNormalizedValue(dictTable4_1Subrange[&quot;K_GR&quot;]); 
          E.Text =  tools.GetNormalizedValue(dictTable4_1Subrange[&quot;e&quot;]); 
          Teta_Sum.Text =  tools.GetNormalizedValue(dictTable4_1Subrange[&quot;Teta_Sum&quot;]); 
          Delta.Text =  tools.GetNormalizedValue(dictTable4_1Subrange[&quot;Delta&quot;]); 
                
          //RowsSpans
          for (int i = 0; i &lt; (Table4_1Results.ColumnCount); i++)
          {          
            switch(i)
            {
              case 3:  
              case 4:
              case 5:  
              case 6:     
              case 7:                                                                
              case 8:                                                                
              case 9:                                                            
                Table4_1Results[i,3].RowSpan =  listPointsTable4_1.Count;
                break;  
            }
          }
          Table4_1Results.PrintRow(3);                                                     
          Table4_1Results.PrintColumns();                                                
        }                 
      }
    }               
      
