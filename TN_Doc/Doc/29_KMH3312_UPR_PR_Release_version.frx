using System;
using System.Reflection;
using System.Collections;
using System.Collections.Generic;
using System.ComponentModel;         
using System.Drawing;
using System.Data;
using System.IO;
using FastReport;
using FastReport.Data;
using FastReport.Dialog;
using FastReport.Barcode;
using FastReport.Table;
using FastReport.Utils;
using System.Linq;
using Newtonsoft.Json;
using TN.DocData;

namespace FastReport
{
  public class ReportScript
  {
    TN_ToolsFastReport.Tools tools = new TN_ToolsFastReport.Tools();  // классы отчета
    TN.Doc.Doc doc; // данные из входного параметра
    TN.DocData.General General;
    TN.Doc.HeaderDoc Header;
    TN.Doc.DataDoc SettingsData;
    TN.Doc.FooterDoc Footer;
    TN.Doc.DictionarysDoc Dictionarys;
    TN.Doc.DataIVKDoc DataIVK;  
      
    List &lt;TN.Doc.PRs_Info&gt; listPRs_Info;
      
    int tempCounter;
      
    private void Page_StartPage(object sender, EventArgs e)
    {
      //using (var sr = new StreamReader(&quot;D:/!_Work/!_Транснефть/SVN/Work/Sources/Reports/FRX/Входящие данные от Алексея (классы и json)/29_TableKMH3312_UPR_PR/DocKMH3312_UPR_PR.json&quot;))
      //{
      // Read the stream as a string
      //   Report.SetParameterValue(&quot;Protocol&quot;, sr.ReadToEnd());
      //}
         
      //// Десериализация данных (формат json) из входного параметра - Json                         
      string json = (string)Report.GetParameterValue(&quot;JsonDoc&quot;);
      Newtonsoft.Json.JsonSerializerSettings settings = new Newtonsoft.Json.JsonSerializerSettings();
      settings.TypeNameHandling = TypeNameHandling.All;
         
      doc = JsonConvert.DeserializeObject&lt;TN.Doc.Doc&gt;(json, settings);
      General = (TN.DocData.General) doc.Doc.Settings.General;
      Header = (TN.Doc.HeaderDoc) doc.Doc.Settings.Header;
      SettingsData = (TN.Doc.DataDoc) doc.Doc.Settings.Data;
      Footer = (TN.Doc.FooterDoc) doc.Doc.Settings.Footer;
      Dictionarys = (TN.Doc.DictionarysDoc) doc.Doc.Settings.Dictionarys;  
      DataIVK = (TN.Doc.DataIVKDoc) doc.Doc.DataIVK;  
      
      //// === Настройки страницы 
      // Ширина и высота (в мм)
         
      Page.PaperHeight = General.PageSettings.PaperHeight;
      Page.PaperWidth = General.PageSettings.PaperWidth;
      //Page.Border.Lines = BorderLines.All;
         
      // Поля/отступы от краёв (в мм)
      Page.TopMargin = General.PageSettings.TopMargin;
      Page.BottomMargin = General.PageSettings.BottomMargin;
      Page.LeftMargin = General.PageSettings.LeftMargin;
      Page.RightMargin = General.PageSettings.RightMargin;

      // Запуск отрисовки таблиц на странице отчета
      DrawTableHeader();
      DrawTableSourceData();
      //DrawTableResults(); 
      DrawTableConclusion();
    }
      
    public void DrawTableHeader()
    {
      listPRs_Info = DataIVK.TableKMH3312_UPR_PR.AdditionalInfo.PRs_Info.Where(i =&gt; ! i.PR_Type.Contains(&quot;-&quot;)  &amp; String.IsNullOrEmpty(i.PR_Type) == false).ToList();
      Nullable&lt;int&gt; z;
         
      if (listPRs_Info.Count == 0)
      listPRs_Info.Add(new TN.Doc.PRs_Info(){ PR_Type = &quot;&quot;, 
      PR_FactoryNumber = &quot;&quot;, 
      PR_LineName = &quot;&quot;, 
      MM_Sensor_Type = &quot;&quot;, 
      MM_Sensor_DU = &quot;&quot;, 
      MM_Sensor_FactoryNumber = &quot;&quot;, 
      MM_PEP = &quot;&quot;, 
      MM_PEP_FactoryNumber = &quot;&quot; });
      
      // Setup Columns (set widths of the current table columns as previous table columns)
      float widthDynamicCols=Page.PaperWidth-Page.LeftMargin-Page.RightMargin;
      for (int i = 0; i &lt; (TableHeader.ColumnCount); i++)                 
      {
        TableHeader.Columns[i].Width = TableHeader01.Columns[0].Width = TablePRs.Columns[0].Width=TableHeader02.Columns[0].Width=widthDynamicCols*Units.Millimeters;
      }
           
      // Fill cells with data   
      ProtocolType.Text = string.Format(&quot;Протокол № {0}&lt;br&gt;КМХ ПР РСУ по ПР основной схемы учета&quot;,
        DataIVK.TableKMH3312_UPR_PR.AdditionalInfo.ProtokolNum);
         
      UPR_Type.Text = string.Format(&quot;Тип узла РСУ: &lt;u&gt;{0}&quot;, 
        DataIVK.TableKMH3312_UPR_PR.AdditionalInfo.UPR_Type);
            
      PR_FactoryNumber.Text = string.Format(&quot;Заводской №: &lt;u&gt;{0}&quot;, 
        DataIVK.TableKMH3312_UPR_PR.AdditionalInfo.PRs_Info[0].PR_FactoryNumber);
         
      Place_SIKN.Text = string.Format(&quot;Место проведения КМХ: &lt;u&gt;СИКН№ {0}, {1}, {2} &lt;/u&gt; (СИКН, НГДУ, ПСП) Линия №&lt;u&gt;{3}&lt;/u&gt;&quot;, 
        DataIVK.TableKMH3312_UPR_PR.AdditionalInfo.Place_SIKN,
        DataIVK.TableKMH3312_UPR_PR.AdditionalInfo.Place_PSP,
        DataIVK.TableKMH3312_UPR_PR.AdditionalInfo.Place_Factory,
        DataIVK.TableKMH3312_UPR_PR.AdditionalInfo.PRs_Info[0].PR_LineName);
         
      #region // Add rows into TablePRs if number of the PR &gt; 1
        
      switch(listPRs_Info.Count)
      {
        case 1:
          z=null;
          break;  
            
        default:
          // Add need number of rows for 
          z=0;
          if (Engine.FirstPass == true)
          {
            int rows;
            for (rows = 0; rows &lt; (listPRs_Info.Count-1); rows++)                 
            {
              TableRow row = new TableRow(); 
              TablePRs.Rows.Add(row);
              TablePRs[0, (rows+1)].AssignAll(TablePRs[0, 0]);
            }      
          }
          break;
      }
      #endregion
         
      // Fill cells of the TablePRs with data from json
      for (int i=0; i &lt;listPRs_Info.Count ; i++)
      {
        TablePRs[0,i].Text=string.Format(&quot;ПР{3}: Тип &lt;u&gt;{0}&lt;/u&gt; Зав. № &lt;u&gt;{1}&lt;/u&gt; Линия № &lt;u&gt;{2}&lt;/u&gt;&quot;, 
          listPRs_Info[i].PR_Type, 
          listPRs_Info[i].PR_FactoryNumber,
          listPRs_Info[i].PR_LineName,
          (z+1));
        z++;     
      }
         
      IVK_Type.Text = string.Format(&quot;ИВК: Тип &lt;u&gt;{0}&lt;/u&gt; Зав. № &lt;u&gt;{1}&quot;, 
        DataIVK.TableKMH3312_UPR_PR.AdditionalInfo.IVK_Type,
        DataIVK.TableKMH3312_UPR_PR.AdditionalInfo.IVK_FactoryNumber);
         
      OilType.Text = string.Format(&quot;Рабочая жидкость: &lt;u&gt;{0}&lt;/u&gt; Вязкость, мм&lt;sup&gt;2&lt;/sup&gt;/с &lt;u&gt;{1}&quot;, 
        DataIVK.TableKMH3312_UPR_PR.Protokol.OilType,
        DataIVK.TableKMH3312_UPR_PR.Protokol.KinimVisc_middle);
      }
               
    private void DrawTableSourceData()
    {
      List &lt;string&gt; listPointsQ = DataIVK.TableKMH3312_UPR_PR.Protokol.Table1.Q.Where(i =&gt; ! i.Contains(&quot;-&quot;) &amp; i.Length  &gt; 0).ToList();
      tempCounter = listPointsQ.Count;

      if (Engine.FinalPass == true)
      {
        ////=== Insert Columns for Flow Points  (Q0) &amp; fill them headers with text
        for (int i=0; i &lt;listPointsQ.Count ; i++)
        {
          TableColumn column = new TableColumn();  
          TableSourceData.Columns.Insert(0,column);
               
          for (int j=0;j&lt;TableSourceData.RowCount;j++)
          {
            TableSourceData[0,j].AssignAll(TableSourceData[1,j]);
          }

          TableSourceData[0,2].Text=String.Format(&quot;Q&lt;sub&gt; {0}&lt;/sub&gt;,&lt;br&gt;(f/v)&lt;sub&gt; {1}&lt;/sub&gt;&quot;, tempCounter, tempCounter);
          tempCounter--;
        }
            
        TableSourceData[0,1].Text=&quot;Точки расходов (м&lt;sup&gt;3&lt;/sup&gt;/ч) или &lt;i&gt;f/v&lt;/i&gt; (Гц/сСт) для ПР&quot;;
            
        //// Span Columns
        TableSourceData[0,0].ColSpan=TableSourceData.ColumnCount;
        TableSourceData[0,1].ColSpan=listPointsQ.Count;
        TableSourceData[(listPointsQ.Count),1].ColSpan=3;

        // Setup Columns         
        int sumDynamicCols=TableSourceData.ColumnCount;
        float widthDynamicCol=(Page.PaperWidth-Page.LeftMargin-Page.RightMargin)/sumDynamicCols;                  

        // Set the width of the columns depending on the number of columns
        if (TableSourceData.ColumnCount &lt;10)
        {
          widthDynamicCol = (widthDynamicCol*(float)0.6);
        }
            
        for (int w = 0; w &lt; (TableSourceData.ColumnCount); w++)                 
        {
          TableSourceData.Columns[w].Width = widthDynamicCol * Units.Millimeters;
        }
            
        //Fill Columns headers numeration
        for (int i = 0; i &lt; TableSourceData.ColumnCount; i++)
        {
          TableSourceData[i,3].Text = (i+1).ToString();
        }     
            
        //// Fill data for Q points
        for (int j = 0; j &lt; listPointsQ.Count; j++)
        {
          TableSourceData[j,4].Text = tools.GetNormalizedValue(listPointsQ[j]);
        }     
      }
    }      
                                        
    private void TableResults_ManualBuild(object sender, EventArgs e)
    {
      List &lt;TN.Doc.Table2&gt; listTable2Results;
      List &lt;TN.Doc.Table3&gt; listTable3Results;
      List &lt;TN.Doc.Table4&gt; listTable4Results;
         
      listTable2Results = DataIVK.TableKMH3312_UPR_PR.Protokol.Table2.Where(i =&gt; ! i.Ser.Contains(&quot;-&quot;) &amp; String.IsNullOrEmpty(i.Ser) == false).ToList();
      listTable3Results = DataIVK.TableKMH3312_UPR_PR.Protokol.Table3.Where(i =&gt; ! i.Ser.Contains(&quot;-&quot;) &amp; String.IsNullOrEmpty(i.Ser) == false).ToList();
      listTable4Results = DataIVK.TableKMH3312_UPR_PR.Protokol.Table4.Where(i =&gt; ! i.Point.Contains(&quot;-&quot;) &amp; String.IsNullOrEmpty(i.Point) == false).ToList();

      List &lt;int&gt; listPointsRows = new List &lt;int&gt;();

      //Setup Columns width
      int sumDynamicCols=TableResults.ColumnCount;
      float widthDynamicCol=(Page.PaperWidth-Page.LeftMargin-Page.RightMargin)/sumDynamicCols;                  
      for (int w = 0; w &lt; (TableResults.ColumnCount); w++)                 
      {
        TableResults.Columns[w].Width = widthDynamicCol * Units.Millimeters;
      }      
         
      //Draw Fixed rows
      for (int n = 0; n &lt; TableResults.FixedRows; n++)
      {
        TableResults.PrintRow(n);
        TableResults.PrintColumns();                                             
      }

      //Calculate Points &amp; Rows to List &lt;int&gt; 
      if (Engine.FinalPass == true)
      {
        int counterRows = 0;
        for (int n = 0; n &lt; (listTable2Results.Count); n++)
        {
          counterRows = (from x in listTable2Results where x.Ser == (n+1).ToString() select x).Count();
          //MessageBox.Show(&quot;counterRows - &quot; + counterRows.ToString()+ &quot; | n - &quot; + n.ToString());
          if (counterRows != 0)
          {
            listPointsRows.Add(counterRows);
          }
        }
      }
         
      //Fill table with data
      tempCounter = 0;
      for (int n = 0; n &lt; (listPointsRows.Count); n++)
      {
        for (int z = 0; z &lt; (listPointsRows[n]); z++)
        {                   
          Ser.Text = listTable2Results[tempCounter].Ser;
          Row.Text = listTable2Results[tempCounter].Row;
          PR.Text = listTable2Results[tempCounter].PR;
          Q_ji.Text = tools.GetNormalizedValue(listTable3Results[tempCounter].Q_ji);
          f_ji.Text = tools.GetNormalizedValue(listTable3Results[tempCounter].f_ji);
          t_PR_jik.Text = tools.GetNormalizedValue(listTable2Results[tempCounter].t_PR_jik);
          P_PR_jik.Text = tools.GetNormalizedValue(listTable2Results[tempCounter].P_PR_jik);
          t_UPR_ji.Text = tools.GetNormalizedValue(listTable3Results[tempCounter].t_UPR_ji);
          P_UPR_ji.Text = tools.GetNormalizedValue(listTable3Results[tempCounter].P_UPR_ji);
          k_tp_ji.Text = tools.GetNormalizedValue(listTable3Results[tempCounter].k_tp_ji);
          N_ji.Text = tools.GetNormalizedValue(listTable3Results[tempCounter].N_ji);
          N_jik.Text = tools.GetNormalizedValue(listTable2Results[tempCounter].N_jik);
          K_ji.Text = tools.GetNormalizedValue(listTable3Results[tempCounter].K_ji);
          K_j.Text = tools.GetNormalizedValue(listTable4Results[n].K_j);
          K_rasch_j.Text = tools.GetNormalizedValue(listTable4Results[n].K_rasch_j);
          Delta_KMH_j.Text = tools.GetNormalizedValue(listTable4Results[n].Delta_KMH_j);
           
          //Span Rows
          TableResults[13,4].RowSpan = TableResults[14,4].RowSpan =TableResults[15,4].RowSpan = listPointsRows[n]; 
               
          TableResults.PrintRow(4);     
          TableResults.PrintColumns();  
          tempCounter++;
        }  
      }
    }
    
    public void  DrawTableConclusion()
    {
      //// ===  Fill table with data
      Conclusion.Text = string.Format(&quot;&lt;b&gt;3 Заключение: δ &lt;sub&gt;j mах &lt;/sub&gt; = {0}%. {1}&quot;,                                                     
        tools.GetNormalizedValue(DataIVK.TableKMH3312_UPR_PR.Protokol.Delta_max),                                        
        DataIVK.TableKMH3312_UPR_PR.AdditionalInfo.ARM_Poverka_Result);                                       
         
      DateTimeLong.Text = string.Format(&quot;Дата проведения КМХ: &lt;u&gt;{0:dd.MM.yyyy} г.&quot;,
        tools.UnixTimestampToDatetime(DataIVK.TableKMH3312_UPR_PR.DateTimeLong));               
         
      ServiceStaffData.Text = DataIVK.TableKMH3312_UPR_PR.AdditionalInfo.ServiceStaffData;     
      DeliveryStaffData.Text = DataIVK.TableKMH3312_UPR_PR.AdditionalInfo.DeliveryStaffData;                
      RecievingStaffData.Text = DataIVK.TableKMH3312_UPR_PR.AdditionalInfo.RecievingStaffData;   
    }  

    private void PageFooter_BeforeLayout(object sender, EventArgs e)
    {
      if((Int32)Report.GetVariableValue(&quot;TotalPages&quot;) &lt; 2) 
      { 
        PageFooter.Visible = false; 
      }
      else
      {
        PageNumeration.Width = (Page.PaperWidth-Page.LeftMargin-Page.RightMargin)*Units.Millimeters;
      }
    }
  }    
}

