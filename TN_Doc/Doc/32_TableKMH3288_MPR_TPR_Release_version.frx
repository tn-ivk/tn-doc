        delta_ji_4.Text = tools.GetNormalizedValue(listTable4Results[n].delta_ji);
            
        //RowSpans
        for (int i = 0; i &lt; (Table4Results.ColumnCount); i++)
        {          
          switch(i)
          {
            case 14:
            case 15:  
            case 16:
              Table4Results[i,3].RowSpan =  listTable4Results.Count;
              break;  
          }
        }
        Table4Results.PrintRow(3);     
        Table4Results.PrintColumns();  
      }  
    }

    public void  DrawTableConclusion()
    {                                                    
      // Fill Table with data
      Conclusion.Text =string.Format(&quot;&lt;b&gt;5. Заключение: δ &lt;sub&gt; mах &lt;/sub&gt; = {0}%. {1}&quot;,                                                     
        tools.GetNormalizedValue(DataIVK.TableKMH3288_MPR_TPR.Protokol_MPR.delta_max),                                        
        DataIVK.TableKMH3288_MPR_TPR.AdditionalInfo_MPR.ARM_KMH_Result);                                       

      DateTimeLong.Text = string.Format(&quot;Дата: &lt;u&gt;{0:dd.MM.yyyy} г.&quot;,
        (tools.UnixTimestampToDatetime(DataIVK.TableKMH3288_MPR_TPR.DateTimeLong)));               
         
      ServiceStaffData.Text = DataIVK.TableKMH3288_MPR_TPR.AdditionalInfo_MPR.ARM_ServiceStaffData;     
      DeliveryStaffData.Text = DataIVK.TableKMH3288_MPR_TPR.AdditionalInfo_MPR.ARM_DeliveryStaffData;                
      RecievingStaffData.Text = DataIVK.TableKMH3288_MPR_TPR.AdditionalInfo_MPR.ARM_RecievingStaffData;              
      PageNumeration.Width = (Page.PaperWidth-Page.LeftMargin-Page.RightMargin)*Units.Millimeters; 
    }  
      
    //// Setup heights of the all objects on the Page
    private void PageFooter_BeforeLayout(object sender, EventArgs e)
    {
      if((Int32)Report.GetVariableValue(&quot;TotalPages&quot;) &lt; 2) 
      { 
        PageFooter.Visible = false; 
      }
      else
      {
        PageNumeration.Width = (Page.PaperWidth-Page.LeftMargin-Page.RightMargin)*Units.Millimeters;
      }
    }
  }    
}

