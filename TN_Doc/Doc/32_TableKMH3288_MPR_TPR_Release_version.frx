  public class ReportScript
  {
    TN_ToolsFastReport.Tools tools = new TN_ToolsFastReport.Tools();  // классы отчета
    TN.Doc.Doc doc; // данные из входного параметра
    TN.DocData.General General;
    TN.Doc.HeaderDoc Header;
    TN.Doc.DataDoc SettingsData;
    TN.Doc.FooterDoc Footer;
    TN.Doc.DictionarysDoc Dictionarys;
    TN.Doc.DataIVKDoc DataIVK;
    
    private void Page_StartPage(object sender, EventArgs e)
    {
      
      //using (var sr = new StreamReader(&quot;D:/!_Work/!_Транснефть/SVN/Work/Sources/Reports/FRX/Входящие данные от Алексея (классы и json)/32_TableKMH3288_MPR_TPR/DocKMH3288_MPR_TPR.json&quot;))
      //{
      // Read the stream as a string
      //   Report.SetParameterValue(&quot;JsonDoc&quot;, sr.ReadToEnd());
      //}
         
      //// Десериализация данных (формат json) из входного параметра - Json                         
      string json = (string)Report.GetParameterValue(&quot;JsonDoc&quot;);
      Newtonsoft.Json.JsonSerializerSettings settings = new Newtonsoft.Json.JsonSerializerSettings();
      settings.TypeNameHandling = TypeNameHandling.All;
         
      doc = JsonConvert.DeserializeObject&lt;TN.Doc.Doc&gt;(json, settings);
      General = (TN.DocData.General) doc.Doc.Settings.General;
      Header = (TN.Doc.HeaderDoc) doc.Doc.Settings.Header;
      SettingsData = (TN.Doc.DataDoc) doc.Doc.Settings.Data;
      Footer = (TN.Doc.FooterDoc) doc.Doc.Settings.Footer;
      Dictionarys = (TN.Doc.DictionarysDoc) doc.Doc.Settings.Dictionarys;  
      DataIVK = (TN.Doc.DataIVKDoc) doc.Doc.DataIVK;         
     
      //// === Настройки страницы 
      // Ширина и высота (в мм)
      Page.PaperHeight = General.PageSettings.PaperHeight;
      Page.PaperWidth = General.PageSettings.PaperWidth;
      //Page.Border.Lines = BorderLines.All;

      // Поля/отступы от краёв (в мм)
      Page.TopMargin = General.PageSettings.TopMargin;
      Page.BottomMargin = General.PageSettings.BottomMargin;
      Page.LeftMargin = General.PageSettings.LeftMargin;
      Page.RightMargin = General.PageSettings.RightMargin;

      // Запуск отрисовки таблиц на странице отчета
      DrawTableHeader();    
      DrawTableConclusion();        
    }
    #region //Имхо лишний метод
    private void PrintTable(TableObject table)
    {
      for (int i=0;i&lt;table.RowCount;i++)
      {       
        table.PrintRow(i);
        table.PrintColumns();
      }    
    } 
    #endregion
      
    public void DrawTableHeader()
    {
      //Setup Columns width
      TableHeader01.Columns[0].Width = (Page.PaperWidth-Page.LeftMargin-Page.RightMargin)*Units.Millimeters;
         
      // Fill table with data   
      ProtokolNum.Text = &quot;П Р О Т О К О Л  № &quot;  +  DataIVK.TableKMH3288_MPR_TPR.AdditionalInfo_MPR.ProtokolNum;
      Place_SIKN_Name.Text = string.Format(&quot;СИКН №{0}, {1}, {2}&quot;, 
        DataIVK.TableKMH3288_MPR_TPR.AdditionalInfo_MPR.Place_SIKN_Name, 
        DataIVK.TableKMH3288_MPR_TPR.AdditionalInfo_MPR.Place_PSP,
        DataIVK.TableKMH3288_MPR_TPR.AdditionalInfo_MPR.Place_Factory);
      MPR_Sensor_Type.Text = DataIVK.TableKMH3288_MPR_TPR.AdditionalInfo_MPR.MPR_Sensor_Type;
      MPR_Sensor_FactoryNumber.Text = DataIVK.TableKMH3288_MPR_TPR.AdditionalInfo_MPR.MPR_Sensor_FactoryNumber;
      MPR_LineName.Text = DataIVK.TableKMH3288_MPR_TPR.AdditionalInfo_MPR.LineName;
         
      MPR_PEP_Type.Text = DataIVK.TableKMH3288_MPR_TPR.AdditionalInfo_MPR.MPR_PEP_Type;
      MPR_PEP_FactoryNumber.Text = DataIVK.TableKMH3288_MPR_TPR.AdditionalInfo_MPR.MPR_PEP_FactoryNumber;
      MPR_CP_Type.Text = DataIVK.TableKMH3288_MPR_TPR.AdditionalInfo_MPR.CP_Type;
      MPR_CP_FactoryNumber.Text = DataIVK.TableKMH3288_MPR_TPR.AdditionalInfo_MPR.CP_FactoryNumber;
      MPR_PP_Type.Text = DataIVK.TableKMH3288_MPR_TPR.AdditionalInfo_MPR.PP_Type;
      MPR_PP_FactoryNumber.Text = DataIVK.TableKMH3288_MPR_TPR.AdditionalInfo_MPR.PP_FactoryNumber;
      MPR_PR_Type.Text = DataIVK.TableKMH3288_MPR_TPR.AdditionalInfo_MPR.PR_Type;
      MPR_PR_FactoryNumber.Text = DataIVK.TableKMH3288_MPR_TPR.AdditionalInfo_MPR.PR_FactoryNumber;
         
      MPR_IVK_Type.Text = DataIVK.TableKMH3288_MPR_TPR.AdditionalInfo_MPR.IVK_Type;
      MPR_IVK_FactoryNumber.Text = DataIVK.TableKMH3288_MPR_TPR.AdditionalInfo_MPR.IVK_FactoryNumber;
      MPR_OilType.Text = DataIVK.TableKMH3288_MPR_TPR.Protokol_MPR.OilType;
    }
              
    private void Table1SourceData_ManualBuild(object sender, EventArgs e)
    {
      List &lt;TN.Doc.Table1MPR&gt; listTable1Results;
      listTable1Results = DataIVK.TableKMH3288_MPR_TPR.Protokol_MPR.Table1.Where(i =&gt; i.DetName.Length &gt; 1 &amp; String.IsNullOrEmpty(i.DetName) == false).ToList();
      
      //Setup Columns width
      int sumDynamicCols=Table1SourceData.ColumnCount;
      float widthDynamicCol=(Page.PaperWidth-Page.LeftMargin-Page.RightMargin)/sumDynamicCols;                  
 
      for (int w = 0; w &lt; (Table1SourceData.ColumnCount); w++)                 
      {
        Table1SourceData.Columns[w].Width = widthDynamicCol * Units.Millimeters;
      }      
                            
      //Draw Fixed rows
      for (int n = 0; n &lt; Table1SourceData.FixedRows; n++)
      {
        Table1SourceData.PrintRow(n);
        Table1SourceData.PrintColumns();                                             
      }
                                                     
      //Fill table with data
      for (int n = 0; n &lt; (listTable1Results.Count); n++)
      {
        V0.Text =  tools.GetNormalizedValue(listTable1Results[n].V0);        
        m_D.Text = tools.GetNormalizedValue(listTable1Results[n].m_D);
        m_S.Text = tools.GetNormalizedValue(listTable1Results[n].m_S);
        m_E.Text = tools.GetNormalizedValue(listTable1Results[n].m_E);
        Alpha_k1.Text = tools.GetNormalizedValue(listTable1Results[n].Alpha_k1);
        Alpha_D.Text = tools.GetNormalizedValue(listTable1Results[n].Alpha_D);
        Teta_Sum_0.Text = tools.GetNormalizedValue(listTable1Results[n].Teta_Sum_0);
        Teta_V_0.Text = tools.GetNormalizedValue(listTable1Results[n].Teta_V_0);
        Delta_t_PU.Text = tools.GetNormalizedValue(listTable1Results[n].Delta_t_PU);
        Delta_t_PP.Text = tools.GetNormalizedValue(listTable1Results[n].Delta_t_PP);
        Delta_PP.Text = tools.GetNormalizedValue(listTable1Results[n].Delta_PP);
        Delta_t_PR.Text = tools.GetNormalizedValue(listTable1Results[n].Delta_t_PR);
        delta_PR.Text = tools.GetNormalizedValue(listTable1Results[n].delta_PR);
        delta_IVK.Text = tools.GetNormalizedValue(listTable1Results[n].delta_IVK);
        K_PM_ust.Text = tools.GetNormalizedValue(listTable1Results[n].K_PM_ust);
        ZS.Text = tools.GetNormalizedValue(listTable1Results[n].ZS);
                         
        //RowSpans
        for (int i = 0; i &lt; (Table1SourceData.ColumnCount); i++)
        {          
          switch(i)
          {
            case 6:
            case 7:  
              Table1SourceData[i,3].RowSpan =  listTable1Results.Count;
              break;  
          }
        }
                             
        Table1SourceData.PrintRow(3);     
        Table1SourceData.PrintColumns();  
      } 
    }

    private void Table2Results_ManualBuild(object sender, EventArgs e)
    { 
      List &lt;TN.Doc.Table2MPR&gt; listTable2Results;
      listTable2Results = DataIVK.TableKMH3288_MPR_TPR.Protokol_MPR.Table2.Where(i =&gt; i.Activated != 0 &amp; i.Activated != null).ToList();

         
      //Setup Columns width
      int sumDynamicCols=Table2Results.ColumnCount;
      float widthDynamicCol=(Page.PaperWidth-Page.LeftMargin-Page.RightMargin)/sumDynamicCols;                  
      for (int w = 0; w &lt; (Table2Results.ColumnCount); w++)                 
      {
        Table2Results.Columns[w].Width = widthDynamicCol * Units.Millimeters;
      }      
         
      //Draw Fixed rows
      for (int n = 0; n &lt; Table2Results.FixedRows; n++)
      {
        Table2Results.PrintRow(n);
        Table2Results.PrintColumns();                                             
      }
          
      //Fill table with data
      for (int n = 0; n &lt; (listTable2Results.Count); n++)
      {
        SerRow_2.Text = String.Format(&quot;{0}/{1}&quot;, listTable2Results[n].Ser, listTable2Results[n].Row);
        Q_ji_2.Text = tools.GetNormalizedValue(listTable2Results[n].Q_ji);
        T_ji_2.Text = tools.GetNormalizedValue(listTable2Results[n].T_ji);
        t_PU_ji_2.Text = tools.GetNormalizedValue(listTable2Results[n].t_PU_ji);
        P_PU_ji_2.Text = tools.GetNormalizedValue(listTable2Results[n].P_PU_ji);
        t_D_ji_2.Text = tools.GetNormalizedValue(listTable2Results[n].t_D_ji);
        Dens_PP_ji_2.Text = tools.GetNormalizedValue(listTable2Results[n].Dens_PP_ji);
        DensTemp_ji_2.Text = tools.GetNormalizedValue(listTable2Results[n].DensTemp_ji);
        DensPress_ji_2.Text = tools.GetNormalizedValue(listTable2Results[n].DensPress_ji);
        Beta_ji_2.Text = tools.GetNormalizedValue(listTable2Results[n].Beta_ji);
        t_PR_ji_2.Text = tools.GetNormalizedValue(listTable2Results[n].t_PR_ji);
        P_PR_ji_2.Text = tools.GetNormalizedValue(listTable2Results[n].P_PR_ji);
        N_ji_2.Text = tools.GetNormalizedValue(listTable2Results[n].N_ji);
        K_PR_ji_2.Text = tools.GetNormalizedValue(listTable2Results[n].K_PR_ji);
            
        Table2Results.PrintRow(3);     
        Table2Results.PrintColumns();  
      }  
    }
      
    private void Table3Results_ManualBuild(object sender, EventArgs e)
    {  
      List &lt;TN.Doc.Table3MPR&gt; listTable3Results;
      listTable3Results = DataIVK.TableKMH3288_MPR_TPR.Protokol_MPR.Table3.Where(i =&gt; i.Activated != 0 &amp; i.Activated != null).ToList();
      
      //Setup Columns width
      int sumDynamicCols=Table3Results.ColumnCount;
      float widthDynamicCol=(Page.PaperWidth-Page.LeftMargin-Page.RightMargin)/sumDynamicCols;                  
      for (int w = 0; w &lt; (Table3Results.ColumnCount); w++)                 
      {
        Table3Results.Columns[w].Width = widthDynamicCol * Units.Millimeters;
      }      
         
      //Draw Fixed rows 
      for (int n = 0; n &lt; Table3Results.FixedRows; n++)
      {
        Table3Results.PrintRow(n);
        Table3Results.PrintColumns();                                             
      }
             
      //Fill table with data
      for (int n = 0; n &lt; (listTable3Results.Count); n++)
      {
        Point.Text =  listTable3Results[n].Point;
        Q_j.Text = tools.GetNormalizedValue(listTable3Results[n].Q_j);
        K_PR_j.Text = tools.GetNormalizedValue(listTable3Results[n].K_PR_j);
        S_j.Text =tools.GetNormalizedValue( listTable3Results[n].S_j);
        n_j.Text = tools.GetNormalizedValue(listTable3Results[n].n_j);
        S_0_j.Text = tools.GetNormalizedValue(listTable3Results[n].S_0_j);
        t_095_j.Text = tools.GetNormalizedValue(listTable3Results[n].t_095_j);
        Epsilon_j.Text =  tools.GetNormalizedValue(listTable3Results[n].Epsilon_j);
        delta_PR_j.Text =  tools.GetNormalizedValue(listTable3Results[n].delta_PR_j);
           
        Table3Results.PrintRow(3);     
        Table3Results.PrintColumns();  
      } 
    }
      
    private void Table4Results_ManualBuild(object sender, EventArgs e)
    {       
      List &lt;TN.Doc.Table4&gt; listTable4Results;
      listTable4Results = DataIVK.TableKMH3288_MPR_TPR.Protokol_MPR.Table4.Where(i =&gt; i.Activated != 0 &amp; i.Activated != null).ToList();
      
      //Setup Columns width
      int sumDynamicCols=Table4Results.ColumnCount;
