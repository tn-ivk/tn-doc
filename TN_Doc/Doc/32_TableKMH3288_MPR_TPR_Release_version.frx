      //Draw Fixed rows
      for (int n = 0; n &lt; Table4Results.FixedRows; n++)
      {
        Table4Results.PrintRow(n);
        Table4Results.PrintColumns();                                             
      }                   
         
      //Fill table with data
      for (int n = 0; n &lt; (listTable4Results.Count); n++)
      {
        SerRow_4.Text =  String.Format(&quot;{0}/{1}&quot;, listTable4Results[n].Ser, listTable4Results[n].Row);
        Q_ji_4.Text = tools.GetNormalizedValue(listTable4Results[n].Q_ji);
        T_ji_4.Text = tools.GetNormalizedValue(listTable4Results[n].T_ji);
        Q_PR_ji_4.Text = tools.GetNormalizedValue(listTable4Results[n].Q_PR_ji);
        t_PR_ji_4.Text =  tools.GetNormalizedValue(listTable4Results[n].t_PR_ji);
        P_PR_ji_4.Text =  tools.GetNormalizedValue(listTable4Results[n].P_PR_ji);
        K_PR_ji_4.Text =  tools.GetNormalizedValue(listTable4Results[n].K_PR_ji);
        N_PR_ji_4.Text =  tools.GetNormalizedValue(listTable4Results[n].N_PR_ji);
        Dens_PP_ji_4.Text = tools.GetNormalizedValue(listTable4Results[n].Dens_PP_ji);
        DensTemp_ji_4.Text =  tools.GetNormalizedValue(listTable4Results[n].DensTemp_ji);
        DensPress_ji_4.Text =  tools.GetNormalizedValue(listTable4Results[n].DensPress_ji);
        Dens_pr_ji_4.Text =  tools.GetNormalizedValue(listTable4Results[n].Dens_pr_ji);
