  <ScriptText>using System;

using System.Collections.Generic;
using System.Linq;
using FastReport;
using FastReport.Data;
using FastReport.Dialog;
using FastReport.Barcode;
using FastReport.Table;  
using FastReport.Utils;
using Newtonsoft.Json.Linq;

namespace FastReport
{
  //Скрипт формирования отчёта
  public class ReportScript
  {
    JToken JDoc;
    JToken JSettings;    
    JToken JProtokol;
    JToken JAdditionalInfo;

    //Инициализации страницы отчёта
    private void Page_StartPage(object sender, EventArgs e)
    {
      JDoc = JToken.Parse(Report.GetParameterValue(&quot;JsonDoc&quot;).ToString());
      
      JSettings = JDoc[&quot;Doc&quot;][&quot;Settings&quot;];
      JProtokol = JDoc[&quot;Doc&quot;][&quot;DataIVK&quot;][&quot;TablePoverka3266&quot;][&quot;Protokol&quot;];
      JAdditionalInfo = JDoc[&quot;Doc&quot;][&quot;DataIVK&quot;][&quot;TablePoverka3266&quot;][&quot;AdditionalInfo&quot;];
      
      //Настройки страницы 
      //Ширина и высота (в мм)
      Page.PaperHeight = (int)JSettings[&quot;General&quot;][&quot;PageSettings&quot;][&quot;PaperHeight&quot;];
      Page.PaperWidth = (int)JSettings[&quot;General&quot;][&quot;PageSettings&quot;][&quot;PaperWidth&quot;];
         
      //Поля/отступы от краёв (в мм)
      Page.TopMargin = (int)JSettings[&quot;General&quot;][&quot;PageSettings&quot;][&quot;TopMargin&quot;];
      Page.BottomMargin = (int)JSettings[&quot;General&quot;][&quot;PageSettings&quot;][&quot;BottomMargin&quot;];
      Page.LeftMargin = (int)JSettings[&quot;General&quot;][&quot;PageSettings&quot;][&quot;LeftMargin&quot;];
      Page.RightMargin = (int)JSettings[&quot;General&quot;][&quot;PageSettings&quot;][&quot;RightMargin&quot;];
         
      DrawTableHeader();    
      DrawTableConclusion();
    }      
    
    // Отрисовка заголовка таблицы
    public void DrawTableHeader()
    {
      ProtokolNum.Text =  &quot;ПРОТОКОЛ № &quot;+JAdditionalInfo[&quot;ProtokolNum&quot;].ToString();
      Place.Text = JAdditionalInfo[&quot;Place&quot;].ToString();
      PR_Type.Text = JAdditionalInfo[&quot;PR_Type&quot;].ToString();
      PR_FactoryNumber.Text = JAdditionalInfo[&quot;PR_FactoryNumber&quot;].ToString();
      PU_Type.Text = JAdditionalInfo[&quot;PU_Type&quot;].ToString();
      PU_FactoryNumber.Text = JAdditionalInfo[&quot;PU_FactoryNumber&quot;].ToString();
      IVK_Type.Text = JAdditionalInfo[&quot;IVK_Type&quot;].ToString();
      IVK_FactoryNumber.Text = JAdditionalInfo[&quot;IVK_FactoryNumber&quot;].ToString();
      OilType.Text = JProtokol[&quot;OilType&quot;].ToString();
      Visc.Text = JProtokol[&quot;Visc&quot;].ToString().Replace('.',',');
    }
    
    // Формирование заключения отчёта
    public void  DrawTableConclusion()
    { 
      TableConclusion3.Columns[0].Width=(Page.PaperWidth-Page.LeftMargin-Page.RightMargin)  * Units.Millimeters;
      ARM_Poverka_Result.Text = JAdditionalInfo[&quot;ARM_Poverka_Result&quot;].ToString();
      StaffData.Text = JAdditionalInfo[&quot;StaffData&quot;].ToString();
      long dateTimeLong = long.Parse(JDoc[&quot;Doc&quot;][&quot;DataIVK&quot;][&quot;TablePoverka3266&quot;][&quot;DateTimeLong&quot;].ToString());     
      DateTimeLong.Text = string.Format(&quot;Дата проведения поверки: {0:dd.MM.yyyy} г.&quot;, DateTimeOffset.FromUnixTimeSeconds(dateTimeLong));             
      PageNumeration.Width = (Page.PaperWidth-Page.LeftMargin-Page.RightMargin)*Units.Millimeters; 
    } 

    //Обработка печати заключения таблицы
    private void PageFooter_BeforeLayout(object sender, EventArgs e)
    {
      if((Int32)Report.GetVariableValue(&quot;TotalPages&quot;) &lt; 2) 
      { 
        PageFooter.Visible = false; 
      }
      else
      {
        PageNumeration.Width = (Page.PaperWidth-Page.LeftMargin-Page.RightMargin)*Units.Millimeters;
      }
    }
                                                                 
    //Формирование таблицы &quot;Таблица 1 - Исходные данные&quot;
    private void Table1_1_ManualBuild(object sender, EventArgs e)
    {  
      //печатаем заголовок таблицы
      PrintTableHeader(Table1_1);
      //Заполнение данными таблицу
      var rowCount = JProtokol[&quot;Table1&quot;][&quot;DetName&quot;].Count();
      var isfirstRow= true;
      for(int rowIndex =0;rowIndex &lt;rowCount;rowIndex++){
        var detectorName = JProtokol[&quot;Table1&quot;][&quot;DetName&quot;][rowIndex].ToString();
        if(detectorName.Equals (&quot;-&quot;) || string.IsNullOrEmpty(detectorName))
          continue;
        DetName.Text = RS(detectorName);
        V0.Text = RS(JProtokol[&quot;Table1&quot;][&quot;V0&quot;][rowIndex].ToString());
        if(isfirstRow){
          m_D.Text = RS(JProtokol[&quot;Table1&quot;][&quot;m_D&quot;].ToString());
          m_S.Text = RS(JProtokol[&quot;Table1&quot;][&quot;m_S&quot;].ToString());
          m_E.Text = RS(JProtokol[&quot;Table1&quot;][&quot;m_E&quot;].ToString());
          Alpha_t.Text = RS(JProtokol[&quot;Table1&quot;][&quot;Alpha_t&quot;].ToString());
          Alpha_k1.Text = RS(JProtokol[&quot;Table1&quot;][&quot;Alpha_k1&quot;].ToString());
          Alpha_D.Text = RS(JProtokol[&quot;Table1&quot;][&quot;Alpha_D&quot;].ToString());
          m_D.RowSpan = rowCount; 
          m_S.RowSpan = rowCount; 
          m_E.RowSpan = rowCount; 
          Alpha_t.RowSpan = rowCount;
          Alpha_k1.RowSpan = rowCount; 
          Alpha_D.RowSpan = rowCount;
          isfirstRow= false;
        }
        Table1_1.PrintRow(Table1_1.FixedRows);
        Table1_1.PrintColumns();

      }
    }
  
    // Формирование окончание таблицы 1 &quot;Окончание таблицы 1&quot;
    private void Table1_2_ManualBuild(object sender, EventArgs e)
    {
      //печатаем заголовок таблицы
      PrintTableHeader(Table1_2);
      //Заполнение данными таблицу
      var rowCount = JProtokol[&quot;Table1&quot;][&quot;Teta_Sum_0&quot;].Count();
      var isfirstRow= true;
      for(int rowIndex = 0; rowIndex &lt; rowCount ; rowIndex++){
        var detectorName = JProtokol[&quot;Table1&quot;][&quot;DetName&quot;][rowIndex].ToString();
        if(detectorName.Equals (&quot;-&quot;) || string.IsNullOrEmpty(detectorName))
          continue;
        Teta_Sum_0.Text = RS (JProtokol[&quot;Table1&quot;][&quot;Teta_Sum_0&quot;][rowIndex].ToString());
        Teta_V_0.Text = RS (JProtokol[&quot;Table1&quot;][&quot;Teta_V_0&quot;][rowIndex].ToString());
        if(isfirstRow){
          Delta_t_PU.Text = RS (JProtokol[&quot;Table1&quot;][&quot;Delta_t_PU&quot;].ToString());
          Delta_t_PR.Text =  RS(JProtokol[&quot;Table1&quot;][&quot;Delta_t_PR&quot;].ToString());
          Delta_IVK.Text =  RS(JProtokol[&quot;Table1&quot;][&quot;Delta_IVK&quot;].ToString());
          Delta_Visc.Text =  RS(JProtokol[&quot;Table1&quot;][&quot;Delta_Visc&quot;].ToString());  
          Delta_t_PU.RowSpan = rowCount;
          Delta_t_PR.RowSpan = rowCount;
          Delta_IVK.RowSpan = rowCount;
          Delta_Visc.RowSpan = rowCount;
        }
        Table1_2.PrintRow(Table1_2.FixedRows);
        Table1_2.PrintColumns();
      }  
    }
    
    // Формирование таблицы 2 &quot;Таблица 2 - Результаты измерений и вычислений&quot;
    private void Table2_1_ManualBuild(object sender, EventArgs e)
    {
      //печатаем заголовок таблицы
      PrintTableHeader(Table2_1);
      //Заполнение данными таблицу
      foreach(var item in JProtokol[&quot;Table2&quot;])
      {
        var act =  int.Parse(item[&quot;Activated&quot;].ToString());
        if(act ==0)
          continue;
        SerRow.Text = RS(item[&quot;Ser&quot;].ToString()+&quot;/&quot;+item[&quot;Row&quot;].ToString());
        Q_ji.Text =RS(item[&quot;Q_ji&quot;].ToString()); 
        Det.Text = RS(item[&quot;Det&quot;].ToString()); 
        T_ji.Text = RS(item[&quot;T_ji&quot;].ToString());
        t_PU_ji.Text=RS(item[&quot;t_PU_ji&quot;].ToString());
        P_PU_ji.Text=RS(item[&quot;P_PU_ji&quot;].ToString());
        t_D_ji.Text=RS(item[&quot;t_D_ji&quot;].ToString());
        Dens_ji.Text=RS(item[&quot;Dens_ji&quot;].ToString());
        DensTemp_ji.Text=RS(item[&quot;DensTemp_ji&quot;].ToString());
        Table2_1.PrintRow(Table2_1.FixedRows);
        Table2_1.PrintColumns();
      }   
    }
    

    // Формирование окончания таблицы 2 &quot;Таблиц 2 - Результат измерений и вычислений&quot;
    private void Table2_2_ManualBuild(object sender, EventArgs e)
    {
      //печатаем заголовок таблицы
      PrintTableHeader(Table2_2);
      foreach(var item in JProtokol[&quot;Table2&quot;])
      {
        var act =  int.Parse(item[&quot;Activated&quot;].ToString());
        if(act ==0)
          continue;
        SerRow2.Text = RS(item[&quot;Ser&quot;].ToString()+&quot;/&quot;+item[&quot;Row&quot;].ToString());
        DensPress_ji.Text =RS(item[&quot;DensPress_ji&quot;].ToString()); 
        Beta_ji.Text = RS(item[&quot;Beta_ji&quot;].ToString()); 
        v_ji.Text = RS(item[&quot;v_ji&quot;].ToString());
        t_PR_ji.Text=RS(item[&quot;t_PR_ji&quot;].ToString());
        P_PR_ji.Text=RS(item[&quot;P_PR_ji&quot;].ToString());
        f_ji.Text=RS(item[&quot;f_ji&quot;].ToString());
        N_ji.Text=RS(item[&quot;N_ji&quot;].ToString());
        K_ji.Text=RS(item[&quot;K_ji&quot;].ToString());
        Table2_2.PrintRow(Table2_1.FixedRows);
        Table2_2.PrintColumns();
      }  
    }
         
    // Формирование таблицы 3 &quot;Таблица 3 - Результаты поверки в точках рабочего диапазона&quot;
    private void Table3_ManualBuild(object sender, EventArgs e)
    {
      //печатаем заголовок таблицы
      PrintTableHeader(Table3);
      foreach(var item in JProtokol[&quot;Table3&quot;])
      {
        var point = item[&quot;Point&quot;].ToString();
        if(point.Equals(&quot;-&quot;)||string.IsNullOrEmpty(point))
          continue;
        Point.Text = RS(point);
//        Point.Text = RS(item[&quot;Point&quot;].ToString());
        Q_j.Text = RS(item[&quot;Q_j&quot;].ToString());
        f_j.Text = RS(item[&quot;f_j&quot;].ToString());
        K_j.Text = RS(item[&quot;K_j&quot;].ToString());
        S_j.Text = RS(item[&quot;S_j&quot;].ToString());
        n_j.Text = RS(item[&quot;n_j&quot;].ToString());
        S0_j.Text = RS(item[&quot;S0_j&quot;].ToString());
        t099_j.Text = RS(item[&quot;t099_j&quot;].ToString());
        e_j.Text = RS(item[&quot;e_j&quot;].ToString());  
        Table3.PrintRow(Table3.FixedRows);
        Table3.PrintColumns();
      }  
    }    

    // Формирование таблицы 4 &quot;Таблица 4 - Результаты поверки в рабочем диапазоне&quot; 
    private void Table4_ManualBuild(object sender, EventArgs e)
    {
      //печатаем заголовок таблицы
      PrintTableHeader(Table4);
      var q_min =JProtokol[&quot;Table4&quot;][&quot;Q_min&quot;].ToString();
      if(q_min.Equals(&quot;-&quot;) || string.IsNullOrEmpty(q_min))
        return;
      Q_min.Text = RS(q_min);
      Q_max.Text = RS(JProtokol[&quot;Table4&quot;][&quot;Q_max&quot;].ToString());
      v_min.Text = RS(JProtokol[&quot;Table4&quot;][&quot;v_min&quot;].ToString());
      v_max.Text = RS(JProtokol[&quot;Table4&quot;][&quot;v_max&quot;].ToString());
      S0.Text = RS(JProtokol[&quot;Table4&quot;][&quot;S0&quot;].ToString());
      eps.Text = RS(JProtokol[&quot;Table4&quot;][&quot;e&quot;].ToString());
      Teta_A.Text = RS(JProtokol[&quot;Table4&quot;][&quot;Teta_A&quot;].ToString());
      Teta_t.Text = RS(JProtokol[&quot;Table4&quot;][&quot;Teta_t&quot;].ToString());
      Teta_Sum.Text = RS(JProtokol[&quot;Table4&quot;][&quot;Teta_Sum&quot;].ToString());
      Delta.Text = RS(JProtokol[&quot;Table4&quot;][&quot;Delta&quot;].ToString());
      Table4.PrintRow(Table4.FixedRows);
      Table4.PrintColumns();
    }
    
    // Печать заголовка таблицы
    private void PrintTableHeader(TableObject table){
      //Установка размера колонок
      int sumDynamicCols = table.ColumnCount;
      float widthDynamicCol = (Page.PaperWidth-Page.LeftMargin-Page.RightMargin)/sumDynamicCols;
      for (int w = 0; w &lt; table.ColumnCount; w++)                 
      {
        table.Columns[w].Width = widthDynamicCol * Units.Millimeters;
      } 
      // Печать заголовка таблицы  
      for (int n = 0; n &lt; Table2_1.FixedRows; n++)
      {
        table.PrintRow(n);
        table.PrintColumns();                                             
      }
    }
    
    // Замена точек на запятые
    private string RS(string valueStr) {
      return valueStr.Replace('.',','); 
    } 
  }    
}

