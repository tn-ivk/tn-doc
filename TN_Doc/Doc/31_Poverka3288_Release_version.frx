               TPR_delta_PR.Text=tools.GetNormalizedValue(DataIVK.TablePoverka3288.Protokol_TPR.Table3.delta_PR);        
                                                  
               //RowSpans
               for (int i = 0; i &lt; (TPR_Table3Results.ColumnCount); i++)
