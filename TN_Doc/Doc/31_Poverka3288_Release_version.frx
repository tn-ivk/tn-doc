      private void TPR_Table1SourceData_ManualBuild(object sender, EventArgs e)
      {
         if (DataIVK.TablePoverka3288.Mode &gt; 3)
         {
            List &lt;TN.Doc.Table1TPR&gt; listTPR_Table1SourceData;
            listTPR_Table1SourceData = DataIVK.TablePoverka3288.Protokol_TPR.Table1.Where(i =&gt; i.DetName.Length &gt; 1 &amp; String.IsNullOrEmpty(i.DetName) == false).ToList();
         
            //Setup Columns width
            int sumDynamicCols=TPR_Table1SourceData.ColumnCount;
            float widthDynamicCol=(Page.PaperWidth-Page.LeftMargin-Page.RightMargin)/sumDynamicCols;                  
 
            for (int w = 0; w &lt; (TPR_Table1SourceData.ColumnCount); w++)                 
            {
               TPR_Table1SourceData.Columns[w].Width = widthDynamicCol * Units.Millimeters;
            }      
                            
            //Draw Fixed rows
            for (int n = 0; n &lt; TPR_Table1SourceData.FixedRows; n++)
            {
               TPR_Table1SourceData.PrintRow(n);
               TPR_Table1SourceData.PrintColumns();                                             
            }
                                                     
            //Fill table with data
            for (int n = 0; n &lt; (listTPR_Table1SourceData.Count); n++)
            {                                
               TPR_V0.Text =  tools.GetNormalizedValue(listTPR_Table1SourceData[n].V0);        
               TPR_m_D.Text =  tools.GetNormalizedValue(listTPR_Table1SourceData[n].m_D);        
               TPR_m_S.Text =  tools.GetNormalizedValue(listTPR_Table1SourceData[n].m_S);        
               TPR_m_E.Text =  tools.GetNormalizedValue(listTPR_Table1SourceData[n].m_E);        
               TPR_Alpha_k1.Text =  tools.GetNormalizedValue(listTPR_Table1SourceData[n].Alpha_k1);        
               TPR_Alpha_D.Text =  tools.GetNormalizedValue(listTPR_Table1SourceData[n].Alpha_D);        
               TPR_Teta_Sum_0.Text =  tools.GetNormalizedValue(listTPR_Table1SourceData[n].Teta_Sum_0);        
               TPR_Teta_V_0.Text =  tools.GetNormalizedValue(listTPR_Table1SourceData[n].Teta_V_0);        
               TPR_Delta_t_PU.Text =  tools.GetNormalizedValue(listTPR_Table1SourceData[n].Delta_t_PU);        
               TPR_Delta_t_PR.Text =  tools.GetNormalizedValue(listTPR_Table1SourceData[n].Delta_t_PR);        
               TPR_delta_IVK.Text =  tools.GetNormalizedValue(listTPR_Table1SourceData[n].delta_IVK);        
                                            
               //RowSpans
               for (int i = 0; i &lt; (TPR_Table1SourceData.ColumnCount); i++)
               {          
                  switch(i)
                  {
                     case 1:
                     case 2:
                     case 3:  
                     case 4:
                     case 5:  
                     case 8:     
                     case 9:     
                     case 10:     
                        TPR_Table1SourceData[i,3].RowSpan =  listTPR_Table1SourceData.Count;
                        break;  
                  }
               }
               TPR_Table1SourceData.PrintRow(3);     
               TPR_Table1SourceData.PrintColumns();  
            }     
         }
         else
         {
            DataBand_TPR_Table1SourceData.Visible=false;
         }
      } 
      
