            {
               TPR_Point.Text =  listTable3Points[n].Point;//+ &quot; | &quot; + (n+1).ToString();
               TPR_Q_j.Text=tools.GetNormalizedValue(listTable3Points[n].Q_j);        
               TPR_K_PR_j.Text=tools.GetNormalizedValue(listTable3Points[n].K_PR_j);        
