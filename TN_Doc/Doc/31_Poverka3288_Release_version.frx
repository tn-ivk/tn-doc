      private void TPR_Table2Results_ManualBuild(object sender, EventArgs e)
      {                
         if (DataIVK.TablePoverka3288.Mode &gt; 3)
         {
            List &lt;TN.Doc.Table2&gt; listTable2Results;
            listTable2Results = DataIVK.TablePoverka3288.Protokol_TPR.Table2.Where(i =&gt; i.Activated != 0 &amp; i.Activated != null).ToList();

            //Setup Columns width
            int sumDynamicCols=TPR_Table2Results.ColumnCount;
            float widthDynamicCol=(Page.PaperWidth-Page.LeftMargin-Page.RightMargin)/sumDynamicCols;                  
         
            for (int w = 0; w &lt; (TPR_Table2Results.ColumnCount); w++)                 
            {
               TPR_Table2Results.Columns[w].Width = widthDynamicCol * Units.Millimeters;
            }      
         
            //Draw Fixed rows
            for (int n = 0; n &lt; TPR_Table2Results.FixedRows; n++)
            {
               TPR_Table2Results.PrintRow(n);
               TPR_Table2Results.PrintColumns();                                             
            }
         
            //Fill table with data
            for (int n = 0; n &lt; (listTable2Results.Count); n++)
            {
               SerRow_2.Text =  String.Format(&quot;{0}/{1}&quot;, listTable2Results[n].Ser, listTable2Results[n].Row);//+ &quot; | &quot; + (n+1).ToString();
               Q_ji_2.Text=tools.GetNormalizedValue(listTable2Results[n].Q_ji);        
