               t_PR_ji_2.Text=tools.GetNormalizedValue(listTable2Results[n].t_PR_ji);        
               P_PR_ji_2.Text=tools.GetNormalizedValue(listTable2Results[n].P_PR_ji);        
               N_ji_2.Text=tools.GetNormalizedValue(listTable2Results[n].N_ji);     
               K_PR_ji_2.Text=tools.GetNormalizedValue(listTable2Results[n].K_PR_ji);        

               TPR_Table2Results.PrintRow(3);     
