      //// ======================== //// ======================== //// ======================== ////
      private void MPR_Table3Results_ManualBuild(object sender, EventArgs e)
      {                                                   
         List &lt;TN.Doc.Table3MPR&gt; listTable3Results;
         listTable3Results = DataIVK.TablePoverka3288.Protokol_MPR.Table3.Where(i =&gt; i.Activated != 0 &amp; i.Activated != null).ToList();
         string K_MF_F_j; 
         
         switch(DataIVK.TablePoverka3288.Protokol_MPR.CalcMode)
         {
            case 0:
               MPR_Table3Results.Columns.Remove(tab3_CalcMode1);
               MPR_Table3Results.Columns.Remove(tab3_CalcMode2);
               MPR_Table3Results.Columns.Remove(tab3_CalcMode3);
               break;  
            
            case 1:  
               MPR_Table3Results.Columns.Remove(tab3_CalcMode0);
               MPR_Table3Results.Columns.Remove(tab3_CalcMode2);
               MPR_Table3Results.Columns.Remove(tab3_CalcMode3);
               break;  
            
            case 2:   
               MPR_Table3Results.Columns.Remove(tab3_CalcMode0);
               MPR_Table3Results.Columns.Remove(tab3_CalcMode1);
               MPR_Table3Results.Columns.Remove(tab3_CalcMode3);
               break;  
            
            case 3:   
               MPR_Table3Results.Columns.Remove(tab3_CalcMode0);
               MPR_Table3Results.Columns.Remove(tab3_CalcMode1);
               MPR_Table3Results.Columns.Remove(tab3_CalcMode2);
               break;  
         }
         
         K_MF_F_j= &quot;MPR_K_MF_F_j_&quot; + DataIVK.TablePoverka3288.Protokol_MPR.CalcMode.ToString(); 
         
         //Setup Columns width
         int sumDynamicCols=MPR_Table3Results.ColumnCount;
         float widthDynamicCol=(Page.PaperWidth-Page.LeftMargin-Page.RightMargin)/sumDynamicCols;                  
         
         for (int w = 0; w &lt; (MPR_Table3Results.ColumnCount); w++)                 
         {
            MPR_Table3Results.Columns[w].Width = widthDynamicCol * Units.Millimeters;
         }      
         
         //Draw Fixed rows
         for (int n = 0; n &lt; MPR_Table3Results.FixedRows; n++)
         {
            MPR_Table3Results.PrintRow(n);
            MPR_Table3Results.PrintColumns();                                             
         }
         
         //Selecting the Сell by name (depending on the calcMode value)
         TableCell MPR_K_MF_F_j_3 = (TableCell )MPR_Table3Results.FindObject(K_MF_F_j); 
         
         //Fill table with data
         for (int n = 0; n &lt; (listTable3Results.Count); n++)
         {
            MPR_Point.Text =  listTable3Results[n].Point;//+ &quot; | &quot; + (n+1).ToString();
            MPR_Q_j.Text=tools.GetNormalizedValue(listTable3Results[n].Q_j);        
            MPR_K_MF_F_j_3.Text=tools.GetNormalizedValue(listTable3Results[n].K_MF_F_j);        
            MPR_n_j.Text=tools.GetNormalizedValue(listTable3Results[n].n_j);        
            MPR_S_j.Text=tools.GetNormalizedValue(listTable3Results[n].S_j);        
            MPR_S_0_j.Text=tools.GetNormalizedValue(listTable3Results[n].S_0_j);        
            MPR_t_095_j.Text=tools.GetNormalizedValue(listTable3Results[n].t_095_j);        
            MPR_Epsilon_j.Text=tools.GetNormalizedValue(listTable3Results[n].Epsilon_j);        
            MPR_f_j.Text=tools.GetNormalizedValue(listTable3Results[n].f_j);        
            
            MPR_Table3Results.PrintRow(3);     
            MPR_Table3Results.PrintColumns();      
         }         
      }    
