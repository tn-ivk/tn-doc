      private void MPR_Table2_1Results_ManualBuild(object sender, EventArgs e)
      {                         
         List &lt;TN.Doc.Table2_Part1&gt; listTable2_1Results;
         listTable2_1Results = DataIVK.TablePoverka3288.Protokol_MPR.Table2_part1.Where(i =&gt; i.Activated != 0 &amp; i.Activated != null).ToList();
         string K_MF_F_ji; 
         
         switch(DataIVK.TablePoverka3288.Protokol_MPR.CalcMode)
         {
            case 0:
               MPR_Table2_1Results.Columns.Remove(tab2_1_CalcMode1);
               MPR_Table2_1Results.Columns.Remove(tab2_1_CalcMode2);
               MPR_Table2_1Results.Columns.Remove(tab2_1_CalcMode3);
               break;  
            
            case 1:  
