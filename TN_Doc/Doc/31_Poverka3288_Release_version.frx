   public class ReportScript
   {
      TN_ToolsFastReport.Tools tools = new TN_ToolsFastReport.Tools();  // классы отчета
      TN.Doc.Doc doc; // данные из входного параметра
      TN.DocData.General General;
      TN.Doc.HeaderDoc Header;
      TN.Doc.DataDoc SettingsData;
      TN.Doc.FooterDoc Footer;
      TN.Doc.DictionarysDoc Dictionarys;
      TN.Doc.DataIVKDoc DataIVK;
      
      List &lt;TN.Doc.Table1MPR&gt; listMPR_Table1SourceData;

      private void Page_StartPage(object sender, EventArgs e)
      {
         //using (var sr = new StreamReader(&quot;D:/!_Work/!_Транснефть/SVN/Work/Sources/Reports/FRX/Входящие данные от Алексея (классы и json)/31_TablePoverka3288/DocPoverka3288.json&quot;))
         //{
            // Read the stream as a string
         //   Report.SetParameterValue(&quot;JsonDoc&quot;, sr.ReadToEnd());
         //}
         
         //// Десериализация данных (формат json) из входного параметра - Json                         
         string json = (string)Report.GetParameterValue(&quot;JsonDoc&quot;);
         Newtonsoft.Json.JsonSerializerSettings settings = new Newtonsoft.Json.JsonSerializerSettings();
         settings.TypeNameHandling = TypeNameHandling.All;
         
         doc = JsonConvert.DeserializeObject&lt;TN.Doc.Doc&gt;(json, settings);
         General = (TN.DocData.General) doc.Doc.Settings.General;
         Header = (TN.Doc.HeaderDoc) doc.Doc.Settings.Header;
         SettingsData = (TN.Doc.DataDoc) doc.Doc.Settings.Data;
         Footer = (TN.Doc.FooterDoc) doc.Doc.Settings.Footer;
         Dictionarys = (TN.Doc.DictionarysDoc) doc.Doc.Settings.Dictionarys;  
         DataIVK = (TN.Doc.DataIVKDoc) doc.Doc.DataIVK;      
      
         //// === Настройки страницы 
         // Ширина и высота (в мм)
         
         Page.PaperHeight = General.PageSettings.PaperHeight;
         Page.PaperWidth = General.PageSettings.PaperWidth;
         //Page.Border.Lines = BorderLines.All;
         
         // Поля/отступы от краёв (в мм)
         Page.TopMargin = General.PageSettings.TopMargin;
         Page.BottomMargin = General.PageSettings.BottomMargin;
         Page.LeftMargin = General.PageSettings.LeftMargin;
         Page.RightMargin = General.PageSettings.RightMargin;
                                                                
         //// ==== Get Data from classes
         listMPR_Table1SourceData = DataIVK.TablePoverka3288.Protokol_MPR.Table1.Where(i =&gt; i.DetName.Length &gt; 1 &amp; String.IsNullOrEmpty(i.DetName) == false).ToList();
    
         // Запуск отрисовки таблиц на странице отчета
         Draw_MPR_TableHeader();    
         Draw_MPR_TableConclusion();
         
         if (DataIVK.TablePoverka3288.Mode &gt; 3)
         {
            Draw_TPR_TableHeader();
            Draw_TPR_TableConclusion();
         }
         else
         {
            DataBand_TPR_ReportTitle.Visible = false;
            DataBand_TPR_ReportSummary.Visible = false;
         
         }
      }
      #region //Имхо лишний метод
      private void PrintTable(TableObject table)
      {
         for (int i=0;i&lt;table.RowCount;i++)
         {       
            table.PrintRow(i);
            table.PrintColumns();
         }    
      } 
      #endregion
      
      //// ======================== //// ======================== //// ======================== ////
      public void Draw_MPR_TableHeader()
      {
         //Setup Columns width
         MPR_TableHeader01.Columns[0].Width = (Page.PaperWidth-Page.LeftMargin-Page.RightMargin)*Units.Millimeters;
         
         // Fill table with data   
         MPR_ProtokolNum.Text = string.Format(&quot;П Р О Т О К О Л  № {0}&quot;, DataIVK.TablePoverka3288.AdditionalInfo_MPR.ProtokolNum);
         MPR_Place.Text = string.Format(&quot;СИКН №{0}&quot;, DataIVK.TablePoverka3288.AdditionalInfo_MPR.Place_SIKN_Name);
         MPR_Sensor_Type.Text = DataIVK.TablePoverka3288.AdditionalInfo_MPR.MPR_Sensor_Type;
         MPR_Sensor_FactoryNumber.Text = DataIVK.TablePoverka3288.AdditionalInfo_MPR.MPR_Sensor_FactoryNumber;
         MPR_LineName.Text = DataIVK.TablePoverka3288.AdditionalInfo_MPR.LineName;
         MPR_PEP_Type.Text = DataIVK.TablePoverka3288.AdditionalInfo_MPR.MPR_PEP_Type;
         MPR_PEP_FactoryNumber.Text = DataIVK.TablePoverka3288.AdditionalInfo_MPR.MPR_PEP_FactoryNumber;
         MPR_CP_Type.Text = DataIVK.TablePoverka3288.AdditionalInfo_MPR.CP_Type;
         MPR_CP_FactoryNumber.Text = DataIVK.TablePoverka3288.AdditionalInfo_MPR.CP_FactoryNumber;
         MPR_PP_Type.Text = DataIVK.TablePoverka3288.AdditionalInfo_MPR.PP_Type;
         MPR_PP_FactoryNumber.Text = DataIVK.TablePoverka3288.AdditionalInfo_MPR.PP_FactoryNumber;
         MPR_PR_Type.Text = DataIVK.TablePoverka3288.AdditionalInfo_MPR.PR_Type;
         MPR_PR_FactoryNumber.Text = DataIVK.TablePoverka3288.AdditionalInfo_MPR.PR_FactoryNumber;
         MPR_IVK_Type.Text = DataIVK.TablePoverka3288.AdditionalInfo_MPR.IVK_Type;
         MPR_IVK_FactoryNumber.Text = DataIVK.TablePoverka3288.AdditionalInfo_MPR.IVK_FactoryNumber;
         MPR_OilType.Text = DataIVK.TablePoverka3288.AdditionalInfo_MPR.Oil_Type;
      }
              
      //// ======================== //// ======================== //// ======================== ////
      private void MPR_Table1SourceData_ManualBuild(object sender, EventArgs e)
      {
         
            //Setup Columns width
            int sumDynamicCols=MPR_Table1SourceData.ColumnCount;
            float widthDynamicCol=(Page.PaperWidth-Page.LeftMargin-Page.RightMargin)/sumDynamicCols;                  
 
            for (int w = 0; w &lt; (MPR_Table1SourceData.ColumnCount); w++)                 
            {
               MPR_Table1SourceData.Columns[w].Width = widthDynamicCol * Units.Millimeters;
            }      
                            
            //Draw Fixed rows
            for (int n = 0; n &lt; MPR_Table1SourceData.FixedRows; n++)
            {
               MPR_Table1SourceData.PrintRow(n);
               MPR_Table1SourceData.PrintColumns();                                             
            }
                                                     
            //Fill table with data
         for (int n = 0; n &lt; (listMPR_Table1SourceData.Count); n++)
         {
            MPR_V0.Text =  tools.GetNormalizedValue(listMPR_Table1SourceData[n].V0);        
            MPR_m_D.Text =  tools.GetNormalizedValue(listMPR_Table1SourceData[n].m_D);        
            MPR_m_S.Text =  tools.GetNormalizedValue(listMPR_Table1SourceData[n].m_S);        
            MPR_m_E.Text =  tools.GetNormalizedValue(listMPR_Table1SourceData[n].m_E);        
            MPR_Alpha_k1.Text =  tools.GetNormalizedValue(listMPR_Table1SourceData[n].Alpha_k1);        
            MPR_Alpha_D.Text =  tools.GetNormalizedValue(listMPR_Table1SourceData[n].Alpha_D);        
            
            MPR_Teta_Sum_0.Text =  tools.GetNormalizedValue(listMPR_Table1SourceData[n].Teta_Sum_0);        
            MPR_Teta_V_0.Text =  tools.GetNormalizedValue(listMPR_Table1SourceData[n].Teta_V_0);        
            
            MPR_Delta_t_PU.Text =  tools.GetNormalizedValue(listMPR_Table1SourceData[n].Delta_t_PU);        
            MPR_Delta_t_PP.Text =  tools.GetNormalizedValue(listMPR_Table1SourceData[n].Delta_t_PP);        
            MPR_Delta_PP.Text =  tools.GetNormalizedValue(listMPR_Table1SourceData[n].Delta_PP);        
            MPR_Delta_t_PR.Text =  tools.GetNormalizedValue(listMPR_Table1SourceData[n].Delta_t_PR);        
            MPR_delta_PR.Text =  tools.GetNormalizedValue(listMPR_Table1SourceData[n].delta_PR);        

            //RowSpans
            for (int i = 0; i &lt; (MPR_Table1SourceData.ColumnCount); i++)
            {          
               switch(i)
               {
                  case 1:
                  case 2:
                  case 3:  
                  case 4:
                  case 5:  
                  case 8:     
                  case 9:     
                  case 10:     
                  case 11:     
                  case 12:     
                     MPR_Table1SourceData[i,3].RowSpan =  listMPR_Table1SourceData.Count;
                     break;  
               }
            }
            MPR_Table1SourceData.PrintRow(3);     
            MPR_Table1SourceData.PrintColumns();  
         }                                                    
      }
      
      //// ======================== //// ======================== //// ======================== ////
      private void MPR_Table1SourceDataEnding_ManualBuild(object sender, EventArgs e)
      {               
         string MPR_K_M_MF; 
         switch(DataIVK.TablePoverka3288.Protokol_MPR.CalcMode)
         {
            case 0:
               MPR_Table1SourceDataEnding.Columns.Remove(tab1_CalcMode1);
               MPR_Table1SourceDataEnding.Columns.Remove(tab1_CalcMode2);
               MPR_K_M_MF= &quot;MPR_tab1_K_M_MF_ust&quot; + DataIVK.TablePoverka3288.Protokol_MPR.CalcMode.ToString(); 
               
               break;  
            case 1:  
               MPR_Table1SourceDataEnding.Columns.Remove(tab1_CalcMode0);
               MPR_Table1SourceDataEnding.Columns.Remove(tab1_CalcMode2);
               MPR_K_M_MF= &quot;MPR_tab1_K_M_MF_ust&quot; + DataIVK.TablePoverka3288.Protokol_MPR.CalcMode.ToString(); 
               break;  
            case 2:   
               MPR_Table1SourceDataEnding.Columns.Remove(tab1_CalcMode0);
               MPR_Table1SourceDataEnding.Columns.Remove(tab1_CalcMode1);
               MPR_K_M_MF= &quot;MPR_tab1_K_M_MF_ust&quot; + DataIVK.TablePoverka3288.Protokol_MPR.CalcMode.ToString(); 
               break;  
            default:
               MPR_Table1SourceDataEnding.Columns.Remove(tab1_CalcMode0);
               MPR_Table1SourceDataEnding.Columns.Remove(tab1_CalcMode1);
               MPR_K_M_MF= &quot;MPR_tab1_K_M_MF_ust2&quot;; 
            break;  
         }

         //Setup Columns width
         int sumDynamicCols=(MPR_Table1SourceDataEnding.ColumnCount);
         float widthDynamicCol=(Page.PaperWidth-Page.LeftMargin-Page.RightMargin)/sumDynamicCols;                  
         
         for (int w = 0; w &lt; (MPR_Table1SourceDataEnding.ColumnCount); w++)                 
         {
            MPR_Table1SourceDataEnding.Columns[w].Width = widthDynamicCol * Units.Millimeters;
         }      
         
         
         //Draw Fixed rows
         for (int n = 0; n &lt; MPR_Table1SourceDataEnding.FixedRows; n++)
         {
            MPR_Table1SourceDataEnding.PrintRow(n);
            MPR_Table1SourceDataEnding.PrintColumns();                                             
         }
        
         //Selecting the Сell by name (depending on the calcMode value)
        TableCell MPR_K_M_MF_ust = (TableCell )MPR_Table1SourceDataEnding.FindObject(MPR_K_M_MF); 
         
         //Fill table with data
         for (int n = 0; n &lt; (listMPR_Table1SourceData.Count); n++)
         {
            MPR_delta_IVK_PU.Text =  tools.GetNormalizedValue(listMPR_Table1SourceData[n].delta_IVK_PU);        
            MPR_delta_IVK_PR.Text =  tools.GetNormalizedValue(listMPR_Table1SourceData[n].delta_IVK_PR); 
            MPR_K_PM_ust.Text =  tools.GetNormalizedValue(listMPR_Table1SourceData[n].K_PM_ust); 
            
            MPR_K_M_MF_ust.Text=tools.GetNormalizedValue(listMPR_Table1SourceData[n].K_M_MF_ust);        
            
            MPR_Q_M_max.Text=tools.GetNormalizedValue(listMPR_Table1SourceData[n].Q_M_max);        
            MPR_ZS.Text=tools.GetNormalizedValue(listMPR_Table1SourceData[n].ZS);        
            MPR_delta_t_dop.Text=tools.GetNormalizedValue(listMPR_Table1SourceData[n].delta_t_dop);        
            MPR_Q_nom.Text=tools.GetNormalizedValue(listMPR_Table1SourceData[n].Q_nom);        
            MPR_t_min.Text=tools.GetNormalizedValue(listMPR_Table1SourceData[n].t_min);        
            MPR_t_max.Text=tools.GetNormalizedValue(listMPR_Table1SourceData[n].t_max);        
            MPR_delta_P_dop.Text=tools.GetNormalizedValue(listMPR_Table1SourceData[n].delta_P_dop);        
            MPR_P_min.Text=tools.GetNormalizedValue(listMPR_Table1SourceData[n].P_min);        
            MPR_P_max.Text=tools.GetNormalizedValue(listMPR_Table1SourceData[n].P_max);        
                                            
            /* TEMP 
            //RowSpans
            for (int i = 0; i &lt; (MPR_Table1SourceDataEnding.ColumnCount); i++)
            {          
               switch(i)
               {
                  case 2:
                  case 3:  
                  case 4:   
                     MPR_Table1SourceDataEnding[i,3].RowSpan =  listMPR_Table1SourceData.Count;
                     break;  
               }
            }*/
            
            MPR_Table1SourceDataEnding.PrintRow(3);     
            MPR_Table1SourceDataEnding.PrintColumns();           
         }   
      }
