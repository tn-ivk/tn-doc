               MPR_Table2_1Results.Columns.Remove(tab2_1_CalcMode2);
               MPR_Table2_1Results.Columns.Remove(tab2_1_CalcMode3);
               break;  
            
            case 2:   
               MPR_Table2_1Results.Columns.Remove(tab2_1_CalcMode0);
               MPR_Table2_1Results.Columns.Remove(tab2_1_CalcMode1);
               MPR_Table2_1Results.Columns.Remove(tab2_1_CalcMode3);
               break;  
            
            case 3:   
               MPR_Table2_1Results.Columns.Remove(tab2_1_CalcMode0);
               MPR_Table2_1Results.Columns.Remove(tab2_1_CalcMode1);
               MPR_Table2_1Results.Columns.Remove(tab2_1_CalcMode2);
               break;  
         }
         
         K_MF_F_ji= &quot;K_MF_F_ji_2_1_&quot; + DataIVK.TablePoverka3288.Protokol_MPR.CalcMode.ToString(); 
         
         //Setup Columns width
         int sumDynamicCols=MPR_Table2_1Results.ColumnCount;
         float widthDynamicCol=(Page.PaperWidth-Page.LeftMargin-Page.RightMargin)/sumDynamicCols;                  
         
         for (int w = 0; w &lt; (MPR_Table2_1Results.ColumnCount); w++)                 
         {
            MPR_Table2_1Results.Columns[w].Width = widthDynamicCol * Units.Millimeters;
         }      
         
         //Draw Fixed rows
         for (int n = 0; n &lt; MPR_Table2_1Results.FixedRows; n++)
         {
            MPR_Table2_1Results.PrintRow(n);
            MPR_Table2_1Results.PrintColumns();                                             
         }
         
         //Selecting the Сell by name (depending on the calcMode value)
         TableCell K_MF_F_ji_2_1 = (TableCell )MPR_Table2_1Results.FindObject(K_MF_F_ji); 
         
         //Fill table with data
         for (int n = 0; n &lt; (listTable2_1Results.Count); n++)
         {
            SerRow_2_1.Text =  String.Format(&quot;{0}/{1}&quot;, listTable2_1Results[n].Ser, listTable2_1Results[n].Row);//+ &quot; | &quot; + (n+1).ToString();
            Q_ji_2_1.Text=tools.GetNormalizedValue(listTable2_1Results[n].Q_ji);        
            T_ji_2_1.Text=tools.GetNormalizedValue(listTable2_1Results[n].T_ji);        
            t_PU_ji_2_1.Text=tools.GetNormalizedValue(listTable2_1Results[n].t_PU_ji);        
            P_PU_ji_2_1.Text=tools.GetNormalizedValue(listTable2_1Results[n].P_PU_ji);        
            t_D_ji_2_1.Text=tools.GetNormalizedValue(listTable2_1Results[n].t_D_ji);        
            Dens_PP_ji_2_1.Text=tools.GetNormalizedValue(listTable2_1Results[n].Dens_PP_ji);        
            DensTemp_ji_2_1.Text=tools.GetNormalizedValue(listTable2_1Results[n].DensTemp_ji);        
            DensPress_ji_2_1.Text=tools.GetNormalizedValue(listTable2_1Results[n].DensPress_ji);        
            Beta_ji_2_1.Text=tools.GetNormalizedValue(listTable2_1Results[n].Beta_ji);        
            N_ji_2_1.Text=tools.GetNormalizedValue(listTable2_1Results[n].N_ji);        
            M_0_ji_2_1.Text=tools.GetNormalizedValue(listTable2_1Results[n].M_0_ji);        
            M_ji_2_1.Text=tools.GetNormalizedValue(listTable2_1Results[n].M_ji);        
            K_MF_F_ji_2_1.Text=tools.GetNormalizedValue(listTable2_1Results[n].K_MF_F_ji);        
            f_ji_2_1.Text=tools.GetNormalizedValue(listTable2_1Results[n].f_ji);        

            MPR_Table2_1Results.PrintRow(3);     
            MPR_Table2_1Results.PrintColumns();      
         }                                                                       
      }                                                                          
