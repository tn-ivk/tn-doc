   public class ReportScript
   {
      
      TN_ToolsFastReport.Tools tools = new TN_ToolsFastReport.Tools();  // классы отчета
      TN.Doc.Doc doc; // данные из входного параметра
      TN.DocData.General General;
      TN.Doc.HeaderDoc Header;
      TN.Doc.DataDoc SettingsData;
      TN.Doc.FooterDoc Footer;
      TN.Doc.DictionarysDoc Dictionarys;
      TN.Doc.DataIVKDoc DataIVK;    
    
      List &lt;TN.Doc.PRsInfo&gt; listPRsInfo;
      List &lt;TN.Doc.Table2&gt; listTable2Results;
      List &lt;TN.Doc.Table3&gt; listTable3Results;

      private void Page_StartPage(object sender, EventArgs e)
      {
         //using (var sr = new StreamReader(&quot;D:/!_Work/!_Транснефть/SVN/Work/Sources/Reports/FRX/Входящие данные от Алексея (классы и json)/20_TablePoverka3265_UPR_PR/DocPoverka3265_UPR_PR.json&quot;))
         //{
            // Read the stream as a string
         //   Report.SetParameterValue(&quot;Protocol&quot;, sr.ReadToEnd());
         //}
         
         //// Десериализация данных (формат json) из входного параметра - Json                         
         string json = (string)Report.GetParameterValue(&quot;JsonDoc&quot;);
         Newtonsoft.Json.JsonSerializerSettings settings = new Newtonsoft.Json.JsonSerializerSettings();
         settings.TypeNameHandling = TypeNameHandling.All;
         
         doc = JsonConvert.DeserializeObject&lt;TN.Doc.Doc&gt;(json, settings);
         General = (TN.DocData.General) doc.Doc.Settings.General;
         Header = (TN.Doc.HeaderDoc) doc.Doc.Settings.Header;
         SettingsData = (TN.Doc.DataDoc) doc.Doc.Settings.Data;
         Footer = (TN.Doc.FooterDoc) doc.Doc.Settings.Footer;
         Dictionarys = (TN.Doc.DictionarysDoc) doc.Doc.Settings.Dictionarys;  
         DataIVK = (TN.Doc.DataIVKDoc) doc.Doc.DataIVK;         
         
         //// === Настройки страницы 
         // Ширина и высота (в мм)
         
         Page.PaperHeight = General.PageSettings.PaperHeight;
         Page.PaperWidth = General.PageSettings.PaperWidth;
         //Page.Border.Lines = BorderLines.All;
         
         // Поля/отступы от краёв (в мм)
         Page.TopMargin = General.PageSettings.TopMargin;
         Page.BottomMargin = General.PageSettings.BottomMargin;
         Page.LeftMargin = General.PageSettings.LeftMargin;
         Page.RightMargin = General.PageSettings.RightMargin;
         
         //// ==== Get Data from classes
         listTable3Results = DataIVK.TablePoverka3265_UPR_PR.Protokol.Table3.Where(i =&gt; ! i.Ser.Contains(&quot;-&quot;)  &amp; String.IsNullOrEmpty(i.Ser) == false).ToList();
         
         // Запуск отрисовки таблиц на странице отчета
         DrawTableHeader();    
         DrawTableConclusion();
      }
      #region //Имхо лишний метод
      private void PrintTable(TableObject table)
      {
         for (int i=0;i&lt;table.RowCount;i++)
         {       
            table.PrintRow(i);
            table.PrintColumns();
         }    
      } 
      #endregion
      
      //// ======================== //// ======================== //// ======================== ////
      public void DrawTableHeader()
      {
         //Setup Columns width
         TableHeader01.Columns[0].Width = (Page.PaperWidth-Page.LeftMargin-Page.RightMargin)*Units.Millimeters;
         
         // Fill table with data   
         ProtokolNum.Text = &quot;П Р О Т О К О Л  № &quot;  +  DataIVK.TablePoverka3265_UPR_PR.AdditionalInfo.ProtokolNum;
         Place.Text = DataIVK.TablePoverka3265_UPR_PR.AdditionalInfo.Place;
         UPR_Type.Text = DataIVK.TablePoverka3265_UPR_PR.AdditionalInfo.UPR_Type;
         UPR_FactoryNumber.Text = DataIVK.TablePoverka3265_UPR_PR.AdditionalInfo.UPR_FactoryNumber;
         PU_Type.Text = DataIVK.TablePoverka3265_UPR_PR.AdditionalInfo.PU_Type;
         PU_FactoryNumber.Text = DataIVK.TablePoverka3265_UPR_PR.AdditionalInfo.PU_FactoryNumber;
         listPRsInfo = DataIVK.TablePoverka3265_UPR_PR.AdditionalInfo.PRs_Info.Where(i =&gt; ! i.PR_Type.Contains(&quot;-&quot;) &amp; String.IsNullOrEmpty(i.PR_Type) == false).ToList();

         if (listPRsInfo.Count==0)
          listPRsInfo.Add(new TN.Doc.PRsInfo () { PR_Type = &quot;&quot;, PR_FactoryNumber=&quot;&quot;, PR_LineName=&quot;&quot;});
      
         // === Add rows for PRs form 
         if (Engine.FirstPass == true)
         {
            int cols;
            int rows;
            for (rows = 1; rows &lt; (listPRsInfo.Count); rows++)                 
            {
               TableRow row = new TableRow(); 
               TablePRs.Rows.Add(row);
               for (cols=0; cols &lt;TablePRs.ColumnCount; cols++)
               {
                  TablePRs[cols, rows].AssignAll(TablePRs[cols, rows-1]);
               }
            }      
         }
       
         //Setup columns widht
         for (int i=0; i &lt;TableHeader03.ColumnCount ; i++)
         {
            TablePRs.Columns[i].Width=TableHeader04.Columns[i].Width=TableHeader03.Columns[i].Width;
         }
      
         //Fill PRs table with data                                  
         for (int i=0; i &lt;TablePRs.RowCount ; i++)
         {
            if (listPRsInfo.Count == 1)
            {
               TablePRs[0,i].Text= String.Format(&quot;ПР:&quot;);         
            }
            else 
            {
               TablePRs[0,i].Text= String.Format(&quot;ПР{0}:&quot;, i+1);
            }
        
            TablePRs[2,i].Text= listPRsInfo[i].PR_Type;
            TablePRs[4,i].Text= listPRsInfo[i].PR_FactoryNumber;
            TablePRs[6,i].Text= listPRsInfo[i].PR_LineName;
         }
      
         IVK_Type.Text = DataIVK.TablePoverka3265_UPR_PR.AdditionalInfo.IVK_Type;
         IVK_FactoryNumber.Text = DataIVK.TablePoverka3265_UPR_PR.AdditionalInfo.IVK_FactoryNumber;
         OilType.Text = DataIVK.TablePoverka3265_UPR_PR.Protokol.OilType;
         AvgLineTemp.Text = tools.GetNormalizedValue(DataIVK.TablePoverka3265_UPR_PR.Protokol.AvgLineTemp);
         Visc.Text = tools.GetNormalizedValue(DataIVK.TablePoverka3265_UPR_PR.Protokol.Visc);
      }
              
  
      //// ======================== //// ======================== //// ======================== ////
      private void Table1SourceData_ManualBuild(object sender, EventArgs e)
      {                                                            
         //Setup Columns width
         int sumDynamicCols=Table1SourceData.ColumnCount;
         float widthDynamicCol=((Page.PaperWidth-Page.LeftMargin-Page.RightMargin)/2)/sumDynamicCols;                  
 
         for (int w = 0; w &lt; (Table1SourceData.ColumnCount); w++)                 
         {
            Table1SourceData.Columns[w].Width = widthDynamicCol * Units.Millimeters;
         }      
                            
         //Draw Fixed rows
         for (int n = 0; n &lt; Table1SourceData.FixedRows; n++)
         {
            Table1SourceData.PrintRow(n);
            Table1SourceData.PrintColumns();                                             
         }
                                                     
         //Fill table with data
         Teta_V.Text = tools.GetNormalizedValue(DataIVK.TablePoverka3265_UPR_PR.Protokol.Table1.Teta_V);
         Delta_t_UPR.Text = tools.GetNormalizedValue(DataIVK.TablePoverka3265_UPR_PR.Protokol.Table1.Delta_t_UPR);
         Delta_t_PR.Text = tools.GetNormalizedValue(DataIVK.TablePoverka3265_UPR_PR.Protokol.Table1.Delta_t_PR);
         Delta_IVK.Text = tools.GetNormalizedValue(DataIVK.TablePoverka3265_UPR_PR.Protokol.Table1.Delta_IVK);
         
         Table1SourceData.PrintRow(3);     
         Table1SourceData.PrintColumns();           
      }
      //// ======================== //// ======================== //// ======================== ////
      private void Table2Results_ManualBuild(object sender, EventArgs e)
      {                              
         listTable2Results = DataIVK.TablePoverka3265_UPR_PR.Protokol.Table2.Where(i =&gt; ! i.Ser.Contains(&quot;-&quot;) &amp; String.IsNullOrEmpty(i.Ser) == false).ToList();
         
         int n = 0;
         float initialHeight = 0;
         
         //Setup Columns width
         int sumDynamicCols=Table2Results.ColumnCount;
         float widthDynamicCol=(Page.PaperWidth-Page.LeftMargin-Page.RightMargin)/sumDynamicCols;                  
         for (int w = 0; w &lt; (Table2Results.ColumnCount); w++)                 
         {
            Table2Results.Columns[w].Width = widthDynamicCol * Units.Millimeters;
         }      
         
         //Draw Fixed rows
         for (n = 0; n &lt; Table2Results.FixedRows; n++)
         {
            Table2Results.PrintRow(n);
            Table2Results.PrintColumns();                                             
         }
                                
         //Fill table with data
         n = 0;
         for (int z = 0; z &lt; (listTable2Results.Count/listPRsInfo.Count); z++)                    
         {
            for (int j = 0; j &lt; listPRsInfo.Count; j++)                    
            {
               //RowSpans    
               SerRow2.RowSpan = listPRsInfo.Count;//+1;
               
               //Fill cells with data
               SerRow2.Text =  String.Format(&quot;{0}/{1}&quot;, listTable2Results[n].Ser, listTable2Results[n].Row);//+ &quot; | &quot; + (n+1).ToString();
               PR.Text = tools.GetNormalizedValue(listTable2Results[n].PR);
               Q_jik.Text = tools.GetNormalizedValue(listTable2Results[n].Q_jik);
               N_jik.Text =  tools.GetNormalizedValue(listTable2Results[n].N_jik);
               K_jik.Text = tools.GetNormalizedValue(listTable2Results[n].K_jik);
               t_PR_jik.Text = tools.GetNormalizedValue(listTable2Results[n].t_PR_jik);
               P_PR_jik.Text = tools.GetNormalizedValue(listTable2Results[n].P_PR_jik);
               Beta_jik.Text = tools.GetNormalizedValue(listTable2Results[n].Beta_jik);
               n++;

               Table2Results.PrintRow(3);     
               Table2Results.PrintColumns();  
            }
            SerRow2.RowSpan =  1;
            initialHeight = baseRowTable2Results.Height;
            baseRowTable2Results.Height = 0;
            Table2Results.PrintRow(3);     
            Table2Results.PrintColumns();  
            baseRowTable2Results.Height= initialHeight;
         }
      }
      //// ======================== //// ======================== //// ======================== ////
      private void Table3Results_ManualBuild(object sender, EventArgs e)
      {              

         //Setup Columns width
            int sumDynamicCols=Table3Results.ColumnCount;
            float widthDynamicCol=(Page.PaperWidth-Page.LeftMargin-Page.RightMargin)/sumDynamicCols;                  
            for (int w = 0; w &lt; (Table3Results.ColumnCount); w++)                 
            {
               Table3Results.Columns[w].Width = widthDynamicCol * Units.Millimeters;
            }      
         
            //Draw Fixed rows 
            for (int n = 0; n &lt; Table3Results.FixedRows; n++)
            {
               Table3Results.PrintRow(n);
               Table3Results.PrintColumns();                                             
            }
              
            //Fill table with data
            for (int n = 0; n &lt; (listTable3Results.Count); n++)
            {
               SerRow3_1.Text =  String.Format(&quot;{0}/{1}&quot;, listTable3Results[n].Ser, listTable3Results[n].Row);
               Q_ji.Text = tools.GetNormalizedValue(listTable3Results[n].Q_ji);
               T_ji.Text = tools.GetNormalizedValue(listTable3Results[n].T_ji);
               Dens_ji.Text = tools.GetNormalizedValue(listTable3Results[n].Dens_ji);
               DensTemp_ji.Text =tools.GetNormalizedValue( listTable3Results[n].DensTemp_ji);
               DensPress_ji.Text = tools.GetNormalizedValue(listTable3Results[n].DensPress_ji);
               KinVisc_ji.Text = tools.GetNormalizedValue(listTable3Results[n].KinVisc_ji);
               t_UPR_ji.Text = tools.GetNormalizedValue(listTable3Results[n].t_UPR_ji);
            
               Table3Results.PrintRow(3);     
               Table3Results.PrintColumns();  
            }                                                 
      }
      //// ======================== //// ======================== //// ======================== ////
      private void Table3ResultsEnding_ManualBuild(object sender, EventArgs e)
      {     
         //Setup Columns widths as previous table
         for (int i = 0; i &lt; (Table3ResultsEnding.ColumnCount); i++)
         {          
            Table3ResultsEnding.Columns[i].Width =  Table3Results.Columns[i].Width;
         }

            //Draw Fixed rows
            for (int n = 0; n &lt; Table3ResultsEnding.FixedRows; n++)
            {
               Table3ResultsEnding.PrintRow(n);
               Table3ResultsEnding.PrintColumns();                                             
            }
                                                                   
         //Fill table with data
         for (int n = 0; n &lt; (listTable3Results.Count); n++)
         {
            SerRow3_2.Text =  String.Format(&quot;{0}/{1}&quot;, listTable3Results[n].Ser, listTable3Results[n].Row);                                                              
            P_UPR_ji.Text =  tools.GetNormalizedValue(listTable3Results[n].P_UPR_ji);
            f_ji.Text =  tools.GetNormalizedValue(listTable3Results[n].f_ji);
            N_ji.Text =  tools.GetNormalizedValue(listTable3Results[n].N_ji);
            K_ji.Text =  tools.GetNormalizedValue(listTable3Results[n].K_ji);
         
            Table3ResultsEnding.PrintRow(3);                                                                                                                                                                                  
            Table3ResultsEnding.PrintColumns();  
         }
      }
      //// ======================== //// ======================== //// ======================== ////
      private void Table4Results_ManualBuild(object sender, EventArgs e)
      {
         List &lt;TN.Doc.Table4&gt; listTable4Results;
         listTable4Results = DataIVK.TablePoverka3265_UPR_PR.Protokol.Table4.Where(i =&gt; ! i.Point.Contains(&quot;-&quot;) &amp; String.IsNullOrEmpty(i.Point) == false).ToList();

         //Setup Columns width
         int sumDynamicCols=Table4Results.ColumnCount;
         float widthDynamicCol=(Page.PaperWidth-Page.LeftMargin-Page.RightMargin)/sumDynamicCols;                  
         for (int w = 0; w &lt; (Table4Results.ColumnCount); w++)                 
         {
            Table4Results.Columns[w].Width = widthDynamicCol * Units.Millimeters;
         }      
         
         //Draw Fixed rows 
         for (int n = 0; n &lt; Table4Results.FixedRows; n++)
         {
            Table4Results.PrintRow(n);
            Table4Results.PrintColumns();                                             
         }
         
         //Fill table with data
         for (int n = 0; n &lt; (listTable4Results.Count); n++)
         {
            Point.Text =  listTable4Results[n].Point;                                                          
            Q_j.Text =  tools.GetNormalizedValue(listTable4Results[n].Q_j);
            f_j.Text =  tools.GetNormalizedValue(listTable4Results[n].f_j);
            K_j.Text =  tools.GetNormalizedValue(listTable4Results[n].K_j);
            S_j.Text =  tools.GetNormalizedValue(listTable4Results[n].S_j);
            n_j.Text =  tools.GetNormalizedValue(listTable4Results[n].n_j);
            S0_j.Text =  tools.GetNormalizedValue(listTable4Results[n].S0_j);
            t095_j.Text =  tools.GetNormalizedValue(listTable4Results[n].t095_j);
            e_j.Text =  tools.GetNormalizedValue(listTable4Results[n].e_j);
            
            Table4Results.PrintRow(3);                                                                                                                                                                                  
            Table4Results.PrintColumns();  
         }
      }
       //// ======================== //// ======================== //// ======================== ////
      private void Table5Results_ManualBuild(object sender, EventArgs e)
      {
         //Setup Columns width
         int sumDynamicCols=Table5Results.ColumnCount;
         float widthDynamicCol=(Page.PaperWidth-Page.LeftMargin-Page.RightMargin)/sumDynamicCols;                  
         for (int w = 0; w &lt; (Table5Results.ColumnCount); w++)                 
         {
            Table5Results.Columns[w].Width = widthDynamicCol * Units.Millimeters;
         }      
         
         //Draw Fixed rows 
         for (int n = 0; n &lt; Table5Results.FixedRows; n++)
         {
            Table5Results.PrintRow(n);
            Table5Results.PrintColumns();                                             
         }
         
         Q_min.Text = tools.GetNormalizedValue(DataIVK.TablePoverka3265_UPR_PR.Protokol.Table5.Q_min);
         Q_max.Text = tools.GetNormalizedValue(DataIVK.TablePoverka3265_UPR_PR.Protokol.Table5.Q_max);
         K.Text = tools.GetNormalizedValue(DataIVK.TablePoverka3265_UPR_PR.Protokol.Table5.K);
         S0.Text = tools.GetNormalizedValue(DataIVK.TablePoverka3265_UPR_PR.Protokol.Table5.S0);
         e5.Text = tools.GetNormalizedValue(DataIVK.TablePoverka3265_UPR_PR.Protokol.Table5.e);
         Teta_A.Text = tools.GetNormalizedValue(DataIVK.TablePoverka3265_UPR_PR.Protokol.Table5.Teta_A);
         Teta_t.Text = tools.GetNormalizedValue(DataIVK.TablePoverka3265_UPR_PR.Protokol.Table5.Teta_t);
         Teta_Sum.Text = tools.GetNormalizedValue(DataIVK.TablePoverka3265_UPR_PR.Protokol.Table5.Teta_Sum);
         Delta.Text = tools.GetNormalizedValue(DataIVK.TablePoverka3265_UPR_PR.Protokol.Table5.Delta);
         
         Table5Results.PrintRow(3);                                                                                                                                                                                  
         Table5Results.PrintColumns();  
      
      }
      //// ======================== //// ======================== //// ======================== ////
      public void  DrawTableConclusion()
      {                                                    
         // Setup Cols width    
         TableConclusion3.Columns[0].Width=(Page.PaperWidth-Page.LeftMargin-Page.RightMargin)  * Units.Millimeters;
        
         // Fill Table with data
         ARM_Poverka_Result.Text = DataIVK.TablePoverka3265_UPR_PR.AdditionalInfo.ARM_Poverka_Result;
         StaffData.Text = DataIVK.TablePoverka3265_UPR_PR.AdditionalInfo.StaffData;
         DateTimeLong.Text = string.Format(&quot;Дата проведения поверки: &lt;u&gt;{0:dd.MM.yyyy} г.&quot;,
            (tools.UnixTimestampToDatetime(DataIVK.TablePoverka3265_UPR_PR.DateTimeLong)));               
         PageNumeration.Width = (Page.PaperWidth-Page.LeftMargin-Page.RightMargin)*Units.Millimeters; 
      }  
      
      //// ======================== //// ======================== //// ======================== ////
      //// Setup heights of the all objects on the Page
      private void PageFooter_BeforeLayout(object sender, EventArgs e)
      {
         if((Int32)Report.GetVariableValue(&quot;TotalPages&quot;) &lt; 2) 
         { 
            PageFooter.Visible = false; 
         }
         else
         {
            PageNumeration.Width = (Page.PaperWidth-Page.LeftMargin-Page.RightMargin)*Units.Millimeters;
         }
      }
   }    
}

