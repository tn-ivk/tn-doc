using System;
using System.Reflection;
using System.Collections;
using System.Collections.Generic;
using System.ComponentModel;         
using System.Drawing;
using System.Data;
using System.IO;
using FastReport;
using FastReport.Data;
using FastReport.Dialog;
using FastReport.Barcode;
using FastReport.Table;
using FastReport.Utils;
using System.Linq;
using Newtonsoft.Json;
using TN.DocData;

namespace FastReport
{
  public class ReportScript
  {
      
    TN_ToolsFastReport.Tools tools = new TN_ToolsFastReport.Tools();  // классы отчета
    TN.Doc.Doc doc; // данные из входного параметра
    TN.DocData.General General;
    TN.Doc.HeaderDoc Header;
    TN.Doc.DataDoc SettingsData;
    TN.Doc.FooterDoc Footer;
    TN.Doc.DictionarysDoc Dictionarys;
    TN.Doc.DataIVKDoc DataIVK;      
    
    List &lt;TN.Doc.Table1_1&gt; listTable1SourceData;
    List &lt;TN.Doc.Table2&gt; listTable2Results;
    List &lt;TN.Doc.Table3&gt; listTable3Results;
    List &lt;TN.Doc.Table4&gt; listTable4Results;

    private void Page_StartPage(object sender, EventArgs e)
    {
      //using (var sr = new StreamReader(&quot;D:/!_Work/!_Транснефть/SVN/Work/Sources/Reports/FRX/Входящие данные от Алексея (классы и json)/10_TablePoverka3287/DocPoverka3287.json&quot;))
      //{
      // Read the stream as a string
      //   Report.SetParameterValue(&quot;Protocol&quot;, sr.ReadToEnd());
      //}
         
      //// Десериализация данных (формат json) из входного параметра - Json                         
      string json = (string)Report.GetParameterValue(&quot;JsonDoc&quot;);
      Newtonsoft.Json.JsonSerializerSettings settings = new Newtonsoft.Json.JsonSerializerSettings();
      settings.TypeNameHandling = TypeNameHandling.All;
         
      doc = JsonConvert.DeserializeObject&lt;TN.Doc.Doc&gt;(json, settings);
      General = (TN.DocData.General) doc.Doc.Settings.General;
      Header = (TN.Doc.HeaderDoc) doc.Doc.Settings.Header;
      SettingsData = (TN.Doc.DataDoc) doc.Doc.Settings.Data;
      Footer = (TN.Doc.FooterDoc) doc.Doc.Settings.Footer;
      Dictionarys = (TN.Doc.DictionarysDoc) doc.Doc.Settings.Dictionarys;  
      DataIVK = (TN.Doc.DataIVKDoc) doc.Doc.DataIVK;
         
      //// === Настройки страницы 
      // Ширина и высота (в мм)
         
      Page.PaperHeight = General.PageSettings.PaperHeight;
      Page.PaperWidth = General.PageSettings.PaperWidth;
      //Page.Border.Lines = BorderLines.All;
         
      // Поля/отступы от краёв (в мм)
      Page.TopMargin = General.PageSettings.TopMargin;
      Page.BottomMargin = General.PageSettings.BottomMargin;
      Page.LeftMargin = General.PageSettings.LeftMargin;
      Page.RightMargin = General.PageSettings.RightMargin;
                                                                
      // Load Data from classes
      listTable1SourceData = DataIVK.TablePoverka3287.Protokol.Table1_1.Where(i =&gt; i.DetName.Length &gt; 1 | ! i.DetName.Contains(&quot;&quot;)).ToList();
      listTable2Results = DataIVK.TablePoverka3287.Protokol.Table2.Where(i =&gt; i.Activated==1).ToList();
      listTable3Results = DataIVK.TablePoverka3287.Protokol.Table3.Where(i =&gt; ! i.Point.Contains(&quot;-&quot;) &amp; String.IsNullOrEmpty(i.Point) == false).ToList();
      listTable4Results = DataIVK.TablePoverka3287.Protokol.Table4.Where(i =&gt; ! i.Q_min.Contains(&quot;-&quot;)   &amp; String.IsNullOrEmpty(i.Q_min) == false).ToList();
         
      // Запуск отрисовки таблиц на странице отчета
         
      if (DataIVK.TablePoverka3287.Protokol.ActivatedTables[0].Table0==1)
      {               
        DrawTableHeader();    
      }
      DrawTableConclusion();
    }
    #region //Имхо лишний метод
    private void PrintTable(TableObject table)
    {
      for (int i=0;i&lt;table.RowCount;i++)
      {       
        table.PrintRow(i);
        table.PrintColumns();
      }    
    } 
    #endregion
      
    public void DrawTableHeader()
    {
      // Setup Columns
         
      // Setup rows

      // Fill table with data   
      ProtokolNum.Text = &quot;Протокол № &quot;  +  DataIVK.TablePoverka3287.AdditionalInfo.ProtokolNum;
      Place.Text = DataIVK.TablePoverka3287.AdditionalInfo.Place;
      PR_Type.Text = DataIVK.TablePoverka3287.AdditionalInfo.PR_Type;
      PU_Type.Text = DataIVK.TablePoverka3287.AdditionalInfo.PU_Type;
      IVK_Type.Text = DataIVK.TablePoverka3287.AdditionalInfo.IVK_Type;
      PR_FactoryNumber.Text = DataIVK.TablePoverka3287.AdditionalInfo.PR_FactoryNumber;
      PU_FactoryNumber.Text = DataIVK.TablePoverka3287.AdditionalInfo.PU_FactoryNumber;
      IVK_FactoryNumber.Text = DataIVK.TablePoverka3287.AdditionalInfo.IVK_FactoryNumber;
      PR_LineName.Text = DataIVK.TablePoverka3287.AdditionalInfo.PR_LineName;
      OilType.Text = DataIVK.TablePoverka3287.Protokol.Table0[0].OilType;
      Visc.Text = DataIVK.TablePoverka3287.Protokol.Table0[0].Visc;
    }
              
    private void Table1SourceData_ManualBuild(object sender, EventArgs e)
    {
      if (DataIVK.TablePoverka3287.Protokol.ActivatedTables[0].Table1==1)
      { 
        //Setup Columns width
        int sumDynamicCols=Table1SourceData.ColumnCount;
        float widthDynamicCol=(Page.PaperWidth-Page.LeftMargin-Page.RightMargin)/sumDynamicCols;                  
 
        for (int w = 0; w &lt; (Table1SourceData.ColumnCount); w++)                 
        {
          Table1SourceData.Columns[w].Width = widthDynamicCol * Units.Millimeters;
        }      
                            
        //Draw Fixed rows
        for (int n = 0; n &lt; Table1SourceData.FixedRows; n++)
        {
          Table1SourceData.PrintRow(n);
          Table1SourceData.PrintColumns();                                             
        }
         
        //Fill table with data
        for (int n = 0; n &lt; (listTable1SourceData.Count); n++)
        {
          DetName.Text =  listTable1SourceData[n].DetName;
                                       
            
          V0.Text =  tools.GetNormalizedValue(listTable1SourceData[n].V0);
          m_D.Text = tools.GetNormalizedValue(DataIVK.TablePoverka3287.Protokol.Table1[0].m_D);
          m_S.Text = tools.GetNormalizedValue(DataIVK.TablePoverka3287.Protokol.Table1[0].m_S);
          m_E.Text = tools.GetNormalizedValue(DataIVK.TablePoverka3287.Protokol.Table1[0].m_E);
          Alpha_t.Text = tools.GetNormalizedValue(DataIVK.TablePoverka3287.Protokol.Table1[0].Alpha_t);
          Alpha_k1.Text = tools.GetNormalizedValue(DataIVK.TablePoverka3287.Protokol.Table1[0].Alpha_k1);
          Alpha_D.Text = tools.GetNormalizedValue(DataIVK.TablePoverka3287.Protokol.Table1[0].Alpha_D);
          Teta_Sum_0.Text =  tools.GetNormalizedValue(listTable1SourceData[n].Teta_Sum_0);
           
          //RowSpans
          for (int i = 0; i &lt; (Table1SourceData.ColumnCount); i++)
          {          
            switch(i)
            {
              case 2:
              case 3:  
              case 4:
              case 5:  
              case 6:     
              case 7:      
                Table1SourceData[i,3].RowSpan =  listTable1SourceData.Count;
                break;  
            }
          }
          //PrintTable(Table1SourceData);
          Table1SourceData.PrintRow(3);     
          Table1SourceData.PrintColumns();  
        }
      }       
    }
      
    private void Table1SourceDataEnding_ManualBuild(object sender, EventArgs e)
    {
      if (DataIVK.TablePoverka3287.Protokol.ActivatedTables[0].Table1==1)
      { 
        //Setup Columns width as in the previous table
        for (int i = 0; i &lt; (Table1SourceDataEnding.ColumnCount); i++)
        {          
          Table1SourceDataEnding.Columns[i].Width =  Table1SourceData.Columns[i].Width;
        }
         
        //Draw Fixed rows
        for (int n = 0; n &lt; Table1SourceDataEnding.FixedRows; n++)
        {
          Table1SourceDataEnding.PrintRow(n);
          Table1SourceDataEnding.PrintColumns();                                             
        }
         
        //Fill table with data
        for (int n = 0; n &lt; (listTable1SourceData.Count); n++)
        {
          Teta_V_0.Text =  tools.GetNormalizedValue(listTable1SourceData[n].Teta_V_0);
          Delta_t_PU.Text = tools.GetNormalizedValue(DataIVK.TablePoverka3287.Protokol.Table1[0].Delta_t_PU);
          Delta_t_PR.Text = tools.GetNormalizedValue(DataIVK.TablePoverka3287.Protokol.Table1[0].Delta_t_PR);
          Delta_IVK.Text = tools.GetNormalizedValue(DataIVK.TablePoverka3287.Protokol.Table1[0].Delta_IVK);
          Delta_Visc.Text = tools.GetNormalizedValue(DataIVK.TablePoverka3287.Protokol.Table1[0].Delta_Visc);
               
          if (DataIVK.TablePoverka3287.Protokol.Table0[0].UseMF == 0)
            KF.Text = &quot;-&quot;;
          else
            KF.Text = tools.GetNormalizedValue(DataIVK.TablePoverka3287.Protokol.Table1[0].KF);
              
          //RowSpans
          for (int i = 0; i &lt; (Table1SourceDataEnding.ColumnCount); i++)
          {          
            switch(i)
            {
              case 1:
              case 2:
              case 3:   
              case 4:   
              case 5:
                Table1SourceDataEnding[i,3].RowSpan =  listTable1SourceData.Count;
                break;
            }
          }
          Table1SourceDataEnding.PrintRow(3);     
          Table1SourceDataEnding.PrintColumns();  
        }
      }                       
    }

    private void Table2Results_ManualBuild(object sender, EventArgs e)
    {      
      if (DataIVK.TablePoverka3287.Protokol.ActivatedTables[0].Table2==1)
      { 
        //Setup Columns width
        int sumDynamicCols=Table2Results.ColumnCount;
        float widthDynamicCol=(Page.PaperWidth-Page.LeftMargin-Page.RightMargin)/sumDynamicCols;                  
        for (int w = 0; w &lt; (Table2Results.ColumnCount); w++)                 
        {
          Table2Results.Columns[w].Width = widthDynamicCol * Units.Millimeters;
        }      
         
        //Draw Fixed rows
        for (int n = 0; n &lt; Table2Results.FixedRows; n++)
        {
          Table2Results.PrintRow(n);
          Table2Results.PrintColumns();                                             
        }
        
        //Fill table with data
        for (int n = 0; n &lt; (listTable2Results.Count); n++)
        {
          SerRow.Text =  String.Format(&quot;{0}/{1}&quot;, listTable2Results[n].Ser, listTable2Results[n].Row);//+ &quot; | &quot; + (n+1).ToString();
          Q_ji.Text = tools.GetNormalizedValue(listTable2Results[n].Q_ji);
          Detector.Text =  tools.GetNormalizedValue(listTable2Results[n].Detector);
          T_ji.Text = tools.GetNormalizedValue(listTable2Results[n].T_ji);
          t_PU_ji.Text = tools.GetNormalizedValue(listTable2Results[n].t_PU_ji);
          P_PU_ji.Text = tools.GetNormalizedValue(listTable2Results[n].P_PU_ji);
          t_D_ji.Text = tools.GetNormalizedValue(listTable2Results[n].t_D_ji);
          Dens_ji.Text = tools.GetNormalizedValue(listTable2Results[n].Dens_ji);
          DensTemp_ji.Text =  tools.GetNormalizedValue(listTable2Results[n].DensTemp_ji);
            
          Table2Results.PrintRow(3);     
          Table2Results.PrintColumns();  
        }
      }               
    }

    private void Table2ResultsEnding_ManualBuild(object sender, EventArgs e)
    {
      if (DataIVK.TablePoverka3287.Protokol.ActivatedTables[0].Table2==1)
      { 
        //Setup Columns widths as previous table
        for (int i = 0; i &lt; (Table2ResultsEnding.ColumnCount); i++)
        {          
          Table2ResultsEnding.Columns[i].Width =  Table2Results.Columns[i].Width;
        }
         
        //Draw Fixed rows
        for (int n = 0; n &lt; Table2ResultsEnding.FixedRows; n++)
        {
          Table2ResultsEnding.PrintRow(n);
          Table2ResultsEnding.PrintColumns();                                             
        }
        
        if (DataIVK.TablePoverka3287.Protokol.Table0[0].UseMF == 0)
          T2_K_MF.Text = &quot;K&lt;sub&gt; jI &lt;/sub&gt;,&lt;br&gt;имп/м&lt;sup&gt;3&lt;/sup&gt;&quot;;
        else
          T2_K_MF.Text = &quot;MF&lt;sub&gt;jI&lt;/sub&gt;,&lt;br&gt;имп/м&lt;sup&gt;3&lt;/sup&gt;&quot;;
        
        //Fill table with data
        for (int n = 0; n &lt; (listTable2Results.Count); n++)
        {
          SerRow2.Text =  String.Format(&quot;{0}/{1}&quot;, listTable2Results[n].Ser, listTable2Results[n].Row);//+ &quot; | &quot; + (n+1).ToString();
          DensPress_ji.Text =  tools.GetNormalizedValue(listTable2Results[n].DensPress_ji);
          Beta_ji.Text = tools.GetNormalizedValue(listTable2Results[n].Beta_ji);
          v_ji.Text = tools.GetNormalizedValue(listTable2Results[n].v_ji);
          t_PR_ji.Text = tools.GetNormalizedValue( listTable2Results[n].t_PR_ji);
          P_PR_ji.Text = tools.GetNormalizedValue(listTable2Results[n].P_PR_ji);
          f_ji.Text =tools.GetNormalizedValue( listTable2Results[n].f_ji);
          N_ji.Text = tools.GetNormalizedValue(listTable2Results[n].N_ji);
          K_MF_ji.Text = tools.GetNormalizedValue(listTable2Results[n].K_MF_ji);

          Table2ResultsEnding.PrintRow(3);     
          Table2ResultsEnding.PrintColumns();  
        }
      }       
    }
      
    private void Table3Results_ManualBuild(object sender, EventArgs e)
    {
      if (DataIVK.TablePoverka3287.Protokol.ActivatedTables[0].Table3==1)
      { 
        //Setup Columns width
        int sumDynamicCols=Table3Results.ColumnCount;
        float widthDynamicCol=(Page.PaperWidth-Page.LeftMargin-Page.RightMargin)/sumDynamicCols;                  
        for (int w = 0; w &lt; (Table3Results.ColumnCount); w++)                 
        {
          Table3Results.Columns[w].Width = widthDynamicCol * Units.Millimeters;
        }      
         
        //Draw Fixed rows 
        for (int n = 0; n &lt; Table3Results.FixedRows; n++)
        {
          Table3Results.PrintRow(n);
          Table3Results.PrintColumns();                                             
        }

        if (DataIVK.TablePoverka3287.Protokol.Table0[0].UseMF == 0)
          T3_K_MF.Text = &quot;K &lt;sub&gt;j&lt;/sub&gt;,&lt;br&gt;имп/м&lt;sup&gt;3&lt;/sup&gt;&quot;;
        else
          T3_K_MF.Text = &quot;MF&lt;sub&gt;j&lt;/sub&gt;,&lt;br&gt;имп/м&lt;sup&gt;3&lt;/sup&gt;&quot;;
        
        //Fill table with data
        for (int n = 0; n &lt; (listTable3Results.Count); n++)
        {
          Point.Text =  listTable3Results[n].Point;
          Q_j.Text = tools.GetNormalizedValue(listTable3Results[n].Q_j);
          f_j.Text =  tools.GetNormalizedValue(listTable3Results[n].f_j);
          K_MF_j.Text = tools.GetNormalizedValue(listTable3Results[n].K_MF_j);
          S_j.Text =tools.GetNormalizedValue( listTable3Results[n].S_j);
          n_j.Text = tools.GetNormalizedValue(listTable3Results[n].n_j);
          S0_j.Text = tools.GetNormalizedValue(listTable3Results[n].S0_j);
          t095_j.Text = tools.GetNormalizedValue(listTable3Results[n].t095_j);
          e_j.Text =  tools.GetNormalizedValue(listTable3Results[n].e_j);
            
          Table3Results.PrintRow(3);     
          Table3Results.PrintColumns();  
        }
      }  
    }

    private void Table4Results_ManualBuild(object sender, EventArgs e)
    {     
      if (DataIVK.TablePoverka3287.Protokol.ActivatedTables[0].Table4==1)
      { 
        //Setup Columns width
        int sumDynamicCols=Table4Results.ColumnCount;
        float widthDynamicCol=(Page.PaperWidth-Page.LeftMargin-Page.RightMargin)/sumDynamicCols;                  
        for (int w = 0; w &lt; (Table4Results.ColumnCount); w++)                 
        {
          Table4Results.Columns[w].Width = widthDynamicCol * Units.Millimeters;
        }      
         
        //Draw Fixed rows
        for (int n = 0; n &lt; Table4Results.FixedRows; n++)
        {
          Table4Results.PrintRow(n);
          Table4Results.PrintColumns();                                             
        }

        //Fill table with data
        for (int n = 0; n &lt; (listTable4Results.Count); n++)
        {
          Q_min.Text =  tools.GetNormalizedValue(listTable4Results[n].Q_min);
          Q_max.Text = tools.GetNormalizedValue(listTable4Results[n].Q_max);
          v_min.Text =  tools.GetNormalizedValue(listTable4Results[n].v_min);
          v_max.Text = tools.GetNormalizedValue(listTable4Results[n].v_max);
          S0.Text =tools.GetNormalizedValue( listTable4Results[n].S0);
          ee.Text =tools.GetNormalizedValue( listTable4Results[n].e);
          Teta_A.Text =tools.GetNormalizedValue( listTable4Results[n].Teta_A);
          Teta_t.Text =tools.GetNormalizedValue( listTable4Results[n].Teta_t);
          Teta_Sum.Text = tools.GetNormalizedValue( listTable4Results[n].Teta_Sum);
          Delta.Text =  tools.GetNormalizedValue(listTable4Results[n].Delta);
            
          Table4Results.PrintRow(3);     
          Table4Results.PrintColumns();  
        }
      }     
    }

    public void  DrawTableConclusion()
    {                                                    
      TableConclusion3.Columns[0].Width=(Page.PaperWidth-Page.LeftMargin-Page.RightMargin)  * Units.Millimeters;
         
      ARM_Poverka_Result.Text = DataIVK.TablePoverka3287.AdditionalInfo.ARM_Poverka_Result;
      StaffData.Text = DataIVK.TablePoverka3287.AdditionalInfo.StaffData;
      DateTimeLong.Text = string.Format(&quot;Дата проведения поверки: &lt;u&gt;{0:dd.MM.yyyy} г.&quot;,(tools.UnixTimestampToDatetime(DataIVK.TablePoverka3287.DateTimeLong)));               
      PageNumeration.Width = (Page.PaperWidth-Page.LeftMargin-Page.RightMargin)*Units.Millimeters; 
    } 

    private void PageFooter_BeforeLayout(object sender, EventArgs e)
    {
      if((Int32)Report.GetVariableValue(&quot;TotalPages&quot;) &lt; 2) 
      { 
        PageFooter.Visible = false; 
      }
      else
      {
        PageNumeration.Width = (Page.PaperWidth-Page.LeftMargin-Page.RightMargin)*Units.Millimeters;
      }
    }
  }    
}

