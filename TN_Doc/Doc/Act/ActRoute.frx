namespace FastReport
{
  public class ReportScript
  {
    TN_ToolsFastReport.Tools tools = new TN_ToolsFastReport.Tools();      
    TN.Doc.Doc doc;
    TN.DocData.General General;
    TN.Doc.DataIVKDoc DataIVK;
    TN.Doc.HeaderDoc Header;
    TN.Doc.DataDoc SettingsData;
    TN.Doc.FooterDoc Footer;
    TN.Doc.DictionarysDoc Dictionarys;
     
    private void Page_StartPage(object sender, EventArgs e)
    {   
      //// Десериализация данных (формат json) из входного параметра - Json                         
      string json = (string)Report.GetParameterValue(&quot;JsonDoc&quot;);
      Newtonsoft.Json.JsonSerializerSettings settings = new Newtonsoft.Json.JsonSerializerSettings();
      settings.TypeNameHandling = TypeNameHandling.All;
         
      doc = JsonConvert.DeserializeObject&lt;TN.Doc.Doc&gt;(json, settings);
      General = (TN.DocData.General) doc.Doc.Settings.General;
      DataIVK = (TN.Doc.DataIVKDoc)doc.Doc.DataIVK;
      Header = (TN.Doc.HeaderDoc)doc.Doc.Settings.Header;
      SettingsData = (TN.Doc.DataDoc)doc.Doc.Settings.Data;
      Footer = (TN.Doc.FooterDoc)doc.Doc.Settings.Footer;
      Dictionarys = (TN.Doc.DictionarysDoc)doc.Doc.Settings.Dictionarys;  
      
      // === Настройки страницы 
      // Ширина и высота (в мм)
      Page.PaperHeight = General.PageSettings.PaperHeight;
      Page.PaperWidth = General.PageSettings.PaperWidth;
      //Page.Border.Lines = BorderLines.All;
         
      // Поля/отступы от краёв (в мм)
      Page.TopMargin = General.PageSettings.TopMargin;
      Page.BottomMargin = General.PageSettings.BottomMargin;
      Page.LeftMargin = General.PageSettings.LeftMargin;
      Page.RightMargin = General.PageSettings.RightMargin;
         
      // Запуск отрисовки таблиц на странице отчета
      DrawTableHeader();
      DrawTableSigners();
    }
      
    public void DrawTableHeader()
    {             
      DateTime End =  tools.UnixTimestampToDatetime((long)DataIVK.TableRouteActs.Route.RouteActDate);
      
      ActNumberAndDate.Text = string.Format(&quot;Акт приема-сдачи нефти №&lt;u&gt; {0}&lt;/u&gt; от &lt;u&gt;{1:dd.MM.yyyy}&lt;/u&gt; г. (сдача по СИКН)&quot;,  
        DataIVK.TableRouteActs.Route.RouteActNumber,
        End);                            
         
      DelivePoint.Text = DataIVK.TableRouteActs.RouteData.Psp;
      Factory.Text = DataIVK.TableRouteActs.RouteData.Factory;
      SIKN_Number.Text = DataIVK.TableRouteActs.RouteData.SIKN_Number;
      Contract.Text = DataIVK.TableRouteActs.RouteData.Contract;
      Route_Telegram.Text = DataIVK.TableRouteActs.RouteData.RouteInstruction;
      Refinery_Plant.Text = DataIVK.TableRouteActs.RouteData.Producer;
      Consignor.Text = DataIVK.TableRouteActs.RouteData.Consigner;
      SubsurfaceUser.Text = DataIVK.TableRouteActs.RouteData.SubsurfaceUser;
      FirstOwnerPetroleum.Text = DataIVK.TableRouteActs.RouteData.FirstOwner;
      LastOwnerPetroleum.Text = DataIVK.TableRouteActs.RouteData.LastOwner;
      Consignee.Text = DataIVK.TableRouteActs.RouteData.Consignees != null &amp;&amp; DataIVK.TableRouteActs.RouteData.Consignees.Count &gt; 0 ? DataIVK.TableRouteActs.RouteData.Consignees[0] : &quot;&quot;;
      Destination.Text = DataIVK.TableRouteActs.RouteData.DestinationPoint;
      Exporter_Importer.Text = DataIVK.TableRouteActs.RouteData.Exporter;
      Declaration.Text = DataIVK.TableRouteActs.RouteData.CustomsDeclaration;
      Delive_FIO.Text = DataIVK.TableRouteActs.RouteData.Delive_FIO;
      Delive_Lic_Date.Text = DataIVK.TableRouteActs.RouteData.Delive_Lic_Date;
      Delive_Lic_Number.Text = DataIVK.TableRouteActs.RouteData.Delive_Lic_Number;
      Receive_FIO.Text = DataIVK.TableRouteActs.RouteData.Receive_FIO;
      Receive_Lic_Date.Text = DataIVK.TableRouteActs.RouteData.Receive_Lic_Date;
      Receive_Lic_Number.Text = DataIVK.TableRouteActs.RouteData.Receive_Lic_Number;
    }

    private void TableAct_ManualBuild(object sender, EventArgs e)
    {
      List&lt;TN.Doc.ActShift&gt; listShiftsData = DataIVK.TableRouteActs.Route.ActShifts.Where(x =&gt; !string.IsNullOrEmpty(x.GostIndex51858)).ToList();
      if(!listShiftsData.Any())
        return;
        
      if (Engine.FinalPass == true)
      {
        // Calculate Dynamic Columns width
        float widthDynamicCols=(
          Page.PaperWidth-
          Page.LeftMargin-
          Page.RightMargin-
          TableAct.Columns[0].Width/Units.Millimeters-
          TableAct.Columns[1].Width/Units.Millimeters)
          /listShiftsData.Count;         

        // Insert Columns for Volumes  (V0) &amp; fill them headers with text
        int indexColTemplate = ColumnTemplate.Index;
        for (int i=1; i&lt;listShiftsData.Count; i++)
        {
          TableAct.Columns.Insert(indexColTemplate+1, new TableColumn());
          
          foreach(TableRow row in TableAct.Rows)
            row[indexColTemplate+1].AssignAll(row[indexColTemplate]);
        }
            
        // Setup Dynamic Columns Width
        for (int i = indexColTemplate; i &lt; TableAct.ColumnCount; i++)                 
        {
          TableAct.Columns[i].Width = widthDynamicCols*Units.Millimeters;
        }
            
        // Span Columns
        TableAct[indexColTemplate,0].ColSpan=listShiftsData.Count;
        
        for (int i = 0; i &lt; (listShiftsData.Count); i++)                 
        {
          DateTime Begin = new DateTime(1970, 1, 1, 0, 0, 0, DateTimeKind.Utc).AddSeconds(listShiftsData[i].Period.Begin);
          DateTime End = new DateTime(1970, 1, 1, 0, 0, 0, DateTimeKind.Utc).AddSeconds(listShiftsData[i].Period.End);
          
          Period.Text = $&quot;{Begin.ToShortDateString()} {Begin.ToString(&quot;HH:mm&quot;)}&lt;br&gt;{End.ToShortDateString()} {End.ToString(&quot;HH:mm&quot;)}&quot;;
          
          TableAct[(2+i),1].Text = $&quot;{Begin.ToShortDateString()} {Begin.ToString(&quot;HH:mm&quot;)}&lt;br&gt;{End.ToShortDateString()} {End.ToString(&quot;HH:mm&quot;)}&quot;;
          TableAct[(2+i),3].Text = listShiftsData[i].Vol_LastShift.ToString();
          TableAct[(2+i),4].Text = listShiftsData[i].Mass_LastShift.ToString();
          TableAct[(2+i),6].Text = listShiftsData[i].Vol_CurrShift.ToString();
          TableAct[(2+i),7].Text = listShiftsData[i].Mass_CurrShift.ToString();
          TableAct[(2+i),9].Text = (listShiftsData[i].Vol_Gross + listShiftsData[i].DebalanceVolume).ToString();
          TableAct[(2+i),10].Text = (listShiftsData[i].Mass_Gross + listShiftsData[i].DebalanceBrutto).ToString();
          
          TableAct[(2+i),11].Text = listShiftsData[i].Temp.ToString(&quot;F1&quot;);
          TableAct[(2+i),12].Text = listShiftsData[i].Press.ToString(&quot;F2&quot;);
          TableAct[(2+i),13].Text = listShiftsData[i].Density.ToString(&quot;F1&quot;);
          TableAct[(2+i),14].Text = listShiftsData[i].Density_correction.ToString();
          TableAct[(2+i),15].Text = listShiftsData[i].PassportID.ToString();
          TableAct[(2+i),16].Text = listShiftsData[i].Balast_Mass_Frac.ToString(&quot;F4&quot;);
          TableAct[(2+i),18].Text = listShiftsData[i].Ballast.Water.ToString(&quot;F2&quot;);
          TableAct[(2+i),19].Text = listShiftsData[i].Ballast.Chlorides.ToString(&quot;F4&quot;);
          TableAct[(2+i),20].Text = listShiftsData[i].Ballast.Impurity.ToString(&quot;F4&quot;);
          TableAct[(2+i),21].Text = listShiftsData[i].Sulfur.ToString(&quot;F2&quot;);
          TableAct[(2+i),22].Text = listShiftsData[i].Chloride_Salts.ToString(&quot;F1&quot;);
          TableAct[(2+i),23].Text = listShiftsData[i].Balast_Mass.ToString();
          TableAct[(2+i),24].Text = (listShiftsData[i].Net_Mass + listShiftsData[i].DebalanceNetto).ToString();
        }
      }
         
      //Draw rows
      for (int n = 0; n &lt; TableAct.RowCount; n++)
      {
        TableAct.PrintRow(n);
        TableAct.PrintColumns();                                             
      }
    }         
      
    private void TableAdditionlInfo_ManualBuild(object sender, EventArgs e)
    {
      // Setup Last Column width
      TableAdditionlInfo.Columns[0].Width=(Page.PaperWidth-Page.LeftMargin-Page.RightMargin)*Units.Millimeters;
         
      string wholePart = DataIVK.TableRouteActs.WholePart;
      WholePart.Text =  string.Format(&quot;Масса нефти нетто (прописью) &lt;u&gt; {0}&lt;/u&gt; т.&quot;, wholePart);
         
      //Draw static Rows
      TableAdditionlInfo.PrintRow(0);
      TableAdditionlInfo.PrintColumns();                                             
    
      //Fill &amp; Draw dynamic Rows
      var listGostIndex51858 = DataIVK.TableRouteActs.Route.ActShifts.Select(x =&gt; x.GostIndex51858).Where(x =&gt; !String.IsNullOrEmpty(x)).ToList();
      var distListGostIndex51858 = listGostIndex51858.Distinct().ToList();
         
      for (int n = 0; n &lt; distListGostIndex51858.Count; n++)
      {
        GostIndex51858.Text = string.Format(&quot;Обозначение нефти: &lt;u&gt; {0}&lt;/u&gt; по ГОСТ Р 51858.&quot;,  distListGostIndex51858[n]);
        TableAdditionlInfo.PrintRow(1);
        TableAdditionlInfo.PrintColumns();                                             
      }
    }
      
    public void  DrawTableSigners()
    {
      if (Page.PaperWidth == 297)
      {
        if (Engine.FinalPass == true)
        {  
          for (int n = 0; n &lt; TableSigners.ColumnCount; n++)
          {
            TableSigners.Columns[n].Width=(TableSigners.Columns[n].Width*(float)1.455);//*Units.Millimeters;
          }       
        }
      }
         
      Delive_IOF.Text = DataIVK.TableRouteActs.RouteData.Delive_IOF; 
      Receive_IOF.Text = DataIVK.TableRouteActs.RouteData.Receive_IOF;
      if (!string.IsNullOrEmpty(Footer.LabMIDensity))
        LabMIDensity.Text = $&quot;*) заполняют при отказе поточного преобразователя плотности (определяют по {Footer.LabMIDensity})&quot;;
    }  
      
    private void PageFooter_BeforeLayout(object sender, EventArgs e)
    {
      if((Int32)Report.GetVariableValue(&quot;TotalPages&quot;) &lt; 2) 
      { 
        PageFooter.Visible = false; 
      }
      else
      {
        PageNumeration.Width = (Page.PaperWidth-Page.LeftMargin-Page.RightMargin)*Units.Millimeters;
      }
    }
  }    
}</ScriptText>
