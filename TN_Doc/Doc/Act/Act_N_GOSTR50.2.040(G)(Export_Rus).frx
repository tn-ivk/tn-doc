  <ScriptText>using System;
using System.Reflection;
using System.Collections;
using System.Collections.Generic;
using System.ComponentModel;         
using System.Drawing;
using System.Data;
using System.IO;
using FastReport;
using FastReport.Data;
using FastReport.Dialog;
using FastReport.Barcode;
using FastReport.Table;
using FastReport.Utils;
using System.Linq;
using Newtonsoft.Json;
using TN.DocData;

namespace FastReport
{
  // Измы:
  // Форма паспорт на экспорт. Форма взята из ГОСТ 50.2.040(Приложение Ж).
  // Форма отличается от &quot;Act_N_GOSTR50.2.040(G).frx&quot; тем, что в обозначение марки нефти указывается марка для  экспорта
  // Не GostIndexResult,а ExtendGostIndexResult
  public class ReportScript
  {
    TN_ToolsFastReport.Tools tools = new TN_ToolsFastReport.Tools();
    TN.Doc.Doc doc;
    TN.Doc.DataIVKDoc DataIVK;
    TN.Doc.HeaderDoc Header;
    TN.Doc.DataDoc SettingsData;
    TN.Doc.FooterDoc Footer;
    TN.Doc.DictionarysDoc Dictionarys;

    int shiftCount;
    List&lt;TN.Doc.Act&gt; activeShifts;

    DateTime Begin;
     
    private void Page_StartPage(object sender, EventArgs e)
    {
      string json = (string)Report.GetParameterValue(&quot;JsonDoc&quot;);
      Newtonsoft.Json.JsonSerializerSettings settings = new Newtonsoft.Json.JsonSerializerSettings();
      settings.TypeNameHandling = TypeNameHandling.All;         
         
      doc = JsonConvert.DeserializeObject&lt;TN.Doc.Doc&gt;(json, settings);
      DataIVK = (TN.Doc.DataIVKDoc)doc.Doc.DataIVK;
      Header = (TN.Doc.HeaderDoc)doc.Doc.Settings.Header;
      SettingsData = (TN.Doc.DataDoc)doc.Doc.Settings.Data;
      Footer = (TN.Doc.FooterDoc)doc.Doc.Settings.Footer;
      Dictionarys = (TN.Doc.DictionarysDoc)doc.Doc.Settings.Dictionarys;      
      
      // Настройки страницы 
      // Ширина и высота (в мм)
      Page.PaperHeight = doc.Doc.Settings.General.PageSettings.PaperHeight;
      Page.PaperWidth= doc.Doc.Settings.General.PageSettings.PaperWidth;
      //Page.Border.Lines = BorderLines.All;
         
      // Поля/отступы от краёв (в мм)
      Page.TopMargin=doc.Doc.Settings.General.PageSettings.TopMargin;
      Page.BottomMargin=doc.Doc.Settings.General.PageSettings.BottomMargin;
      Page.LeftMargin=doc.Doc.Settings.General.PageSettings.LeftMargin;
      Page.RightMargin=doc.Doc.Settings.General.PageSettings.RightMargin;
       
      Begin =  tools.UnixTimestampToDatetime((long)DataIVK.TableResultActAndPassport.Begin);
      
      // Запуск отрисовки таблиц на странице отчета
      DrawTableHeader();
      //DrawTableTotal();
      DrawTableSigners();
    }
      
    public void DrawTableHeader()
    {            
      ActNumberAndDate.Text = string.Format(&quot;Акт приема-сдачи нефти №&lt;u&gt; {0}&lt;/u&gt; от &lt;u&gt;{1:dd.MM.yyyy}&lt;/u&gt; г. (сдача по СИКН)&quot;,  
        DataIVK.TableResultActAndPassport.AdditionalInfo.ActNumber,
        Begin);     
      
      DelivePoint.Text = DataIVK.TableResultActAndPassport.AdditionalInfo.DelivePoint; 
      Factory.Text = DataIVK.TableResultActAndPassport.AdditionalInfo.Factory; 
      SIKN_Number.Text = DataIVK.TableResultActAndPassport.AdditionalInfo.SIKN_Number; 
      Delive_FIO.Text = DataIVK.TableResultActAndPassport.AdditionalInfo.Delive_FIO; 
      Delive_Lic_Date.Text = DataIVK.TableResultActAndPassport.AdditionalInfo.Delive_Lic_Date; 
      Delive_Lic_Number.Text = DataIVK.TableResultActAndPassport.AdditionalInfo.Delive_Lic_Number; 
         
      Receive_FIO.Text = DataIVK.TableResultActAndPassport.AdditionalInfo.Receive_FIO; 
      Receive_Lic_Date.Text = DataIVK.TableResultActAndPassport.AdditionalInfo.Receive_Lic_Date; 
      Receive_Lic_Number.Text = DataIVK.TableResultActAndPassport.AdditionalInfo.Receive_Lic_Number; 
    }
      
    private void TableAct_ManualBuild(object sender, EventArgs e)
    {
      bool ShowResultColumn = SettingsData.ShowResultColumn;
      int ColumnsCount = 0; 
      List&lt;TN.Doc.Act&gt; listShiftsData;
      string usedShiftStrInit = DataIVK.TableResultActAndPassport.ResultActAndPassport.Common.UsedShift;
      int usedShiftInit;
      var listActs = DataIVK.TableResultActAndPassport.ResultActAndPassport.Act;
      if (listActs == null || listActs.Count == 0)
      {
        return; // Нет данных для отображения
      }
      if (int.TryParse(usedShiftStrInit, out usedShiftInit) &amp;&amp; usedShiftInit &gt;= 1)
        listShiftsData = listActs.Take(usedShiftInit).ToList();
      else
        listShiftsData = listActs.Where(i =&gt; !i.Vol_LastShift.Contains(&quot;-&quot;) &amp;&amp; !String.IsNullOrEmpty(i.Vol_LastShift)).ToList();
      
      shiftCount = listShiftsData
        .Where(act =&gt; !String.IsNullOrEmpty(act.Vol_LastShift) &amp;&amp; ! act.Vol_LastShift.Contains(&quot;-&quot;))
        .Count();
      activeShifts = listShiftsData
        .Where(act =&gt; !String.IsNullOrEmpty(act.Vol_LastShift) &amp;&amp; ! act.Vol_LastShift.Contains(&quot;-&quot;))
        .ToList();
      
      if (Engine.FinalPass == true)
      {
        if (ShowResultColumn)
        {
          ColumnsCount = shiftCount + 1;
        }
        else
        {
          TableAct.Columns.Remove(ColumnResult);
          ColumnsCount = shiftCount;
        }           
                                                    
        // Calculate Dynamic Columns width
        float widthDynamicCols=(
          Page.PaperWidth-
          Page.LeftMargin-
          Page.RightMargin-
          TableAct.Columns[0].Width/Units.Millimeters-
          TableAct.Columns[1].Width/Units.Millimeters)
          /ColumnsCount;         

        // Insert Columns for Volumes  (V0) &amp; fill them headers with text
        int indexColTemplate = ColumnTemplate.Index;
        for (int i=1; i&lt;shiftCount; i++)
        {
          TableAct.Columns.Insert(indexColTemplate+1, new TableColumn());
          
          foreach(TableRow row in TableAct.Rows)
            row[indexColTemplate+1].AssignAll(row[indexColTemplate]);
        }
            
        // Setup Dynamic Columns Width
        for (int i = indexColTemplate; i &lt; TableAct.ColumnCount; i++)                 
        {
          TableAct.Columns[i].Width = widthDynamicCols*Units.Millimeters;
        }
            
        // Span Columns
        TableAct[indexColTemplate,0].ColSpan=shiftCount;
        
        for (int i = 0, j = 0; i &lt; (listShiftsData.Count); i++)
        {
          if(String.IsNullOrEmpty(listShiftsData[i].Vol_LastShift) || listShiftsData[i].Vol_LastShift.Contains(&quot;-&quot;))
            continue;
          
          var begin = string.Empty;
          var end = string.Empty;
          var date = &quot;-&quot;;
          if(i &lt; DataIVK.TableResultActAndPassport.ResultActAndPassport.PassportPeriodDT.Count)
          {
            var samplingBeginTs = DataIVK.TableResultActAndPassport.ResultActAndPassport.PassportPeriodDT[i].Begin;
            var samplingEndTs = DataIVK.TableResultActAndPassport.ResultActAndPassport.PassportPeriodDT[i].End;
            date = tools.UnixTimestampToDatetime(samplingBeginTs).ToString(&quot;dd.MM.yyyy&quot;);
            begin = tools.UnixTimestampToDatetime(samplingBeginTs).ToString(&quot;HH:mm&quot;);
            end = tools.UnixTimestampToDatetime(samplingEndTs).ToString(&quot;HH:mm&quot;).Replace(&quot;00:00&quot;, &quot;24:00&quot;);
          }
       
          TableAct[(2+j),1].Text = date;
          TableAct[(2+j),2].Text = $&quot;{begin}-{end}&quot;;            
          TableAct[(2+j),3].Text = $&quot;Смена {i+1}&quot;;  
          TableAct[(2+j),5].Text = tools.GetNormalizedValue(listShiftsData[i].Vol_LastShift);
          TableAct[(2+j),6].Text = tools.GetNormalizedValue(listShiftsData[i].Mass_LastShift);         
          TableAct[(2+j),8].Text = tools.GetNormalizedValue(listShiftsData[i].Vol_CurrShift);           
          TableAct[(2+j),9].Text = tools.GetNormalizedValue(listShiftsData[i].Mass_CurrShift);     
          TableAct[(2+j),11].Text = tools.GetNormalizedValue(listShiftsData[i].Vol_Gross);     
          TableAct[(2+j),12].Text = tools.GetNormalizedValue(listShiftsData[i].Mass_Gross);     
          TableAct[(2+j),13].Text = tools.GetNormalizedValue(listShiftsData[i].Temp);     
          TableAct[(2+j),14].Text = tools.GetNormalizedValue(listShiftsData[i].Press);     
          TableAct[(2+j),15].Text = tools.GetNormalizedValue(listShiftsData[i].Density);     
          TableAct[(2+j),16].Text = tools.GetNormalizedValue(listShiftsData[i].Density_correction);     
          TableAct[(2+j),17].Text = tools.GetNormalizedValue(listShiftsData[i].PassportID);     
          TableAct[(2+j),18].Text = tools.GetNormalizedValue(listShiftsData[i].Balast_Mass_Frac);             
          TableAct[(2+j),20].Text = tools.GetNormalizedValue(listShiftsData[i].Balast.Water);             
          TableAct[(2+j),21].Text = tools.GetNormalizedValue(listShiftsData[i].Balast.Chlorides);             
          TableAct[(2+j),22].Text = tools.GetNormalizedValue(listShiftsData[i].Balast.Impurity);             
          TableAct[(2+j),23].Text = tools.GetNormalizedValue(listShiftsData[i].Sulfur);             
          TableAct[(2+j),24].Text = tools.GetNormalizedValue(listShiftsData[i].Chloride_Salts);             
          TableAct[(2+j),25].Text = tools.GetNormalizedValue(listShiftsData[i].Balast_Mass);             
          TableAct[(2+j),26].Text = tools.GetNormalizedValue(listShiftsData[i].Net_Mass );
          
          j++;
        }
      }
         
      Gross_Vol.Text = DataIVK.TableResultActAndPassport.ResultActAndPassport.Common.Gross_Vol;
      Gross_Mass.Text = DataIVK.TableResultActAndPassport.ResultActAndPassport.Common.Gross_Mass;
      Balast_Mass.Text = DataIVK.TableResultActAndPassport.ResultActAndPassport.Common.Balast_Mass;
      Net_Mass.Text = DataIVK.TableResultActAndPassport.ResultActAndPassport.Common.Net_Mass;
      
      //Draw rows                                                             
      for (int n = 0; n &lt; TableAct.RowCount; n++)
      {
        TableAct.PrintRow(n);
        TableAct.PrintColumns();                                             
      }
    }      
    
        
    private void TableAdditionlInfo_ManualBuild(object sender, EventArgs e)
    {
      // Setup Last Column width
      TableAdditionlInfo.Columns[0].Width=(Page.PaperWidth-Page.LeftMargin-Page.RightMargin)*Units.Millimeters;

      // Определяем обозначения нефти по ГОСТ для каждой смены
      List &lt;string&gt; listExtendGostIndex51858 = (DataIVK.TableResultActAndPassport.ResultActAndPassport.Common.ExtendGostIndex51858 ?? new List&lt;string&gt;()).Where(i =&gt; ! i.Contains(&quot;-&quot;)  &amp; String.IsNullOrEmpty(i) == false).ToList();
      List &lt;string&gt; distListExtendGostIndex51858 = listExtendGostIndex51858.Distinct().ToList();

      if (distListExtendGostIndex51858.Count &gt; 1 &amp;&amp; activeShifts != null &amp;&amp; activeShifts.Count &gt; 1)
      {
        // Разные обозначения ГОСТ для смен — чередуем: масса прописью + ГОСТ для каждой смены
        int count = Math.Min(activeShifts.Count, listExtendGostIndex51858.Count);
        for (int i = 0; i &lt; count; i++)
        {
          string inWords = activeShifts[i].Net_Mass_InWords ?? &quot;&quot;;
          WholePart.Text = string.Format(&quot;Масса нефти нетто (прописью) &lt;u&gt; {1}&lt;/u&gt; т.&quot;, i + 1, inWords);
          TableAdditionlInfo.PrintRow(0);
          TableAdditionlInfo.PrintColumns();

          ExtendGostIndex51858.Text = string.Format(&quot;Обозначение нефти: &lt;u&gt; {0}&lt;/u&gt; по ГОСТ Р 51858.&quot;, listExtendGostIndex51858[i]);
          TableAdditionlInfo.PrintRow(1);
          TableAdditionlInfo.PrintColumns();
        }
      }
      else
      {
        // Одно обозначение ГОСТ для всего акта — исходная масса из ИВК + одна строка ГОСТ
        string wholePart = DataIVK.TableResultActAndPassport.ResultActAndPassport.Common.ValueInWords.WholePart;
        int startIndexTon = wholePart.IndexOf(&quot; тон&quot;);

        if (startIndexTon != -1)
          wholePart = wholePart.Remove(startIndexTon);

        WholePart.Text = string.Format(&quot;Масса нефти нетто (прописью) &lt;u&gt; {0}&lt;/u&gt; т.&quot;, wholePart);
        TableAdditionlInfo.PrintRow(0);
        TableAdditionlInfo.PrintColumns();

        List &lt;string&gt; resultListExtendGostIndex51858 = distListExtendGostIndex51858.Count == 1 ? distListExtendGostIndex51858 : listExtendGostIndex51858;
        for (int n = 0; n &lt; resultListExtendGostIndex51858.Count; n++)
        {
          ExtendGostIndex51858.Text = string.Format(&quot;Обозначение нефти: &lt;u&gt; {0}&lt;/u&gt; по ГОСТ Р 51858.&quot;,  resultListExtendGostIndex51858[n]);
          TableAdditionlInfo.PrintRow(1);
          TableAdditionlInfo.PrintColumns();
        }
      }
    }
      
    public void  DrawTableSigners()
    {
      if (Page.PaperWidth == 297)
      {
        if (Engine.FinalPass == true)
        {  
          for (int n = 0; n &lt; TableSigners.ColumnCount; n++)
          {
            TableSigners.Columns[n].Width=(TableSigners.Columns[n].Width*(float)1.455);//*Units.Millimeters;
          }       
        }
      }
         
      Delive_IOF.Text = DataIVK.TableResultActAndPassport.AdditionalInfo.Delive_IOF; 
      Receive_IOF.Text = DataIVK.TableResultActAndPassport.AdditionalInfo.Receive_IOF;
      if (!string.IsNullOrEmpty(Footer.LabMIDensity))
        LabMIDensity.Text = $&quot;*) заполняют при отказе поточного преобразователя плотности (определяют по {Footer.LabMIDensity})&quot;;
    }  
      
    private void PageFooter_BeforeLayout(object sender, EventArgs e)
    {
      if((Int32)Report.GetVariableValue(&quot;TotalPages&quot;) &lt; 2) 
      { 
        PageFooter.Visible = false; 
      }
      else
      {
        PageNumeration.Width = (Page.PaperWidth-Page.LeftMargin-Page.RightMargin)*Units.Millimeters;
      }
    }
  }    
}

