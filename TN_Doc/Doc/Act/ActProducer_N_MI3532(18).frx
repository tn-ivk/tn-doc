using TN.DocData;

namespace FastReport
{
  public class ReportScript
  {
    TN_ToolsFastReport.Tools tools = new TN_ToolsFastReport.Tools();      
    TN.Doc.Doc doc;
    TN.Doc.DataIVKDoc DataIVK;
    TN.Doc.HeaderDoc Header;
    TN.Doc.DataDoc SettingsData;
    TN.Doc.FooterDoc Footer;
    TN.Doc.DictionarysDoc Dictionarys;
    TN.Doc.AdditionalInfo AdditionalInfo;
    List&lt;TN.Doc.ActShift&gt; ActShifts;
    DateTime Begin;
     
    private void Page_StartPage(object sender, EventArgs e)
    {
      string json = (string)Report.GetParameterValue(&quot;JsonDoc&quot;);
      Newtonsoft.Json.JsonSerializerSettings settings = new Newtonsoft.Json.JsonSerializerSettings();
      settings.TypeNameHandling = TypeNameHandling.All;         
         
      doc = JsonConvert.DeserializeObject&lt;TN.Doc.Doc&gt;(json, settings);
      DataIVK = (TN.Doc.DataIVKDoc)doc.Doc.DataIVK;
      Header = (TN.Doc.HeaderDoc)doc.Doc.Settings.Header;
      SettingsData = (TN.Doc.DataDoc)doc.Doc.Settings.Data;
      Footer = (TN.Doc.FooterDoc)doc.Doc.Settings.Footer;
      Dictionarys = (TN.Doc.DictionarysDoc)doc.Doc.Settings.Dictionarys;
      AdditionalInfo = doc.AdditionalInfo;
      ActShifts = doc.ActShifts;
        
      // Ширина и высота (в мм)
      Page.PaperHeight = doc.Doc.Settings.General.PageSettings.PaperHeight;
      Page.PaperWidth= doc.Doc.Settings.General.PageSettings.PaperWidth;
      //Page.Border.Lines = BorderLines.All;
         
      // Поля/отступы от краёв (в мм)
      Page.TopMargin=doc.Doc.Settings.General.PageSettings.TopMargin;
      Page.BottomMargin=doc.Doc.Settings.General.PageSettings.BottomMargin;
      Page.LeftMargin=doc.Doc.Settings.General.PageSettings.LeftMargin;
      Page.RightMargin=doc.Doc.Settings.General.PageSettings.RightMargin;
       
      Begin =  tools.UnixTimestampToDatetime((long)DataIVK.TableRouteSummary.Begin);
      
      // Запуск отрисовки таблиц на странице отчета
      DrawTableHeader();
      DrawTableSigners();
    }
      
    public void DrawTableHeader()
    {
      ActNumberAndDate.Text = string.Format(&quot;Акт приема-сдачи нефти №&lt;u&gt; {0}&lt;/u&gt; от &lt;u&gt;{1:dd.MM.yyyy}&lt;/u&gt; г. (сдача по СИКН)&quot;,  
        AdditionalInfo.ActNumber,
        Begin);     
      
      DelivePoint.Text = AdditionalInfo.DelivePoint; 
      Factory.Text = AdditionalInfo.Factory; 
      SIKN_Number.Text = AdditionalInfo.SIKN_Number; 
      Delive_FIO.Text = AdditionalInfo.Delive_FIO; 
      Delive_Lic_Date.Text = AdditionalInfo.Delive_Lic_Date; 
      Delive_Lic_Number.Text = AdditionalInfo.Delive_Lic_Number; 
         
      Receive_FIO.Text = AdditionalInfo.Receive_FIO; 
      Receive_Lic_Date.Text = AdditionalInfo.Receive_Lic_Date; 
      Receive_Lic_Number.Text = AdditionalInfo.Receive_Lic_Number;
    }
      
    private void TableAct_ManualBuild(object sender, EventArgs e)
    {
      bool ShowResultColumn = false; //.ShowResultColumn;
      int ColumnsCount = 0; 
      List&lt;TN.Doc.ActShift&gt; listShiftsData;
      listShiftsData = ActShifts.Where(x =&gt; !string.IsNullOrEmpty(x.GostIndex51858)).ToList();
         
      if (Engine.FinalPass == true)
      {
        if (ShowResultColumn)
        {
          ColumnsCount = listShiftsData.Count + 1;
        }
        else
        {
          TableAct.Columns.Remove(ColumnResult);
          ColumnsCount = listShiftsData.Count;
        }           
                                                    
        // Calculate Dynamic Columns width
        float widthDynamicCols=(
          Page.PaperWidth-
          Page.LeftMargin-
          Page.RightMargin-
          TableAct.Columns[0].Width/Units.Millimeters-
          TableAct.Columns[1].Width/Units.Millimeters)
          /ColumnsCount;         

        // Insert Columns for Volumes  (V0) &amp; fill them headers with text
        int indexColTemplate = ColumnTemplate.Index;
        for (int i=1; i&lt;listShiftsData.Count; i++)
        {
          TableAct.Columns.Insert(indexColTemplate+1, new TableColumn());
          
          foreach(TableRow row in TableAct.Rows)
            row[indexColTemplate+1].AssignAll(row[indexColTemplate]);
        }
            
        // Setup Dynamic Columns Width
        for (int i = indexColTemplate; i &lt; TableAct.ColumnCount; i++)                 
        {
          TableAct.Columns[i].Width = widthDynamicCols*Units.Millimeters;
        }
            
        // Span Columns
        TableAct[indexColTemplate,0].ColSpan=listShiftsData.Count;
            
        // Fill TableAct with data
        double hoursPerShift = 24.0 / listShiftsData.Count;
        
        for (int i = 0; i &lt; (listShiftsData.Count); i++)                 
        {
          string begin = FormatTime(i * hoursPerShift);
          string end = FormatTime((i + 1) * hoursPerShift);
          TableAct[(2+i),1].Text = Begin.ToString(&quot;dd.MM.yyyy&quot;);
          TableAct[(2+i),2].Text = $&quot;{begin}-{end}&quot;;            
          TableAct[(2+i),3].Text = $&quot;Смена {i+1}&quot;;            
          TableAct[(2+i),5].Text = tools.GetNormalizedValue(listShiftsData[i].Vol_LastShift);
          TableAct[(2+i),6].Text = tools.GetNormalizedValue(listShiftsData[i].Mass_LastShift);         
          TableAct[(2+i),8].Text = tools.GetNormalizedValue(listShiftsData[i].Vol_CurrShift);           
          TableAct[(2+i),9].Text = tools.GetNormalizedValue(listShiftsData[i].Mass_CurrShift);     
          TableAct[(2+i),11].Text = tools.GetNormalizedValue(listShiftsData[i].Vol_Gross);     
          TableAct[(2+i),12].Text = tools.GetNormalizedValue(listShiftsData[i].Mass_Gross);     
          TableAct[(2+i),13].Text = tools.GetNormalizedValue(listShiftsData[i].Temp);     
          TableAct[(2+i),14].Text = tools.GetNormalizedValue(listShiftsData[i].Press);     
          TableAct[(2+i),15].Text = tools.GetNormalizedValue(listShiftsData[i].Density);     
          TableAct[(2+i),16].Text = tools.GetNormalizedValue(listShiftsData[i].Density_correction);     
          TableAct[(2+i),17].Text = tools.GetNormalizedValue(listShiftsData[i].PassportID);     
          TableAct[(2+i),18].Text = tools.GetNormalizedValue(listShiftsData[i].Balast_Mass_Frac);             
          TableAct[(2+i),20].Text = tools.GetNormalizedValue(listShiftsData[i].Ballast.Water);             
          TableAct[(2+i),21].Text = tools.GetNormalizedValue(listShiftsData[i].Ballast.Chlorides);             
          TableAct[(2+i),22].Text = tools.GetNormalizedValue(listShiftsData[i].Ballast.Impurity);             
          TableAct[(2+i),23].Text = tools.GetNormalizedValue(listShiftsData[i].Sulfur);             
          TableAct[(2+i),24].Text = tools.GetNormalizedValue(listShiftsData[i].Chloride_Salts);             
          TableAct[(2+i),25].Text = tools.GetNormalizedValue(listShiftsData[i].Balast_Mass);             
          TableAct[(2+i),26].Text = tools.GetNormalizedValue(listShiftsData[i].Net_Mass );     
        }
      }
         
      //Gross_Vol.Text = DataIVK.TableResultActAndPassport.ResultActAndPassport.Common.Gross_Vol;
      //Gross_Mass.Text = DataIVK.TableResultActAndPassport.ResultActAndPassport.Common.Gross_Mass;
      //Balast_Mass.Text = DataIVK.TableResultActAndPassport.ResultActAndPassport.Common.Balast_Mass;
      //Net_Mass.Text = DataIVK.TableResultActAndPassport.ResultActAndPassport.Common.Net_Mass;
      
      //Draw rows                                                             
      for (int n = 0; n &lt; TableAct.RowCount; n++)
      {
        TableAct.PrintRow(n);
        TableAct.PrintColumns();                                             
      }
    }
     
    private string FormatTime(double totalHours)
    {
      int hours = (int)totalHours;
      int minutes = (int)((totalHours - hours) * 60);

      if (hours == 24)
        return &quot;24:00&quot;;

      return $&quot;{hours:00}:{minutes:00}&quot;;
    }
    
    private void TableFootnote_ManualBuild(object sender, EventArgs e)
    {
      // Setup Last Column width
      TableFootnote.Columns[2].Width=(Page.PaperWidth-Page.LeftMargin-Page.RightMargin-
        (TableFootnote.Columns[0].Width/Units.Millimeters)-
        (TableFootnote.Columns[1].Width/Units.Millimeters))*Units.Millimeters;
         
      //Draw TableFootnote
      for (int n = 0; n &lt; TableFootnote.RowCount; n++)
      {
        TableFootnote.PrintRow(n);
        TableFootnote.PrintColumns();                                             
      }       
    }
      
    private void TableAdditionlInfo_ManualBuild(object sender, EventArgs e)
    {
      // Setup Last Column width
      TableAdditionlInfo.Columns[0].Width=(Page.PaperWidth-Page.LeftMargin-Page.RightMargin)*Units.Millimeters;  
      WholePart.Text =  string.Format(&quot;Масса нефти нетто (прописью) &lt;u&gt; {0}&lt;/u&gt; т.&quot;, doc.WholePart ?? string.Empty);
         
      //Draw static Rows
      TableAdditionlInfo.PrintRow(0);
      TableAdditionlInfo.PrintColumns();                                             
         
      //Fill &amp; Draw dynamic Rows
      var listGostIndex51858 = ActShifts.Select(x =&gt; x.GostIndex51858).Where(x =&gt; String.IsNullOrEmpty(x)).ToList();
         
      for (int n = 0; n &lt; listGostIndex51858.Count; n++)
      {
        GostIndex51858.Text = string.Format(&quot;Обозначение нефти: &lt;u&gt; {0}&lt;/u&gt; по ГОСТ Р 51858.&quot;,  listGostIndex51858[n]);
        TableAdditionlInfo.PrintRow(1);
        TableAdditionlInfo.PrintColumns();                                             
      }
    }
      
    public void  DrawTableSigners()
    {
      if (Page.PaperWidth == 297)
      {
        if (Engine.FinalPass == true)
        {  
          for (int n = 0; n &lt; TableSigners.ColumnCount; n++)
          {
            TableSigners.Columns[n].Width=(TableSigners.Columns[n].Width*(float)1.455);//*Units.Millimeters;
          }       
        }
      }
         
      Delive_IOF.Text = AdditionalInfo.Delive_IOF; 
      Receive_IOF.Text = AdditionalInfo.Receive_IOF; 
      if (!string.IsNullOrEmpty(Footer.LabMIDensity))
        LabMIDensity.Text = $&quot;* заполняют при отказе поточного преобразователя плотности (определяют по {Footer.LabMIDensity})&quot;;
    }  
      
    private void PageFooter_BeforeLayout(object sender, EventArgs e)
    {
      if((Int32)Report.GetVariableValue(&quot;TotalPages&quot;) &lt; 2) 
      { 
        PageFooter.Visible = false; 
      }
      else
      {
        PageNumeration.Width = (Page.PaperWidth-Page.LeftMargin-Page.RightMargin)*Units.Millimeters;
      }
    }
  }    
}

