using TN.DocData;

namespace FastReport
{
  public class ReportScript
  {
    TN_ToolsFastReport.Tools tools = new TN_ToolsFastReport.Tools();  // классы отчета
    TN.Doc.Doc doc; // данные из входного параметра
    TN.DocData.General General;
    TN.Doc.HeaderDoc Header;
    TN.Doc.DataDoc SettingsData;
    TN.Doc.FooterDoc Footer;
    TN.Doc.DictionarysDoc Dictionarys;
    TN.Doc.DataIVKDoc DataIVK;      
      
    List &lt;TN.Doc.Table3&gt; listTable3Results;     

    private void Page_StartPage(object sender, EventArgs e)
    {
      //using (var sr = new StreamReader(&quot;D:/!_Work/!_Транснефть/SVN/Work/Sources/Reports/FRX/Входящие данные от Алексея (классы и json)/27_TablePoverka3312_UPR_PR/DocPoverka3312_UPR_PR.json&quot;))
      //{
      // Read the stream as a string
      //   Report.SetParameterValue(&quot;Protocol&quot;, sr.ReadToEnd());
      //}
         
      //// Десериализация данных (формат json) из входного параметра - Json                         
      string json = (string)Report.GetParameterValue(&quot;JsonDoc&quot;);
      Newtonsoft.Json.JsonSerializerSettings settings = new Newtonsoft.Json.JsonSerializerSettings();
      settings.TypeNameHandling = TypeNameHandling.All;
      
      doc = JsonConvert.DeserializeObject&lt;TN.Doc.Doc&gt;(json, settings);
      General = (TN.DocData.General) doc.Doc.Settings.General;
      Header = (TN.Doc.HeaderDoc) doc.Doc.Settings.Header;
      SettingsData = (TN.Doc.DataDoc) doc.Doc.Settings.Data;
      Footer = (TN.Doc.FooterDoc) doc.Doc.Settings.Footer;
      Dictionarys = (TN.Doc.DictionarysDoc) doc.Doc.Settings.Dictionarys;  
      DataIVK = (TN.Doc.DataIVKDoc) doc.Doc.DataIVK; 
      
      //// === Настройки страницы 
      // Ширина и высота (в мм)
      Page.PaperHeight = General.PageSettings.PaperHeight;
      Page.PaperWidth = General.PageSettings.PaperWidth;
         
      // Поля/отступы от краёв (в мм)
      Page.TopMargin = General.PageSettings.TopMargin;
      Page.BottomMargin = General.PageSettings.BottomMargin;
      Page.LeftMargin = General.PageSettings.LeftMargin;
      Page.RightMargin = General.PageSettings.RightMargin;

      // Load data into global lists
      listTable3Results = DataIVK.TablePoverkaSikn425_UPR_PR.Protokol.Table3.Where(i =&gt; ! i.ser.Contains(&quot;-&quot;) &amp; String.IsNullOrEmpty(i.ser) == false).ToList();
    
      // Запуск отрисовки таблиц на странице отчета
      DrawTableHeader();    
      DrawTable1SourceData(); 
      DrawTable1SourceDataEnding();
      DrawTable5SourceData();
      DrawTable5SourceDataEnding();
      DrawTableConclusion();
    }
    #region //Имхо лишний метод
    private void PrintTable(TableObject table)
    {
      for (int i=0;i&lt;table.RowCount;i++)
      {       
        table.PrintRow(i);
        table.PrintColumns();
      }    
    } 
    #endregion
      
    public void DrawTableHeader()
    {
      List &lt;TN.Doc.MprInfo&gt; listPRs_Info;
      listPRs_Info = DataIVK.TablePoverkaSikn425_UPR_PR.AdditionalInfo.MprOsuInfo.Where(i =&gt; ! i.Sensor.DevType.Contains(&quot;-&quot;) &amp; String.IsNullOrEmpty(i.Sensor.DevType) == false).ToList();
         
      if (listPRs_Info.Count == 0)
      listPRs_Info.Add(new TN.Doc.MprInfo(){ LineName = &quot;&quot;, 
      Sensor = new TN.Doc.DeviceInfo() { DevType = &quot;&quot;, DevNumb = &quot;&quot; }, 
      Pep = new TN.Doc.DeviceInfo() { DevType = &quot;&quot;, DevNumb = &quot;&quot; }});
      
      //Setup Columns width
      TableHeader01.Columns[0].Width = (Page.PaperWidth-Page.LeftMargin-Page.RightMargin)*Units.Millimeters;
         
      // Fill table with data   
      ProtokolNum.Text = &quot;П Р О Т О К О Л  № &quot; + DataIVK.TablePoverkaSikn425_UPR_PR.AdditionalInfo.ProtokolNum;
      Place_SIKN.Text = string.Format(&quot;СИКН №{0}, {1}, {2}&quot;, 
        DataIVK.TablePoverkaSikn425_UPR_PR.AdditionalInfo.PlaceSikn, 
        DataIVK.TablePoverkaSikn425_UPR_PR.AdditionalInfo.PlacePsp,
        DataIVK.TablePoverkaSikn425_UPR_PR.AdditionalInfo.PlaceFactory);
      CPM_RSU_Type.Text = DataIVK.TablePoverkaSikn425_UPR_PR.AdditionalInfo.MprRsuInfo.Sensor.DevType;
      CPM_RSU_FactoryNumber.Text = DataIVK.TablePoverkaSikn425_UPR_PR.AdditionalInfo.MprRsuInfo.Sensor.DevNumb;
      CPM_RSU_PEP_Type.Text = DataIVK.TablePoverkaSikn425_UPR_PR.AdditionalInfo.MprRsuInfo.Pep.DevType;
      CPM_RSU_PEP_FactoryNumber.Text = DataIVK.TablePoverkaSikn425_UPR_PR.AdditionalInfo.MprRsuInfo.Pep.DevNumb;
      CPM_RSU_LineName.Text = DataIVK.TablePoverkaSikn425_UPR_PR.AdditionalInfo.MprRsuInfo.LineName;
  
      switch(listPRs_Info.Count)
      {
        case 1:
          PRs_Info.Text=&quot;СРМ:&quot;;
          MM_Sensor_Type.Text=listPRs_Info[0].Sensor.DevType;
          MM_Sensor_FactoryNumber.Text=listPRs_Info[0].Sensor.DevNumb;
          PR_LineName.Text = listPRs_Info[0].LineName;
          MM_PEP.Text = listPRs_Info[0].Pep.DevType;
          MM_PEP_FactoryNumber.Text = listPRs_Info[0].Pep.DevNumb;
          break;  
            
        default:
          // Add need number of rows for 
          if (Engine.FirstPass == true)
          {
            int cols;
            int rows;
            for (rows = 2; rows &lt; (listPRs_Info.Count*2); rows++)                 
            {
              TableRow row = new TableRow(); 
              TablePRs.Rows.Add(row);
                     
              if ((TablePRs.Rows.Count % 2) == 1)
              {
                for (cols=0; cols &lt;TablePRs.ColumnCount; cols++)
                {
                  TablePRs[cols, rows].AssignAll(TablePRs[cols, 0]);
                }
              }
              else
              {
                for (cols=0; cols &lt;(TablePRs.ColumnCount); cols++)
                {
                  TablePRs[cols, rows].AssignAll(TablePRs[cols, 1]);
                }
              }
            }      
                  
            // Fill cells of the TablePRs with data from json
            int tempCounter = 0;
            for (int i=0; i &lt;TablePRs.RowCount ; i++)
            {
              if ((i % 2) == 0)
              {
                TablePRs[0,i].Text= String.Format(&quot;СРМ{0}:&quot;, tempCounter+1);
                TablePRs[3,i].Text= listPRs_Info[tempCounter].Sensor.DevType;
                TablePRs[5,i].Text= listPRs_Info[tempCounter].Sensor.DevNumb;
                TablePRs[7,i].Text= listPRs_Info[tempCounter].LineName;
                TablePRs[3,i+1].Text= listPRs_Info[tempCounter].Pep.DevType;
                TablePRs[5,i+1].Text= listPRs_Info[tempCounter].Pep.DevNumb;                  
                tempCounter++;
              }
            }
          }
          break;
      }
      IVK_Type.Text = DataIVK.TablePoverkaSikn425_UPR_PR.AdditionalInfo.IvkInfo.DevType;
      IVK_FactoryNumber.Text = DataIVK.TablePoverkaSikn425_UPR_PR.AdditionalInfo.IvkInfo.DevNumb;
      Oil_Type.Text = DataIVK.TablePoverkaSikn425_UPR_PR.Protokol.OilType;
      }
              
    private void DrawTable1SourceData()
    {
      //Setup Columns width
      int sumDynamicCols=9;
      float widthDynamicCol=(Page.PaperWidth-Page.LeftMargin-Page.RightMargin)/sumDynamicCols;                  
      for (int w = 0; w &lt; (Table1SourceData.ColumnCount); w++)                 
      {
        Table1SourceData.Columns[w].Width = widthDynamicCol * Units.Millimeters;
      }      
         
      //Fill table with data
      Teta_M.Text = tools.GetNormalizedValue(DataIVK.TablePoverkaSikn425_UPR_PR.Protokol.Table1.TetaM);
      deltaIVK.Text = tools.GetNormalizedValue(DataIVK.TablePoverkaSikn425_UPR_PR.Protokol.Table1.deltaIVK);
      Kpm.Text = tools.GetNormalizedValue(DataIVK.TablePoverkaSikn425_UPR_PR.Protokol.Table1.Kpm);
      KmMFust.Text = tools.GetNormalizedValue(DataIVK.TablePoverkaSikn425_UPR_PR.Protokol.Table1.KmMFust);
      QmMax.Text = tools.GetNormalizedValue(DataIVK.TablePoverkaSikn425_UPR_PR.Protokol.Table1.QmMax);
      ZS.Text = tools.GetNormalizedValue(DataIVK.TablePoverkaSikn425_UPR_PR.Protokol.Table1.ZS); 
      Qnom.Text = tools.GetNormalizedValue(DataIVK.TablePoverkaSikn425_UPR_PR.Protokol.Table1.Qnom); 
      deltaTempDop.Text = tools.GetNormalizedValue(DataIVK.TablePoverkaSikn425_UPR_PR.Protokol.Table1.deltaTempDop);
      tMin.Text = tools.GetNormalizedValue(DataIVK.TablePoverkaSikn425_UPR_PR.Protokol.Table1.tMin);
    }
      
    private void DrawTable1SourceDataEnding()
    {   
      //Setup Columns widths as previous table
      for (int i = 0; i &lt; (Table1SourceDataEnding.ColumnCount); i++)
      {          
        Table1SourceDataEnding.Columns[i].Width =  Table1SourceData.Columns[i].Width;
      }
     
      //Fill table with data
      tMax.Text = tools.GetNormalizedValue(DataIVK.TablePoverkaSikn425_UPR_PR.Protokol.Table1.tMax);
      deltaPdop.Text = tools.GetNormalizedValue(DataIVK.TablePoverkaSikn425_UPR_PR.Protokol.Table1.deltaPdop);
      Pmin.Text = tools.GetNormalizedValue(DataIVK.TablePoverkaSikn425_UPR_PR.Protokol.Table1.Pmin);
      Pmax.Text = tools.GetNormalizedValue(DataIVK.TablePoverkaSikn425_UPR_PR.Protokol.Table1.Pmax);            
    } 
    
    private void Table2Results_ManualBuild(object sender, EventArgs e)
    {            
      List &lt;TN.Doc.Table2&gt; listTable2Results;
      listTable2Results = DataIVK.TablePoverkaSikn425_UPR_PR.Protokol.Table2.Where(i =&gt; ! i.ser.Contains(&quot;-&quot;) &amp; String.IsNullOrEmpty(i.ser) == false).ToList();
         
      //Setup Columns width
      int sumDynamicCols=8;
      float widthDynamicCol=(Page.PaperWidth-Page.LeftMargin-Page.RightMargin)/sumDynamicCols;                  
      for (int w = 0; w &lt; (Table2Results.ColumnCount); w++)                 
      {
        Table2Results.Columns[w].Width = widthDynamicCol * Units.Millimeters;
      }  
         
      //Draw Fixed rows
      for (int n = 0; n &lt; Table2Results.FixedRows; n++)
      {
        Table2Results.PrintRow(n);
        Table2Results.PrintColumns();                                             
      }
      //         MessageBox.Show(listTable2Results.Count.ToString());
      //Fill table with data      
      for (int n = 0; n &lt; (listTable2Results.Count); n++)
      {
        SerRowTable2.Text = String.Format(&quot;{0}/{1}&quot;, listTable2Results[n].ser, listTable2Results[n].row);//+ &quot; | &quot; + (n+1).ToString();
        MPR_Id.Text = tools.GetNormalizedValue(listTable2Results[n].MPR_Id);
        Q_jik.Text = tools.GetNormalizedValue(listTable2Results[n].Q_jik);
        N_jik.Text = tools.GetNormalizedValue(listTable2Results[n].N_jik); 
        M_jik.Text = tools.GetNormalizedValue(listTable2Results[n].M_jik);
        Kpm_jik.Text = tools.GetNormalizedValue(listTable2Results[n].Kpm_jik);

        Table2Results.PrintRow(3);     
        Table2Results.PrintColumns();          
      }
    }
  
    private void Table3Results_ManualBuild(object sender, EventArgs e)
    {
         
                   
      //Setup Columns width
      int sumDynamicCols=Table3Results.ColumnCount;
      float widthDynamicCol=(Page.PaperWidth-Page.LeftMargin-Page.RightMargin)/sumDynamicCols;                  
      for (int w = 0; w &lt; (Table3Results.ColumnCount); w++)                 
      {
        Table3Results.Columns[w].Width = widthDynamicCol * Units.Millimeters;
      }      
         
      //Draw Fixed rows 
      for (int n = 0; n &lt; Table3Results.FixedRows; n++)
      {
        Table3Results.PrintRow(n);
        Table3Results.PrintColumns();                                             
      }
             
      //Fill table with data
      for (int n = 0; n &lt; (listTable3Results.Count); n++)
      {
        SerRowTable3.Text = String.Format(&quot;{0}/{1}&quot;, listTable3Results[n].ser, listTable3Results[n].row);
        Q_ji.Text = tools.GetNormalizedValue(listTable3Results[n].Q_ji);
        T_ji.Text = tools.GetNormalizedValue(listTable3Results[n].T_ji);
        N_ji.Text = tools.GetNormalizedValue(listTable3Results[n].N_ji);
        Me_ji.Text = tools.GetNormalizedValue(listTable3Results[n].Me_ji);
        M_ji.Text = tools.GetNormalizedValue(listTable3Results[n].M_ji);
        Km_MF_ji.Text = tools.GetNormalizedValue(listTable3Results[n].Km_MF_ji);
        
        Table3Results.PrintRow(3);     
        Table3Results.PrintColumns();  
      }                                          
    }
      
    
      
    private void Table4Results_ManualBuild(object sender, EventArgs e)
    {
      List &lt;TN.Doc.Table4&gt; listTable4Results;
      listTable4Results = DataIVK.TablePoverkaSikn425_UPR_PR.Protokol.Table4.Where(i =&gt; ! i.ser.Contains(&quot;-&quot;) &amp; String.IsNullOrEmpty(i.ser) == false).ToList();
         
         
      //Setup Columns width
      int sumDynamicCols=Table4Results.ColumnCount;
      float widthDynamicCol=(Page.PaperWidth-Page.LeftMargin-Page.RightMargin)/sumDynamicCols;             
         
      for (int w = 0; w &lt; (Table4Results.ColumnCount); w++)                 
      {
        Table4Results.Columns[w].Width = widthDynamicCol * Units.Millimeters;
      }      
         
      //Draw Fixed rows 
      for (int n = 0; n &lt; Table4Results.FixedRows; n++)
      {
        Table4Results.PrintRow(n);
        Table4Results.PrintColumns();                                             
      }
             
      //Fill table with data
      for (int n = 0; n &lt; (listTable4Results.Count); n++)
      {
            
        Point.Text = listTable4Results[n].ser;
        Q_j.Text = tools.GetNormalizedValue(listTable4Results[n].Q_j);
        Km_MF_j.Text = tools.GetNormalizedValue(listTable4Results[n].Km_MF_j);
        n_j.Text = tools.GetNormalizedValue(listTable4Results[n].n_j);
        S_j.Text = tools.GetNormalizedValue(listTable4Results[n].S_j);
        S0_j.Text = tools.GetNormalizedValue(listTable4Results[n].S0_j);
        t095_j.Text = tools.GetNormalizedValue(listTable4Results[n].t095_j);
        e_j.Text = tools.GetNormalizedValue(listTable4Results[n].e_j);
            
        Table4Results.PrintRow(3);     
        Table4Results.PrintColumns();  
      }
    }
      
    private void DrawTable5SourceData()
    {
      //Setup Columns width
      int sumDynamicCols=Table5Results.ColumnCount;
      float widthDynamicCol=(Page.PaperWidth-Page.LeftMargin-Page.RightMargin)/sumDynamicCols;             
         
      for (int w = 0; w &lt; (Table5Results.ColumnCount); w++)                 
      {
        Table5Results.Columns[w].Width = widthDynamicCol * Units.Millimeters;
      }      
         
      //Fill table with data                 
      Q_min.Text = tools.GetNormalizedValue(DataIVK.TablePoverkaSikn425_UPR_PR.Protokol.Table5.Q_min);
      Q_max.Text = tools.GetNormalizedValue(DataIVK.TablePoverkaSikn425_UPR_PR.Protokol.Table5.Q_max);
      Km_MF.Text = tools.GetNormalizedValue(DataIVK.TablePoverkaSikn425_UPR_PR.Protokol.Table5.Km_MF);
      S0.Text = tools.GetNormalizedValue(DataIVK.TablePoverkaSikn425_UPR_PR.Protokol.Table5.S0);
      e.Text = tools.GetNormalizedValue(DataIVK.TablePoverkaSikn425_UPR_PR.Protokol.Table5.e);
      Teta_A.Text = tools.GetNormalizedValue(DataIVK.TablePoverkaSikn425_UPR_PR.Protokol.Table5.Teta_A);
      Teta_Z.Text = tools.GetNormalizedValue(DataIVK.TablePoverkaSikn425_UPR_PR.Protokol.Table5.Teta_Z);
      t_P.Text = tools.GetNormalizedValue(DataIVK.TablePoverkaSikn425_UPR_PR.Protokol.Table5.t_P);
      Teta_Mt.Text = tools.GetNormalizedValue(DataIVK.TablePoverkaSikn425_UPR_PR.Protokol.Table5.Teta_Mt);
    }
    
    private void DrawTable5SourceDataEnding()
    {   
      //Setup Columns widths as previous table
      for (int i = 0; i &lt; (Table5ResultsEnding.ColumnCount); i++)
      {          
        Table5ResultsEnding.Columns[i].Width =  Table5Results.Columns[i].Width;
      }
     
      //Fill table with data
      P_P.Text = tools.GetNormalizedValue(DataIVK.TablePoverkaSikn425_UPR_PR.Protokol.Table5.P_P);
      Teta_Mp.Text = tools.GetNormalizedValue(DataIVK.TablePoverkaSikn425_UPR_PR.Protokol.Table5.Teta_Mp);
      Teta_Sum.Text = tools.GetNormalizedValue(DataIVK.TablePoverkaSikn425_UPR_PR.Protokol.Table5.Teta_Sum);
      Delta.Text = tools.GetNormalizedValue(DataIVK.TablePoverkaSikn425_UPR_PR.Protokol.Table5.delta);             
    } 
    
    public void  DrawTableConclusion()
    {                                                    
      // Setup Cols width    
      TableConclusion3.Columns[0].Width=(Page.PaperWidth-Page.LeftMargin-Page.RightMargin)  * Units.Millimeters;
        
      // Fill Table with data
      ARM_Poverka_Result.Text = DataIVK.TablePoverkaSikn425_UPR_PR.AdditionalInfo.ARM_Poverka_Result;
      StaffData.Text = DataIVK.TablePoverkaSikn425_UPR_PR.AdditionalInfo.StaffData;
      DateTimeLong.Text = string.Format(&quot;Дата проведения поверки: &lt;u&gt;{0:dd.MM.yyyy} г.&quot;,
        (tools.UnixTimestampToDatetime(DataIVK.TablePoverkaSikn425_UPR_PR.DateTimeLong)));               
      PageNumeration.Width = (Page.PaperWidth-Page.LeftMargin-Page.RightMargin)*Units.Millimeters; 
    }  
      
    //// Setup heights of the all objects on the Page
    private void PageFooter_BeforeLayout(object sender, EventArgs e)
    {
      if((Int32)Report.GetVariableValue(&quot;TotalPages&quot;) &lt; 2) 
      { 
        PageFooter.Visible = false; 
      }
      else
      {
        PageNumeration.Width = (Page.PaperWidth-Page.LeftMargin-Page.RightMargin)*Units.Millimeters;
      }
    }
  }    
}

