using TN.DocData;

namespace FastReport
{
  public class ReportScript
  {
    TN_ToolsFastReport.Tools tools = new TN_ToolsFastReport.Tools();      
    TN.Doc.Doc doc;
    TN.Doc.DataIVKDoc DataIVK;
    TN.Doc.HeaderDoc Header;
    TN.Doc.DataDoc SettingsData;
    TN.Doc.FooterDoc Footer;
    TN.Doc.DictionarysDoc Dictionarys;
    
    string tempDate;
    string actDate;
      
    #region Collecting the Act date from few input parameters
    public string CollectingDate (string tempDay, string tempMonth, string tempYear, out string tempDate)
    {
      tempDay = (tempDay.Length == 1) ? (&quot;0&quot;+tempDay) : (tempDay);
      tempMonth = (tempMonth.Length == 1) ? (&quot;0&quot;+tempMonth) : (tempMonth);
      tempDate=  string.Format(&quot;{0}.{1}.{2}&quot;,tempDay, tempMonth, tempYear); 
      return tempDate;
    }
    #endregion
      
    private void Page_StartPage(object sender, EventArgs e)
    {
      //using (var sr = new StreamReader(&quot;C:/SVN/FastReport/Входящие данные от Алексея (классы и json)/11_Act/DocAct.json&quot;))
      //{                                                                                          
      // Read the stream as a string
      //   Report.SetParameterValue(&quot;Act&quot;, sr.ReadToEnd());
      //}
      //// Десериализация данных (формат json) из входного параметра - Json                         
      string json = (string)Report.GetParameterValue(&quot;JsonDoc&quot;);
      Newtonsoft.Json.JsonSerializerSettings settings = new Newtonsoft.Json.JsonSerializerSettings();
      settings.TypeNameHandling = TypeNameHandling.All;         
         
      doc = JsonConvert.DeserializeObject&lt;TN.Doc.Doc&gt;(json, settings);
      DataIVK = (TN.Doc.DataIVKDoc)doc.Doc.DataIVK;
      Header = (TN.Doc.HeaderDoc)doc.Doc.Settings.Header;
      SettingsData = (TN.Doc.DataDoc)doc.Doc.Settings.Data;
      Footer = (TN.Doc.FooterDoc)doc.Doc.Settings.Footer;
      Dictionarys = (TN.Doc.DictionarysDoc)doc.Doc.Settings.Dictionarys;      
      
      //// === Настройки страницы 
      // Ширина и высота (в мм)
      Page.PaperHeight = doc.Doc.Settings.General.PageSettings.PaperHeight;
      Page.PaperWidth= doc.Doc.Settings.General.PageSettings.PaperWidth;
      //Page.Border.Lines = BorderLines.All;
         
      // Поля/отступы от краёв (в мм)
      Page.TopMargin=doc.Doc.Settings.General.PageSettings.TopMargin;
      Page.BottomMargin=doc.Doc.Settings.General.PageSettings.BottomMargin;
      Page.LeftMargin=doc.Doc.Settings.General.PageSettings.LeftMargin;
      Page.RightMargin=doc.Doc.Settings.General.PageSettings.RightMargin;
         
      actDate =  CollectingDate(
        DataIVK.TableResultActAndPassport.Day.ToString(),
        DataIVK.TableResultActAndPassport.Month.ToString(),
        DataIVK.TableResultActAndPassport.Year.ToString(),
        out tempDate);
         
      // Запуск отрисовки таблиц на странице отчета
      DrawTableHeader();
      DrawTableAct();
      DrawTableAdditionlInfo();
      DrawTableSigners();
    }
      
    public void DrawTableHeader()
    {             
      ActNumberAndDate.Text = string.Format(&quot;Акт приема-сдачи нефтепродукта №&lt;u&gt; {0}&lt;/u&gt; от &lt;u&gt;{1}&lt;/u&gt;г.&quot;,  
        DataIVK.TableResultActAndPassport.AdditionalInfo.ActNumber,
        actDate);
      
      DelivePoint.Text = DataIVK.TableResultActAndPassport.AdditionalInfo.DelivePoint; 
      Factory.Text = DataIVK.TableResultActAndPassport.AdditionalInfo.Factory; 
      SIKN_Number.Text = DataIVK.TableResultActAndPassport.AdditionalInfo.SIKN_Number;
      
      Oil_Name.Text = DataIVK.TableResultActAndPassport.AdditionalInfo.Oil_Name;;
      
      Delive_Factory.Text = $&quot;Уполномоченный представитель сдающей стороны &lt;sup&gt;1)&lt;/sup&gt;,&lt;br&gt;{DataIVK.TableResultActAndPassport.AdditionalInfo.Delive_Factory}&quot;;
      Delive_FIO.Text = DataIVK.TableResultActAndPassport.AdditionalInfo.Delive_IOF; 
      Delive_Lic_Date.Text = DataIVK.TableResultActAndPassport.AdditionalInfo.Delive_Lic_Date; 
      Delive_Lic_Number.Text = DataIVK.TableResultActAndPassport.AdditionalInfo.Delive_Lic_Number; 
      
      Receive_Factory.Text = $&quot;Уполномоченный представитель принимающей стороны &lt;sup&gt;1)&lt;/sup&gt;,&lt;br&gt;{DataIVK.TableResultActAndPassport.AdditionalInfo.Receive_Factory}&quot;;
      Receive_FIO.Text = DataIVK.TableResultActAndPassport.AdditionalInfo.Receive_IOF; 
      Receive_Lic_Date.Text = DataIVK.TableResultActAndPassport.AdditionalInfo.Receive_Lic_Date; 
      Receive_Lic_Number.Text = DataIVK.TableResultActAndPassport.AdditionalInfo.Receive_Lic_Number;            
    }
      
    private void DrawTableAct()       
    {
      TableActText_1.Text = $&quot;Результаты измерений СИКН {DataIVK.TableResultActAndPassport.AdditionalInfo.SIKN_Number} (показания СОИ или ВА):&quot;;
      
      Begin_Mass.Text = tools.GetNormalizedValue(DataIVK.TableResultActAndPassport.ResultActAndPassport.Common.Begin_Mass);    
      End_Mass.Text = tools.GetNormalizedValue(DataIVK.TableResultActAndPassport.ResultActAndPassport.Common.End_Mass);    
      Gross_Mass.Text = tools.GetNormalizedValue(DataIVK.TableResultActAndPassport.ResultActAndPassport.Common.Gross_Mass);    
      
      List&lt;string&gt; pasportId = new List&lt;string&gt;();
      
      if (!string.IsNullOrEmpty(DataIVK.TableResultActAndPassport.ResultActAndPassport.Act[0].PassportID))
        pasportId.Add(DataIVK.TableResultActAndPassport.ResultActAndPassport.Act[0].PassportID);
      if (!string.IsNullOrEmpty(DataIVK.TableResultActAndPassport.ResultActAndPassport.Act[1].PassportID))
        pasportId.Add(DataIVK.TableResultActAndPassport.ResultActAndPassport.Act[1].PassportID);
      if (!string.IsNullOrEmpty(DataIVK.TableResultActAndPassport.ResultActAndPassport.Act[2].PassportID))
        pasportId.Add(DataIVK.TableResultActAndPassport.ResultActAndPassport.Act[2].PassportID);
      if (!string.IsNullOrEmpty(DataIVK.TableResultActAndPassport.ResultActAndPassport.Act[3].PassportID))
        pasportId.Add(DataIVK.TableResultActAndPassport.ResultActAndPassport.Act[3].PassportID);
      
      PassportID.Text = String.Join(&quot;,&quot;, pasportId);       
    }
      

      
    private void DrawTableAdditionlInfo()
    {
      // Setup Last Column width
      //TableAdditionlInfo.Columns[0].Width=(Page.PaperWidth-Page.LeftMargin-Page.RightMargin)*Units.Millimeters;
      
      string tmp = DataIVK.TableResultActAndPassport.ResultActAndPassport.Common.ValueInWords.WholePart;
      // с заглавной буквы
      string t1 = (!String.IsNullOrEmpty(tmp)) ? tmp.First().ToString().ToUpper() + tmp.Substring(1) : &quot;&quot;;
      // убираем единицы измерения
      foreach (Match match in Regex.Matches(t1, @&quot;\sт(он\w*)?\s?\z&quot;))
        t1 = t1.Remove(match.Index, match.Length);

      string str1 = t1, str2 = &quot;&quot;;
      // точка переноса

      int StartPos = 50;
      if (!String.IsNullOrEmpty(t1) &amp;&amp; t1.Length &gt; 50)
        foreach (Match match in Regex.Matches(t1.Substring(StartPos), @&quot;\s\w+&quot;))
        {
          ++StartPos;
          str1 = t1.Substring(0, match.Length + StartPos);
          str2 = t1.Substring(match.Length + StartPos);
          break;
        }
      
      WholePart1.Text = str1;
      WholePart2.Text = str2;
      Fraction.Text = DataIVK.TableResultActAndPassport.ResultActAndPassport.Common.ValueInWords.Fraction;
         
      //Draw static Rows
      //TableAdditionlInfo.PrintRow(0);
      //TableAdditionlInfo.PrintColumns();                                    
    }
      
    public void  DrawTableSigners()
    {
      if (Page.PaperWidth == 297)
      {
        if (Engine.FinalPass == true)
        {  
          for (int n = 0; n &lt; TableSigners.ColumnCount; n++)
          {
            TableSigners.Columns[n].Width=(TableSigners.Columns[n].Width*(float)1.455);//*Units.Millimeters;
          }       
        }
      }             
      Delive_IOF.Text = DataIVK.TableResultActAndPassport.AdditionalInfo.Delive_IOF; 
      Receive_IOF.Text = DataIVK.TableResultActAndPassport.AdditionalInfo.Receive_IOF; 
    }  
      
    private void PageFooter_BeforeLayout(object sender, EventArgs e)
    {
      //PageNumeration.Width = (Page.PaperWidth-Page.LeftMargin-Page.RightMargin)*Units.Millimeters;      
    }
  }    
}

