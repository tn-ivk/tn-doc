<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      autoReload="true"
      internalLogLevel="Info"
      internalLogFile="c:\temp\internal-nlog-AspNetCore.txt">

    <variable name="logLevel" value="Info" />

    <!--
    See https://github.com/nlog/nlog/wiki/Configuration-file
    for information on customizing logging rules and outputs.
     -->
    <targets>
        <!-- write logs to file -->
        <target xsi:type="File" name="logfile" fileName="${basedir}/logs/${shortdate}.log"
                layout="${longdate} | ${uppercase:${level}} | ${message} | ${logger} | ${processid} | ${threadid}" />
        <target xsi:type="Console" name="logconsole"
                layout="${longdate} | ${uppercase:${level}} | ${message} | ${logger} | ${processid} | ${threadid}" />
    </targets>

    <rules>
        <!-- add your logging rules here -->
        <logger name="TN*" minlevel="${var:logLevel}" writeTo="logfile" />
        <logger name="*" minlevel="Trace" writeTo="logconsole" condition=" '${basedir}' == 'bin\\Debug' " />
        <!--
        Write all events with minimal level of Debug (So Debug, Info, Warn, Error and Fatal, but not Trace)  to "f"
        <logger name="*" minlevel="Debug" writeTo="f" />
        -->
    </rules>
</nlog>
